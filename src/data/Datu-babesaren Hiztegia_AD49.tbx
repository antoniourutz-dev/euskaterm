<termEntry id="534912">
  <descrip type='subjectField'>Datu pertsonalen babesa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona fisiko edo juridikoa, izaera publiko zein pribatukoa, edo administrazioko organoa, baina ondorengoetako bat ez dena: ukitua edo interesatua, tratamenduaren arduraduna, tratamendu-eragilea, edo azken bi horien zuzeneko agintepean datuak tratatzeko baimena duten pertsonetako bat. Era berean, datuen trafikoan subjektu berezitu gisa diharduen nortasun juridikorik gabeko erakundea.</descrip>
    </descripGrp>
    <tig>
      <term>hirugarren</term>
      <termNote type='normativeAuthorization'>4</termNote>
