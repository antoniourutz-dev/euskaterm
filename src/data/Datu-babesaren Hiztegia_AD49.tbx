<termEntry id="534869">
  <descrip type='subjectField'>Datu pertsonalen babesa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Datu pertsonalen tratamendu oro, baldin eta lortzen den informazioa ezin bada lotu pertsona fisiko identifikatuarekin edo identifikagarriarekin.</descrip>
