<termEntry id="534870">
  <descrip type='subjectField'>Datu pertsonalen babesa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ezereztutako datu pertsonalak identifikatzea eta erreserbatzea, trata ez daitezen. Blokeatutako datu pertsonalak administrazio publikoen, epaileen edo auzitegien esku geratzen dira soilik.</descrip>
