  <descrip type='subjectField'>Etxerako burdin tresnak eta osagarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Atea zertxobait ireki arren segurtasun-lotura bat izateko jartzen den katea. Katearen mutur bat atearen orrian finkatuta dago, eta, segurtasun-lotura ezarri nahi denean, beste muturra atearen markoari lotzen zaio.</descrip>
