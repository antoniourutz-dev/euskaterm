<termEntry id="-1">
  <descrip type='subjectField'>Finkatzeko materiala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi pieza metaliko askez osatutako giltzadura. Pieza horietako bat zuloduna edo emea da, eta atearen edo leihoaren markoari lotzen zaio; bestea ziri modukoa edo arra da, eta ate- edo leiho-orrian lotzen da.</descrip>
