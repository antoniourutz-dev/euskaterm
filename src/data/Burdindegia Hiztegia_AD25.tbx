<termEntry id="-1">
  <descrip type='subjectField'>Finkatzeko materiala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kabila luzea eta, beraz, xafla luze eta estuak dituen banda-mota. Ohiko zentimetro urrien ordez, lotura-gainazal luze eta jarraitua eskaintzen du; adibidez, piano baten tapa ixteko.</descrip>
