<termEntry id="-1">
  <descrip type='subjectField'>Erreminta elektrikoak eta osagarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ardatzaren inguruan disko urragarri bat birarazten duen biraketa-tresna elektrikoa. Gauzak zorrozteko, ebakitzeko, leuntzeko, bizarrak kentzeko eta antzeko lanetarako erabiltzen da.</descrip>
