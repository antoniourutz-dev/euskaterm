  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kanpoaldetik ildaska bat duen metalezko uztai luzanga. Kanpoko ildaska inguratzen duen soka babesteko erabiltzen da, uztaiaren barrutik pasatzen den elementuak soka honda ez dezan.</descrip>
