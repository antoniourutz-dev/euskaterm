<termEntry id="-1">
  <descrip type='subjectField'>Finkatzeko materiala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lotu beharreko piezak besarkatzen dituen eraztun moduko lotura-elementua. Torloju batez estutu ohi da.</descrip>
    </descripGrp>
