  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zuloaren barruko material guztia harrotu ordez, diskoa edo zilindroa osorik ebakitzen duen barauts-mota. Hodi horzdun baten moduko muturra du, eta, gehienetan, diametro handiko zuloak egiteko erabiltzen da.</descrip>
