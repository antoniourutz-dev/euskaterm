<termEntry id="-1">
  <descrip type='subjectField'>Finkatzeko materiala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lotu beharreko piezak inguratzen eta estutzen dituen lotura-elementu malgu eta estua. Hortz modukoak ditu luzera osoan zehar, eta muturretako bat zuloduna da; beste muturra zulo horretatik sartzen da, eta, estutu eta gero, hortzek ez dute brida askatzen edo lasaitzen uzten.</descrip>
    </descripGrp>
    <tig>
      <term>brida</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>brida</term>
    </tig>
  </langSet>
