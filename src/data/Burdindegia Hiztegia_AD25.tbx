<termEntry id="-1">
  <descrip type='subjectField'>Finkatzeko materiala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>U itxura duen metalezko lotura-pieza. Bi muturrak zulatuak ditu, eta zulo horietatik kabila bat sartzen da, pieza ixteko.</descrip>
