<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Plaka edo pantaila moduko tresna, gaur egun elektronikoa izan ohi dena gehienetan. Bertan adierazten dira taldeen nahiz jokalarien izenak, partida bitartean lortzen diren emaitzak, eta baita bestelako hainbat informazio osagarri ere; esate baterako, gertatzen diren ordezpen edo aldaketak, emaitza, joko-denbora, etab.</descrip>
