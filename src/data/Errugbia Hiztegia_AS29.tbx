  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alboko marrekiko paralelo eta 15 metroko distantziara dauden bi marra etenetako bakoitza.</descrip>
