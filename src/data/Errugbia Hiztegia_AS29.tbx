    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>corner post</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alboko epaileak jokoan gertatzen diren zenbait ekintza adierazteko baliatzen duen bandera.</descrip>
