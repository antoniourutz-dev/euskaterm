  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eragozpen-taktika: baloia daraman jokalariak bera markatzeaz arduratzen den aurkariari bizkarra eman, eta baloia bere lasterketa-ibilbidea gurutzatzen duen taldekide bati pasatzen dio.</descrip>
