<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Baloiaren inguruan taldekide askoren parte hartzearekin eta elkarri babesa emanez, baloia aurrera eramaten saiatzen den joko-mota.</descrip>
