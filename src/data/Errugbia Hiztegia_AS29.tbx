  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pasea egiten duen jokalariaren atzetik eta ibilbide zeiharrarekin datorren taldekide bati emandako pasea, aurkaria kontraoinean hartu nahian egiten dena.</descrip>
