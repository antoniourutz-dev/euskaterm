    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>lateral axis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zelai edo zorutik gorantz doan ardatza. Ardatz horretan mugitzean, jokalariak eraman gabe egiten du aurrera baloiak, goitiko baloien kasuan, adibidez.</descrip>
    </descripGrp>
    <tig>
      <term>ardatz bertikal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
