  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Talde bakoitzeko zortzi aitzinekoen oldarraldi bateratu gogorra; uztartze geldoan egiten da, elkarren aurka borrokatuz bere orpokatzaileari baloia berreskuratu eta irabazten laguntzeko.</descrip>
