  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Babeseko pieza, plastiko gogorrekoa, zangoaren aurreko aldea estali eta babesten duena; errugbilariak galtzerdien azpitik eraman ohi du, hasi botatik eta belaunaren hasieraraino.</descrip>
