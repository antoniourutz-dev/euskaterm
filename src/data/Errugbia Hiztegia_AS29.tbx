<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Entrenamenduak planifikatu eta zuzentzeaz gain taldearen hamabostekoa eta ordezkoen zerrenda izendatu eta partidan zehar taldearen zuzendaritzaz arduratzen den kirol-teknikaria.</descrip>
