  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alboko marratik gertu dagoen jokalari batek (sarritan hegalekoa izan ohi da) jokoak jarrai dezan baloiari zelai-erdirantz ematen dion ostikoa.</descrip>
