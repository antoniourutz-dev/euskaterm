</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kluben arteko Europako txapelketa. Bertan Italiako, Frantziako, Galeseko, Eskoziako, Ingalaterrako eta Irlandako talderik onenek hartzen dute parte.</descrip>
    </descripGrp>
    <tig>
      <term>Europako Errugbi Txapeldunen Kopa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>European Rugby Champions Cup</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
