    <tig>
      <term>axe profond</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>deep axis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Entsegu-marrekiko paraleloa den ardatza. Ardatz horretan mugitzean, baloia albo batetik bestera eramaten da.</descrip>
    </descripGrp>
    <tig>
      <term>albo-ardatz</term>
