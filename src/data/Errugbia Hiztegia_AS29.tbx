  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Defentsan ari den taldeak 22 metroko marraren atzetik egiten duen punpa-lasterreko ostikoa; aurrez bere entsegu-eremuan baloia pausatu duelako edo baloi hila gertatu delako egiten da, baloia berriz jokoan jartzeko.</descrip>
