  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Soinu edo hots zolia eta jarraitua ateratzen duen tresna akustikoa, epaileak jokoak dirauen bitartean gertaturiko arau-hausteak, kolpe frankoak eta abar adierazteko erabili ohi duena.</descrip>
