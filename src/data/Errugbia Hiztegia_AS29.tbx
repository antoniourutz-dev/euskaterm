<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrelarien atzean kokatu ohi den jokalaria; baloia uztartze-erdilariarengandik, alboko sake batetik edo biltze batetik jaso ondoren, jokalari-lerroen arteko jokoa lotzeaz eta taldea aurrerarazteaz arduratzen da. Zabaltzaileak 10 zenbakia darama.</descrip>
