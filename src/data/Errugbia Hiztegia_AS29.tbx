  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erasoan ari den jokalariari baloia aurrerantz erortzen zaionean gertatzen den falta. Aurreratua uztartze geldo batekin zigortzen da, baloia aurkariei emanez.</descrip>
