  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurkarien entsegu-eremuan baloia lurrean pausatzea. Entsegu batek bost puntu balio ditu, eta hagetarako jaurtiketa bat egiteko aukera ematen dio entsegua egin duen taldeko edozein jokalariri.</descrip>
