  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Uztartze bateko jokalari-lerroa, pasabidearen alboetako bat eratzen duten hiru aurrelarik osatua. Hiru jokalari horiek bata besteari helduta jartzen dira, baina oinak gurutzatu gabe.</descrip>
