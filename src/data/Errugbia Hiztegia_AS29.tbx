    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>exit of scrum</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alboko bi marren eta 22 metroko bi marren ebaketa-puntuetatik 2 metroko distantziara dauden alboko lau zutoinetako banderetako bakoitza.</descrip>
    </descripGrp>
