  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alboko sakean bi jokalari-lerroak banantzen dituen tartea, baloia jaurtitzailearen eskuetatik irteten den artean metro batekoa izan behar duena.</descrip>
