    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>European Rugby Champions Cup</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alboko marrekiko paraleloa den ardatza. Ardatz horretan aurrera egitean, baloia entsegu-marrarantz eramaten da.</descrip>
    </descripGrp>
    <tig>
      <term>sakoneko ardatz</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
