<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Araudia urratzea, partida jokatu bitartean debekatua dagoen ekintzaren bat egitean gertatzen dena. Faltak duen garrantziaren arabera, uztartze batekin, zigor-kolpe batekin, kolpe franko batekin, kargu-hartze batekin edo kanporatze batekin zigor daiteke.</descrip>
    </descripGrp>
