<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Baloirik ez daukan jokalari bati egindako plakatzea, epaileak joko arriskutsutzat hartu eta zigor-kolpe edo penalizazio batekin zigor dezakeena. Dena den, zenbait kasutan, plakatze hori arauzkotzat jo daiteke, epaileak "mugimendua egin bitartean" (inor zauritzeko asmorik gabe, alegia) egina izan dela uste badu.</descrip>
    </descripGrp>
    <tig>
      <term>plakatze atzeratu</term>
