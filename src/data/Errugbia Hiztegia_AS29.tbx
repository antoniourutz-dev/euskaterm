<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Baloirik gabeko jokalari bat baloia daraman taldekidearen aurretik pasatzean gertatzen den eragozpena. Defentsen lana eragozteko asmoz egiten da, eta epaileak zigor-kolpe batekin zigortu ohi du.</descrip>
