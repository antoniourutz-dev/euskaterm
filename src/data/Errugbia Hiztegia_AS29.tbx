  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Baloia daraman jokalariak eta gutxienez talde bakoitzetik jokalari batek zutik eta kontaktuan osatutako taldekatzea. Taldekatzean parte hartzen duten jokalari guztiek lotuta egon behar dute, zutik, eta entsegu-eremu baterantz aurrera egin.</descrip>
