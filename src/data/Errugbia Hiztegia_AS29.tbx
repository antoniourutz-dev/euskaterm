<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Uztartze geldoan bi taldeetako jokalari-lerroen artean geratzen den tartea. Arbitroak hirugarren agindua eman ondoren, uztartze-erdilariak tarte horretan jartzen du baloia jokoan, eta multzo biak baloia irabazteko bultzaka hasten dira.</descrip>
