    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>free kick</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Norberaren entsegu-eremuan baloia lurrean pausatzea. Entsegu horrek ez du baliorik, eta, ondorioz, ez du eraginik izaten markagailuan. Entsegu baliogabe baten ondotik, jokoa 22 metroko sake-ostiko batekin edo uztartze geldo batekin berrabiatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>entsegu baliogabe</term>
      <termNote type='normativeAuthorization'>4</termNote>
