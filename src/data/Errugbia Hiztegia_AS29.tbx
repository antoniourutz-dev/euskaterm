<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Partida jokatu bitartean jokalariak gainean daraman guztia: elastikoa edo kamiseta, galtzamotzak, galtzerdiak, bota takodunak, eta baita slip bat ere batzuetan. Ekipamendua osatzeko, hainbat babes-pieza erabiltzen dituzte sarritan jokalariek, hala nola kaskoa, zango-babesak, hortzetako babesgarriak nahiz belarri-babesak.</descrip>
    </descripGrp>
