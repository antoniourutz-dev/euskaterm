<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alboko bi marren eta bi entsegu-marren nahiz baloi hilaren bi marren arteko ebaketa-puntuetan kokatuak dauden alboko zortzi zutoinetako bakoitza. Zutoin horiek entsegu-eremu bakoitzaren mugak adierazten dituzte.</descrip>
    </descripGrp>
