<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Baloirik ez duen taldeko jokalariek osatzen duten lerroa, erasotzaileak aurrera ez egiteko eratzen dena. Ondo antolatutako talde batek defentsako bigarren eta are hirugarren hesi bat ere eduki dezake, aurrenekoa saihestuko luketen aurkariak harrapatzeko.</descrip>
