  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Partida zein taldek hasi edo jokalekuaren zein aldetan hasi erabakitzeko txanpona botatzea; epaileak botatzen du bi taldeetako kapitainen aurrean, partida edo luzapena hasi aurretik.</descrip>
