<termEntry id="-1">
  <descrip type='subjectField'>Errugbia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arbitroak partida-amaiera adierazi ondoren, bi taldeek osatzen duten jende-ilaretako bakoitza, aurkariak txalotzeko talde bateko eta besteko jokalariek aurrez aurre jarrita egiten dutena. Ohitura da etxean jokatzen duen taldea hastea korridore hori osatzen, baina beste batzuetan irabazi duen taldeak egiten du, aurkako taldeari dion errespetua erakusteko.</descrip>
