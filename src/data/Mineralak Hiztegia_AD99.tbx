    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>flint</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kristal bat presiopean jartzen denean bere muturren edo poloen artean potentzial elektrikoa sortzean datzan fenomenoa.</descrip>
    </descripGrp>
