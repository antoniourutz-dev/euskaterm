  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kristal baten simetria irudikatzea ahalbidetzen duen egitura geometrikoa. Simetria-zentroa, simetria-planoa eta simetria-ardatza simetria-elementuak dira.</descrip>
