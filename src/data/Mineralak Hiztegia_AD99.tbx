<termEntry id="-1">
  <descrip type='subjectField'>Sulfuroak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Merkurio sulfuroa (HgS), kolore gorri bizikoa, sistema trigonalean kristaldua. Lurralde igneoekin erlazionatutako hobi hidrotermaletan agertu ohi da; batzuetan, arrakalak edo bestelako hutsuneak betetzen ditu, normalean pirita, antimonita, kuartzoa, kaltzedonia, kaltzita eta beste karbonato batzuekin batera. Merkurio-mearik garrantzitsuena da.</descrip>
    </descripGrp>
    <tig>
      <term>zinabrio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cinabrio</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>cinabre</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>cinnabar</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sulfuroak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Burdin sulfuroa (FeS2), sistema kubikoan kristaldua, markasitaren polimorfoa. Urre-kolore horia du, distira metalikoa eta aurpegiak ildaskatuak. Hauskorra da. Oso ezaguna da sulfurorik arruntena delako eta edozein motatako arroketan aurki daitekeelako. Kolpekatuz gero, txinpartak igortzen dituelako du pirita izena, "pyrítes"ek su esan nahi baitu grekoz. Azido sulfurikoa, sufrea eta burdina lortzeko erabiltzen da.</descrip>
    </descripGrp>
    <tig>
      <term>pirita</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
