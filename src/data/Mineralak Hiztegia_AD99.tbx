<termEntry id="-1">
  <descrip type='subjectField'>Konposatu organikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesu geologikoen ondorioz sortu diren karbonodun substantzia biogenikoak (adibidez, mellita, guanina eta whewellita).</descrip>
