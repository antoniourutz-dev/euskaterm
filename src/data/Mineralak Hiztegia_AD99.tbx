<body>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Material solido ez-organikoa, naturala, barne-egitura ordenatua (kristalinoa) eta konposizio kimiko nahitaez finkoa dituena.</descrip>
    </descripGrp>
    <tig>
      <term>mineral</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>mineral</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>minéral</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>mineral</term>
    </tig>
  </langSet>
</termEntry>
