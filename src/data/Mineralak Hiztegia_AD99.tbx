<termEntry id="-1">
  <descrip type='subjectField'>Silikatoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kristal-sistema desberdinetan kristal daitekeen silizearen taldeko tenperatura altuko minerala, SiO2. Kristal txikitan agertzen da, askotan maklak osatuz. Ohikoa da siliziotan aberatsak diren arroka bolkanikoetan (esate baterako, erriolitan eta obsidianan), askotan sanidinarekin eta kristobalitarekin batera.</descrip>
    </descripGrp>
    <tig>
      <term>tridimita</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
