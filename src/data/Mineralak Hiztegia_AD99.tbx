      <term>piezoelectricity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kristal bat beroaren eraginpean jartzen denean bere muturren edo poloen artean potentzial elektrikoa sortzean datzan fenomenoa.</descrip>
