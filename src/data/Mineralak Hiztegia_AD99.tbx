<termEntry id="-1">
  <descrip type='subjectField'>Sulfuroak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sulfuroak ez diren mineral sufredun ez-oxidatuen taldea. Zilar, kobre edo berunezko mineralak izan ohi dira, eta zain hidrotermaletan kantitate txikitan agertzen dira, normalean sulfuro ohikoenekin batera.</descrip>
    </descripGrp>
    <tig>
      <term>sulfogatz</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
