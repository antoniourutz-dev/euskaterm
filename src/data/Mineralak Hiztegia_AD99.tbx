    <tig>
      <term>errealgar</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>rejalgar</term>
    </tig>
  </langSet>
