<termEntry id="-1">
  <descrip type='subjectField'>Silikatoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>(SiO4)4- tetraedroak elkarri erpinetatik lotuz eraztun-formako egitura isolatuak sortzen dituzten silikatoen taldea. Talde honetako mineralen formulan silikatoari dagokion zatia SinO3n izaten da gehienetan; n-k eraztuneko tetraedroen kopurua adierazten du.</descrip>
    </descripGrp>
    <tig>
      <term>ziklosilikato</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ciclosilicato</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
