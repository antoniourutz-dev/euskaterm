      <term>pyroelectricity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lurraren azaletik gertu, bertan kokatutako mineral batzuetatik abiatuta, meteorizazio bidez sortutako minerala; nagusiki, soluzio urtsuen zirkulazioaren ondorioz sortu ohi da.</descrip>
    </descripGrp>
