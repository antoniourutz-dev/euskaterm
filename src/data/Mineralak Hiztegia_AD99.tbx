<termEntry id="-1">
  <descrip type='subjectField'>Silikatoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tektosilikatoen azpitaldea, sodio, potasio, kaltzio eta litio aluminosilikatoak barnean hartzen dituena. Feldespatoen antza dute konposizio kimikoari dagokionez, baina feldespatoek baino silizio-eduki eta dentsitate txikiagoak izaten dituzte. Feldespatoak ordezten dituzte magmak alkali ugari eta silizio gutxiegi dituenean. Nefelina, leuzita, sodalita eta kankrinita mineralak feldespatoideak dira.</descrip>
    </descripGrp>
    <tig>
      <term>feldespatoide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
