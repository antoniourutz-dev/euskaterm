    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>supergene mineral</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arrokarekin batera sortu den eta ordutik forma- zein konposizio-aldaketarik izan ez duen minerala.</descrip>
    </descripGrp>
    <tig>
      <term>mineral primario</term>
