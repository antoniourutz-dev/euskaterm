<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kristal batzuek erakusten duten fenomeno optikoa, ardatz nagusiarekiko zut ebakiz gero sei besoko izar argi zurixka ikustean datzana.</descrip>
    </descripGrp>
    <tig>
      <term>asterismo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>asterismo</term>
    </tig>
    <tig>
      <term>efecto estrella</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>astérisme</term>
    </tig>
    <tig>
      <term>effet d'étoile</term>
    </tig>
  </langSet>
