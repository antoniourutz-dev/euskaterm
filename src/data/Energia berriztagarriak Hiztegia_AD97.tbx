<termEntry id="-1">
  <descrip type='subjectField'>Eguzki-energia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Dorre baten inguruan heliostatoak dituen eguzki-zentrala. Heliostato bakoitza eguzki-erradiazioa dorreko hargailuan etengabe islatzeko moduan orientatzen da. Horrela, galdararen barnealdetik dabilen fluidoa berotu egiten da, eta, fluido hori lurrun bihurtuz, ur-lurrun ziklo konbentzionalari ematen zaio hasiera.</descrip>
    </descripGrp>
    <tig>
      <term>dorre-motako eguzki-zentral</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
