    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>long-term storage</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Energia hidroelektrikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Uraren aldi baterako metaketa. Mota honetako metaketa azalekoa izan daiteke edo emaria handituz gerta daiteke.</descrip>
    </descripGrp>
