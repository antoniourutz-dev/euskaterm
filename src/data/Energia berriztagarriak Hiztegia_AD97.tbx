    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Energia hidroelektrikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Urtegi batean ura biltzea, energia hidroelektrikoa puntako orduetan bakarrik ekoizteko.</descrip>
    </descripGrp>
