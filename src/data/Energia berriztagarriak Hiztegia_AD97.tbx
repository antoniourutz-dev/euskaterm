<termEntry id="-1">
  <descrip type='subjectField'>Itsas energia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Itsasoaren ezaugarri fisikoen edo kimikoen alderdiren bat baliatuz lor daitekeen energia. Itsas energia zenbait motatakoa izan daiteke baliatutako ezaugarriaren arabera; hala, itsas energiaren barnean marea-energia, olatuen energia, itsasoko bero-energia, gatz-gradientearen energia edo itsaslasterren energia bereizten dira.</descrip>
    </descripGrp>
    <tig>
      <term>itsas energia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>energía del mar</term>
    </tig>
    <tig>
      <term>energía oceánica</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>énergie marine</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ocean energy</term>
    </tig>
    <tig>
      <term>sea energy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Itsas energia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Itsasgorako eta itsasbeherako itsas mailaren aldaketak baliatuz ekoizten den energia.</descrip>
    </descripGrp>
    <tig>
      <term>marea-energia</term>
      <termNote type='normativeAuthorization'>4</termNote>
