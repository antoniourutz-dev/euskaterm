<termEntry id="-1">
  <descrip type='subjectField'>Eguzki-energia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lurrarekiko orbita finko batean kokatutako eguzki-zentrala. Eguzki-erradiazioa energia elektriko bihurtzen du bere zelula fotovoltaikoen bidez, eta ondoren energia elektrikoa Lurrera igortzen du mikrouhin-sortak direla medio.</descrip>
    </descripGrp>
