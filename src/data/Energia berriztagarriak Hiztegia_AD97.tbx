<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beroa hiri-sare baten bidez banatzen duen berokuntza-sistema. Zentral batean ura berotu, eta ur bero hori hainbat eraikinetara banatzen da; erabili eta gero, ura zentralera itzultzen da, eta han berriro berotzen da.</descrip>
