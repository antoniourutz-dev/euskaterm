<termEntry id="-1">
  <descrip type='subjectField'>Energia hidroelektrikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Haran-orduetan ura presaren azpialdetik urtegira ponpatuz puntako orduetan elektrizitate-ekoizpena handiagoa izatea ahalbidetzen duen zentral hidroelektriko baten eskema hidraulikoa. (Elektrizitate-eskaera minimoa da haran-orduetan, eta maximoa puntako orduetan.)</descrip>
    </descripGrp>
    <tig>
      <term>ponpatze bidezko metaketa</term>
