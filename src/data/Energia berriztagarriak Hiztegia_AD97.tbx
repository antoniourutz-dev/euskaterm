<termEntry id="-1">
  <descrip type='subjectField'>Biomasa-energia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi ziklo termodinamiko konbinatzen dituen sistema. Batetik, gas-turbina bat du; turbina horren ihes-gasen beroa lurruna sortzeko erabiltzen da, eta lurrun horrek lurrun-turbina bat ibilarazten du.</descrip>
    </descripGrp>
