    </tig>
    <tig>
      <term>solar power tower</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Eguzki-energia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Energia elektrikoa sortzeko panel fotovoltaiko ugari elkarri elektrikoki konektatuta dituen instalazioa.</descrip>
    </descripGrp>
