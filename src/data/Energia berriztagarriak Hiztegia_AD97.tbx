<termEntry id="-1">
  <descrip type='subjectField'>Energia geotermikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lur azpiko formazio geologiko iragazgaitza, geotermiaren eraginez sortua izan arren barnean urik ez duena (gainerako baliabide geotermikoek ez bezala). Arroka horien energia geotermikoa baliatzeko arroka zulatu egiten da, eta bero-trukerako sistema handi bat sortzen da arrokan artifizialki sartutako ura berotzeko.</descrip>
    </descripGrp>
    <tig>
      <term>arroka lehor bero</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>roca caliente seca</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>roche chaude sèche</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>Hot Dry Rock</term>
    </tig>
    <tig>
      <term>HDR</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Energia geotermikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beroa eta energia ekoizteko sistema; bertako bero-trukagailuak zunda geotermikoen antzekoak dira, baina, zunda haiek baino sakonera handiagora iristen direnez, bestelako materialak erabiltzen dituzte.</descrip>
    </descripGrp>
    <tig>
      <term>bero-meatzaritza sakon</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>minería profunda de calor</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>géothermie profonde</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>Deep Heat Mining</term>
    </tig>
    <tig>
      <term>DHM</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Energia geotermikoa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>zunda geotermiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sonda de intercambio geotérmico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
