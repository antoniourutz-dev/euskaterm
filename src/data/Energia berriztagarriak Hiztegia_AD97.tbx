      <term>central eólico-solar</term>
    </tig>
    <tig>
      <term>central solar de chimenea</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>centrale solaire éolienne</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>solar chimney power plant</term>
    </tig>
    <tig>
      <term>solar-wind power plant</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Eguzki-energia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ziklo termodinamiko baten bidez energia termikoa elektrizitate bihurtzen duen eguzki-zentrala. Beroa likido bat lurruntzeko erabiltzen du, eta lurrunak turbina birarazten du. Turbinak, berriz, sorgailuari eragiten dio, eta hala energia elektrikoa ekoizten da.</descrip>
    </descripGrp>
    <tig>
      <term>eguzki-zentral termoelektriko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>zentral heliotermiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
