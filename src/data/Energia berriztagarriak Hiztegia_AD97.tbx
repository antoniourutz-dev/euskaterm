  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ur-lasterren edozein zatitan (ibilguan zein uraldiak hartutako lurrean) gertatutako ur-metaketa.</descrip>
    </descripGrp>
    <tig>
