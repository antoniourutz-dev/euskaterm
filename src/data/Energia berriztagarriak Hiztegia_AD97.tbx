<termEntry id="-1">
  <descrip type='subjectField'>Eguzki-energia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eguzkian gertatzen den elementu arinen fusioaren ondorioz Lurrera uhin elektromagnetiko gisa iristen den erradiazio-energia. Baliatu ahal izateko, gizakiak bero-energia bihurtzen du energia hori, eguzki-sistema aktibo zein pasiboen bidez, edo, zuzenean, energia elektriko bihurtzen du, zelula fotovoltaikoen bidez.</descrip>
    </descripGrp>
    <tig>
      <term>eguzki-energia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>energía solar</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>énergie solaire</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>solar energy</term>
    </tig>
    <tig>
      <term>solar power</term>
    </tig>
  </langSet>
</termEntry>
