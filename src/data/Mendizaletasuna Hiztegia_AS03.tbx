<termEntry id="-1">
  <descrip type='subjectField'>Kirolak osasunaren gain dituen eraginak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputzean, gorputz-adarretan bereziki, sentitzen diren min edo sastadak, ariketa gogorrak, jarraituak edota energia handikoak egin ondoren agertzen direnak.</descrip>
