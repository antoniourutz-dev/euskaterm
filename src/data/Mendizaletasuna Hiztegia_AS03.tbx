<termEntry id="-1">
  <descrip type='subjectField'>Mendia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendi, hegal, harkaitz nahiz murru batetik lurra, harriak edo haitzak erortzea. Hainbat izan daitezke horretarako arrazoiak: trumoi-ekaitzak, urtze-aldiak, lurzoru ez-egonkorrak edo mugimendu tektonikoak.</descrip>
    </descripGrp>
