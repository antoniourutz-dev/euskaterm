<termEntry id="-1">
  <descrip type='subjectField'>Mendizaletasuna, kirol gisa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Igoerari ekin aurretik helburuaren norabidean egiten den distantzia. Esaterako, autoa utzi dugun lekutik gaua emango dugun aterperaino edo bibakeraino dagoen distantzia.</descrip>
    </descripGrp>
    <tig>
      <term>hurbilketa</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
