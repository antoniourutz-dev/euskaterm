<termEntry id="-1">
  <descrip type='subjectField'>Ekipamendua. Tresneria</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hauts moduan saltzen den magnesio karbonatoa, eskalatzeko orduan eskuetako transpirazioa saihesteko erabiltzen dena.</descrip>
