  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendian gaua pasatzeko, babestuta egoteko edota aldi baterako bizitzeko erabiltzen den objektua. Forma eta tamaina desberdinak ditu, eta erraz eraman daiteke leku batetik bestera.</descrip>
