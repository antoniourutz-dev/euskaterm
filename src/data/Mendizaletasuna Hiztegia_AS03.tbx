<termEntry id="-1">
  <descrip type='subjectField'>Kirolak osasunaren gain dituen eraginak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputz-atalak beren mugimendu-zabaltasunik handienean hedatzea, muskulatura eta giltzadurak ondorengo esfortzurako ahalik eta modurik hoberenean prestatzeko. Ariketa horrek oreka muskularra mantendu eta lesioak gertatzeko arriskua gutxitzen du.</descrip>
    </descripGrp>
