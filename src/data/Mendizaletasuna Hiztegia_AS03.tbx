<termEntry id="-1">
  <descrip type='subjectField'>Mendizaletasuna, kirol gisa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Leku bertikal, malkartsu edo pikoetan gora egitea, oinez gain eskuak ere baliatuz, baliabide artifizialak erabiliz edo erabili gabe. Eskalada modu askean egin daiteke, edo bestela, eskalada artifiziala, kirol-eskalada edo eskalada mistoa izaten da, erabilitako progresioko baliabideen arabera.</descrip>
    </descripGrp>
