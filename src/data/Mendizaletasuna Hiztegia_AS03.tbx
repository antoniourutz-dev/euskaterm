  <descrip type='subjectField'>Ekipamendua. Tresneria</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mapa-mota berezia, ibilbideen ohar grafikoak eskaini eta horietako ezaugarri nabarmenen berri ematen duena.</descrip>
