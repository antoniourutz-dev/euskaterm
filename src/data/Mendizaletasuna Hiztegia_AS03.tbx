<termEntry id="-1">
  <descrip type='subjectField'>Mendia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendizale, alpinista nahiz txangozaleek mendian atseden har dezaten eta lo egin dezaten prestatutako babeslekua. Izan daiteke librea edo zaindua, eta horren arabera ordaindu behar da edo ez.</descrip>
