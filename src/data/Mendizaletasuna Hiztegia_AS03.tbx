    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>dénivellation</term>
    </tig>
    <tig>
      <term>dénivelée</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>altitude difference</term>
    </tig>
  </langSet>
</termEntry>
