<termEntry id="-1">
  <descrip type='subjectField'>Mendizaletasuna, kirol gisa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Jatorrian Alpeetako gailurretara igotzean zetzan kirola; hedapenez, edozein menditara igotzea. Bereizi beharra dago alpinismoaren (edo mendizaletasunaren) eta txangozaletasunaren artean. Azken hori, inoiz mendiak igotzen badira ere, gehiago da ibili eta ikusiz gozatzeko kirola. Alpinismoan, ordea, helburu nagusia gailur zail eta garaiak gainditzea da.</descrip>
    </descripGrp>
    <tig>
      <term>alpinismo</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>alpinismo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>alpinisme</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>mountaineering</term>
    </tig>
  </langSet>
</termEntry>
