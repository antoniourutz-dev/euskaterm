  <langSet xml:lang='en'>
    <tig>
      <term>canyoning</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Mendia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eremu menditsuko pasabide oso sakon eta estua, pareta pikoak eta malkartsuak dituena. Arroila baino txikiagoa izaten da.</descrip>
    </descripGrp>
    <tig>
      <term>haitzarte</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
