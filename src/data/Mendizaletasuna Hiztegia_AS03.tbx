<termEntry id="-1">
  <descrip type='subjectField'>Ekipamendua. Tresneria</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendiko botari akoplatzen zaion objektua, azalera handiagoa hartzeko eta, horri esker, elur bigunean ez hondoratzeko.</descrip>
