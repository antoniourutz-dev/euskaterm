<termEntry id="-1">
  <descrip type='subjectField'>Mendizaletasuna, kirol gisa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gailur batera daraman ibilbiderik errazena, ezagunena eta erabiliena. Hala ere, horrek ez du esan nahi bide hori, zailtasun-mailari dagokionez, erraza denik.</descrip>
