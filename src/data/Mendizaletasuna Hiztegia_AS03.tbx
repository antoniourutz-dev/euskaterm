  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hainbat forma eta tamainatako pieza metalikoa, harkaitzetako pitzaduretan edo izotzean sartu ohi dena, era horretan ainguraketa-puntu artifizialak lortzeko.</descrip>
