      <term>alpinisme</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>mountaineering</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Ekipamendua. Tresneria</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Malgukidun pieza giltzatu batez ixten eta irekitzen den titaniozko, altzairuzko edo duraluminiozko eraztuna. Mendiko jardueretan, gauzak erraz eta azkar lotzeko zein askatzeko erabiltzen da, eta harkaitzean sartutako iltzeetan finkatu ondoren, sokak bertatik zehar pasarazten dira, soka-taldean doazen mendizaleen segurtasuna bermatuz.</descrip>
    </descripGrp>
    <tig>
      <term>mosketoi</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
