<termEntry id="-1">
  <descrip type='subjectField'>Mendia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendiak nagusi izanik, hainbat elementu geografikoz (mendi, haran, ordoki, aintzira, eta abarrez) osatutako multzo, sistema edo unitate orografikoa, luzea zabala baino gehiago dena eta norabide orokor bat duena.</descrip>
