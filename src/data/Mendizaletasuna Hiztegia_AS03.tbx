  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pareta edo harkaitz baten zati irtena, tamaina handi samarrekoa, pasaguneak edo korridoreak izan daitezkeen bi sakonuneren artean kokatua.</descrip>
