  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>narrow pass</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kirolak osasunaren gain dituen eraginak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputzeko ur-galera garrantzitsua, esfortzuak eragindakoa. Deshidratazioak mendizalearen errendimendua murriztea dakar, eta, larria baldin bada, haren bizia arriskuan jartzera ere irits daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>deshidratazio</term>
      <termNote type='normativeAuthorization'>5</termNote>
