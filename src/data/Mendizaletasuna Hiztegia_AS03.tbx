  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erreka-zuloak, amildegiak eta gisako oztopoak zeharkatzeko ezartzen den sokazko zubia. Polea batetik zintzilik pasatzen da alde batetik bestera. Izena Tiroleko eskualde alpinotik datorkio tresna horri.</descrip>
