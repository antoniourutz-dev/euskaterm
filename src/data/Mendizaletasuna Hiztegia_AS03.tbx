  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eskalada-bide batean zehar paretan zintzilik dagoela, eskalatzaileak atseden hartzeko edo bibakeatuz gaua pasatzeko erabiltzen duen objektua.</descrip>
