<termEntry id="-1">
  <descrip type='subjectField'>Mendizaletasuna, kirol gisa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Abentura-kirola, eskaladan erabiltzen diren jaitsierako teknikak baliatuz mendiko ibaien ibilguetan eta uharretan behera jaistean datzana. Kirol horretan, ibiltzea, rappelean egindako jaitsierak eta igeriketa konbinatzen dira.</descrip>
    </descripGrp>
    <tig>
      <term>arroila-jaitsiera</term>
