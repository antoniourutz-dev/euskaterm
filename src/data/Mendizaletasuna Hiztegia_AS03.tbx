    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>dehydration</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Mendizaletasuna, kirol gisa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi puntu jakinen artean dagoen maila edo altuera-aldea. Mendian, ibilbideari ekiteko irteera-gunearen eta iritsi nahi den punturik altuenaren (dela aterpearen, aintzira edo lakuaren nahiz gailurraren) arteko diferentzia adierazteko erabili ohi da. Altimetroarekin nahiz GPSarekin neur daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>desnibel</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
