  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pasabide estua, terreno lauan zein maldan kokatua. Sarritan, bat egiten du igoera-biderik begi-bistakoenarekin, denetan errazena ez izan arren.</descrip>
