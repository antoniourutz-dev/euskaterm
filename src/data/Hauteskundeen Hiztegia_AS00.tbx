  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hautagai bat kargu baterako behin baino gehiagotan hautetsia izatea. Sistema presidentzialistek berrautapenerako muga bat ezartzen dute, baina sistema parlamentarioetan hautagai bat etengabe hautetsia izan daiteke.</descrip>
