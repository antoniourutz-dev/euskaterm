  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Udalerria banatuta dagoen errolda-unitate administratiboetako bakoitza, hauteskunde-atal bat edo gehiagoz osatuta dagoena.</descrip>
    </descripGrp>
