  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hauteskunde-prozesuaren eta berdintasun-printzipioaren gardentasuna eta objektibotasuna bermatzea helburu duen administrazioa.</descrip>
    </descripGrp>
