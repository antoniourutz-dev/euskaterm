      <term>voto múltiple</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gehiengo erlatiboko izen askoko barruti batean, hautesleari hautagai bakarra hautatzeko aukera ematen dion botoa.</descrip>
    </descripGrp>
