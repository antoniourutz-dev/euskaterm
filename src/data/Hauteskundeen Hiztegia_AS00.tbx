      <term>boto irisgarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Ikus "Braille sistema bidezko boto irisgarri"</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>voto accesible</term>
    </tig>
  </langSet>
