<text>
<body>
<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-administrazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hauteskundeak egin ondorengo lehen bilkuran izendatzen den behin-behineko organoa, hautetsi zaharrena eta hautetsi gazteena biltzen dituena. Ordezkari-organo bat eratzea da haren helburua.</descrip>
    </descripGrp>
    <tig>
      <term>adin-mahai</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>mesa de edad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-administrazioa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>Administrazioaren ordezkari</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>representante de la Administración</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-prozesua</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>artekari-egiaztagutun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>credencial de nombramiento de interventor</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-administrazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hauteskunde-prozesua askea, irekia, lehiakorra eta berdina izango dela bermatzeko, autonomia-erkidegoek hauteskunde-administrazioa osatzeko era dezaketen organoa.</descrip>
    </descripGrp>
    <tig>
      <term>autonomia-erkidegoko hauteskunde-batzorde</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>junta electoral de Comunidad Autónoma</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-administrazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hautesle Erroldaren Bulegoak egiten duen zerrenda, behin-behineko hauteskunde-zerrendari egindako zuzenketak gehituak dituena.</descrip>
    </descripGrp>
    <tig>
      <term>behin betiko hauteskunde-zerrenda</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>lista electoral definitiva</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-administrazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Udalek, kontsuletxeek, erregistro zibilek eta zigortuen eta auzi-iheslarien erregistroek emandako informazioan oinarrituta, Hautesle Erroldaren Bulegoak urtero berritzen duen zerrenda.</descrip>
    </descripGrp>
    <tig>
      <term>behin-behineko hauteskunde-zerrenda</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>lista electoral provisional</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-administrazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hauteskunde-batzordeko kidea, botere judizialak izendatutakoa ez dena.</descrip>
    </descripGrp>
    <tig>
      <term>bokal ez-judizial</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>vocal no judicial</term>
    </tig>
  </langSet>
</termEntry>
