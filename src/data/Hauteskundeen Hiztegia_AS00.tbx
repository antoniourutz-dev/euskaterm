  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hautesle bakoitzak gehienez hauta daitezkeen jarleku adina hautagai bozka ditzan, gehiengo erlatiboko edo absolutuko izen askoko barrutietan ezartzen den boto-sistema.</descrip>
    </descripGrp>
