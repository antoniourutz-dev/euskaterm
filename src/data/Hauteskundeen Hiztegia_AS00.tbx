<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Jarlekuak modu proportzionalean esleitzeko formula. Sistema horren arabera, hautagai-zerrenden boto-kopuruak zutabe batean handienetik txikienera antolatu ondoren, boto-kopurua barrutiari dagozkion jarleku kopuruarekin zatitzen da, eta jarlekuak esleitzen zaizkie zatidura handiena lortzen duten hautagai-zerrendei, handienetik txikienera.</descrip>
    </descripGrp>
    <tig>
      <term>d'Hondt sistema</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sistema d'Hondt</term>
    </tig>
  </langSet>
</termEntry>
