<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hautesle bakoitzari bere botoa zatikitan banatzeko aukera ematen dion boto-sistema. Botoaren zatiki bakoitza hautagaien artean bere lehentasunen arabera bana dezake hautesleak.</descrip>
    </descripGrp>
    <tig>
      <term>boto zatitu</term>
