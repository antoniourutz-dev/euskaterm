<termEntry id="-1">
  <descrip type='subjectField'>Hauteskunde-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hautesleak gogokoen ez duen hautagaiari ematen dion botoa; beste arrazoi batzuen artean, barruti bateko jarlekuen banaketan edo hauteskundeetatik sortuko den gobernu-eraketan eragina izateko ematen dio.</descrip>
    </descripGrp>
    <tig>
      <term>boto baliagarri</term>
