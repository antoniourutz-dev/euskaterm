  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Leku edo inguruabar berezietan, hala nola itsasoko edo aireko bidaian, espetxeetan, ospitaleetan edo antzeko establezimendu publikoetan, edo inkomunikatuta dauden herriguneetan edo erregistro-bulegotik urrun dauden guneetan gertatutako jaiotzen, ezkontzen edo heriotzen inskripzioak egiteko legeak ahalbidetzen duen baliabidea.</descrip>
    </descripGrp>
    <tig>
      <term>aparteko titulu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>ezohiko titulu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>título extraordinario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>idazpenaren liburuki</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>tomo del asiento</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Idazpen baten eduki osoa beste erregistro batera edo erregistro bereko beste leku batera kopiatzea, jatorrizko idazpena indarrik gabe utziz, ezereztu egiten baita.</descrip>
    </descripGrp>
    <tig>
      <term>idazpena lekualdatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>traslado de asiento</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erakunde juridikoa, guraso ahalpean ez dauden adingabe emantzipatugabeak, ezgai deklaratuak, guraso-ahal luzatuaren menpe daudenak edo babesgabezia-egoeran diren adingabeak eta horien ondasunak zaintzeko eratua.</descrip>
    </descripGrp>
    <tig>
      <term>tutoretza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>tutela</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>inskripzioa sustatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>promover inscripción</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>auzotasun zibil</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>vecindad civil</term>
    </tig>
  </langSet>
</termEntry>
