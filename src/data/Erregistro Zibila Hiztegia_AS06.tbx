  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Inskribatutako idazpenen edukia ziurtatzeko erregistroko arduradunak edo idazkariak ematen duen dokumentua.</descrip>
    </descripGrp>
    <tig>
      <term>erregistroko ziurtagiri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>certificación registral</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Edozein motatako erregistro-idazpenei efikazia, erabat edo zati batean, kentzen dien idazpena. Ezerezten den idazpena deuseza delako, efikaziarik gabea delako, egitate edo egintza hori existitzen ez delako edo legeak ezarritako beste arrazoiren batengatik egiten da.</descrip>
    </descripGrp>
    <tig>
      <term>erregistro-ezerezte</term>
      <termNote type='normativeAuthorizaion'>4</termNote>
    </tig>
    <tig>
      <term>ezerezte</term>
      <termNote type='normativeAuthorizaion'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cancelación registral</term>
    </tig>
    <tig>
      <term>cancelación</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egintza juridiko gisa formalizatuta dagoen errealitatea hirugarrenen aurka balia daitekeela ezartzen duen printzipioa. Hirugarrenek nahitaez kontuan izan beharko dute egintza hori.</descrip>
    </descripGrp>
    <tig>
      <term>hirugarrenen aurka baliatzeko ahalmenaren printzipio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>principio de oponibilidad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>Erregistro Zibilaren bulego orokorreko arduradun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>encargado de la oficina general del Registro Civil</term>
    </tig>
  </langSet>
</termEntry>
</body>
</text>
</martif>
