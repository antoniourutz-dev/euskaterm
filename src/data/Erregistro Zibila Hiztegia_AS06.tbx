<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erregistro Zibilaren zatia, 1957ko ekainaren 8ko Erregistro Zibilaren Legeari jarraikiz egoera zibilaren egitate nagusiak bereizita jasotzen zituena. Erregistro Zibilak lau atal zituen: jaiotzen atala, ezkontzen atala, heriotzen atala eta tutoretzen eta legezko ordezkaritzen atala.</descrip>
    </descripGrp>
    <tig>
      <term>atal</term>
