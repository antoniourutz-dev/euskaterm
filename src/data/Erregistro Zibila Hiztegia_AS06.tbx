  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Espainian gertatu eta espainiarrengan edo atzerritarrengan eragina zuten egitate inskribagarri guztiak jasotzen zituen erregistroa. Kontzeptua 1957ko ekainaren 8ko Erregistro Zibilaren Legeak jasotzen zuen.</descrip>
