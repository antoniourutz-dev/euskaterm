    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erregistro Zibilaren atala, Kode Zibilaren 30. artikuluaren betekizunak betetzen zituzten jaiotzen inskripzio nagusiak eta jaiotakoen egoera zibilean eragina zuten egitate guztien orri-bazterreko inskripzioak jasotzen zituena. Kontzeptua 1957ko ekainaren 8ko Erregistro Zibilaren Legeak jasotzen zuen.</descrip>
    </descripGrp>
