<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tutoreen izendapenak inskribatzen diren erregistroa, haiek beren kargua egikaritu ahal izateko bete beharrekoa dena.</descrip>
    </descripGrp>
