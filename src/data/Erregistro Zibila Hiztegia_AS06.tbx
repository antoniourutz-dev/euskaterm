<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lehen auzialdiko hainbat epaitegi zeuden udalerrietan ezarritako erregistroa, udalerri guztirako bakarra eta lehen auzialdiko epaile baten edo batzuen ardurapekoa. Kontzeptua 1957ko ekainaren 8ko Erregistro Zibilaren Legeak jasotzen zuen.</descrip>
    </descripGrp>
