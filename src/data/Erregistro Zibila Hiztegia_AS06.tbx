    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lehen auzialdiko epailerik gabeko udalerrietarako, hau da, Erregistro Zibila bake-epaileen ardurapean zegoen udalerrietarako eratutako erregistroa. Kontzeptua 1957ko ekainaren 8ko Erregistro Zibilaren Legeak jasotzen zuen.</descrip>
    </descripGrp>
    <tig>
      <term>udal-erregistro delegatu</term>
