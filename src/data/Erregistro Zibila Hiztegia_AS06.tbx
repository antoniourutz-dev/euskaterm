    <descripGrp>
      <descrip type='definition'>Ezkontza zibilen edo erlijiosoen inskripzioak jasotzen zituen Erregistro Zibilaren atala. Kontzeptua 1957ko ekainaren 8ko Erregistro Zibilaren Legeak jasotzen zuen.</descrip>
    </descripGrp>
    <tig>
      <term>ezkontzen atal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
