<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona bakoitzak duen erregistroa, identitateari, egoera zibilari eta Erregistro Zibilaren uztailaren 21eko 20/2011 Legean jasotako gainerako inguruabarrei buruzko egitate eta egintzak jasotzen dituena.</descrip>
