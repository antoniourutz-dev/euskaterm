<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aldebakarreko borondatezko adierazpena, etorkizunean ezgaitasun bat izatea aurreikusten duen pertsona batek beste pertsona bati ahalmenak eskuordetzan ematekoa, haren izenean jardun dezan.</descrip>
    </descripGrp>
    <tig>
      <term>prebentziozko ahalordetze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
