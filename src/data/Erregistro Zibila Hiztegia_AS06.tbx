  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Froga-baliorik ez duen idazpena; informazio-balio hutsa izaten du legeak bestelakorik zehaztu ezean.</descrip>
