  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Heriotzen egitate egiaztatuen inskripzioak jasotzen zituen Erregistro Zibilaren atala. Kontzeptua 1957ko ekainaren 8ko Erregistro Zibilaren Legeak jasotzen zuen.</descrip>
    </descripGrp>
