      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>apoderamiento preventivo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Antzinako inskripzioen paper-sortak eta liburuak biltzen zituen artxiboa, erregistroaren bestelako eraikin batean kokatzen zena. Erregistro nagusiak desagertuz gero, desagertutako idazpenak berreratu ahal izango ziren artxibo horri esker. Kontzeptua 1957ko ekainaren 8ko Erregistro Zibilaren Legeak jasotzen zuen.</descrip>
    </descripGrp>
    <tig>
      <term>Erregistro Zibilaren artxibo probintzial</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>Erregistro Zibilaren probintzia-artxibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>archivo provincial del Registro Civil</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Euskarri eta formatu elektronikoan egindako idazpena, Erregistroen eta Notariotzaren Zuzendaritza Nagusiak onartutako ereduetara egokitua.</descrip>
    </descripGrp>
    <tig>
      <term>idazpen elektroniko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>asiento electrónico</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erregistro Zibilean dokumentatzen diren datu eta egitateen adierazpen idatzia. Hiru motatako idazpenak egiten dira: inskripzioak, idatzoharrak eta ezerezteak.</descrip>
    </descripGrp>
    <tig>
      <term>erregistro-idazpen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>asiento registral</term>
    </tig>
  </langSet>
</termEntry>
