  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Barruti judizialeko buruan soilik zegoen erregistroa, lehen auzialdiko epailearen ardurapekoa. Kontzeptua 1957ko ekainaren 8ko Erregistro Zibilaren Legeak jasotzen zuen.</descrip>
    </descripGrp>
