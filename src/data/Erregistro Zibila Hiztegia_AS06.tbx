<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paper tinbreduna, abortatutako haurren gurasoen datuak, jaiotza- eta heriotza-akta eta ehorzketa-lizentzia jasotzen dituena. Kontzeptua 1957ko ekainaren 8ko Erregistro Zibilaren Legeak jasotzen zuen.</descrip>
    </descripGrp>
    <tig>
      <term>abortuen paper-sorta</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
