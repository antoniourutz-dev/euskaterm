    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erregistro zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erregistro Zibilaren Legea betearaztea helburu duen erregelamendua. Bertan zehazten dira erregistroko datu-fitxategi automatizatuen konfigurazioa eta kudeaketa, eta idazpenak nahiz ziurtagiriak egiteko modua eta gainerako xehetasunak.</descrip>
    </descripGrp>
    <tig>
      <term>Erregistro Zibilaren Erregelamendua</term>
      <termNote type='normativeAuthorization'>4</termNote>
