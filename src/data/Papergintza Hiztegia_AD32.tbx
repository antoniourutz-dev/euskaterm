  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alde batetik presioz transferitzen den koloragarri bat duen papera; kopiak egiteko erabiltzen da, idazmakinetan bereziki.</descrip>
    </descripGrp>
