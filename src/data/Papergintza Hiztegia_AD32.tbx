  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Orea lehortzeko makina baten edo paper-makina baten atal bat; hezean prentsatu ondoren, ore- edo paper-bandari geratu zaion ura lurrundu egiten da atal horretan, beroa aplikatuz.</descrip>
