<termEntry id="186">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erresistentzia mekaniko handiko papera, zorroak egiteko erabiltzen dena. Kraft papera izaten da gehien erabiltzen dena.</descrip>
    </descripGrp>
