      <term>machine finishing</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="15">
  <descrip type='subjectField'>Papergintzako lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hainbat landaretatik ateratzen den gluzidoa. Likido bero batean sartuz gero, hazi egiten da, eta, beraz, lodigarria da.</descrip>
    </descripGrp>
    <tig>
      <term>almidoi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>almidón</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>amidon</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>starch</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="16">
  <descrip type='subjectField'>Papergintzako lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Papergileen artean aluminio sulfatoaren hainbat kalitate adierazten dituen izena.</descrip>
    </descripGrp>
    <tig>
      <term>alumina</term>
      <termNote type='normativeAuthorization'>4</termNote>
