      <term>anthraquinone</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>anthraquinone</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="19">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paperaren akats bat, gune batean papera gardenago ikusten delako antzematen dena. Prentsatzearen hasierako faseetan nahiz papera kalandratzean sortzen da, egina baina hezea dagoen paper-orrian orea mugitzen delako.</descrip>
    </descripGrp>
    <tig>
      <term>zapaltze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aplastado</term>
    </tig>
    <tig>
      <term>aplastamiento</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>écrasé</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>crushing</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="20">
  <descrip type='subjectField'>Oregintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ore batek zuritzeko duen gaitasun erlatiboa.</descrip>
    </descripGrp>
    <tig>
      <term>zuritze-gaitasun</term>
