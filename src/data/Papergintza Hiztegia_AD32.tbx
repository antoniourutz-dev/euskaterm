    </tig>
  </langSet>
</termEntry>
<termEntry id="14">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paper-makina bateko lisagailuan egiten den leunketa.</descrip>
    </descripGrp>
    <tig>
      <term>makinako akabera</term>
      <termNote type='normativeAuthorization'>4</termNote>
