<termEntry id="270">
  <descrip type='subjectField'>Papergintzako lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sortzen den urte berean loratzen, fruitua ematen eta hiltzen den landare zurik gabea. Adibidez, zerealak (lastoa), azukre-kanabera eta horrelakoak.</descrip>
    </descripGrp>
