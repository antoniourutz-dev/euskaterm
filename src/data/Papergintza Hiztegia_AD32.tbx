<termEntry id="189">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kalitate arrunteko papera, egunkariak inprimatzeko erabiltzen dena.</descrip>
