      <term>alum</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="17">
  <descrip type='subjectField'>Papergintzako lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oregintzan erabiltzen den gehigarria; ore-suspentsioetatik eta egoste-nahasketetatik aparra kentzeko balio du, apar-burbuilek poltsak eta zuloak sortzen baitituzte paper-orrian.</descrip>
    </descripGrp>
    <tig>
      <term>apar-kontrako</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>antiespumante</term>
    </tig>
    <tig>
      <term>desespumante</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>anti-mousse</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>antifoam</term>
    </tig>
    <tig>
      <term>defoamer</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="18">
  <descrip type='subjectField'>Papergintzako lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Antrazenoaren oxidaziotik sortutako produktua; sulfonazioz lortutako azido antrakinosulfonikoen bidez koloragarriak eta pigmentuak egiteko erabiltzen da.</descrip>
    </descripGrp>
    <tig>
      <term>antrakinona</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>antraquinona</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
