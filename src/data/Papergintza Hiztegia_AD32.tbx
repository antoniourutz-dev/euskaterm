<termEntry id="182">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi geruzak edo gehiagok osatutako papera, geruza bakoitza bata bestearekin, itsasgarririk gabe, heze dauden bitartean elkartuz egiten dena.</descrip>
