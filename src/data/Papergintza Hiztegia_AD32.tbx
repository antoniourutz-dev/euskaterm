<termEntry id="31">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Papera edo kartoia kalandratik pasatzea. Jakina, paper edo kartoi horrek gutxienez partzialki lehortua egon behar du. Gainazalari akabera hobea emateko edota, neurri batean, bandaren lodiera berdintzeko egiten da.</descrip>
