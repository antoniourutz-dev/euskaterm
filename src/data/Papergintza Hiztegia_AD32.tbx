    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>catalog paper</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="174">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paketeak egiteko edo gauzak biltzeko erabiltzen den papera.</descrip>
    </descripGrp>
