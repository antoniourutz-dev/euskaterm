<termEntry id="223">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Fluido batekin betetzeko gai diren poroak kontuan hartuz, paper edo kartoi batek duen poro-bolumena, paper edo kartoi horren bolumen errealarekin konparatuta.</descrip>
