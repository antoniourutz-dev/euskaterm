<termEntry id="187">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gutun-azalak eta posta-zorroak egiteko erabiltzen den papera, erresistentzia mekaniko egokikoa. Gainean idazteko, inprimatzeko eta itsasgarri bat emateko gai izan behar du.</descrip>
    </descripGrp>
