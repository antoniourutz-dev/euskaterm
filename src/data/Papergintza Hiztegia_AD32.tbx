<termEntry id="21">
  <descrip type='subjectField'>Papergintzako lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zur-zati txikia, orea egiteko egokia, eta 10-30 mm-ko luzera eta 2-10 mm-ko lodiera izaten duena.</descrip>
    </descripGrp>
