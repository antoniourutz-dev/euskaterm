  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ore-suspentsioa formazio-oihalera botatzeko kutxa edo ganbera. Aurrez ezarritako abiaduran eta presio konstantean zabaltzen du orea, oihalaren zabalera guztian berdin banatuz.</descrip>
