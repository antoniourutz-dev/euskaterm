  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paper-bandari kolazko, iztukuzko edo beste akabera-produktu batezko geruza uniforme bat emateko erabiltzen den prentsa. Paper-makinaren bi lehorgailu-baterien artean kokatzen da prentsa.</descrip>
