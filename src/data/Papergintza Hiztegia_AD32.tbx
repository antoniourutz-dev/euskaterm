  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alde batetik edo bietatik iztuku-saltsa batekin estalitako papera. Itxura, akabera eta inprimagarritasuna hobetzeko ematen zaio iztukua.</descrip>
