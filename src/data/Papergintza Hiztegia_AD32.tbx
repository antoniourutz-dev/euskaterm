<termEntry id="23">
  <descrip type='subjectField'>Ingurumena errespetatzeko neurriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Substantzia edo produktu batek ingurumenean dauden mikroorganismoen eraginez desegiteko duen gaitasuna.</descrip>
