  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oreak lehortu ondoren duen masaren eta lagina hartzeko unean zuen masaren arteko erlazioa, ehuneko gisa adierazia, saiakuntza-baldintza arautuetan neurtua.</descrip>
