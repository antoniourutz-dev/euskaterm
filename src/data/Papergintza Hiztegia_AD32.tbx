<termEntry id="244">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Papera lehortzeko metodo bat: aire-korronte mugikor batekin kontaktuan jarriz lehortzen dira orriak. Paper-banda, normalean, aire beroarekin kontaktuan jarriz lehortzen da, areto batean edo tunel batean.</descrip>
