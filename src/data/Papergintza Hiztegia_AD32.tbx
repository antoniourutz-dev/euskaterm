    <tig>
      <term>acanalado</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>cannelure</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>flute</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="4">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Papera eta ura kontaktuan daudenean, paperak ura azidotzeko duen gaitasuna.</descrip>
    </descripGrp>
    <tig>
      <term>paperaren azidotasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acidez del papel</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acidité du papier</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>paper acidity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="5">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paperari ematen zaion tratamendua: baldintza jakineko ingurune batean jartzen denean ematen zaio, hezetasunaren eta tenperaturaren aldetik behar duen oreka izan dezan.</descrip>
    </descripGrp>
    <tig>
      <term>paper-egokitze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acondicionado del papel</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>conditionnement du papier</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>conditioning of paper</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="6">
  <descrip type='subjectField'>Papergintzako lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi gainazal elkarrekin itsasteko produktua.</descrip>
    </descripGrp>
    <tig>
      <term>itsasgarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>adhesivo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>adhésif</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>adhesive</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="7">
  <descrip type='subjectField'>Papergintzako lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paperaren edo prozesuaren ezaugarriak hobetzeko edo beste berri batzuk eransteko gehitzen den substantzia. Iztukatu-lanetan erabiltzen diren sakabanatzaileak, koloragarriak, plastifikatzaileak, eta abar, adibidez.</descrip>
    </descripGrp>
    <tig>
      <term>gehigarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aditivo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>additif</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>additive</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="8">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zuntz-suspentsio batetik edo formazio-banda batetik bereizten diren urak; adibidez, papera egiteko makina batean edo forma biribil batean bereizten direnak. Zuntz-hondarrak, kargak, koloragarriak, kolak eta horrelakoak izaten dituzte ur zuriek, eta, normalean, birziklatu egiten dira.</descrip>
    </descripGrp>
    <tig>
      <term>ur zuriak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aguas blancas</term>
    </tig>
    <tig>
      <term>agua colada</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>eaux blanches</term>
    </tig>
    <tig>
      <term>eaux collées</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>white water</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="9">
  <descrip type='subjectField'>Ingurumena errespetatzeko neurriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Industriako prozesuren batean erabili eta gero kanpora botatzen diren urak. Prozesu horren hondakinak izaten dituzte batzuetan.</descrip>
    </descripGrp>
    <tig>
      <term>hondakin-urak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aguas residuales</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>eaux résiduaires</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>waste water</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="10">
  <descrip type='subjectField'>Oregintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egosteko lixiba alkalino batek dituen osagai alkalinoen kontzentrazioa neurtzeko faktore bat. Sodio hidroxidoko kontzentrazioaren eta sodio sulfuroko kontzentrazioaren batura da, eta lixiba-litro bakoitzeko sodio hidroxido gramotan edo sodio oxido gramotan neurtzen da.</descrip>
    </descripGrp>
    <tig>
      <term>alkali aktibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>álcali activo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>alcali actif</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>active alkali</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="11">
  <descrip type='subjectField'>Oregintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egosteko lixiba alkalino batek dituen osagai alkalinoen kontzentrazioa neurtzeko faktore bat. Egoste-lixibak duen soda-kantitate osoaren eta sodio sulfuro kantitatearen erdiaren batura da, eta lixiba-litro bakoitzeko sodio hidroxido gramotan edo sodio oxido gramotan neurtzen da.</descrip>
    </descripGrp>
    <tig>
      <term>alkali efektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>álcali efectivo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>alcali effectif</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>effective alkali</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="12">
  <descrip type='subjectField'>Oregintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sodio hidroxidoaren (OHNa), sodio sulfuroaren (Na2S), sodio karbonatoaren (Na2CO3) eta sodio sulfatoaren (Na2SO4) arteko batura, sodio oxido gisa (Na2O) adierazita.</descrip>
    </descripGrp>
    <tig>
      <term>alkali total</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>álcali total</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>alcali total</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>total alkali</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="13">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Papera eta ura kontaktuan daudenean, paperak ura alkalinotzeko duen gaitasuna.</descrip>
    </descripGrp>
    <tig>
      <term>paperaren alkalinotasun</term>
