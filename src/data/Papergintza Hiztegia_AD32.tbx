<termEntry id="227">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Papergintzako prozesuaren edozein fasetan kentzen den eta berriro orearekin nahasteko erabili ohi den paper- edo kartoi-zatia. Fase lehorrean hautsitako zatiak eta fase hezean hautsitako zatiak bereizten dira.</descrip>
