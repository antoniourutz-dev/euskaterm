<termEntry id="24">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oreak edo paperak argi-errainu bat espektroaren zati urdinean islatzeko duen gaitasuna, araututako baldintzetan neurtua.</descrip>
    </descripGrp>
