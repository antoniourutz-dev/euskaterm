<termEntry id="185">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paper kalandratua, iztukatu gabea edo iztukatua, normalean ore mekanikoa izaten duena (prentsako paperak baino gutxiago, hala ere). Aldizkariak, igandeetako prentsa-aldizkariak eta horrelakoak egiteko erabiltzen da.</descrip>
