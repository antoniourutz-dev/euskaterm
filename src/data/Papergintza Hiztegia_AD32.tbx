    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>wet-strength paper</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="193">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bereizitako kalandra batetik edo superkalandra batetik pasatu den papera, makinako akabera duen papera baino leuntasun eta distira handiagokoa.</descrip>
    </descripGrp>
    <tig>
      <term>paper satinatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
