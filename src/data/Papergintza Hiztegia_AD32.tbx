<body>
<termEntry id="1">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paper- edo kartoi-orri batek azalean izan dezakeen deformazioa, hau da, bere norabideetako batean erabat edo partzialki kurbatzeko izan dezakeen joera.</descrip>
    </descripGrp>
    <tig>
      <term>biribiltze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>bihurritze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>abarquillado</term>
    </tig>
    <tig>
      <term>abarquillamiento</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>gode</term>
    </tig>
    <tig>
      <term>roulage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>curl</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="2">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paperari akabera egokia emateko faseetako bat, prentsatze mekaniko bidez eta lehortze-eragiketaz paperari distira ematen diona.</descrip>
    </descripGrp>
    <tig>
      <term>distira-emate</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>abrillantado</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>glaçage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>glazing</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="3">
  <descrip type='subjectField'>Papergintza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Uhinak uhin-paperari ematen dion forma.</descrip>
    </descripGrp>
    <tig>
      <term>ildaska</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acanaladura</term>
