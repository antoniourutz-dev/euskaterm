  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zur-ezpalak lurrunez tratatuz, tenperatura altuan finduz eta, azkenean, presio atmosferikoan berriz ere finduz lantzen den ore mekanikoa.</descrip>
