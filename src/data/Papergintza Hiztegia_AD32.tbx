<termEntry id="271">
  <descrip type='subjectField'>Papergintzako lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zurik gabeko landareen zurtoinetik, hostoetatik edo fruituetatik ateratzen den zuntza; kotoi-zuntza, adibidez.</descrip>
    </descripGrp>
