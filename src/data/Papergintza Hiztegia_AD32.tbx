<termEntry id="171">
  <descrip type='subjectField'>Paper- eta kartoi-motak eta ezaugarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Azalean, leunago eta malguago geratzeko, uhin txiki paraleloak atera zaizkion papera; bildu behar duen objektuaren forma hobeto hartzeko gaitasuna ematen dio horrek.</descrip>
    </descripGrp>
