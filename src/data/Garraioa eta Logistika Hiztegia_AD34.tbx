<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Estibatzeko eragiketa bat: salgaia ibilgailuaren kutxara, garraioa egin behar duen plataformara edo ibilgailuko elementu finkoetara (habe, kartola, kako, eta abarretara) lotzea, ibilgailuak mugimendu zakarrak eginez gero karga lekuz alda edo eror ez dadin.</descrip>
    </descripGrp>
