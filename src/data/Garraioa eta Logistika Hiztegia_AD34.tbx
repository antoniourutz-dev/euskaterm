    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Trenbideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ibilgailu komertzialetako gidariek hainbat herrialdetara sartzeko eta ateratzeko aurkeztu behar duten agiria; daramatzaten salgaien edo bidaiarien identitatea egiaztatzeko eta egindako ibilbideari buruzko xehetasunak emateko balio du.</descrip>
    </descripGrp>
