<termEntry id="-1">
  <descrip type='subjectField'>Garraio intermodala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zorua luzera guztian beheratua duen tren-bagoia; kamioi osoak eramateko balio du, eta, trenean era bereko beste bagoi batzuekin lotuta, errepide gurpildun moduko bat osatzen du.</descrip>
