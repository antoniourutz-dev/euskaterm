  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garraiolariaren erruz ezusteko bat gertatu denean, bidalketa bat jaso behar duenak salgaia hartzeari uko egin eta salgaiaren balioa jasotzeko duen eskubidea.</descrip>
