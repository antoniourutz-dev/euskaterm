  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Itsasontzi batean espazio jakin bat kontratatu eta gero espazio hura bete gabe uzteagatik ordaindu behar den kalte-ordaina. Kontratuko pleitaren % 50 izaten da.</descrip>
