<termEntry id="-1">
  <descrip type='subjectField'>Logistika</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hirian bertan banatu behar diren salgai guztiak bildu eta antolatzeko lekua. Salgaiak banatzean sortzen den zirkulazioa ahalik eta gehien murriztea da helburua.</descrip>
