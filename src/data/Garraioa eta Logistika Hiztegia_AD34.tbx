      <term>fletamento por viaje</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>affrètement au voyage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>voyage charter</term>
    </tig>
  </langSet>
</termEntry>
