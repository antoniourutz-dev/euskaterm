  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garraiatutako salgaiaren helburuko helbidea. Kontrako itunik ez badago, jasotzailearen egoitza izaten da, garraio-gutunean azaltzen denaren arabera.</descrip>
