<termEntry id="-1">
  <descrip type='subjectField'>Garraio intermodala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Karga edukiontzitan sartuta eramateko garraio-modua; salgaiak fardelez fardel eramaten ibili gabe, edukiontzi batean sartu eta edukiontzia osorik mugituz egiten da.</descrip>
