<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ibilgailuak elkarrekin eta zentral batekin konektatuta egoteko erabiltzen den komunikazio mugikorren sistema. Ibilbideak optimizatzeko eta ibilgailuei buruzko datuak denbora errealean ezagutzeko eta antolatzeko tresna egokia da.</descrip>
    </descripGrp>
    <tig>
      <term>trunking</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>trunking</term>
    </tig>
  </langSet>
