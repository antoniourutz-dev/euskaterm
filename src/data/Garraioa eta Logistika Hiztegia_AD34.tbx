<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Salgaiak jasotzeko, lekuz aldatzeko eta helmugako lekuan uzteko egin behar diren eragiketen multzoa: biltegian hartzea, metatzea, antolatzea eta, azkenik, berriro atera eta ibilgailu batean kargatzea.</descrip>
    </descripGrp>
