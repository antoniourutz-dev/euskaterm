    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>miscarriage</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garraiatu behar diren salgaien pisua neurtzea. Aski da kontratua egiten duen alderdietako batek bidalketaren pisua jakin nahi izatea, kargako edo deskargako lekuan salgaia pisatu behar izateko. Pisatzea kostatzen dena eskatzen duenaren kontura izaten da.</descrip>
    </descripGrp>
