<termEntry id="-1">
  <descrip type='subjectField'>Trenbideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kamioiak trenez eramatean datzan garraio-sistema. Zirkulazio zaileko lekuetan, adibidez leku menditsuetan, eta errepide-azpiegitura eskaseko lekuetan erabiltzen da, eta ohiko garraio-moduak baino garestiagoa, eraginkorragoa eta fidagarriagoa da.</descrip>
    </descripGrp>
