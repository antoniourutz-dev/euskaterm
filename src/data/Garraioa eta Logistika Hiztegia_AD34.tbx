<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Edukiontzi isotermoa, beroa sortzeko gailua duena; gailu horren bidez, edukiontziaren barruko tenperatura igo, eta balio ia konstante batzuen artean mantentzen da, gutxienez +12 ºC-an.</descrip>
