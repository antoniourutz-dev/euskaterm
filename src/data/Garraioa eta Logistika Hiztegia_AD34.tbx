<termEntry id="-1">
  <descrip type='subjectField'>Errepideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Errepideko garraioan kosturik edo beharrezkoa ez den arriskurik eragin gabe bi zati edo gehiagotan banatu ezin den zama; haren neurriak edota masa direla-eta, ezin da garraiatu araudiak ezarritakoa betetzen duen ibilgailu motordun, atoi, errepideko tren edo ibilgailu artikulatu batean.</descrip>
