<termEntry id="-1">
  <descrip type='subjectField'>Itsasoko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ingurumen-baldintza sentikorreko eremuetan errepideko zirkulazio sarria arintzeko itsas garraioko ibilbidea, behar adinako portu-zerbitzuak jarriz eratzen dena. Kamioi kargatuak edo atoiak itsasoz eramatean datza.</descrip>
