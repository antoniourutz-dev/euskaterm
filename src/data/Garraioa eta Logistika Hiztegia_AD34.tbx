    <tig>
      <term>transporte aéreo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>transport aérien</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>air transport</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Behar bezala kontserbatzeko tratamendu termiko espezifiko bat behar duten salgaien garraioa. Janarien kasuan tenperatura hotza behar izaten den arren, zenbaitetan beroa ere behar izaten da salgai batzuk garraiatzeko (hainbat olio, petrolioa, asfaltoa eta abar).</descrip>
    </descripGrp>
    <tig>
      <term>tenperatura kontrolatuko garraio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>transporte bajo temperatura dirigida</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>transport sous température dirigée</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>transport of goods at controlled temperature</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Animaliak leku batetik bestera bizirik eramateko garraioa. Baldintza egokietan egin behar da, beharrezko ekipamendu eta zaintzako instalazioaz hornituz, atsedenaldi eta animalien otorduetako denborak hartuz, eta abar.</descrip>
    </descripGrp>
    <tig>
      <term>animalia bizien garraio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>transporte de animales vivos</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>transport des animaux vivants</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>transport of live animals</term>
    </tig>
    <tig>
      <term>carriage of live animals</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Salgaiak zatika banatuta eramateko garraio-modua. Garraiolariari beste eragiketa batzuk egitea eskatzen dio horrek; adibidez, salgaiak manipulatzea, biltegiratzea, taldekatzea, sailkatzea eta enbalatzea eta, azkenean, banatzea.</descrip>
    </descripGrp>
    <tig>
      <term>karga zatituko garraio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>zama zatituko garraio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>transporte de mercancías de carga fraccionada</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>transport fractionné</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>segmented transport</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsonak eta haien bagajeak leku batetik bestera eramatea, modu pertsonalizatuan edo kolektiboan, hartarako egokitutako ibilgailuetan.</descrip>
    </descripGrp>
    <tig>
      <term>bidaiarien garraio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>transporte de viajeros</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>transport de voyageurs</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>carriage of passengers</term>
    </tig>
    <tig>
      <term>passenger transport</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrez ezarritako ibilbide, egutegi eta ordutegirik gabeko garraioa.</descrip>
    </descripGrp>
    <tig>
      <term>eskatu ahalako garraio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
