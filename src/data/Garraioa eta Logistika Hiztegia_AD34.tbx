      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>trincaje</term>
    </tig>
    <tig>
      <term>trincado</term>
    </tig>
  </langSet>
