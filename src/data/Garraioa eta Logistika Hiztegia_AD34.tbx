  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Salgai arriskutsuen, animalia bizien, salgai galkorren, ontzi gaineko salgaien eta antzekoen kasuan aplikatzen den pleita. Beti aurrez ordaintzen da, salgaia helmugara iritsi edo ez iritsi.</descrip>
