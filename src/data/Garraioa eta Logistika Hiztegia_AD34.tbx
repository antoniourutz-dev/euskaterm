  <descrip type='subjectField'>Garraio intermodala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi punturen artean ordutegi jakin baten barruan bidaiak egiten dituen itsasontzia, bidaiariak eta bestelako ibilgailuak garraia ditzakeena.</descrip>
    </descripGrp>
    <tig>
      <term>transbordadore</term>
