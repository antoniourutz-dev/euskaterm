    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Logistika</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Korridore oso estuetan kargak oso azkar garraiatzeko eta altxatzeko gailu mekanikoa; gaur egun salgaiak manipulatzeko eta biltegiratzeko instalazioetan gehien erabiltzen denetako bat da.</descrip>
    </descripGrp>
    <tig>
      <term>garabi pilatzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>transelevador</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
