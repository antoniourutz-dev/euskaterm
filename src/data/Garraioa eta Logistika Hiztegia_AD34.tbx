  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errepideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garraio-zerbitzu baten ibilbidea; zerbitzu hori bera.</descrip>
    </descripGrp>
