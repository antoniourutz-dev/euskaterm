  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>weighing</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errepideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ibilgailu batek, bide publikoetan zirkulatzeko, zama eta guzti izan dezakeen gehieneko masa.</descrip>
    </descripGrp>
