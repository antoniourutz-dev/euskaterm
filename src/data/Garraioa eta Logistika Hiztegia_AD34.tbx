<termEntry id="-1">
  <descrip type='subjectField'>Itsasoko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Itsasontzi baten jabea, ontzia bere izenean erregistratua duena. Berak ustia dezake itsasontzia, hainbat zerbitzutarako erabiliz, edota akuratu egin dezake, era bateko edo besteko kontratua eginez (aldi batekoa, bidaiakakoa, eta abar).</descrip>
