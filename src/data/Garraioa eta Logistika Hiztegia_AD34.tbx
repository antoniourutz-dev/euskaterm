<termEntry id="-1">
  <descrip type='subjectField'>Trenbideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Trenbide-zirkulazioko nazioarteko dokumentua. Nazioarteko hitzarmen baten arabera, salgai bat zuzenean eta aduanako zigilua hautsi gabe irteerako aduana-bulego batetik beste herrialde bateko aduana-bulego batera eramateko ahalmena ematen du dokumentu horrek; tarteko mugak pasatzean ez da zigiluen kontrola beste izapiderik egin behar.</descrip>
    </descripGrp>
    <tig>
      <term>nazioarteko trenbide-iraganbideko txartel</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
