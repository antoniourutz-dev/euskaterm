<termEntry id="-1">
  <descrip type='subjectField'>Itsasoko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bereziki edukiontziak garraiatzeko erabiltzen den itsasontzia. Gidari batzuk izaten ditu sotoetan, edukiontziak, kargatu ondoren, ez daitezen mugitu. Garabi bidez bertikalean mugituz kargatzen dira edukiontziak.</descrip>
