<termEntry id="-1">
  <descrip type='subjectField'>Errepideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ibilgailu motordun bati lotuta eramatekoa den atoi edo erdiatoi baten gehieneko masa baimendua; masa hura gainditzen duen atoia edo erdiatoia ezin da ez matrikulatu ez zerbitzuan jarri.</descrip>
