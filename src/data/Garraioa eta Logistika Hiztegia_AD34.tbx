<termEntry id="-1">
  <descrip type='subjectField'>Garraio intermodala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eremu geografiko jakin batean salgaiak jasotzeko, sailkatzeko eta berriz banatzeko zerbitzugune nagusia.</descrip>
