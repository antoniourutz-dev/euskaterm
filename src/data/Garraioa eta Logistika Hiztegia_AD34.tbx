    </tig>
    <tig>
      <term>charterer</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Itsasoko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Denbora-bitarte jakin baterako pleitatzea; bidaia bat baino gehiago egin daitezke denboraldi horretan. Pleitariaren kontrolpean geratzen da itsasontziaren merkataritza-kudeaketa, eta hark erabakitzen du jarraitu beharreko ibilbidea; itsasontzi-jabearen esku geratzen da, berriz, tripulazioaren kudeaketa eta ontziaren segurtasuna eta mantentzea.</descrip>
    </descripGrp>
    <tig>
      <term>denboraren araberako pleitatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>fletamento por tiempo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>affrètement à temps</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>time charter</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Itsasoko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bidaia jakin baterako pleitatzea. Pleitaria itsasontziaren karga-edukieraz arduratzen da: edukiera osoa har dezake bere salgaientzat, edo azpikotratatu egin ditzake edukiera-zatiak. Gainerako kudeaketa eta ardurak itsasontzi-jabearen esku geratzen dira.</descrip>
    </descripGrp>
    <tig>
      <term>bidaiaren araberako pleitatze</term>
