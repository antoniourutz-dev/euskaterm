  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bidaltzaile bat baino gehiagorengandik datozen eta jasotzaile bat baino gehiagorentzat diren karga-unitateak, fardelak edo bidalketak elkarrekin biltzeko eragiketa; loteak helmugen arabera antolatzeko egiten da, garraioa egin behar duen ibilgailuaren gaitasuna kontuan hartuz ibilgailua ahalik eta gehien aprobetxatzeko.</descrip>
    </descripGrp>
    <tig>
      <term>taldekatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
