  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Likidoak garraiatzeko edukiontzi berezia, kanpotik egitura egoki bat eta barrutik altzairu herdoilgaitzezko andel bat dituena.</descrip>
