  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bitarteko gisa jokatzen duen garraio-enpresa. Salgai-garraioen kontratazioa egiteko baldintzen arabera, bidaltzaileen eta garraiolarien arteko harreman-lana egiten du.</descrip>
