  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Abiapuntua, helmuga eta tarteko bidea estatu bereko lurraldean dituen garraioa.</descrip>
    </descripGrp>
