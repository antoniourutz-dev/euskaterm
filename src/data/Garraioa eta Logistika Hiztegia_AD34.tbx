    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>véhicule à deux essieux</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>two-axle vehicle</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errepideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Direkzioko ardatz bat eta, atzean, beste ardatz bikoitz bat dituen ibilgailua.</descrip>
    </descripGrp>
    <tig>
      <term>hiru ardatzeko ibilgailu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
