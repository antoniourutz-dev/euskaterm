<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tarifa berezia izaten duen garraio-erregimena; karga hartzen denetik helmugan entregatzen den arte bestelako lan osagarririk (hau da, manipulaziorik, biltegiratzerik, taldekatzerik, sailkatzerik, enbalatzerik edo banatzerik) behar ez delako da berezia.</descrip>
    </descripGrp>
