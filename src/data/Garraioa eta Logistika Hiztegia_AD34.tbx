    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>means of transport</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona-talde bat aldi berean garraiatzeko diseinatuta dauden garraiobideen multzoa: tarifak, ordutegiak eta ibilbideak finkoak izan daitezke, edo unean uneko beharrei egokituak.</descrip>
    </descripGrp>
    <tig>
      <term>garraio kolektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>transporte colectivo</term>
    </tig>
    <tig>
      <term>transporte colectivo de viajeros</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>transport collectif</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>collective transportation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>1. Pertsonak edo salgaiak ibilgailuen bidez leku batetik bestera eramatea. 2. Horretarako erabiltzen diren bide edo moduen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>garraio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>transporte</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
