  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi hankaren gainean eutsitako zubi batez osatutako jasogailua; eremu mugatu baten barruan errailen gainean ibil daiteke, eta kargak bertikalean, horizontalean edo aldeetarantz mugi ditzake.</descrip>
