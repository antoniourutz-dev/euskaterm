<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bereziki paletak edo plataformak mugitzeko diseinatutako gailu mekanikoa; eskuz maneiatzekoa nahiz elektrikoa izan daiteke. Bi beso horizontaleko urkila bat eta gurpilak ditu; paletaren azpian sartu eta gora altxa edo behera jaitsi ondoren, nahi den lekura eramaten da.</descrip>
    </descripGrp>
