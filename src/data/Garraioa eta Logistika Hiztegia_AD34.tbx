      <term>transitario</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>transitaire</term>
    </tig>
    <tig>
      <term>commissionnaire de transport</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>forwarding agent</term>
    </tig>
    <tig>
      <term>freight forwarder</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aireko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hegazkinez egiten den garraioa.</descrip>
    </descripGrp>
    <tig>
      <term>aireko garraio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
