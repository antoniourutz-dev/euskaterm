</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Garraio intermodala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Edukiontziak bi ilaratan, bata bestearen gainean pilatuta, eramateko egokia den tren-bagoia.</descrip>
