<termEntry id="-1">
  <descrip type='subjectField'>Errepideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pisua lurrera transmititzeko bi biraketa-ardatzeko sistema duen ibilgailua.</descrip>
    </descripGrp>
    <tig>
      <term>bi ardatzeko ibilgailu</term>
