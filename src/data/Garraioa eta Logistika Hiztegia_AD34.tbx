<termEntry id="-1">
  <descrip type='subjectField'>Trenbideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Salgai-garraioan, bagoi osoa hartzen duen karga-unitatea. Bagoi osoa hartzeko adinako pisuko edo bolumeneko karga garraiatu behar denean erabiltzen da, bagoi beteari aplikatzen zaion tarifa bereziaz baliatzeko.</descrip>
