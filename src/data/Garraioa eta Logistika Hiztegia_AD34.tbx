  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aireko garraioko karga-unitatea, aire-nabigazioko arauak betetzeko egokitua eta barrutik metro kubiko bateko edo gehiagoko bolumena duena.</descrip>
