  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zama txikiak jasotzeko eta, oro har, haiek ibilbide laburretan garraiatzeko garabi txiki bat edo urkila-plataforma bat dituen ibilgailua.</descrip>
