<body>
<termEntry id="-1">
  <descrip type='subjectField'>Errepideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Udalerri artean egiten den garraioa.</descrip>
