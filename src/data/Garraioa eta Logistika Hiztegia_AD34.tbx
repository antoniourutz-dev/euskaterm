<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garraio-kontratu bat egin dela ziurtatzen duen dokumentua, bidaltzaileak eta garraiolariak elkarri eska diezaioketena. Bidaltzailearen, garraiolariaren eta jasotzailearen identifikazio-datuak jasotzen dira dokumentu horretan, bai eta bidalketa non eta noiz entregatu behar den eta salgaiaren pisua, izaera eta identifikatzeko datuak ere.</descrip>
    </descripGrp>
