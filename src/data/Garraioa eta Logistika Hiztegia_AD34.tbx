  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Neurri txikiko produktu asko elkartuz osatzen den multzoa. Hobeto garraiatzeko eta manipulatzeko osatzen da, eta paleta izaten da gehien erabiltzen den unitatea.</descrip>
