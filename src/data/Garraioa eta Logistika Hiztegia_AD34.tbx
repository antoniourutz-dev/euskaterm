    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Salgaiak garraiatzeko behar diren izapide administratiboak eta logistikoak egiteaz arduratzen den pertsona fisikoa edo juridikoa; bereziki, portuetan eta aireportuetan aritzen da.</descrip>
    </descripGrp>
