<termEntry id="-1">
  <descrip type='subjectField'>Itsasoko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Itsasontzi-jabe bati itsasontzi bat edo itsasontziaren parte bat akuran aldi baterako kontratatzen dion pertsona fisikoa edo juridikoa. Bidaltzaileen aurrean benetako garraiolari bihurtuko duten kontratuak egin behar dira pleitariaren eta itsasontzi-jabearen artean.</descrip>
    </descripGrp>
