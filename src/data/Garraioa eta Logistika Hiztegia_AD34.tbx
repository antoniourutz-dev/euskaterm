    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garraiatu beharreko salgai guztiak edo salgaien parte bat desagertzea. Arrazoia izan daiteke suntsiketa, sutea, lapurreta, non utzi zen ez gogoratzea, eta abar.</descrip>
    </descripGrp>
