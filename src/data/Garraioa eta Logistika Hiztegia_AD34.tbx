    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>mode of transport</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errepideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Etxebizitza, bulego edo negozio-lokal bateko altzariak eta hornidurak leku batetik bestera eramateko garraio espezializatua.</descrip>
