<termEntry id="-1">
  <descrip type='subjectField'>Itsasoko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Salgaiak itsasoz bide laburrean garraiatzea; adibidez, Europako portu batetik bestera, edota Europako portu batetik Europarekin muga egiten duen itsaso baten ertzean dagoen beste herrialde bateko portu batera.</descrip>
    </descripGrp>
    <tig>
      <term>bide laburreko itsas garraio</term>
