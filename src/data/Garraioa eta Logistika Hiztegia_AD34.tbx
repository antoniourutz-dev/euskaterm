  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ibilbidea estatu bateko baino gehiagotako lurraldetatik egiten duen garraioa.</descrip>
    </descripGrp>
