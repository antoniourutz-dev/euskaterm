  <langSet xml:lang='en'>
    <tig>
      <term>ferryboat</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Garraio intermodala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bidaiariak edo salgaiak ibilgailu batetik beste batera pasaraztea.</descrip>
    </descripGrp>
    <tig>
      <term>ibilgailu-aldaketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Testuingurua orokorra edo zehaztugabea denean, ibilgailu-aldaketa erabil daiteke. Hala ere, aldaketa mota bereko ibilgailuen artekoa dela jakinez gero, haien aipamena egiten duen terminoa erabil daiteke: ontzi-aldaketa, tren-aldaketa, hegazkin-aldaketa eta abar.</termNote>
    </tig>
    <tig>
      <term>aldaketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
