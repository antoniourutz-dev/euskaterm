    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garraiolariari entregatzen zaion unean bidalketako beste unitate guztietatik garbi bereizitako unitate-karga bat osatzen duen objektua edo objektu-multzoa; neurriak eta bolumena edozein izan daitezke, eta enbalajea ere barnean hartzen da. Pakete bakar batek edo pakete-sail batek osa dezake fardela.</descrip>
