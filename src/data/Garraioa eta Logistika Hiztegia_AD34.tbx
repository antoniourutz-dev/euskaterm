  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>container transport</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsonak eta salgaiak eramateko garraioa; horretarako bereziki prestatutako ibilgailuetan egiten da, batzuentzako eta besteentzako instalazioak ondo bananduz.</descrip>
    </descripGrp>
