    </tig>
    <tig>
      <term>conexión</term>
    </tig>
    <tig>
      <term>correspondencia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>correspondance</term>
    </tig>
    <tig>
      <term>transbordement</term>
    </tig>
