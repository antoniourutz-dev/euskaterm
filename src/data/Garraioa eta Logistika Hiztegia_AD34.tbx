    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>logistics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bidaltzaile berak aldi berean bidaltzen dituen fardelen multzoa.</descrip>
    </descripGrp>
