  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsonak eta haien bagajeak garraiatzeko bereziki prestatutako automobila, gidariarena barne bederatzi plaza baino gehiago dituena.</descrip>
