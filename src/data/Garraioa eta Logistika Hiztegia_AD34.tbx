      <term>express</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Salerosketako ondasun materiala, dagozkion prezioak eta zergak aplikatuz garraiatzen dena.</descrip>
    </descripGrp>
