  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Errepideko garraioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ibilgailuaren eta haren zamaren masa osoa, zerbitzu-langileena eta bidaiariena barne.</descrip>
    </descripGrp>
