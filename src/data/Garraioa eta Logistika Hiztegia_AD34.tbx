<termEntry id="-1">
  <descrip type='subjectField'>Kontzeptu orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktuak, paletetan banatu ondoren, bata bestearen gainean jartzea, lekua hobeto betetze aldera. Mantentze-orga baten laguntzaz egin ohi da.</descrip>
