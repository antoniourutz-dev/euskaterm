  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Solaskideen arteko harremanen, haien asmoen, gaien, formaltasun-mailaren eta egoera definitzen duten beste hainbat faktoreren arabera erabiltzen diren hizkuntza-barietateetako bakoitza.</descrip>
