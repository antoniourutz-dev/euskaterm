<termEntry id="411404">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Soziolinguistika parametro matematikoetan analizatzen duen azterketa-arlo soziolinguistikoa.</descrip>
    </descripGrp>
    <tig>
      <term>soziolinguistika matematiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
