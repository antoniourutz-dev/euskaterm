    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>convergence linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic convergence</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411189">
  <descrip type='subjectField'>Teknikak eta metodoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Azterketa soziolinguistiko bat egiteko biltzen diren datuen, pertsonen edo bestelako elementuen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>corpus</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
