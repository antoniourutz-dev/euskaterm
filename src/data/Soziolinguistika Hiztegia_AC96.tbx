    </tig>
  </langSet>
</termEntry>
<termEntry id="411395">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lehen hizkuntzaren ondoren ikasten den hizkuntza. Euskaldun berrientzat euskara bigarren hizkuntza da.</descrip>
    </descripGrp>
    <tig>
      <term>bigarren hizkuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>H2</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
