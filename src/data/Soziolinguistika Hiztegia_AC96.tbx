<termEntry id="411199">
  <descrip type='subjectField'>Dialektologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Dialektoak eta bestelako hizkuntza-barietate geografikoak aztertzen dituen diziplina linguistikoa.</descrip>
    </descripGrp>
    <tig>
      <term>dialektologia</term>
