    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic atlas</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411470">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Norberaren hizkuntza-ezaugarriak edo -portaerak ezkutatzeko jarrera. Gizartean prestigio handiagoa duten portaera edo estereotipoekin bat etortzeko helburua izan ohi du jarrera horrek.</descrip>
    </descripGrp>
    <tig>
      <term>norberarenganako gorroto</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>autogorroto</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>autoodio</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>haine de soi</term>
    </tig>
    <tig>
      <term>autodénigration</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>self-hatred</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411471">
  <descrip type='subjectField'>Arlo instituzionala eta zuzenbide-arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzaren erabilera zuzena mugatzeko arau linguistikoak ezartzen dituen erakundea. Euskararen kasuan, Euskaltzaindia.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-agintaritza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>autoridad lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>autorité linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic authority</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411472">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzaren existentzia eta hiztunaren existentzia (hizkuntza erabiltzeko gai den pertsona gisa kontuan hartuta) bata bestearen mende daudela ezartzen duten axiomak.</descrip>
    </descripGrp>
    <tig>
      <term>osagarritasun-axiomak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>axiomas de complementariedad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411473">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beste hizkuntza batetik hartutako hitz edo esapide bertakotu gabea, hau da, arauen bidez onartuta ez dagoena.</descrip>
    </descripGrp>
    <tig>
      <term>barbarismo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>barbarismo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>barbarisme</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>barbarism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411474">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Behe-mailako hizkuntza-barietatea; bereziki, maila apaleko klase soziokulturalena.</descrip>
    </descripGrp>
    <tig>
      <term>basilekto</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>basilecto</term>
    </tig>
  </langSet>
