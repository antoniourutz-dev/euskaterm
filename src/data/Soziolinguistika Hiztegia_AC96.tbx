  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-ukipena bizi duen lurralde batean, hiztun gehienek erabiltzen duten hizkuntza.</descrip>
    </descripGrp>
    <tig>
      <term>gehiengoaren hizkuntza</term>
