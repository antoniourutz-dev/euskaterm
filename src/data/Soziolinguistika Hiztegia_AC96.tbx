  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-ukipeneko edo -gatazkako egoeretan inolako esku-hartzerik ez egitea babesten duen hizkuntza-ideologia.</descrip>
    </descripGrp>
