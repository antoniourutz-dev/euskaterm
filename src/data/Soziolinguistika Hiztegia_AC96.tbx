<termEntry id="411301">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herrialde baten naziotasunaren ezaugarri gisa aitortzen den hizkuntza.</descrip>
