    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>minorization</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411323">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-aniztasuna hein batean errespetatzen badu ere, hizkuntza-komunitate nagusiaren aldeko joera duen hizkuntza-politikak aplikatzen duen eredua.</descrip>
    </descripGrp>
    <tig>
      <term>kontrol-eredu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>modelo de control</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>modèle de contrôle</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>control model</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411324">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-komunitate batean, komunikazio-interakzio bakoitzerako hizkuntza-barietate jakin bat markatu gabekotzat jotzen duen arau-sistema. Sistema edo eredu horren arabera, beste barietate bat erabiltzea erabilera markatu gisa hautemango litzateke.</descrip>
    </descripGrp>
    <tig>
      <term>markatze-eredu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>modelo de marcaje</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>modèle de marquage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>marking model</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411325">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irakaskuntzan erabiltzen diren komunikazio-hizkuntzen araberako bereizketa ezartzen duten ereduetako bakoitza. OHARRA: Adibidez, EAEko irakastereduak dira A eredua (gaztelania da komunikazio-hizkuntza eta euskara ikasgai gisa eskaintzen da), B eredua (gaztelania eta euskara, biak, dira komunikazio-hizkuntzak), eta D eredua (euskara da komunikazio-hizkuntza eta gaztelania ikasgai gisa eskaintzen da).</descrip>
    </descripGrp>
    <tig>
      <term>irakasteredu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>irakaskuntzako hizkuntza-eredu</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>modelo lingüístico de enseñanza</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>modèle linguistique d'enseignement</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>educational linguistic model</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411326">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-aniztasuna aintzat hartu gabe, lurralde osoan hizkuntza nagusi bakarra ezarri nahi duen hizkuntza-politikaren eredua.</descrip>
    </descripGrp>
    <tig>
      <term>eredu elebakar</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>modelo monolingüista</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>modèle monolingue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>monolinguistic model</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411327">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-aniztasuna errespetatuz, hizkuntza-komunitate guztiak ia modu bertsuan kontuan hartzen dituen hizkuntza-politikaren eredua.</descrip>
    </descripGrp>
    <tig>
      <term>eredu eleaniztun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>modelo plurilingüista</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>modèle plurilingue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>plurilinguistic model</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411328">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiztun edo giza talde batek hizkuntza bakarra jakin eta erabiltzea.</descrip>
    </descripGrp>
    <tig>
      <term>elebakartasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
