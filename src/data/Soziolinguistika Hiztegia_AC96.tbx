  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-barietateak edo bestelako hizkuntza-fenomenoak lurraldean eta gizartean nola banatzen diren aztertzen duen diziplina.</descrip>
