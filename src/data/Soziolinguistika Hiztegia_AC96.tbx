<!DOCTYPE martif PUBLIC "ISO 12200:1999A//DTD MARTIF core (DXFcdV04)//EN" "TBXcdv04.dtd">
<martif type="TBX" xml:lang="en">
  <martifHeader>
    <fileDesc>
      <titleStmt>
        <title>Soziolinguistika Hiztegia</title>
      </titleStmt>
      <sourceDesc>
        <p>Soziolinguistika Hiztegiaren TBX esportazioa</p>
      </sourceDesc>
    </fileDesc>
  </martifHeader>
<text>
<body>
<termEntry id="411164">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiztunak bigarren hizkuntza ikastean, lehendik zekien hizkuntzaren galera dakarren elebitasuna. Lehen hizkuntzarekiko motibazioa apaldu egiten da, eta bigarren hizkuntzak lehena ordezkatzea ere gerta daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>elebitasun kengarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bilingüismo sustractivo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>bilinguisme à effet négatif</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>subtractive bilingualism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411165">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi hizkuntzak argi bereizitako bi lurralde-eremu desberdinetan hitz egiten diren elebitasuna.</descrip>
    </descripGrp>
    <tig>
      <term>lurralde-elebitasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bilingüismo territorial</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>bilinguisme territorial</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>territorial bilingualism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411166">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Noranzko batean bakarrik garatzen den elebitasuna. Hizkuntza gutxituko hiztunek hizkuntza menderatzailea ikastera behartuta daude; hizkuntza menderatzailekoak, berriz, elebakar izaten segi dezakete.</descrip>
    </descripGrp>
    <tig>
      <term>noranzko bakarreko elebitasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>elebitasun aldebakar</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bilingüismo unidireccional</term>
    </tig>
    <tig>
      <term>bilingüismo unilateral</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>bilinguisme unilatéral</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>unilateral bilingualism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411167">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza batek beste hizkuntza bateko hitza edo esamoldea itzuliz osatzen duen mailegua.</descrip>
    </descripGrp>
    <tig>
      <term>kalko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>calco</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>calque</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>loan</term>
    </tig>
    <tig>
      <term>calque</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411168">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza baten ezaugarri linguistikoak etengabe aldatzeko edo galtzeko prozesua.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-aldaketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cambio lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>changement linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic change</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411169">
  <descrip type='subjectField'>Gizarte-arloa eta antropologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek hizkuntza-merkatuan eta, oro har, gizartean lehiatzeko baliabide gisa erabil ditzakeen ezagutza linguistiko eta komunikazio-gaitasunen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-kapital</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>capital lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>capital linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic capital</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411170">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Personne dont la première langue a été l'espagnol, qui ne parle pas le basque du tout et qui ne le comprend ni ne le lit bien.</descrip>
    </descripGrp>
    <tig>
      <term>erdaldun zahar</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>castellanófono</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>hispanophone</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>spanish speaker</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411171">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzaren barietate estandarra finkatzeko arauak ezartzen dituen estandarizazio-fasea. Lexikalizazioa, grafizazioa eta gramatikalizazioa hartzen ditu barnean.</descrip>
    </descripGrp>
    <tig>
      <term>kodetze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>codificación</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>codification</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>encoding</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411172">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-arauak ondo betetzen dituen soziolektoa, aberastasun lexiko eta morfosintaktiko handikoa.</descrip>
    </descripGrp>
    <tig>
      <term>kode landu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>código elaborado</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>code élaboré</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>elaborated code</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411173">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza bateko zeinu eta arau linguistikoen sistema, hiztunek komunikatzeko erabil dezaketena.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-kode</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>código lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>code linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic code</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411174">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-arauak ondo betetzen ez dituen soziolektoa, aberastasun lexiko eta morfosintaktiko urrikoa.</descrip>
    </descripGrp>
    <tig>
      <term>kode murriztu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>código restringido</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>code restreint</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>restricted code</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411175">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kolonietan edo menderatutako lurraldeetan metropoliko hizkuntza ezartzeko prozesua. Hizkuntza menderatua eta hizkuntza horretako hiztunak botere-eremuetatik baztertuz gauzatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-kolonialismo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>colonialismo lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>colonialisme linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic colonialism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411176">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-komunitate bereko hiztunen artean interakzio linguistikoa indartzea, beste hizkuntza-komunitate batetik datozen kanpo-eraginak murrizteko.</descrip>
    </descripGrp>
    <tig>
      <term>trinkotze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>compactación</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>compactage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>compacting</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411177">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiztunak egoera desberdinetan behar bezala komunikatzeko behar dituen ezagutzen multzoa. Arlo honetan, garrantzi handia du hizkuntza-barietate edo kode aproposa aukeratzeak, edo konbentzio sozial eta linguistikoak errespetatzeak.</descrip>
    </descripGrp>
    <tig>
      <term>komunikazio-gaitasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>competencia comunicativa</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>compétence communicative</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>communicative competence</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411178">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiztun batek hizkuntzaz duen ezagutza-maila. Gaitasun horren bidez, perpausak sortzeko eta ulertzeko gai da hiztuna, baita perpaus bat gramatikala den edo ez den ebazteko ere.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-gaitasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>hizkuntza-ezagutza</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>competencia lingüística</term>
    </tig>
    <tig>
      <term>conocimiento lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>compétence linguistique</term>
    </tig>
    <tig>
      <term>connaissance linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic competence</term>
    </tig>
    <tig>
      <term>language knowledge</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411179">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiztunak egoera soziolinguistiko jakin batean egiten dituen aukera linguistikoak. Komunikazio-testuingurua, solaskidea eta interakzio-lekua zein den kontuan hartuz, hizkuntza jakin bat aukeratuko du, hizkuntza-erregistro jakin bat, eta abar.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-portaera</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comportamiento lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>comportement linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic behaviour</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411180">
  <descrip type='subjectField'>Gizarte-arloa eta antropologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lehen hizkuntza bera duten edo hizkuntza berean mintzatzen diren pertsonen multzoa. Soziolinguistikak aztertzen duen unitate sozial nagusia da.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-komunitate</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comunidad lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>communauté linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic community</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411181">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Norberaren hizkuntzari kultura-balio bereizgarria ematetik eta hizkuntza horrek norberaren hizkuntza-komunitatea definitzen duela kontsideratzetik sortzen den motibazio arrazionala. Motibazio horren bidez, hizkuntzaren ezagutzari eustea eta ezagutza hori sakontzeko joera sustatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-kontzientzia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>conciencia lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>conscience linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic consciousness</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411182">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi hizkuntzaren edo bi hizkuntza-komunitateren artean gertatzen den lehia. Gizartean erabilera-eremuak eta funtzio sozialak eskuratzea eta, ondorioz, besteari nolabait kentzea da lehia horren funtsa.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-gatazka</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>conflicto lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>conflit linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic conflict</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411183">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizarte berean hizkuntza bat baino gehiago hitz egiten direnean, hizkuntza horien artean sortzen den erlazioa.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-ukipen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>contacto de lenguas</term>
    </tig>
    <tig>
      <term>contacto lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>contact de langues</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language contact</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411184">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona edo hizkuntza-komunitate batek bere hizkuntzari eustea eta, beraz, hizkuntza hori ez galtzea.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-jarraipen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>continuidad lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>continuité linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language maintenance</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411185">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-plangintza baten eraginak moteltzeko edo eragin horien aurka egiteko ekintzen multzoa. Hizkuntza menderatzailearen nagusigoari eustea izan ohi da ekintza horien helburua.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-kontraplangintza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>contraplanificación lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>contre-planification linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language counterplanning</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411186">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Agintaritzak hizkuntza baten erabilera-arauak eta hizkuntza-portaerak kontrolatzea. Kontrol horren bitartez, hiztunek nolabait bete beharko duten ordena soziolinguistiko bat ezartzen da.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-kontrol</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>control lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>contrôle linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language control</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411187">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza bateko dialektoen arteko desberdintasuna murriztea.</descrip>
    </descripGrp>
