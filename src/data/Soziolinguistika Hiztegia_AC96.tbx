<termEntry id="411192">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzek Darwinen eboluzio-teorien araberako bilakaera dutela pentsatzen duen hizkuntza-ideologia. Horren arabera, hizkuntza-komunitate indartsuenak gailenduko lirateke, ahulenak baztertuta.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-darwinismo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>darwinismo lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
