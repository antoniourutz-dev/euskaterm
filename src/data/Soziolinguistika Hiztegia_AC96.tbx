    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>migrations</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411320">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-kontzientzia eta -leialtasuna sustatuz, hizkuntza baten aldeko ekintzak egiten dituen pertsonaren jarrera.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-militantzia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>militancia lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>militantisme linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic militancy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411321">
  <descrip type='subjectField'>Teknikak eta metodoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Estatu bateko hizkuntza ofiziala edo nagusia ez den beste hizkuntza bat hitz egiten duen giza taldea.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-gutxiengo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>minoría lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>minorité linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic minority</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411322">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza menderatzaile baten eraginez hainbat erabilera-esparru eta funtzio galduz doan hizkuntzak bizi duen prozesua.</descrip>
    </descripGrp>
    <tig>
      <term>gutxitze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>minorizazio</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
