<termEntry id="411382">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lurralde-bereizketa egiten duen hizkuntza-politikaren oinarrizko printzipioa. Bereizketa horren arabera, lurralde batzuetan bakarrik bermatuko da zerbitzuak hizkuntza jakin batean eskaintzea.</descrip>
    </descripGrp>
    <tig>
