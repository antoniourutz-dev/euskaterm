  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>demolinguistics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411194">
  <descrip type='subjectField'>Arlo instituzionala eta zuzenbide-arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herritarrek, bakarka nahiz taldean, jatorrizko lurraldean beren hizkuntzan bizitzeko duten eskubidearen alde guztiak arautzen dituen ordenamendu juridikoaren atala.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-zuzenbide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>derecho lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>droit linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic law</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411195">
  <descrip type='subjectField'>Arlo instituzionala eta zuzenbide-arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herritarrek, bakarka nahiz taldean, bakoitzak bere lurraldearen barruan, bere hizkuntzan bizitzeko duen eskubidea, ordenamendu juridikoak aitorturikoa.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-eskubideak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>derechos lingüísticos</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>droits linguistiques</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic rights</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411196">
  <descrip type='subjectField'>Dialektologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza bat dialekto gero eta desberdinagoetan bereizteko prozesua.</descrip>
    </descripGrp>
