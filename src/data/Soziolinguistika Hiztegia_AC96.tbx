  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lanean erabiltzen den hizkuntza, laneko komunikazioa bideratzeko gaitasuna duena.</descrip>
    </descripGrp>
    <tig>
