    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>immersion program</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411384">
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Solaskideek beren artean duten distantzia fisikoaren, gorputz-jarreren eta beren artean dituzten (ala ez dituzten) kontaktu fisikoen azterketa. Faktore horiek beha daitezke, sexuaren, adinaren, aurrekin sozial eta kulturalen arabera eta baita elkarrekiko dituzten iritzien arabera ere.</descrip>
    </descripGrp>
    <tig>
      <term>proxemika</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
