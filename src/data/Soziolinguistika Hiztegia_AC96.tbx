    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>bilingual speaker</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411477">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Personne dont les premières langues ont été le basque et l'espagnol, et qui comprend et parle bien le basque.</descrip>
    </descripGrp>
    <tig>
      <term>jatorrizko elebidun</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
