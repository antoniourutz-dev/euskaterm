  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-gatazkako egoeran, hizkuntza menderatzailearen esku hainbat esparru eta funtzio galdu dituen hizkuntza.</descrip>
    </descripGrp>
