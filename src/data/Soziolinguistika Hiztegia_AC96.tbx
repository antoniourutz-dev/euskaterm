<termEntry id="411290">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-gatazkako egoeran, hizkuntza menderatuaren hainbat esparru eta funtzio irabazi dituenez gailen agertzen den hizkuntza.</descrip>
    </descripGrp>
