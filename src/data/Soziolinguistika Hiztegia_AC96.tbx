    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>langue conversationnelle</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>colloquial language</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411285">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gaur egungo gizarte garatuan beharrezkoak diren funtzio guztiak betetzeko gai den hizkuntza.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza oso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
