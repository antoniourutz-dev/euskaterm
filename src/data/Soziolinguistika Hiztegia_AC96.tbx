    <tig>
      <term>variété de transition</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>transition variety</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411440">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza bateko lurraldeen arabera bereizten diren hizkuntza-barietateetako bakoitza.</descrip>
    </descripGrp>
    <tig>
      <term>barietate geografiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>variedad geográfica</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>variété géographique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>geographical variety</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411391">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kultura bakoitzak mundua bere erara ikusten duela eta kultura-adierazpen guztiak funtzio horretarako baliozkoak direla uste duen ideologia. Horren arabera, ezin da kulturen balorazio etiko edo moralik egin, bata bestea baino hobea dela esateko.</descrip>
    </descripGrp>
    <tig>
      <term>kultura-erlatibismo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>relativismo cultural</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>relativisme culturel</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>cultural relativism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411392">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizarte batek kategoriak, pertsonak, egoerak eta bestelako errealitateak irudikatzeko erabiltzen dituen balio, irudi, sinbolo eta ereduen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>gizarte-irudikapen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>irudikapen sozial</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>representación social</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>représentation sociale</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>social representation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411441">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giza talde bati edo ekoizpen linguistikoko testuinguru bati lotutako sistema linguistikoa. Hizkuntza-barietateak dira, alde batetik, hizkuntzak, eta bestetik, hizkuntza baten barruan lurralde, funtzio, gizarte-talde eta abarren arabera bereizten diren sistemak.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-barietate</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>variedad lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>variété linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic variety</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411442">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lehen hizkuntza euskara izanik, euskaraz ondo ulertzen eta hitz egiten duen pertsona.</descrip>
    </descripGrp>
    <tig>
      <term>euskaldun zahar</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>El término "euskaldun zahar" se utiliza en euskera para denominar a la persona cuya primera lengua ha sido el euskera y que entiende y habla bien el euskera.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>Le terme "euskaldun zahar"  est utilisé en basque pour nommer la personne dont la première langue a été le basque et qui le comprend et le parle bien.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>The term "euskaldun zahar"  is used in Basque to name a  person for whom Basque is his/her first language, and who understands and speaks it well.</termNote>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411443">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lehen hizkuntza euskara izanik, euskaraz ondo ulertzen eta hitz egin duen eta etxeko hizkuntza euskara duen pertsona.</descrip>
    </descripGrp>
    <tig>
      <term>euskaldun zahar aktibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>El término "euskaldun zahar aktibo" se utiliza en euskera para denominar a la persona cuya primera lengua ha sido el euskera, que lo entiende y lo habla bien y para quien la lengua de uso en casa es el euskera.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>Le terme "euskaldun zahar aktibo" est utilisé en basque pour nommer la personne dont la première langue a été le basque, qui le comprend et le parle bien et qui l'utilise à la maison.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>The term "euskaldun zahar aktibo" is used in Basque to name a person for whom Basque is his/her first language, who understands and speaks it well, and whose primary language at home is Basque.</termNote>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411444">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lehen hizkuntza euskara izanik, euskaraz ondo ulertzen eta hitz egiten duen eta etxeko hizkuntza euskara eta gaztelania dituen pertsona.</descrip>
    </descripGrp>
    <tig>
      <term>euskaldun zahar bietan aktibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>El término "euskaldun zahar bietan aktibo" se utiliza en euskera para denominar a la persona cuya primera lengua ha sido el euskera, que lo entiende y lo habla bien y para quien las lenguas de uso en casa son tanto el euskera como el castellano.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>Le terme "euskaldun zahar bietan aktibo" est utilisé en basque pour nommer la personne dont la première langue a été le basque, qui le comprend et le parle bien et qu'utilise à la maison aussi bien le basque que l'espagnol.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>The term "euskaldun zahar bietan aktibo" is used in Basque to name a person for whom Basque is his/her first language, who understands and speaks it well, and whose primary languages at home are both Basque and Spanish.</termNote>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411445">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lehen hizkuntza euskara izanik, euskaraz ondo ulertzen eta hitz egiten duen arren, etxeko hizkuntza gaztelania duen pertsona.</descrip>
    </descripGrp>
    <tig>
      <term>euskaldun zahar pasibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>El término "euskaldun zahar pasibo" se utiliza en euskera para denominar a la persona cuya primera lengua ha sido el euskera, que lo entiende y lo habla bien pero cuya lengua de uso en casa es el castellano.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>Le terme "euskaldun zahar pasibo" est utilisé en basque pour nommer la personne dont la première langue a été le basque, qui le comprend et le parle bien mais qui, à la maison, utilise l'espagnol.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>---</term>
      <termNote type='usageNote'>The term "euskaldun zahar pasibo"  is used in Basque to name a person for whom Basque is his/her first language, who understands and speaks it well, but whose primary language at home is Spanish.</termNote>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411446">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giza talde etnolinguistiko bati izaki kolektibo gisa eratzeko eta jokatzeko ahala ematen dioten faktore sozial eta estrukturalen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>bizindar etnolinguistiko</term>
