    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic anthropology</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411465">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona edo kolektibo batek hizkuntza bat bere egitea, hizkuntza hori erabiltzeko moduan.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza ikaste</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aprendizaje de una lengua</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>apprentissage d'une langue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language learning</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411466">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza bat ikastea, hiztuna hizkuntza horretaz zuzenean eta naturalki inguratuta dagoen ingurunean. Adibidez, haurrek lehen hizkuntza ikasten dutenean gertatzen da ikaskuntza-mota hori.</descrip>
    </descripGrp>
    <tig>
      <term>lehen mailako ikaskuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aprendizaje primario</term>
    </tig>
    <tig>
      <term>aprendizaje natural</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>apprentissage primaire</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>primary learning</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411467">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza berariaz ikasita egiten den ikaskuntza, hots, ikaskuntza akademiko edo eskolatua.</descrip>
    </descripGrp>
    <tig>
      <term>bigarren mailako ikaskuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aprendizaje secundario</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>apprentissage secondaire</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>secondary learning</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411468">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>1. Etorkinak bere jatorrizko hizkuntza utzi eta bertako hizkuntza eskuratzeko egiten duen moldatze-prozesua. 2. Hizkuntza-ordezkapena.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-asimilazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>asimilación lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>assimilation linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic assimilation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411469">
  <descrip type='subjectField'>Dialektologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Dialektologia edo hizkuntza-geografiako ikerketa baten emaitzak mapetan irudikatuta eskaintzen dituen datu-bilduma.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-atlas</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>atlas lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
