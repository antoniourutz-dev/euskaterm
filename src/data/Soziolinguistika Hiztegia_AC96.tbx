  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-erabilera osoa, hots, gizarte-funtzio guztiak behar bezala betetzeko modukoa, eta hizkuntza-kontzientzia bizia dituen hiztuna.</descrip>
