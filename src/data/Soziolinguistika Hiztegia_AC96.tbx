<termEntry id="411372">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizarte bateko hizkuntza-komunitateen berdintasuna, hots, erabiltzen diren hizkuntza guztiek eskubide berak dituztela aldarrikatzen duen ideologia.</descrip>
    </descripGrp>
