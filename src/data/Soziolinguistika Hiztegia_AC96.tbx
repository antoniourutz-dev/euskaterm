<termEntry id="411381">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lurralde-bereizketarik egin gabe, pertsonari zerbitzuak bere hizkuntzan eskaintzea bermatzen duen hizkuntza-politikaren oinarrizko printzipioa.</descrip>
    </descripGrp>
