    <tig>
      <term>sociolinguistique du conflit</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>conflict sociolinguistics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411402">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesu soziolinguistikoen bilakaera historikoan arreta berezia jartzen duen azterketa-arlo soziolinguistikoa.</descrip>
    </descripGrp>
    <tig>
      <term>soziolinguistika historiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
