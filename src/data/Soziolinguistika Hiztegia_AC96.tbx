  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>sociolinguistique historique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>historical sociolinguistics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411403">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zuzeneko komunikazio-interakzioan arreta berezia jartzen duen azterketa-arlo soziolinguistikoa.</descrip>
    </descripGrp>
    <tig>
      <term>interakzioaren soziolinguistika</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
