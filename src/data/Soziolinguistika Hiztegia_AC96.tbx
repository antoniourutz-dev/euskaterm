<termEntry id="411456">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Norbaitek hizkuntza bat ikastea eta bere egitea.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntzaz jabetze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
