    </tig>
  </langSet>
</termEntry>
<termEntry id="411396">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza bat estandarizatzeko lehen fasea; hizkuntza-barietate edo barietate-multzo jakin bat estandarizazioa egiteko oinarri gisa hobestean datza.</descrip>
    </descripGrp>
    <tig>
      <term>hautatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>selección</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>sélection</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>selection</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411397">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Komunikazioan parte hartzen duten baldintza guztien multzoa: lekua, unea, komunikazio-partaideak, eta faktore hauen arteko harremanak. OHARRA: Adibidez, baldintza horien arabera, hizkuntza edo hizkuntza-barietate bat edo beste bat erabiltzeko hautua egingo da.</descrip>
    </descripGrp>
    <tig>
      <term>komunikazio-egoera</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>situación comunicativa</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>situation communicative</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>communicative situation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411398">
  <descrip type='subjectField'>Gizarte-arloa eta antropologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona (haurra, bereziki), inguruneko gizarte eta kulturaren balio, arau eta jokabideak eskuratuz, bizitza sozialera egokitzea eta gizarte horretako kide bihurtzea.</descrip>
    </descripGrp>
    <tig>
      <term>sozializazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>socialización</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>socialisation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>socialization</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411399">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizarte-talde jakin batek erabiltzen duen hizkuntza-barietate berezia.</descrip>
    </descripGrp>
    <tig>
      <term>soziolekto</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
