<termEntry id="411197">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lurralde mugatu batean hitz egiten den hizkuntza-barietatea, sistema linguistikoan ezaugarri bereziak dituena.</descrip>
    </descripGrp>
    <tig>
      <term>dialekto</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
