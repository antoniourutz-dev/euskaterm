    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>social values</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411430">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Era desberdin eta alternatiboetan gauza daitekeen ezaugarri edo elementu linguistikoa (fonema, morfema, hitza eta abar). OHARRA: Gauzatzen denean aldaera bat sortuko du; adibidez, kasu soziatiboa (aldagaia) hainbat modutara (hainbat aldaeratan) gauza daiteke: -kin, -kila, -gaz.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-aldagai</term>
