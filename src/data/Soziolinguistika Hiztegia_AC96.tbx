      <term>lengua vehicular</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>langue véhiculaire</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>everyday language</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411306">
