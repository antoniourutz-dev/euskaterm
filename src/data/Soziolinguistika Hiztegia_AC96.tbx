    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language of civilization</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411288">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Maila jasoko kultura-adierazpenak sortzeko eta zabaltzeko gai den hizkuntza.</descrip>
    </descripGrp>
    <tig>
      <term>kultura-hizkuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
