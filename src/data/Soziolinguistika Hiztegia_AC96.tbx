<termEntry id="411283">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Testu zientifikoen ezaugarri linguistikoak eskaintzeko moduko erregistroa duen hizkuntza. Ezaugarri horiek dira, besteak beste, lexikoaren zorroztasuna, formalizazio-maila handia, sintaxi sistematizatua, estilo objektibo eta inpertsonala.</descrip>
    </descripGrp>
    <tig>
      <term>zientzia-hizkuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>lengua científica</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>langue scientifique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>scientific language</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411284">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eguneroko elkarrizketa eta harreman xeheetan erabiltzen den erregistroa duen hizkuntza.</descrip>
    </descripGrp>
    <tig>
      <term>lagunarteko hizkuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
