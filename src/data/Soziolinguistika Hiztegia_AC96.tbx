<termEntry id="411258">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona edo giza talde baten identitate etnokulturalaren eta hizkuntza baten artean dagoen lotura. Pertsona edo giza talde bakoitzak hizkuntza jakin batekin (edo gehiagorekin) lotzen ditu bere identitate etnikoa eta kulturala.</descrip>
    </descripGrp>
    <tig>
      <term>identitate etnolinguistiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>identidad etnolingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>identité ethnolinguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ethnolinguistic identity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411259">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona edo giza talde baten identitatearen eta hizkuntza baten artean dagoen lotura. Pertsona edo giza talde bakoitzak hizkuntza jakin batekin (edo gehiagorekin) lotzen du bere identitatea.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-identitate</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>identidad lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>identité linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic identity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411260">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek, pertsona-multzo edo gizarte-talde bateko kide sentitzen delako, giza talde horrekin eratzen duen lotura, pertsonaren identitate orokorraren osagaia.</descrip>
    </descripGrp>
    <tig>
      <term>gizarte-identitate</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>identitate sozial</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>identidad social</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>identité sociale</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>social identity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411261">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-aniztasuna eta hizkuntzen arteko oreka gorde behar direla aldarrikatzen duen hizkuntza-ideologia.</descrip>
    </descripGrp>
    <tig>
      <term>ideologia ekolinguistiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ideología ecolingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>idéologie écolinguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ecolinguistic ideology</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411262">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona edo giza talde batek hizkuntzei buruz dituen ideien multzoa. Ideologia hori erabilera, diskurtso edo portaera linguistiko jakin batzuen bidez adierazten da.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-ideologia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ideología lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>idéologie linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic ideology</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411263">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek, eta pertsona horrek bakarrik, erabiltzen duen hizkera edo hizkuntza-barietatea.</descrip>
    </descripGrp>
    <tig>
      <term>idiolekto</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>idiolecto</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>idiolecte</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>idiolect</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411264">
  <descrip type='subjectField'>Gizarte-arloa eta antropologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Maila apaleneko gizarte-klaseek goi-mailakoen portaerak imitatzeko joera edo prozesu soziala.</descrip>
    </descripGrp>
    <tig>
      <term>gizarte-imitazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>imitazio sozial</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>imitación social</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>imitation sociale</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>social emulation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411265">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza batek beste bat menderatzea eta, ondorioz, glotofagia bera justifikatzen eta bultzatzen dituzten iritzi eta portaeren multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-inperialismo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>imperialismo lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>impérialisme linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic imperialism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411266">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzaren barietate estandarra hezkuntza-sistemaren bidez biztanlerian hedatzea eta komunikazio formalaren esparrura eramatea. Estandarizazioaren faseetako bat da.</descrip>
    </descripGrp>
    <tig>
      <term>inplementazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>implementación</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>implémentation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>implementation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411267">
  <descrip type='subjectField'>Teknikak eta metodoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Soziolinguistikaren ikuspegitik azter daitekeen aldagaia; bereziki, estratifikazio sozialaren arabera azter daitekeena.</descrip>
    </descripGrp>
    <tig>
      <term>adierazle soziolinguistiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>indicador sociolingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>indicateur sociolinguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>sociolinguistic indicator</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411268">
  <descrip type='subjectField'>Teknikak eta metodoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabilera-eremu jakin batean hizkuntza bat erabiltzen den proportzioa adierazten duen tasa.</descrip>
    </descripGrp>
    <tig>
      <term>erabilera-tasa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>índice de uso</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>taux d'utilisation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>usage rate</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411269">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-barietate jakin bat erabiltzen edo hizkuntza-ideologia bat izaten jarraitzeko joera. Gizarteak sortzen eta bultzatzen du joera hori, eta erabilera eta ideologia aldatzea geldotu egiten du.</descrip>
    </descripGrp>
    <tig>
      <term>inertzia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>inercia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>inertie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>inertia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411270">
  <descrip type='subjectField'>Teknikak eta metodoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Soziolinguistika-ikerketa batean, ikertzaileari analisirako datuak ematen dizkion hiztuna.</descrip>
    </descripGrp>
    <tig>
      <term>informatzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>informante</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>informateur</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>informant</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411271">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiztunak, elebiduna dela ez adierazteko, jendaurrean ezkutatzen duen hizkuntza. Hizkuntza hori hiztunaren berezko hizkuntza izan ohi da, eta gizartean nolabait gaitzetsia dagoelako ezkutatzen du.</descrip>
    </descripGrp>
    <tig>
      <term>infrahizkuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>infralengua</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>infralangue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>infralanguage</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411272">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabiltzen duen hizkera eta zuzen edo egokitzat jotzen duena bat ez datozela uste izateak hiztunarengan sortzen duen sentimen edo jarrera. Sentimen horrek portaera jakin batzuk eragin ditzake gerora.</descrip>
    </descripGrp>
    <tig>
      <term>segurtasun falta linguistiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>inseguridad lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>insécurité linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic insecurity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411273">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Populazio etorkinak bertako hizkuntza eskuratzea, bertako hizkuntza-komunitateko kide egitea.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-integrazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>integración lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>intégration linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic integration</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411274">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi hiztun edo gehiago hizkuntzaren bidez komunikatzeko ekintza. Testuinguruak mugatutako ekintza denez, hiztunak hainbat aukera egin behar ditu testuinguru horretara egokitzeko.</descrip>
    </descripGrp>
    <tig>
      <term>interakzio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>interacción</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>interaction</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>interaction</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411275">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza edo hizkuntza-barietate desberdinak erabiltzen dituzten hiztunek elkar ulertzeko duten gaitasuna edo ahalmena.</descrip>
    </descripGrp>
    <tig>
      <term>elkar-ulertze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>intercomprensión</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>intercompréhension</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>intercomprehension</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411276">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-ukipenaren ondorioz, hizkuntza bateko elementu linguistiko (fonetiko, morfosintaktiko edo lexiko) bat beste hizkuntzan ezartzea, hizkuntza honek berezkoa duena baztertuta.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-interferentzia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>interferencia lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>interférence linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic interference</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411277">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza menderatuaren eta errealitatearen artean hizkuntza menderatzailea ezartzea. Errealitatea eta berrikuntzak hizkuntza menderatzailearen bitartez iristen dira hizkuntza menderatura, ez dago zuzeneko kontakturik.</descrip>
    </descripGrp>
    <tig>
      <term>tartekatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>interposición</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>interposition</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>interposition</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411278">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Funtzioak eta erabilgarritasuna galduz doan hizkuntza batek hizkuntza-ordezkapeneranzko joera hori etetea eta egoera iraultzea.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza indarberritze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>inversión del desplazamiento lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>inversion du transfert linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>reversing language shift</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411279">
  <descrip type='subjectField'>Dialektologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ezaugarri edo fenomeno linguistiko jakin bat gertatzen den eremua mapa batean mugatzen duen marra.</descrip>
    </descripGrp>
    <tig>
      <term>isoglosa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
