    </tig>
  </langSet>
</termEntry>
<termEntry id="411190">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-egituran edo hizkuntza-barietateetan gertatzen diren aldaketen eta gizarte-egituran gertatzen direnen artean dagoen erlazioa.</descrip>
    </descripGrp>
    <tig>
      <term>kobariazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
