<termEntry id="411453">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Goi-mailako hizkuntza-barietatea; bereziki, goi-mailako klase soziokulturalena.</descrip>
