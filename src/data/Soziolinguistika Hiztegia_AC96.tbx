<termEntry id="411291">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Estandarizazio bidez erabilera orokorrerako finkatu den hizkuntza-barietatea. Hizkuntza-komunitateko hiztun guztientzat barietate jasoa da, eta literaturan, hedabideetan eta hezkuntzan erabiltzen da bereziki. Euskararen kasuan, euskara batua da.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza estandar</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>estandar</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
