  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza desberdinen artean gertatzen den diglosia. Barnean hartzen ditu diglosia partziala eta erabatekoa.</descrip>
