    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>covariation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411191">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kultura batek bere jatorrizko ezaugarriak mantendu eta indartzeko prozesua.</descrip>
    </descripGrp>
    <tig>
      <term>kulturazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
