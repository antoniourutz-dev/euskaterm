  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-ordezkapeneranzko bidea zeramaten erabilera, jarrera eta ohitura linguistikoak errotik aldatzea eta kontrako noranzkoa ezartzea.</descrip>
