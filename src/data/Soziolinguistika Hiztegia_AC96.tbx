  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek gatazkan dauden talde etniko edo linguistikoetako batekin identifika ez dezaten erabiltzen duen kode-aldaketa.</descrip>
    </descripGrp>
