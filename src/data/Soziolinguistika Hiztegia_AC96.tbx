    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>trilingualism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411423">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza erabilera-arau ohikoenen sistemari jarraituz erabiltzea.</descrip>
    </descripGrp>
    <tig>
      <term>erabilera konbentzional</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
