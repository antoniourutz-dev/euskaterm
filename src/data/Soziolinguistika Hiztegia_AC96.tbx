    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>native language</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411305">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Informazio edo zerbitzu bat eskaintzean, komunikatzeko erabiltzen den hizkuntza; bereziki, irakaskuntzan jakintza transmititzeko irakasle eta ikasleek erabiltzen duten hizkuntza.</descrip>
    </descripGrp>
    <tig>
      <term>komunikazio-hizkuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
