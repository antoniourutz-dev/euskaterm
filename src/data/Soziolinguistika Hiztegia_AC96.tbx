    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>langue complète</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>complete language</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411286">
  <descrip type='subjectField'>Arlo instituzionala eta zuzenbide-arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beste hizkuntza ofizial bat (edo gehiago) ere baduen lurralde bateko hizkuntza ofiziala.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza koofizial</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
