  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzak errealitatea eraikitzeko, komunikatzeko edo balio sinbolikoa bideratzeko dituen funtzioen multzoa.</descrip>
