  <descrip type='subjectField'>Gizarte-arloa eta antropologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giza talde batek hizkuntza-gaietan agintzeko edo erabakitzeko duen ahalmena.</descrip>
