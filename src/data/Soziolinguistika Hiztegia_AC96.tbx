<termEntry id="411455">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kultura batek bere jatorrizko ezaugarriak galtzeko prozesua, aldi berean beste kultura batenak hartuz.</descrip>
    </descripGrp>
    <tig>
