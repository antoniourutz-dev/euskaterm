<termEntry id="411457">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza bat hitz egiten badakitenek hizkuntza horretan irakurtzen eta idazten gaitzeko irakaskuntza.</descrip>
    </descripGrp>
    <tig>
      <term>alfabetatze</term>
