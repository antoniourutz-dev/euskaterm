    <tig>
      <term>bilingüe de origen</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>bilingue d'origine</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>native bilingual speaker</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411478">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Personne dont les premières langues ont été le basque et l'espagnol, qui comprend et parle bien le basque et qui, à la maison, utilise le basque.</descrip>
    </descripGrp>
    <tig>
      <term>jatorrizko elebidun aktibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bilingüe de origen activo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>bilingue d'origine actif</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>active native bilingual speaker</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411479">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Personne dont les premières langues ont été le basque et l'espagnol, qui comprend et parle bien le basque et qui, à la maison, utilise aussi bien le basque que l'espagnol.</descrip>
    </descripGrp>
    <tig>
      <term>jatorrizko elebidun bietan aktibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bilingüe de origen activo en ambas lenguas</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>bilingue d'origine actif dans les deux langues</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>native bilingual speaker active in both languages</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411480">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Personne dont les premières langues ont été le basque et l'espagnol, qui comprend et parle bien le basque et qui, à la maison, utilise l'espagnol.</descrip>
    </descripGrp>
    <tig>
      <term>jatorrizko elebidun pasibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
