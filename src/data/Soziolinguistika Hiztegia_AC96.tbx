    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>co-official language</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411287">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Munduko zibilizazio-mota batean nagusi den hizkuntza; adibidez, ingelesa, gaur egungo mendebaldeko zibilizazioan.</descrip>
    </descripGrp>
    <tig>
      <term>zibilizazio-hizkuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
