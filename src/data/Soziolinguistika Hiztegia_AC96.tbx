    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic darwinism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411193">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza baten egoera soziolinguistikoaren eta hiztunen ezaugarri demografikoen arteko erlazioa aztertzen duen diziplina.</descrip>
    </descripGrp>
    <tig>
      <term>demolinguistika</term>
