  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Analisiaren abiapuntutzat makrosoziolinguistikak baino eremu txikiagoa hartzen duen soziolinguistikaren ikuspegia. Hizkuntza bera hartzen da analisigai, eta gizartea hizkuntzaren egitura baldintzatzen duen funtsezko elementu gisa aztertzen da.</descrip>
    </descripGrp>
    <tig>
      <term>mikrosoziolinguistika</term>
