  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>proxemics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411385">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Elebitasuna izan arren, ele-parekotasunera iristen ez den egoera; hots, bi hizkuntzetako baten garapena eta erabilera guztizkoa ez den egoera.</descrip>
