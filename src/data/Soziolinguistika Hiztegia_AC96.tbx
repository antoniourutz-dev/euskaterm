<termEntry id="411375">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza komunikazioan nola erabiltzen eta ulertzen den aztertzen duen diziplina. Perpausen, hiztunen eta testuinguru eta egoeren arteko erlazioez arduratzen da bereziki.</descrip>
    </descripGrp>
