    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>bilingue d'origine passif</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>passive native bilingual speaker</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411481">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Personne qui parle le basque avec difficulté ou qui le comprend ou le lit bien, sans toutefois le parler.</descrip>
    </descripGrp>
    <tig>
      <term>elebidun hartzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
