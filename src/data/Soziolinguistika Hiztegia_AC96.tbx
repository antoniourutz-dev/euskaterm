    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language loyalty</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411281">
  <descrip type='subjectField'>Arlo instituzionala eta zuzenbide-arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzen erabilera arautzen duten legeen eta administrazio-arauen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-legeria</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>legislación lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>législation linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic legislation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411282">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-integrazioa gertatzeko, bertako hizkuntza ez dakienak hizkuntza horri buruz egin behar duen kontzientzia- edo ideologia-aldaketa. Hedabideak, eskolak, lan-munduak eta antzeko esparruak garrantzi handikoak dira hizkuntza baten legitimazioa bideratzeko.</descrip>
    </descripGrp>
    <tig>
      <term>legitimazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
