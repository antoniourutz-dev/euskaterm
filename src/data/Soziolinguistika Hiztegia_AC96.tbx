  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>mathematical sociolinguistics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411405">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-bariazioan arreta berezia jartzen duen azterketa-arlo soziolinguistikoa.</descrip>
    </descripGrp>
    <tig>
      <term>soziolinguistika bariazionista</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
