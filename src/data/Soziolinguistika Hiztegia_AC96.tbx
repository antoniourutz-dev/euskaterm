<termEntry id="411438">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi hizkuntzaren artean luzaroan harremana izan den muga-lurraldeetan sortzen den hizkuntza-barietatea.</descrip>
