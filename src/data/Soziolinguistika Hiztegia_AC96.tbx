    </tig>
    <tig>
      <term>uso de la lengua</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>usage de la langue</term>
    </tig>
    <tig>
      <term>usage linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language usage</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411428">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giza talde baten identitate kolektiboa definitzeko eta egituratzeko funtsezkotzat jotzen diren ezaugarri sozial eta kulturalei ematen zaien balioa. Ezaugarri horien artean hizkuntza dagoen taldeetan, handiagoa izango da hizkuntza-atxikimendua.</descrip>
    </descripGrp>
    <tig>
      <term>funtsezko balio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>valor fundamental</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>valeur fondamentale</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>core value</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411429">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizartean aritzeko jokabide-arauen oinarrian dauden balioak.</descrip>
    </descripGrp>
    <tig>
      <term>gizarte-balio</term>
      <termNote type='normativeAuthorization'>4</termNote>
