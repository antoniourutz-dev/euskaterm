    </tig>
  </langSet>
</termEntry>
<termEntry id="411424">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzak ikur gisa duen garrantziarengatik egiten den erabilera sinboliko edo apologetikoa, gero benetan era naturalean erabiltzen ez denean.</descrip>
    </descripGrp>
    <tig>
      <term>erabilera enblematiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>uso emblemático</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>usage emblématique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>emblematic usage</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411425">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Faktore jakin batzuengatik hizkuntza bat ikasi eta erabiltzen denean, faktore horiek ez daudenean ere hizkuntza hori erabiltzea. Adibidez, lan-kontuengatik ingelesa ikasi duen norbaitek ingelesa familian erabiltzea.</descrip>
    </descripGrp>
    <tig>
      <term>gehiegizko erabilera</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>uso excesivo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>usage abusif</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>excessive usage</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411426">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabilera konbentzionalaren eremua utzi eta hizkuntza beste eremu batean erabiltzea, solaskidearengan eragin jakin bat sortzeko.</descrip>
    </descripGrp>
    <tig>
      <term>erabilera intentzional</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
