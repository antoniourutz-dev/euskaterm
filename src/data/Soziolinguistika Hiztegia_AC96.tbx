<termEntry id="411454">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza, hizkuntza-barietate edo hiztun-talde jakin batekiko izaten den jarrera.</descrip>
    </descripGrp>
    <tig>
