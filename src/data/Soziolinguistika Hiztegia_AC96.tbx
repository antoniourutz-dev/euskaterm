      <term>uso intencional</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>usage intentionnel</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>intentional usage</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411427">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek hizkuntza edo hizkuntza-barietate baten bitartez, ahoz edo idatziz, komunikatzen eta jasotzen duena.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-erabilera</term>
