    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>isogloss</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411280">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiztun batek egoera guztietan bere hizkuntza erabiltzeko jarrera.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-leialtasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>hizkuntza-atxikimendu</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>lealtad lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
