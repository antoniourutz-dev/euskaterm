<termEntry id="411200">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ukipen-egoeran dauden bi hizkuntza edo hizkuntza-barietateren arteko mendekotasun-egoera: hizkuntza edo barietate horiek funtzio desberdinetarako erabiltzen dira; bata funtzio formaletarako (administrazioa, hezkuntza, hedabideak) eta bestea informaletarako (familia, lagunartea).</descrip>
    </descripGrp>
    <tig>
      <term>diglosia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>diglosia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>diglossie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>diglossia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411201">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza batek beste hizkuntzaren funtzio eta erabilera formalak hizkuntza honen lurraldearen zati batean bakarrik bereganatzen dituenean gertatzen den diglosia.</descrip>
    </descripGrp>
    <tig>
      <term>diglosia partzial</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>diglosia parcial</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>diglossie partielle</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>partial diglossia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411202">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza batek beste hizkuntzaren funtzio edo erabilera formalak ez ezik azken honen lurralde osoa bereganatzen duenean gertatzen den diglosia. OHARRA: Euskarari, katalanari edo bretoierari gertatu zaiena har daiteke adibide gisa.</descrip>
    </descripGrp>
    <tig>
      <term>erabateko diglosia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>diglosia total</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>diglossie totale</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>total diglossia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411203">
  <descrip type='subjectField'>Gizarte-arloa eta antropologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek erabiltzen duen hizkuntzaren arabera egiten den diskriminazioa; hots, hizkuntza jakin bat erabiltzeagatik pertsona horri eskubide edo zerbitzu publiko nahiz pribatu bat eskuratzeko aukera ukatzea.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-diskriminazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>discriminación lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>discrimination linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic discrimination</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411204">
  <descrip type='subjectField'>Arlo instituzionala eta zuzenbide-arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza baten aurka luzaro gertatu den diskriminazio baten eragina alderantzikatzeko hizkuntza horren alde hartzen diren erabaki politiko eta sozialen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>diskriminazio positibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>discriminación positiva</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>discrimination positive</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>positive discrimination</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411205">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ideologia, uste edo mentalitate baten adierazpena, pentsamolde hori ezagutarazten duena.</descrip>
    </descripGrp>
    <tig>
      <term>diskurtso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>discurso</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>discours</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>discourse</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411206">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-komunitate menderatu batek bere buruaren gain duen pertzepzio edo balorazio faltsua. Pertzepzio horren eraginez, indargabetu egiten da komunitate horretako hiztunek hizkuntza hori behar bezala lantzeko duten motibazioa, baita galdua dutenek hizkuntza berreskuratzeko motibazioa ere.</descrip>
    </descripGrp>
    <tig>
      <term>irrealitatearen diskurtso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>discurso de la irrealidad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411207">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-komunitate batek irrealitatearen diskurtsoa gainditzeko bideratu beharko lukeen aldaketa politiko eta soziala. Komunitateak bere hizkuntza normaltasunez eta funtzio osoz bizi ahal izatea izango litzateke aldaketa global horren azken helburua.</descrip>
    </descripGrp>
    <tig>
      <term>arduraren diskurtso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>discurso de la responsabilidad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411208">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi hizkuntzaren ezaugarri linguistikoen artean dagoen antzekotasuna. Distantzia txikiagoa izango da familia bereko bi hizkuntzaren artean (adibidez, gaztelaniaren eta galegoaren artean), familia desberdineko beste bi hizkuntzaren artean baino (gaztelaniaren eta euskararen artean baino).</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-distantzia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>distancia lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>distance linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>interlingual distance</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411209">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzen ezaugarri linguistiko bereizgarriak areagotzen dituen prozesua. Hizkuntza-sistemak aldendu egiten dira elkarrengandik prozesu horretan.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-dibergentzia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>divergencia lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>divergence linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic divergence</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411210">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eremu jakin batean, hainbat hizkuntza desberdin hitz egitea. OHARRA: Munduan, hizkuntzak galdu ahala, hizkuntza-aniztasuna murriztuz doa.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-aniztasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>diversidad lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>diversité linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic diversity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411211">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-komunitate batek bere izaera definitzeko beste komunitate baten beharra duenean gertatzen den paradoxa-egoera. Hizkuntza-komunitate menderatzailearen presioaren aurrean, komunitate horren aurka definitzen da hizkuntza-komunitate menderatua; izaera negatiboko definizioa da: ez da azpimarratzen komunitatea zer den, komunitatea zer ez den baizik (komunitate menderatzailea ez dena, alegia).</descrip>
    </descripGrp>
    <tig>
      <term>lotura bikoitz</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>doble atadura</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>double contrainte</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>double bind</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411212">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzaren eta ingurunearen arteko harremana ikuspegi ekologikotik aztertzen duen diziplina. Alde batetik, elkarrekin harremanak dituzten sistema dinamikotzat hartzen ditu hizkuntzak eta hizkuntza-komunitateak, eta haien arteko orekaren eta hizkuntza-aniztasunaren ikuspegitik aztertzen ditu; eta, era berean, ingurunea moldatzen duen elementu gisa aztertzen du hizkuntza.</descrip>
    </descripGrp>
    <tig>
      <term>ekolinguistika</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ecolingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>écolinguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ecolinguistics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411213">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egozentrismo glotikoari kontrajarritako hizkuntza-ideologia. Balio eta indar bereko bi behar hauek bateragarri egitean du oinarria: 1) hizkuntzen ekologia naturalari eustea, hau da, hizkuntza-nazio bakoitzak bere ondare linguistikoa zaintzeko duen eskubidearen eta arduraren bitartez, munduko hizkuntzen aniztasuna gordetzea, eta 2) esparru mugatu eta jakin batean (hizkuntza desberdinetako nazioen arteko komunikazioa bideratzeko, hain zuzen), bigarren hizkuntza bat komunikazio-hizkuntza gisa ezartzea.</descrip>
    </descripGrp>
    <tig>
      <term>ekologismo glotiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ecologismo glótico</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411214">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-aniztasuna murriztu eta giza hizkuntza bakarra (norberarena) ezarri nahi duen hizkuntza-ideologia.</descrip>
    </descripGrp>
    <tig>
      <term>egozentrismo glotiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>egocentrismo glótico</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411215">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzaren barietate estandar arautua eguneratzea, aberastea eta komunikazio-funtzio guztietarako baliagarri egitea. Estandarizazioaren azken fasea da.</descrip>
    </descripGrp>
    <tig>
      <term>elaborazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>elaboración</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>élaboration</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>elaboration</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411216">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Komunikazio-interakzio baterako hizkuntza jakin bat edo beste bat hautatzea. Komunikatu nahi duen egoera guztietan egin behar du hiztunak hautaketa hori.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-hautaketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>elección de la lengua</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>élection de la langue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language choice</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411217">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza menderatua ofizial (koofizial) bihurtu eta gero, hizkuntza hori, funtsean, komunitatearen hizkuntza sinboliko gisa baino ez erabiltzea. Hizkuntza menderatzailea erabiltzen da benetako gizarte-harremanetarako hizkuntza publiko eta pribatu modura.</descrip>
    </descripGrp>
    <tig>
      <term>enblematizazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>emblematización</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>emblematisation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>emblematization</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411218">
  <descrip type='subjectField'>Teknikak eta metodoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona-kopuru jakin batek galde-sorta bati erantzutean eta ikerlariak erantzun horiek aztertzean datzan ikerketa-teknika. Gizabanakoen eta giza taldeen ezaugarri, joera edo portaera soziolinguistikoak hautematea da helburua.</descrip>
    </descripGrp>
    <tig>
      <term>inkesta soziolinguistiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>encuesta sociolingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>enquête sociolinguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>sociolinguistic poll</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411219">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza bereko bi barietateren artean gertatzen den diglosia. OHARRA: Adibide ezaguna da Magrebeko herrialde batzuetan arabiera klasikoak eta bertako arabierak bizi duten diglosia-egoera.</descrip>
    </descripGrp>
    <tig>
      <term>endodiglosia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>barne-diglosia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>endodiglosia</term>
    </tig>
    <tig>
      <term>diglosia interna</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>endodiglossie</term>
    </tig>
    <tig>
      <term>diglossie interne</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>endodiglossia</term>
    </tig>
    <tig>
      <term>internal diglossia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411220">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irakaskuntzako komunikazio-hizkuntza gisa bi hizkuntza erabiltzen dituen irakaskuntza.</descrip>
    </descripGrp>
    <tig>
      <term>irakaskuntza elebidun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>enseñanza bilingüe</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>enseignement bilingue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>bilingual teaching</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411221">
  <descrip type='subjectField'>Ikaskuntza eta hezkuntza</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irakaskuntzako komunikazio-hizkuntza gisa hizkuntza bakarra erabiltzen duen irakaskuntza.</descrip>
    </descripGrp>
    <tig>
      <term>irakaskuntza elebakar</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>enseñanza monolingüe</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>enseignement monolingue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>monolingual teaching</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411222">
  <descrip type='subjectField'>Teknikak eta metodoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Informatzailearengandik datu soziolinguistikoak lortzeko, ikerlariak harekin egiten duen elkarrizketa. Elkarrizketa inkesta modura edo solasaldi informal modura egituratu daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>elkarrizketa soziolinguistiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>entrevista sociolingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>entrevue sociolinguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>sociolinguistic interview</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411223">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzei ahalik eta funtzio gehien lortzeko aukera eskaintzen dien egoera.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-oreka</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>equilibrio lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>équilibre linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic balance</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411224">
  <descrip type='subjectField'>Hiztunen tipologia (Hego Euskal Herria)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Personne qui ne parle pas du tout le basque et ne le comprend ni ne le lit bien.</descrip>
    </descripGrp>
    <tig>
      <term>erdaldun elebakar</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Euskal soziolinguistikaren eremuan erabiltzeko terminoa.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>erdaldun monolingüe</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>hispanophone monolingue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>monolingual non-basque speaker</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411225">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzari garapen osoa ematen dioten hiztunez osatutako nukleoa, hau da, hizkuntzaren garapen osoa eskuratu duten hiztunez osatutakoa.</descrip>
    </descripGrp>
    <tig>
      <term>gune sinboliko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>espacio simbólico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>espace symbolique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>symbolic space</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411226">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek bere hizkuntzan gabezia linguistikoak dituela edo bere hizkerako elementu batzuk forma estandarraren araberakoak ez direla konturatzen delako barne-herstura pairatzea.</descrip>
    </descripGrp>
    <tig>
      <term>eskizoglosia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>esquizoglosia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>schizoglossie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>schizoglossia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411227">
  <descrip type='subjectField'>Teknikak eta metodoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsonen edo bestelako unitateen multzo bati dagozkion zenbakizko datuak biltzeko, sailkatzeko eta aztertzeko hainbat teknika eta analisi matematiko erabiltzen dituen zientzia.</descrip>
    </descripGrp>
    <tig>
      <term>estatistika</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>estadística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>statistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>statistics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411228">
  <descrip type='subjectField'>Arlo instituzionala eta zuzenbide-arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ofizialtasuna hizkuntza bati bakarrik emateaz gainera, bere lurraldeko gainerako hizkuntzei behar bezala garatzeko bideak ukatzen dizkion estatua.</descrip>
    </descripGrp>
    <tig>
      <term>estatu hedakor</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>estado expansionario</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>état expansionniste</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>expansionary state</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411229">
  <descrip type='subjectField'>Arlo instituzionala eta zuzenbide-arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza ofizial bat baino gehiago mintzatzen den estatua.</descrip>
    </descripGrp>
    <tig>
      <term>estatu eleaniztun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>estado multilingüe</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>état multilingue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>multilingual state</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411230">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza baten barietate estandarra zehazteko, ezartzeko eta lantzeko helburua duen prozesu linguistiko eta soziala. Lau fase ditu: hautatzea, kodetzea, inplementazioa eta elaborazioa.</descrip>
    </descripGrp>
    <tig>
      <term>estandarizazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>estandarización</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>standardisation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>standardization</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411231">
  <descrip type='subjectField'>Estandarizazioa, planifikazioa eta normalizazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Formalki programatutako prozesu baten bitartez egiten den estandarizazioa.</descrip>
    </descripGrp>
    <tig>
      <term>estandarizazio formal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>estandarización formal</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>standardisation formelle</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>formal standardization</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411232">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egitura sozial jakin batean, pertsona edo hizkuntza batek besteen aldean duen lekua edo posizioa.</descrip>
    </descripGrp>
    <tig>
      <term>estatus</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>estatus</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>status</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>status</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411233">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza edo hiztun-talde bati buruz izaten den aurreiritzi bidezko irudia. Banakako analisirik egin gabe, multzo osoaz dugun aurretiazko iritzi hori esleitzen zaio banakoari.</descrip>
    </descripGrp>
    <tig>
      <term>estereotipo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>estereotipo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>stéréotype</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>stereotype</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411234">
  <descrip type='subjectField'>Psikosoziolinguistika, ideologia eta jarrerak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Norbait edo zerbait gaitzestea dakarren marka edo ezaugarria. Zenbait egoera edo gizartetan, hizkuntza jakin bat izan daiteke marka edo ezaugarri hori.</descrip>
    </descripGrp>
