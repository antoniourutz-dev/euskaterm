<termEntry id="411188">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Luzaroan ukipen-egoeran izan diren hizkuntzetako baten ezaugarri linguistikoak beste hizkuntzako ezaugarrien arabera moldatzeko prozesua. Bi hizkuntza-sistemak hurbildu egiten dira prozesu horretan.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-konbergentzia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
