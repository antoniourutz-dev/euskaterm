  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-aldagai bat gauzatzen den moduetako bakoitza. Adibidez, kasu soziatiboa -kin, -kila edo -gaz aldaeretan gauza daiteke.</descrip>
