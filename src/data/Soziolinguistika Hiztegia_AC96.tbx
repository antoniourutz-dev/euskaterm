    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>variationist sociolinguistics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411406">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Diziplina soziolinguistikoa, gizarteak hizkuntzarekin duen harremana aztertzen duena. OHARRA: Askotan nahasi egiten dira soziolinguistika eta hizkuntzaren soziologia. Bereizgarri gisa esan daiteke lehenak hizkuntza aztertzen duela, testuinguru sozialarekin duen harremanaren bitartez, eta bigarrenak, berriz, gizartea duela aztergai.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntzaren soziologia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sociología del lenguaje</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>sociologie du langage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>sociology of language</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411407">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Terminologia testuinguru soziolinguistikoa kontuan hartuta aztertzen duen diziplina.</descrip>
    </descripGrp>
    <tig>
      <term>sozioterminologia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>socioterminología</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>socioterminologie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>socioterminology</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411408">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitz edo adierazpen bat oker erabiltzea edo hizkuntzaren sintaxi zuzena aldatzea.</descrip>
    </descripGrp>
    <tig>
      <term>solezismo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>solecismo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>solécisme</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>solecism</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411409">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza bateko hiztunak jarduera publiko eta formaletarako beste hizkuntza bat ikasi eta erabili behar izaten duen egoera soziolinguistikoa.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-menderakuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>subordinación lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>subordination linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic subordination</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411410">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza baten lurraldean sartu den beste hizkuntza batek, lurralde horretatik desagertu ondoren, jatorrizko hizkuntza hartan uzten dituen ezaugarri linguistikoen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>superestratu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>superestrato</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>superstrat</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>superstratum</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411411">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza batek beste hizkuntza baten erabilera-eremuak eta funtzioak irabaziz joatean gertatzen den prozesua. Hizkuntza menderatzaileak aurrera egiten jarraitzen badu, jatorrizko hizkuntza desagertu ere egin daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-ordezkapen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sustitución lingüística</term>
    </tig>
    <tig>
      <term>desplazamiento lingüístico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>substitution linguistique</term>
    </tig>
    <tig>
      <term>transfert linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>language shift</term>
    </tig>
    <tig>
      <term>language transfer</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411412">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lurralde batean hitz egiten den hizkuntzaren aurretik lurralde horretan hitz egiten zen hizkuntzak ondorengo bigarren hizkuntza hartan utzi dituen ezaugarri linguistikoen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>substratu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sustrato</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>substrat</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>substratum</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411413">
  <descrip type='subjectField'>Bariazioa eta barietateak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Jakintza edo jarduera-arlo batean erabiltzen den hizkera berezia. Zientzia edo lanbide jakin batzuetan, adibidez, ezaugarri linguistiko bereziko hizkuntza erabiltzen da.</descrip>
    </descripGrp>
    <tig>
      <term>teknolekto</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>tecnolecto</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>technolecte</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>technolect</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411414">
  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza gutxitu baten mendekotasun-egoera eta gutxitze-prozesua eten eta atzera oreka berreskuratzen hasten den uneko egoera.</descrip>
    </descripGrp>
    <tig>
      <term>etete-tentsio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>tensión de ruptura</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>tension de rupture</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>breaking strain</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411415">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi hizkuntza-barietate desberdin erabiltzen dituzten hiztunen arteko interakzioa gertatzen denean, hiztunek barietate horiek egokitzeko joera azaltzen duen teoria. Egokitze-joera izan daiteke hizkuntza-barietateak hurbiltzea nahiz aldentzea, jarrera eta helburuen arabera.</descrip>
    </descripGrp>
    <tig>
      <term>hizkuntza-egokitzearen teoria</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>teoría de la acomodación lingüística</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>théorie de l'accommodation linguistique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>linguistic accommodation theory</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411416">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Maila apaleko gizarte-taldeen hizkuntza egungo hezkuntza formalera egokitzen ez dela dioen teoria. Horrela, bi hizkuntza-kodeen (landuaren eta murriztuaren) artean dagoen aldea faktore garrantzitsua izan daiteke eskola-porrotean.</descrip>
    </descripGrp>
    <tig>
      <term>kodeen teoria</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>teoría de los códigos</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>théorie des codes</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>theory of codes</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411417">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsonen edo giza taldeen hizkuntza-portaera gobernatzen duten esparru edo funtzioak daudela definitzen duen teoria. Esparru horiek kategoriak dira, hiztunak erabilera-esparru desberdintzat hartzen dituen unitateak, fisiko nahiz mentalak. Esparru horietako batean dagoela hautematen duenean, hizkuntza bat edo beste bat erabiltzeko hautua egingo du hiztunak.</descrip>
    </descripGrp>
    <tig>
      <term>esparruen teoria</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>funtzioen teoria</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>teoría de los espacios</term>
    </tig>
    <tig>
      <term>teoría de las funciones</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="411418">
  <descrip type='subjectField'>Soziolinguistikaren adarrak, eskolak eta korronteak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Harmonia- eta integrazio-fenomenoetan baino arreta handiagoa gatazka-egoera eta -prozesuetan jartzen duen ikuspegi soziologikoa.</descrip>
    </descripGrp>
    <tig>
      <term>gatazkaren teoria</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
