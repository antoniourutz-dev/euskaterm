  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizarte berean mintzatzen diren hizkuntza desberdinak; Euskal Herriaren kasuan, euskara, gaztelania eta frantsesa nagusiki.</descrip>
