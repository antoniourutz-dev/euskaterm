  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntzaren ondare lexikoa finkatzea eta hitz bakoitzaren adiera zehatza bereiztea. Kodetzearen hiru ataletako bat da.</descrip>
