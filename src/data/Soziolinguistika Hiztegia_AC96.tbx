  <descrip type='subjectField'>Hizkuntza-ukipena eta hizkuntza-gatazka</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hizkuntza-ukipenean bizi den lurralde batean, gutxiengo batek erabiltzen duen hizkuntza.</descrip>
