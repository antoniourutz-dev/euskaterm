<termEntry id="345768">
  <descrip type='subjectField'>Programazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Informazioa prozesatzeko modua. Datuak jaso bezain laster tratatzen dira, erantzun-denbora ahalik eta txikiena izan dadin.</descrip>
