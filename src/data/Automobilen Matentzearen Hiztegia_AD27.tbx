<termEntry id="4">
  <descrip type='subjectField'>Osagarriak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auto barneko airea hoztu edo berotzeko eta hezetasuna kentzeko gailua. Kondentsadore bat, konpresore bat eta lurrungailu bat ditu osagai nagusiak.</descrip>
