  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Konponketa egin behar duen lantegiak prestatu eta bezeroak sinatutako dokumentua, konponketa-lanen zerrendarekin eta aurrekontuarekin ados dagoela adierazten duena.</descrip>
