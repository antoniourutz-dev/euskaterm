  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Motorraren balbulak irekitzeko angeluak eta, beraz, zilindroa betetzeko eta husteko behar den denbora aldatzen uzten duen sistema. Sistemaren arabera, balbulak noiz ireki, zenbat igo eta irekita egoteko denbora alda litezke.</descrip>
    </descripGrp>
