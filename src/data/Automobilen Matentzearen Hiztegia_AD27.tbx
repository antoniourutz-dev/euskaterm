      </sourceDesc>
    </fileDesc>
  </martifHeader>
<text>
<body>
<termEntry id="1">
  <descrip type='subjectField'>Funtzionamendu-sistemak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Frenatzeari aplikatutako segurtasun-sistema. Gurpil bakoitzean, abiadura neurtzen duten sentsore batzuk jartzen dira; eta, kalkulagailu elektroniko baten bidez, gurpil bat blokeatzeko zorian noiz dagoen erabakitzen du sistema horrek.</descrip>
    </descripGrp>
    <tig>
      <term>ABS</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>frenoak ez blokeatzeko sistema</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>balaztak ez blokeatzeko sistema</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ABS</term>
    </tig>
    <tig>
      <term>sistema antibloqueo de frenos</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>ABS</term>
    </tig>
    <tig>
      <term>système de freinage antiblocage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ABS</term>
    </tig>
    <tig>
      <term>anti lock brake system</term>
    </tig>
  </langSet>
</termEntry>
