<termEntry id="245">
  <descrip type='subjectField'>Elektromekanika</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aire-girogailuaren osagai bat. Hozgarria lurrundu egiten du, ibilgailu-barruan sartzen den airearen beroa xurgatuz eta airea hoztuz.</descrip>
