<termEntry id="349112">
  <descrip type='subjectField'>Orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>MIDI instrumentuak edo bestelako gailuak konputagailuarekin komunikatu ahal izateko erabiltzen duen gailua. MIDI mezuak jasotzen ditu (esaterako, instrumentuetan jotako notak software-sekuentziagailuan grabatzeko), eta bidaltzen ditu (sekuentziagailuan grabatutako MIDI datuak instrumentuak jo ditzan).</descrip>
    </descripGrp>
    <tig>
      <term>MIDI interfaze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>adaptador MIDI</term>
    </tig>
    <tig>
      <term>interfaz MIDI</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>interface MIDI</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>MIDI interface</term>
    </tig>
  </langSet>
</termEntry>
