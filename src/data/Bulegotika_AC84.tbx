  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Paragrafoei elkarren segidako zenbakiak automatikoki ezartzeko aukera. Horrelako paragrafoak zerrenda bateko osagai bihurtzen dira, eta paragrafo bat kendu edo gehitzen denean, automatikoki ezartzen zaio dagokion zenbakia.</descrip>
