  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Idatzi ahala testuari formatua ematen dion eginbidea, buletak eta zenbakitzea, ertzak, maiuskulak eta horrelakoak ezartzen dituena.</descrip>
