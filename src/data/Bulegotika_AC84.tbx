  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Idatzitako testuaren idazkera zuzena dela egiaztatzeko eginbidea. Tresna honen bidez, zuzentzaile ortografikoak ezagutzen ez dituen hitzak gehi daitezke hiztegi pertsonalean.</descrip>
