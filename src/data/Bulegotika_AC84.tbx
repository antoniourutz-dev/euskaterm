<termEntry id="349033">
  <descrip type='subjectField'>Testu-tratamendua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Saguaren botoia bi aldiz bizkor sakatu eta ondoren askatzea. Hori egiten da, esate baterako, saguaren erakuslea gainean duen hitz bat osorik hautatzeko.</descrip>
