  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Datu-baseko datuak bistaratzeko, edo datuak sartu edo editatzeko norberaren beharren arabera prestatzen den ikuspegia; erabiltzaileak nahi dituen eremuak bakarrik erakusten dira, norberak nahi duen ordenan.</descrip>
