  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pantaila, leiho, orrialde, testu-marko, taula-gelaxka eta abarrek atzean duten planoa, apaingarri edo ezaugarri gisa kolore bat edo objektu grafiko bat eduki dezakeena.</descrip>
