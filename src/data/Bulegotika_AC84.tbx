  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lineako laguntza-sistema, programa osoari buruzko laguntza eman ordez, kasu bakoitzean exekutatzen ari den komando edo eragiketari buruzkoa ematen duena.</descrip>
