<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontsumitzaile edo erabiltzaile bakoitzak dituen zuzeneko interesak. Banakako interesak interes kolektiboei eta interes lausoei kontrajartzen zaizkie.</descrip>
    </descripGrp>
