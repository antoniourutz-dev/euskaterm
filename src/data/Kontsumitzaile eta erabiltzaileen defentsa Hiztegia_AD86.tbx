<termEntry id="-1">
  <descrip type='subjectField'>Kontratuak eta bermeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herri-administrazioaren kontrol-jarduera, kontsumitzaileei zuzendutako produktuen eta zerbitzuen segurtasuna eta kontsumoaren inguruko arauekiko egokitasuna bermatzea helburu duena.</descrip>
    </descripGrp>
