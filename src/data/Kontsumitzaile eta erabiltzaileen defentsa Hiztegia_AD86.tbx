<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Enpresa edo profesional bat Kontsumoko Arbitraje Sistemari atxikita dagoela egiaztatzen duen dokumentu ofiziala, haren bezeroek ikusteko moduan jartzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>Kontsumoko Arbitraje Sistemako atxikipen-bereizgarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>distintivo de adhesión al Sistema Arbitral de Consumo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontsumoko Arbitraje Sistemari atxikitzeko aurkeztu duen eskaintza publikoa onartu zaion enpresa edo profesionala. Establezimendu horrek Kontsumoko Arbitraje Sistemako atxikipen-bereizgarria erabiltzeko eskubidea du.</descrip>
    </descripGrp>
    <tig>
      <term>kontsumo-arbitrajeari atxikitako establezimendu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>establecimiento adherido al arbitraje de consumo</term>
    </tig>
  </langSet>
</termEntry>
