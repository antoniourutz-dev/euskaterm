    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arbitraje-prozeduran gatazkako alderdien arteko adostasuna lortzeko bitartekari-lanetan diharduen pertsonak egiten duen lana.</descrip>
    </descripGrp>
    <tig>
      <term>bitartekaritza</term>
