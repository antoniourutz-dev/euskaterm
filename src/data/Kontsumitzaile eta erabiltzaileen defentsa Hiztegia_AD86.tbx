<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontsumitzaileei eta erabiltzaileei zuzendutako hezkuntza- eta prestakuntza-jarduera; haien eskubideak eta betebeharrak ezagutaraztea, horiek erabiltzen eta betetzen jakitea eta kontsumo arduratsua sustatzea dira jardueraren helburuak.</descrip>
    </descripGrp>
    <tig>
      <term>kontsumo-arloko hezkuntza eta prestakuntza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>formación en materia de consumo</term>
    </tig>
  </langSet>
</termEntry>
</body>
