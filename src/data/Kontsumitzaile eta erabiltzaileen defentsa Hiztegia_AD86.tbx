<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Enpresa edo profesional batek egiten duen aldebakarreko eskaintza, kontsumitzaileekiko edo erabiltzaileekiko kontsumo-harreman juridikoetan izan ditzakeen gatazkak konpontzeko kontsumoko arbitraje sistemaren mende jartzea onartuz egiten duena.</descrip>
    </descripGrp>
