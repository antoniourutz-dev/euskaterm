<termEntry id="-1">
  <descrip type='subjectField'>Kontratuak eta bermeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Europar Batasuneko herrialdeen artean informazioa azkar trukatzeko alerta-sistema; administrazio eskudunei kontsumoko produktu jakin batzuek kontsumitzaileen osasunerako edo segurtasunerako ekar dezaketen arriskuaren berri emateko eratzen da.</descrip>
    </descripGrp>
    <tig>
      <term>RAPEX</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>kontsumo-produktuen erabileratik eratorritako arriskuei buruzko informazioak trukatzeko Europar Batasuneko sistema</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>RAPEX</term>
