      <term>denegación de embarque</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eusko Jaurlaritzan kontsumoaren arloko eskumena duen sailari atxikitako erakunde autonomoa. Kontsumitzaileen eta erabiltzaileen defentsari eta babesari buruzko Eusko Jaurlaritzaren politikak zehaztea, planifikatzea, bultzatzea eta betearaztea dira haren helburuak.</descrip>
    </descripGrp>
    <tig>
      <term>Kontsumobide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>Kontsumoko Euskal Institutua</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
