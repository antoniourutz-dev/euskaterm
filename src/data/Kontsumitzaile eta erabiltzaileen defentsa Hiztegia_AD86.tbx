<termEntry id="-1">
  <descrip type='subjectField'>Bidaia konbinatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Enpresa edo profesional batek kontsumitzaileari egiten dion merkataritza-proposamen idatzia. Proposamenean jasota geratzen dira haren baldintza nagusiak eta haiek errespetatzeko enpresak edo profesionalak hartzen duen konpromisoa. Behin kontratua sinatuta, kontsumitzaileak eskubidea du eskaintzan jasotzen dena eskatzeko.</descrip>
    </descripGrp>
    <tig>
      <term>egitarau-eskaintza lotesle</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>programa-oferta vinculante</term>
    </tig>
  </langSet>
</termEntry>
