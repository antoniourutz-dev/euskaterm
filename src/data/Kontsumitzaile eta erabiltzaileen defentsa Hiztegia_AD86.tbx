<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE martif PUBLIC "ISO 12200:1999A//DTD MARTIF core (DXFcdV04)//EN" "TBXcdv04.dtd">
<martif type="TBX" xml:lang="en">
  <martifHeader>
    <fileDesc>
      <titleStmt>
        <title>Kontsumitzaile eta erabiltzaileen defentsa Hiztegia</title>
      </titleStmt>
      <sourceDesc>
        <p>Kontsumitzaile eta erabiltzaileen defentsa Hiztegiaren TBX esportazioa</p>
      </sourceDesc>
    </fileDesc>
  </martifHeader>
<text>
<body>
<termEntry id="-1">
  <descrip type='subjectField'>Erantzukizun zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Legitimoki espero izatekoa den segurtasun edo kalitate maila eskaintzen ez duen produktua. Segurtasunaren arloan, inguruabar guztiak hartuko dira kontuan, baina, bereziki, produktuaren aurkezpena, produktuaren arrazoizko erabilera eta zirkulazioan jartzeko unea.</descrip>
    </descripGrp>
    <tig>
      <term>produktu akastun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>producto defectuoso</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontratuak eta bermeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Akzio judizial kolektiboa, honako helburu hau duena: demandatua deuseztzat eman diren baldintza orokorrak kentzera eta aurrerantzean horiek ez erabiltzera epai bidez kondenatzea.</descrip>
    </descripGrp>
    <tig>
      <term>bukarazte-akzio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acción de cesación</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontratuak eta bermeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Akzio judizial kolektiboa, honako helburu hau duena: epai bidez deklaratzea kontratu-klausula bat baldintza orokorra dela-eta, Kontratuetako Baldintza Orokorren Erregistroan inskribatu behar dela.</descrip>
    </descripGrp>
    <tig>
      <term>deklaratze-akzio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acción declarativa</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alderdien arteko gatazkan arbitraje-lanak egiten dituen pertsona.</descrip>
    </descripGrp>
    <tig>
      <term>arbitro</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>árbitro</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontratuak eta bermeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontratu batean baino gehiagotan txertatzeko aurrez prestatutako klausulak, alderdietako batek kontratuan sartzen dituenak, edozein dela ere klausula horien egile materiala, kanpoko itxura, hedadura eta bestelako inguruabarrak.</descrip>
    </descripGrp>
    <tig>
      <term>kontratuetako baldintza orokorrak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>condiciones generales de la contratación</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arbitraje Batzorde Nazionalaren bitartez funtzionalki Kontsumo Institutu Nazionalari atxikita dagoen kide anitzeko organoa, Kontsumoko Arbitraje Sisteman irizpide homogeneoak ezartzen dituena.</descrip>
    </descripGrp>
    <tig>
      <term>Kontsumoko Arbitraje Batzordeen Komisioa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Comisión de las Juntas Arbitrales de Consumo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arbitraje Batzordeari aurkeztutako auziak ebazten dituen organoa. Herri Administrazioaren zerbitzuan dagoen langile batez, kontsumitzaileen eta erabiltzaileen sektoreko ordezkari batez eta enpresa-sektoreko ordezkari batez osatuta dago.</descrip>
    </descripGrp>
    <tig>
      <term>arbitraje-elkargo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>colegio arbitral</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontsumitzaile gehienek oinarrizko produktu gisa kontsumitzen duten ondasun edo zerbitzua, legeak bereziki babesten duena.</descrip>
    </descripGrp>
    <tig>
      <term>erabilera arrunteko produktu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>producto de uso común</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontratuak eta bermeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Banan-banan negoziatu gabeko edozein estipulazio eta espresuki onartu gabeko edozein praktika, baldin eta, fede onak eskatzen duenaren kontra, desoreka handia sortzen badu kontratuak alderdiei dakarzkien eskubide eta betebeharren artean, kontsumitzailearen eta erabiltzailearen kaltetan.</descrip>
    </descripGrp>
    <tig>
      <term>abusuzko klausula</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cláusula abusiva</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona fisikoa edo juridikoa, bere enpresa- edo lanbide-jarduera arlo publiko nahiz pribatuan garatzen duena.</descrip>
    </descripGrp>
    <tig>
      <term>enpresaburu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>empresario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Bidaia konbinatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bidaia konbinatua erosten duen edo erosteko konpromisoa hartzen duen pertsona fisikoa edo juridikoa.</descrip>
    </descripGrp>
    <tig>
      <term>kontratugile nagusi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>contratante principal</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Bidaia konbinatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bidaia konbinatuak maiz antolatzen dituen pertsona fisiko edo juridikoa, eta, zuzenean edo txikizkari baten bidez, saltzen dituena edo salmentan eskaintzen dituena.</descrip>
    </descripGrp>
    <tig>
      <term>bidaia-antolatzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>organizador de viajes</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Bidaia konbinatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bidaia-agentzia handizkariekin lan egiten duen agentzia, bidaiariei haiek antolatutako bidaiak eta zerbitzu turistikoak zuzenean saltzen dizkiena.</descrip>
    </descripGrp>
    <tig>
      <term>bidaia-agentzia txikizkari</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>agencia de viajes detallista</term>
    </tig>
    <tig>
      <term>agencia de viajes minorista</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Bidaia konbinatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bidaia-agentzia txikizkarientzat bidaia konbinatuak antolatzen dituen bidaia-agentzia.</descrip>
    </descripGrp>
    <tig>
      <term>bidaia-agentzia handizkari</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>agencia de viajes mayorista</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lehiakide baten izen ona gutxiesten duen publizitatea. Edukiagatik, aurkezteko eragatik edo hedatzeko moduagatik, pertsona edo enpresa bat, enpresaren produktuak, zerbitzuak, jarduerak edo inguruabarrak edo enpresaren markak, izen komertzialak edo zeinu bereizgarriak iraintzen edo gutxiesten ditu, edo horien izen ona zikintzen du, zuzenean edo zeharka.</descrip>
    </descripGrp>
    <tig>
      <term>publizitate desleial</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>publicidad desleal</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktu edo zerbitzu bat hornitzen duen pertsona fisikoa edo juridikoa. Produktu edo zerbitzu hori gerora eraldatu, berriro saldu edo kontsumitu egin daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>hornitzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>proveedor</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Enpresaburuen eta kontsumitzaileen eta erabiltzaileen arteko gatazkak ebazteko judizioz kanpoko sistema; kontsumitzaileen eta erabiltzaileen erreklamazioak ebazten ditu, betiere, intoxikaziorik, lesiorik edo heriotzarik gertatu ez bada eta arrazoizko delitu-zantzurik ez badago. Ebazpena loteslea eta betearazlea da bi alderdientzat.</descrip>
    </descripGrp>
    <tig>
      <term>Kontsumoko Arbitraje Sistema</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Sistema Arbitral de Consumo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabakia auzigaiari buruzko lege-xedapenetan soilik oinarritzen duen arbitrajea.</descrip>
    </descripGrp>
    <tig>
      <term>zuzenbideko arbitraje</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>arbitraje de derecho</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabakia usadioan eta auzipeko egintzak gertatzen diren lekuko ohitura profesionaletan oinarritzen duen arbitrajea.</descrip>
    </descripGrp>
    <tig>
      <term>ekitateko arbitraje</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>arbitraje de equidad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Estatuaren eta autonomia-erkidegoen arteko lankidetzarako organo gorena. Osasun eta Kontsumoko ministroak eta gaian eskumena duten autonomia-erkidegoetako sailburuek osatzen dute, eta ministroa da burua.</descrip>
    </descripGrp>
    <tig>
      <term>Kontsumo Sektoreko Konferentzia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>KSK</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Conferencia Sectorial de Consumo</term>
    </tig>
    <tig>
      <term>CSC</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Baliabide elektronikoak soilik erabiliz bideratzen den kontsumo-arbitrajea; baliabide elektronikoak erabiltzen dira arbitraje-eskaeratik prozedura amaitu arte, baita jakinarazpenak egiteko ere.</descrip>
    </descripGrp>
    <tig>
      <term>kontsumoko arbitraje elektroniko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>arbitraje de consumo electrónico</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Funtzionalki Kontsumo Institutu Nazionalari atxikita dagoen kide anitzeko organoa, kontsumo-arbitrajean ordezkaritza eta partaidetza dituena.</descrip>
    </descripGrp>
    <tig>
      <term>Kontsumoko Arbitraje Sistemaren Kontseilu Orokorra</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Consejo General del Sistema Arbitral de Consumo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontratuak eta bermeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gaixoek beren osasunari buruzko informazioa jasotzeko duten eskubidea.</descrip>
    </descripGrp>
    <tig>
      <term>laguntza-informazioa jasotzeko eskubide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>derecho a la información asistencial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hartzaileak okerreko portaera edo iritzira eraman ditzakeen publizitatea; haien portaera ekonomikoa ukitzera irits daiteke, baita lehiakide bati kalte egitera ere.</descrip>
    </descripGrp>
    <tig>
      <term>publizitate engainagarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>iruzurrezko publizitate</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>publicidad engañosa</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Erantzukizun zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Baliabide materialak, pertsonalak eta diruzkoak erabiliz merkatuan produktu zein zerbitzu bat eskuragarri jartzen duena; horretarako, produktu zein zerbitzu hura eraldatzen du, eta hari balio erantsia ematen dio.</descrip>
    </descripGrp>
    <tig>
      <term>fabrikatzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>fabricante</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Kontratuak eta bermeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontratuetako baldintza orokor diren kontratu-klausulak inskribatzeko erregistroa. Kontratuetako Baldintza Orokorrei buruzko apirilaren 13ko 7/1998 Legean xedatzen dira erregistro honi buruzkoak.</descrip>
    </descripGrp>
    <tig>
      <term>Kontratuetako Baldintza Orokorren Erregistroa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Registro de Condiciones Generales de la Contratación</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Bidaia konbinatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontratugile nagusiak edo beste onuradun batek egindako lagapenaren ondorioz, bidaia konbinatua hartzen duen pertsona fisikoa.</descrip>
    </descripGrp>
    <tig>
      <term>lagapen-hartzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cesionario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontsultarako, aholkurako, partaidetzarako eta administrazioen arteko koordinaziorako organoa. Kontsumoan parte hartzen duten gizarte-eragileen arteko lankidetza sustatzen du, baita kontsumitzaileen eta erabiltzaileen eskubideak babesteaz arduratzen diren herri-administrazioekikoa ere, ahalik eta babes handiena lortzeko Euskal Autonomia Erkidegoan.</descrip>
    </descripGrp>
    <tig>
      <term>Euskadiko Kontsumoko Kontsulta Batzordea</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Comisión Consultiva de Consumo de Euskadi</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontsumitzaileen eta erabiltzaileen kexak eta erreklamazioak jaso, erregistratu, hartu izanaren berri eman eta, ondoren, beharrezko entitateetara edo erakundeetara bidaltzen dituen bulegoa. Kontsumitzaileak eta erabiltzaileak artatzeaz, defendatzeaz eta babesteaz ere arduratzen da.</descrip>
    </descripGrp>
    <tig>
      <term>kontsumitzaileen eta erabiltzaileen informaziorako bulego</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>oficina de información a los consumidores y usuarios</term>
    </tig>
    <tig>
      <term>oficina de información a las personas consumidoras y usuarias</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontsumitzaileek eta erabiltzaileek beren elkarteen bidez kontsultarako eta ordezkaritza instituzionalerako duten estatu-mailako organoa. Barnean hartzen ditu autonomiaz gaindiko eremuan diharduten eta ordezkaritza handiena duten kontsumitzaileen eta erabiltzaileen elkarteak.</descrip>
    </descripGrp>
    <tig>
      <term>Kontsumitzaileen eta Erabiltzaileen Kontseilua</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>KEK</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Consejo de Consumidores y Usuarios</term>
    </tig>
    <tig>
