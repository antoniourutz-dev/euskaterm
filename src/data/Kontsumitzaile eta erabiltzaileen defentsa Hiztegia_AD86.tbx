<termEntry id="-1">
  <descrip type='subjectField'>Kontsumoko arbitraje-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontsumoko arbitraje instituzionala kudeatzen duen administrazio-organoa, arbitrajeko alderdiei eta arbitroei zerbitzu teknikoak eta administrazio nahiz idazkaritzakoak ematen dizkiena.</descrip>
    </descripGrp>
