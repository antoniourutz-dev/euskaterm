<termEntry id="303">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Altzairuen eta burdinurtuen osagaia; martensitaren 450-650 ºC bitarteko tenplaketa eta iraoketazko tratamendu termikoz edo elementu bereziak (kromoa, nikela, manganesoa) gehituz lortzen da.</descrip>
    </descripGrp>
    <tig>
      <term>sorbita</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
