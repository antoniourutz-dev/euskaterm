<termEntry id="58">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erregai artifizial solidoa, gutxi-asko porotsua; materia lurrunkor askoko harrikatz koipetsuak tenperatura altuan destilatuz ateratzen da.</descrip>
