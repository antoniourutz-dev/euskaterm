  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hauts-metalurgian, presioa aplikatzea metal-hautsezko masa konpaktu bat lortzeko, forma eta bolumen jakineko objektu manipulagarri bihur dadin. Sinterizazioaren aurretik egiten den eragiketa da.</descrip>
