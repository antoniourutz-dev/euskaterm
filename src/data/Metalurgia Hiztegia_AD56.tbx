      <term>interstitial compound</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="265">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Korrosioarekiko eta tenperaturarekiko oso erresistentea den konposatua. Adibidez, oxidoak, boruroak, karburoak, nitruroak, siliziuroak, cermetak eta Pyrocerama.  </descrip>
    </descripGrp>
