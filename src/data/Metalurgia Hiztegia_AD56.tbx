<termEntry id="113">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Deformazio mekanikoek edo efektu termikoek eragindako barne-tentsioen ondorioz pieza baten gainazalean zartatu meheak sortzea.</descrip>
    </descripGrp>
