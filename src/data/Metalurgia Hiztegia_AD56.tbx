<termEntry id="30">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Altzairua edo burdinurtua aluminio-geruza mehe batekin babestea; aluminio urtuzko bainu batean tenplatuz egiten da (tenplaketazko aluminizazioa) edo hutsean egindako lurrunketaz (hutseko aluminizazioa).</descrip>
    </descripGrp>
    <tig>
      <term>aluminizazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
