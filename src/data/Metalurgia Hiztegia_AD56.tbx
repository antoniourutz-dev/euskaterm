<termEntry id="257">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aluminiozko edo magnesiozko aleazioa, adizio-elementuren bat edo gehiago (hala nola kobrea, silizioa, magnesioa, zinka, nikela, manganesoa edo titanioa) izaten dituena. 2,6 kg/dm³ eta 3 kg/dm³ bitarteko  dentsitatea izaten du, eroankortasun handia, atmosferako korrosioaren kontrako erresistentzia eta mekanizagarritasun ona, baina elastikotasun-modulu ahula.</descrip>
    </descripGrp>
    <tig>
      <term>aleazio arin</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aleación ligera</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>alliage léger</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>light alloy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="258">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputz batek era bateko baino gehiagoko egoera kristalinoetan kristaltzeko duen ezaugarria; ondorioz, hartzen duen egituraren arabera, ezaugarri fisiko desberdinak izan ditzake.</descrip>
    </descripGrp>
    <tig>
      <term>alotropia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
