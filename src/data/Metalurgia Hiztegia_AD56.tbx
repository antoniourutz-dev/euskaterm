    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>aluminothermie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>aluminothermy</term>
    </tig>
  </langSet>
</termEntry>
