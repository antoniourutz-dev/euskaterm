<termEntry id="28">
  <descrip type='subjectField'>Tresnak, aparatuak, makinak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Upel sakoneko labe bertikala, oso neurri handikoa (20-32 m-ko altuera eta 7-10 m-ko diametroko sabela); burdin mea kastinarekin eta ikatzarekin txandakatuz kargatzen da, eta jarraian lan egiten du, kargan zehar indar handiz putz egindako aire beroarekin.</descrip>
    </descripGrp>
