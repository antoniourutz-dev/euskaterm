<termEntry id="213">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Burdin oxidoa, kolore gorrikoa, hezetasunarekin kontaktuan dauden burdinazko materialen gainean ateratzen dena babesik gabe edo gaizki babestuta daudenean.</descrip>
    </descripGrp>
    <tig>
      <term>herdoil</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>uger</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>herrumbre</term>
    </tig>
    <tig>
      <term>roña</term>
    </tig>
  </langSet>
