  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Objektu bat kobrezko geruza batekin estaltzea, korrosioaren kontra babesteko. Elektrolisiz, prozedura kimikoz, pistola bidezko metalizazioz edo plakatze bidez egiten da.</descrip>
