<termEntry id="215">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Barreiadurako prozedura termikoa erabiliz altzairua zinkarekin babesteko metodoa. Piezak kutxa itxi batean jartzen dira, zink-hauts finarekin eta beste produktu inerte eta erreduzitzaileen nahastura batekin egindako zementu batekin batera, eta atmosfera erreduzitzailea sortzen da 330-400 ºC-ko tenperaturan.</descrip>
    </descripGrp>
    <tig>
      <term>sherardizazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sherardizado</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>shérardisation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>sherardizing</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="216">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Burdin aleazioen gainazalean silizioz aberastutako geruza bat lortzeko egiten den tratamendu termokimikoa.</descrip>
    </descripGrp>
    <tig>
      <term>siliziurazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>siliciuración</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>siliciuration</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>siliconizing</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="217">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
