<termEntry id="300">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hozteko ingurune baten eraginkortasuna neurtzen duen ezaugarria. Piezaren gainazaleko hozte-abiadura erregulatzen duen H = M/2K erlazioaz kalkulatzen da, M izanik aurpegi-tarteko mintz-koefizientea edo eroankortasun termikoa eta K piezaren metalak duen eroankortasun termikoa.</descrip>
    </descripGrp>
    <tig>
      <term>tenplaketa-zorroztasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>severidad de temple</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>sévérité de trempe</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>hardening intensity</term>
    </tig>
  </langSet>
</termEntry>
