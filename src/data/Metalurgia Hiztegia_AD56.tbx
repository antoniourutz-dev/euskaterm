    </tig>
  </langSet>
</termEntry>
<termEntry id="32">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Burdin aleazioari eraldaketa-puntuaren gainetik geratzen den tenperaturan hoztuz ematen zaion tratamendu termikoa; egitura bainitikoa lortzea izaten da helburua, hau da, austenita bainita bihurtzea.</descrip>
    </descripGrp>
