  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Metalezko piezen gainazalean gogortasuna edo higadurarekiko erresistentzia hobetzeko eta, aldi berean, muinean metalaren jatorrizko ezaugarriak kontserbatzeko egiten den tratamendua.</descrip>
