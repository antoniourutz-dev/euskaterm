  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>wire rod</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="256">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <tig>
