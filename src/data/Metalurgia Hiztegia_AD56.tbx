<termEntry id="36">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Altzairuen osagai mikroskopikoa, ferrita-kristalen eta burdin karburozko kristalen agregatu batez eratua. Austenitatik sortzen da altzairuak hoztean, perlitaren azaltze-tenperaturaren eta martensitaren kristaltze-tenperaturaren tarteko tenperaturan.</descrip>
