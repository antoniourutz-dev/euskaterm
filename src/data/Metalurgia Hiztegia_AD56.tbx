    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>sintering</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="219">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gehiegizko tenperatura jasan duen eta nahi ez den pikor-egitura duen pieza baten egoera. Metal gainberotua ez da, nahitaez, behin betiko kaltetuta geratzen; erretako metalaren kasuan ez bezala, zuzendu egin daiteke tratamendu termiko egoki bat aplikatuz, lanketa mekanikoz edo bi prozeduren konbinazioz.</descrip>
    </descripGrp>
    <tig>
      <term>gainberotu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
