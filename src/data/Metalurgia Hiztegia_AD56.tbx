  </martifHeader>
<text>
<body>
<termEntry id="1">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>gainazal-akabera</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acabado superficial</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>fini de surface</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>surface finish</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="2">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>karbono-altzairu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero al carbono</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier au carbone</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>carbon steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="3">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Karbono-oxigenoaren erreakziotik sortutako gasik askatzen ez duen altzairua. Egoera likidoan dagoen bitartean, tratamendu bat aplikatzen zaio; hala, ez solidotu aurreko eta ondorengo hozketan, ez solidotze-prozesuan, ez du gasik askatzen.</descrip>
    </descripGrp>
    <tig>
      <term>altzairu baretu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero calmado</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier calmé</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>killed steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="4">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aleazioko elementuetako batek gutxienez % 5etik gorako edukia duen aleazio-altzairua.</descrip>
    </descripGrp>
    <tig>
      <term>aleazio handiko altzairu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero de alta aleación</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier fortement allié</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>high alloy steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="5">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>mekanizazio errazeko altzairu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero de fácil mecanización</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier de décolletage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>free cutting steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="6">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Baretu gabeko edo aski baretu gabeko altzairua; oraindik oxido-proportzioren bat dauka, beraz, eta hoztean eta solidotzean karbono oxido pixka bat aska dezake, burbuilak sortuz, agian.</descrip>
    </descripGrp>
    <tig>
      <term>altzairu baretugabe</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero efervescente</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier effervescent</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>unkilled steel</term>
    </tig>
    <tig>
      <term>wild steel</term>
    </tig>
    <tig>
      <term>rimming steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="7">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>% 0,700 eta % 1,200 bitarteko karbono-edukia eta 75 kg/mm2-tik gorako erresistentzia duen altzairua. Malgukiak, erremintak, zerrak eta labanak egiteko erabiltzen da.</descrip>
    </descripGrp>
    <tig>
      <term>altzairu estragogor</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero extraduro</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier extra-dur</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>extra-hard steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="8">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kromoa eta % 0,1etik beherako karbono-proportzioa dituen altzairua; material magnetikoa da, eta korrosioaren kontrako erresistentzia handia du.</descrip>
    </descripGrp>
    <tig>
      <term>altzairu ferritiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero ferrítico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier ferritique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ferritic stainless steel</term>
    </tig>
    <tig>
      <term>ferritic steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="9">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Altzairu eutektoideak baino karbono-eduki handiagoa duen altzairua, hau da, % 0,85 baino karbono gehiago baina % 1,5 baino gutxiago duena.</descrip>
    </descripGrp>
    <tig>
      <term>altzairu hipereutektoide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero hipereutectoide</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier hypereutectoïde</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>hypereutectoid steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="10">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Altzairu eutektoideak baino karbono-eduki txikiagoa duen altzairua, hau da, % 0,85 baino gutxiago duena.</descrip>
    </descripGrp>
    <tig>
      <term>altzairu hipoeutektoide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero hipoeutectoide</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier hypoeutectoïde</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>hypoeutectoid steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="11">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giro-tenperaturan edo tenperatura nahiko apaletan korrosiorik ez duen altzairua. Kromo edo nikel ugari edukitzen du, eta, sarritan, beste zenbait elementu ere bai, hala nola molibdenoa eta titanioa. </descrip>
    </descripGrp>
    <tig>
      <term>altzairu herdoilgaitz</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero inoxidable</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier inoxydable</term>
    </tig>
    <tig>
      <term>acier inox</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>stainless steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="12">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>beroan ijeztutako altzairu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero laminado en caliente</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier laminé à chaud</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>hot-rolled steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="13">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tenplaketa garaian austenitaren eraldaketa-prozesua erabat bukatu gabe geratu den karbono-altzairua, edo bere austenita-fasea, gutxiago edo gehiago, martensita bihurtua duen altzairua.</descrip>
    </descripGrp>
    <tig>
      <term>altzairu martensitiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>martensita-altzairu</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero martensítico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier martensitique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>martensitic steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="14">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>altzairu normalizatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero normalizado</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier normalisé</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>normalized steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="15">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erreminta-altzairua, aleazio-elementuen eduki eta karbono-eduki handiak dituena eta 600 ºC arteko tenperaturak onartzen dituena.</descrip>
    </descripGrp>
    <tig>
      <term>altzairu laster</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acero rápido</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acier rapide</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>high-speed steel</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="16">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hotzeko deformazio baten ondorioz gogortasun, hauskortasun eta erresistentzia handiagoa duen metalaren ezaugarria.</descrip>
    </descripGrp>
    <tig>
      <term>garraztasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acritud</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>fragilisation</term>
    </tig>
    <tig>
      <term>fragilité à froid</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>embrittlement</term>
    </tig>
    <tig>
      <term>cold-shortness</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="17">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesu metalurgikoa, helburu hauek dituena: galdaketatik ateratzen den produktu gordin landugabeari kendu behar zaizkion ezpurutasunak kentzea edo, gutxienez, ezpurutasun horiek ahalik eta kalte gutxien egin dezatela lortzea.</descrip>
    </descripGrp>
    <tig>
      <term>finketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>afino</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>affinage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>refining</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="18">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Trakzio-indar aski handia aplikatzen zaienean metalek eta metal-aleazioek indarraren norabidean duten neurri-hazte nabaria.</descrip>
    </descripGrp>
    <tig>
      <term>luzapen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>alargamiento</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>allongement</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>elongation</term>
    </tig>
  </langSet>
</termEntry>
