  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Orri-formako metalak hotzean, deformazio plastikoz, eraldatzeko prozedura. Nahi den formarekin ebakitako xafla mehe bat matrize batean puntzoi mugikor baten bidez sarraraziz egiten da.</descrip>
