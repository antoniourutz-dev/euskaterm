    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>carbide</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="263">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi metalez edo gehiagoz osatutako konposatua, metal puruenak ez diren ezaugarri fisikoak eta kristal-egitura dituena.</descrip>
    </descripGrp>
    <tig>
      <term>konposatu intermetaliko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
