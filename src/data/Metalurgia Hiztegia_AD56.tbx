    </tig>
  </langSet>
</termEntry>
<termEntry id="33">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gamma burdinan disolbatutako karbono-soluzio solidoa; disolbatutako karbono-proportzioak % 1,7koa izan behar du 1.145 ºC-an.</descrip>
