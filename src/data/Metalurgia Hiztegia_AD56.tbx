  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mea edo metal-material bat oso tenperatura altuan urtzean datzan eragiketa; ezpurutasunak baztertuz metal galdatua bereiztea edo egoera likidoko metal sulfuroen nahastura bat lortzea da helburua.</descrip>
