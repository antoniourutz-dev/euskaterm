  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>nikel-kobre aleazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aleación de base níquel-cobre</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>alliage de cuivre et nickel</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>copper nickel alloy</term>
    </tig>
    <tig>
      <term>nickel-copper base alloy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="20">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Metal-nahastura edo aleazio mota: aleazio horren urtze-puntua txikiagoa da nahastura osatzen duten osagaietako bakoitzak berez duena edo osagai horietako beste batzuekin egindako nahasturak duena baino.</descrip>
    </descripGrp>
    <tig>
      <term>aleazio eutektiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aleación eutéctica</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>alliage eutectique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>eutectic alloy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="21">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Burdina eta karbonozko aleazioa, beste elementu bereziren bat gehituz egindakoa; adibidez, manganesoa, kromoa, molibdenoa, tungstenoa edo banadioa gehitutakoa.</descrip>
    </descripGrp>
    <tig>
      <term>ferroaleazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ferroaleación</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>ferroalliage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ferro-alloy</term>
    </tig>
  </langSet>
</termEntry>
