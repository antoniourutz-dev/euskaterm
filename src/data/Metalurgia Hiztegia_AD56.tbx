  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Altzairua lehenengo tenplatuz (disoluzio solido gainasea lortzeko) eta ondoren iraotuz (osagarri gogortzaileak prezipitatzeko) egiten den tratamendu termikoa.</descrip>
