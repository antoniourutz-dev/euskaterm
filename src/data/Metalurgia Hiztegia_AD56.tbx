    </tig>
  </langSet>
</termEntry>
<termEntry id="163">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nitrogenoarekin egindako zementazio-tratamendu termokimikoa. Piezak amoniako-korronte baten barruan 500-550 ºC-an berotuz egiten da.</descrip>
    </descripGrp>
