  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Urtzeko labean galdatutako altzairu likidoa labearen beheko aldean dagoen galda-isurbidetik ateratzea; ondoren, isurketa-zalira pasatzen da, eta adreilu erregogorrez egindako kanal batera husten.</descrip>
