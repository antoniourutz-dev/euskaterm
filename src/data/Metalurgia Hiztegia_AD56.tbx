    </tig>
  </langSet>
</termEntry>
<termEntry id="304">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Trinkotutako piezak matrizetik ateratzen denean jasaten duen deformazio elastikoa.</descrip>
    </descripGrp>
    <tig>
      <term>spring-back</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>spring-back</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
