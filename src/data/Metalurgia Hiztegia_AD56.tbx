    </tig>
  </langSet>
</termEntry>
<termEntry id="55">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Titanioaren antzeko metal gris argia; iturgintzan erabiltzen da korrosioaren kontra duen erresistentzia handiarengatik eta ezaugarri mekaniko onengatik.</descrip>
