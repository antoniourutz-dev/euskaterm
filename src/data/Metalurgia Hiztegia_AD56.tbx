<termEntry id="255">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Berotan ijeztutako produktu bukatua; sekzio trinko eliptikoa, biribila edo poligonala izaten du, gutxienez 5 mm-ko diametroa, eta hariletan bilduta egoten da. Beste bigarren eraldaketaren bat egiten zaio, normalean, erabili ahal izateko.</descrip>
    </descripGrp>
    <tig>
      <term>alanbre-burdina</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
