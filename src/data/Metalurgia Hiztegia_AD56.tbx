<termEntry id="299">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Galdaketako akatsa, aleazio solido (ez eutektiko) bateko hainbat punturen konposizio kimikoan heterogeneotasuna azaltzean datzana; bi fasetako oreka-eremuak eta tenperaturarekin aldatzen den konposizioa dira horren eragileak.</descrip>
    </descripGrp>
