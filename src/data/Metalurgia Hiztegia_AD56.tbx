<termEntry id="164">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Altzairuei ematen zaien tratamendu termikoa; tenperatura kritiko gorenaz goitik 55 ºC berotuz eta ondoren aire barean, giro-tenperaturan, hoztuz egiten da.</descrip>
    </descripGrp>
