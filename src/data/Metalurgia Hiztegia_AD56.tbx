    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>thermochemical treatment</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="311">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Galdaketa egiten den lantegien inguruetan sortzen den hautsa; autoaren gainean itsasten bada, erre egiten du.</descrip>
    </descripGrp>
    <tig>
      <term>burdin hauts</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
