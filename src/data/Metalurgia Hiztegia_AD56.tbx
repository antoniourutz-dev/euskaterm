    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>creep</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="115">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
