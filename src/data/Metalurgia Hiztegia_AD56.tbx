  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pieza presio txikian trinkotu ondoren, prentsaketa normala eta behin betiko sinterizazioa egin aurretik egiten den sinterizazio ez-osoa.</descrip>
