  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Altzairu arrunta edo aleatua, baina bereziki moldekatzeko erabiltzen dena, ijezteko, forjatzeko edo estanpatzeko erabiltzen denari kontrajarria.</descrip>
