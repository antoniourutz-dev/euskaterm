    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>intermetallic compound</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="264">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Trantsizio-metalek hidrogenoarekin, oxigenoarekin, karbonoarekin, boroarekin eta nitrogenoarekin osatzen dituzten konposatuetako bakoitza. Bost elementu horien atomoak diametro txikikoak direnez, metalaren sare espazialeko tarteetan edo hutsuneetan sartzen dira.</descrip>
    </descripGrp>
    <tig>
      <term>konposatu interstizial</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
