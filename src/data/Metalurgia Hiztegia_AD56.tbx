</termEntry>
<termEntry id="31">
  <descrip type='subjectField'>Materialak eta lehengaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Labe garaitik ateratzen den lehen galdaketako burdina. % 2,5etik % 5era bitarteko karbono-edukia izaten du, eta silizioa, manganesoa, sufrea eta fosforoa ere bai, gutxiago edo gehiago. Altzairugintzan eta burdingintzan erabiltzen den lehengaia da.</descrip>
    </descripGrp>
    <tig>
      <term>arrabio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
