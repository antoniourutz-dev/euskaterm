  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Galdatutako metal edo aleazio bati gasezko edo urezko zurrusta bat aplikatzen zaionean grabitatez barreiatu eta erortzen den hauts metalikoa.</descrip>
