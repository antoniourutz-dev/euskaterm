  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sinterizazio-labeetako puntu kritikoa, atmosferak ur-lurrun gehiago eduki ezin duenean lehenengo tanta likidoak azaltzen hasten diren unea.</descrip>
