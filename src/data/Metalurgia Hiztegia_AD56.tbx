<termEntry id="114">
  <descrip type='subjectField'>Ezaugarriak, alterazioak, kontzeptu teorikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Material batek, gutxi gorabehera bere urtze-puntuari dagokion tenperaturaren erdiraino berotu eta zama konstante bat ezartzen bazaio, denboraren arabera izaten duen deformazio-gehikuntza.</descrip>
    </descripGrp>
    <tig>
      <term>isurpen</term>
