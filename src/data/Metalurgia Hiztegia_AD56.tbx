    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>allotropie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>allotropy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="259">
  <descrip type='subjectField'>Eragiketak, prozedurak eta tratamenduak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Metalak lortzeko prozedura, xeheki zatitutako aluminioak metal-oxido askotan duen erredukzio-ahalmen handia baliatzen duena. Errailak soldatzeko ere erabiltzen da, adibidez.</descrip>
    </descripGrp>
    <tig>
      <term>aluminotermia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
