<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zerga-zorra ordaintzeko modua, ondasun materialekin edo diruzkoak ez diren ondasunekin ordaintzean datzana. Herri-administrazioak salbuespen-kasuetan onar dezake ordainketa-modu hau.</descrip>
    </descripGrp>
