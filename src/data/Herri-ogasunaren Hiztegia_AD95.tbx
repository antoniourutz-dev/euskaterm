      <term>obligado tributario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiltzean oinordekoari eskubide eta betebeharrak transmititzen dizkion pertsona.</descrip>
    </descripGrp>
    <tig>
      <term>kausatzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>causante</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zerga-egitate hau duen tributua: herri-lanak egitearen edo zerbitzu publikoak ezarri edo zabaltzearen ondorioz, zergapekoak onura bat lortzea edo haren ondasunen balioa handitzea.</descrip>
    </descripGrp>
