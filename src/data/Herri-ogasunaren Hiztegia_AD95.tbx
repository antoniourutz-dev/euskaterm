      <term>recargo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herrialde bateko zerga-sistemari buruzko araudian aldaketa nabarmena eragiten duen erreforma, zerga-sistema eraginkorragoa izatea helburu duena.</descrip>
    </descripGrp>
    <tig>
      <term>zerga-sistemaren erreforma</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
