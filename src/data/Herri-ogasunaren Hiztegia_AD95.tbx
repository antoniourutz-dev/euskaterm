<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herri-administrazio baten edo haren erakunde autonomoen titulartasunekoak diren zergen eta eduki ekonomikoen gaineko eskubidea, administrazio-ahala gauzatzearen ondoriozkoa.</descrip>
    </descripGrp>
