  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontua aldatzeko modalitatea, ekitaldian lortutako diru-sarrerekin gastuen egoera-orrian ordainketa-kredituak sortzeko erabiltzen dena; sarrera horiek herri-administrazioaren aurrekontuetako sarrera-egoeran aurreikusita ez badaude edo aurreikusitako zenbatekoa gainditzen badute soilik erabiltzen da.</descrip>
