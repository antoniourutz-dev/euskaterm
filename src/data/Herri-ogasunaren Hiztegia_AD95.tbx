  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Administrazio-organo batek denbora-tarte jakin batean izandako egintza, egitate edo antzeko izaerako eragiketa ekonomikoen fiskalizazioa, exhaustiboa ez dena.</descrip>
    </descripGrp>
    <tig>
