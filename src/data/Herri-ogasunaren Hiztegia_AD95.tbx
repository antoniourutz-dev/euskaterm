  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Errentaren aitorpena kalkulatzean kuota likidoaren atxikipenak kendu ondoren ateratzen den zenbatekoa. Positiboa ala negatiboa izan daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>aitorpenaren emaitza</term>
