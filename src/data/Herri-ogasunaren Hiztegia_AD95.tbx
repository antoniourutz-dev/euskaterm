  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona juridiko edo sozietate baten kudeaketa eta administrazioa egiten diren lekua, haren estatutuetan zehaztua egon behar duena.</descrip>
