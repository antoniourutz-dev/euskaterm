  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erakunde batek ekitaldi ekonomikoaren azken egunerako aurrez ikusten duen ondare- eta finantza-egoeraren berri ematen duen balantzea.</descrip>
