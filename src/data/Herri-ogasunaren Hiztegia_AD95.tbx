  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Administrazioaren aurrean kobratzeko eskubiderik ez duen pertsonari errakuntza material, aritmetiko edo egitatezkoa dela-eta egindako ordainketa.</descrip>
