<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Finantzen aurretiazko egoera-orrietan, dagokion erakundeak ekitaldiaren azken egunean izango duen ondare- eta diru-egoeraren aurreikuspena jasotzen duen balantzea.</descrip>
