  <langSet xml:lang='eu'>
    <tig>
      <term>ondasun-konfiskazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>confiscación de bienes</term>
    </tig>
  </langSet>
