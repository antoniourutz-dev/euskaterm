      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>presupuesto consolidado del sector público</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Izaera publikoa duen erakundea: prestazio-jarduerak egitea, zerbitzuak kudeatzea edo kontraprestazioa izan dezaketen interes publikoko ondasunak ekoiztea du helburu.</descrip>
    </descripGrp>
