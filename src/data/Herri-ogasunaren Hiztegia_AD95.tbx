    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>presupuesto de explotación</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>kapital-aurrekontu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>presupuesto de capital</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontuan kasuan-kasuan likidatu eta erantzun beharreko eskubide eta betebehar guztiak inolako salbuespenik gabe jasotzera behartzen duen printzipioa. Aurrez ikusi gabeko eragiketak aurrekontua gauzatzeko prozesuaren barruan erregistratzen dira, kasuan-kasuan aplikatu beharreko arauekin bat.</descrip>
    </descripGrp>
    <tig>
      <term>unibertsaltasun-printzipio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>principio de universalidad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontuetan sarrera-gastuen sailkapen ekonomikoa eratzen duten multzoetako bat; kapitulua, kontzeptua eta azpikontzeptua dira besteak.</descrip>
    </descripGrp>
    <tig>
      <term>artikulu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>artículo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontuetan sarrera-gastuen sailkapen ekonomikoa eratzen duten multzoetako bat; kapitulua, artikulua eta azpikontzeptua dira besteak.</descrip>
    </descripGrp>
    <tig>
      <term>kontzeptu</term>
