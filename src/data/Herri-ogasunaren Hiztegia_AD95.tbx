  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Autonomia-erkidegoaren eskumenekoak ez diren gastu-egitasmoak betearazteko beste herri-erakundeetatik jasotako diru-sarrera.</descrip>
