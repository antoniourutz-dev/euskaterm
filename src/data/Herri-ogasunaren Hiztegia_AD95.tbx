</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontu orokorretan ordainketa-kredituak sailkatzeko modua. Programa bakoitzaren helburuei, beharrezko giza eta finantza-baliabideei, jardunei eta horien arduradunei buruzko argibideak zehaztu behar dira sailkapen honetan.</descrip>
    </descripGrp>
    <tig>
      <term>programen araberako sailkapen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>aurrekontuaren programaz programako sailkapen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>clasificación por programas</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontu orokorretan gastu publikoa sailkatzeko modua. Ezarritako antolakuntza-zehaztasunarekin aurkezten ditu esleitutako ordainketa-kredituak eta konpromiso-kredituak.</descrip>
    </descripGrp>
    <tig>
      <term>sailkapen organiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>clasificación orgánica</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontu orokorretan gastu publikoa sailkatzeko modua. Zehazten den antolakuntza-unitate bakoitzak garatu beharreko jarduera-motaren arabera biltzen ditu ordainketa-kredituak eta konpromiso-kredituak.</descrip>
    </descripGrp>
    <tig>
      <term>sailkapen funtzional</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>clasificación funcional</term>
    </tig>
  </langSet>
</termEntry>
