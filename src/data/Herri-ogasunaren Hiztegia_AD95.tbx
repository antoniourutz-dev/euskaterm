<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herri-erakundeek zordunaren ondasun eta eskubideekiko berme-eskubide errealak eratzea. Zordunaren egoera ekonomiko eta finantzario larriagatik herri-administrazioaren eskubideak galtzeko, urritzeko, gutxitzeko edo ez gauzatzeko arriskuan daudela pentsarazten duten pisuzko zantzuak daudenean, eskubide horien edukia eta gauzatzea berma daitezen egiten da.</descrip>
