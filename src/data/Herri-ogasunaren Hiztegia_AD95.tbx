<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Agintari edo funtzionario publiko batek egiten duen delitua: irabaziak lortzeko asmoz, bere funtzioen zioz dituen ondasun edo efektu publikoak ostea edo asmo bera duen beste norbaitek ondasun horiek ostu ditzan onartzea. Zigor Kodean jasotako delitua da.</descrip>
    </descripGrp>
    <tig>
      <term>ondasun publikoak bidegabe eralgitze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>ondasun publikoen bidegabeko eralgitze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
