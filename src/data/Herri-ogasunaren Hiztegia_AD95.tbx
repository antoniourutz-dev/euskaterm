  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beste erakunde batzuekin hala adosteagatik (edo beren izaera edo berariazko baldintzengatik) diru-sarrera jakin eta zehatzekin osorik edo zati batean finantzatzen den gastua. Nahitaezkoa da diru-sarrera horiek zuzenean eta objektiboki gastuari lotuta egotea.</descrip>
