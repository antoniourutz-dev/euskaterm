    </tig>
    <tig>
      <term>malversación de fondos públicos</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zerga-bilketaren fasea, zerga-prestazioa eta zerga-bilketaren gastuak kobratzea helburu duena. Zorra ezarritako epean ordaintzen ez denean gertatzen da, zergapekoak premiamendu-probidentziaren jakinarazpena jaso eta gero.</descrip>
    </descripGrp>
