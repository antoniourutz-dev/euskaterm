<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zergaldi batean sortutako diru-sarrera zergapegarria.</descrip>
    </descripGrp>
