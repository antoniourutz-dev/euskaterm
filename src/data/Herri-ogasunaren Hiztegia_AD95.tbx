    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>declaración de alienabilidad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontuetako sarreren egoera-orrietako zenbatekoek duten balio-mota lehenetsia.</descrip>
    </descripGrp>
    <tig>
      <term>zenbatekoen balio zenbatetsi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
