<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontzientziak hala agindurik, zerga bat edo zerga-zati bat ordaintzeari uko egitea. Zerga biltzen duen erakundearekin edo haren politikaren batekin ados ez egotea izan ohi da arrazoia.</descrip>
    </descripGrp>
    <tig>
      <term>zerga-eragozpen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>objeción fiscal</term>
    </tig>
  </langSet>
