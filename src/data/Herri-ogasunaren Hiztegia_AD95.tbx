<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zergarik ez ordaintzeko eskubidea edo salbuespena; besteak beste, salgaiak sartu eta ateratzeagatik edo zerbitzu publikoa ustiatzeagatik eskaintzen zaie pertsonei.</descrip>
