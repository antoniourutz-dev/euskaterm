  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Administrazio publikoari edo haren erakunde autonomoei aurrekontuetan dagozkien kreditu-zenbatekoak aldatzeko eragiketa; aurrekontuetako gastuen egoera-orrietan egiten da, eta ez dio aldaketarik eragiten aurrekontuen zenbateko osoari.</descrip>
    </descripGrp>
