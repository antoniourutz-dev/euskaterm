<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Legedia urratuz zergak ez ordaintzea. Legearen aurkako egintza denez, ondorio juridikoak ditu.</descrip>
