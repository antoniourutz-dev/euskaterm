<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beste unitate instituzional baten kapital finkoaren eraketa gordina finantzatzeko herri-administrazioak ematen duen diru-laguntza, hartzaileak itzuli behar ez duena.</descrip>
