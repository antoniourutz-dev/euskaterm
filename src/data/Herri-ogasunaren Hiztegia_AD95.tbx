<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sarrerez mintzatuz, zor batengatik kontabilizatu den zenbatekoa; gastuez mintzatuz, gastu konprometitu batengatik kontabilizatutakoa.</descrip>
    </descripGrp>
