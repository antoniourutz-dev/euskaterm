<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Legediaren hutsuneak baliatuz zergak ez ordaintzea. Ez da, beraz, legearen aurkako egintza, eta ez du ondorio juridikorik.</descrip>
    </descripGrp>
    <tig>
