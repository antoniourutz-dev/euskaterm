<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontu orokorretan gastu publikoa sailkatzeko modua. Sarreren aurrekontuan, eragiketa arruntak, kapital-eragiketak eta finantza-eragiketak bereizten ditu sailkapen ekonomikoak, eta gastuen aurrekontuan, berriz, eragiketa arruntetarako kredituak, kapital-eragiketetarako kredituak, finantza-eragiketetarako kredituak eta ordainketa-kreditu globalaren funtsa.</descrip>
    </descripGrp>
    <tig>
      <term>sailkapen ekonomiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>clasificación económica</term>
    </tig>
  </langSet>
</termEntry>
