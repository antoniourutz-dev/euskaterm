  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>valor definitivo de los importes</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ogasun-eskumena duen herri-administrazioaren hartzeko, ondasun, errenta eta zergen multzoa, administrazioaren beharrak asetzeko erabiltzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>herri-ogasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
