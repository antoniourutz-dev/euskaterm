  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zerga-egitatea gauzatzen duen subjektu pasiboa.</descrip>
    </descripGrp>
    <tig>
      <term>zergadun</term>
      <termNote type='normativeAuthorization'>4</termNote>
