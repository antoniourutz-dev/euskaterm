<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tributu baten oinarriari edo kuotari aplikatzen zaion ehuneko jakin bateko igoera.</descrip>
    </descripGrp>
    <tig>
      <term>errekargu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
