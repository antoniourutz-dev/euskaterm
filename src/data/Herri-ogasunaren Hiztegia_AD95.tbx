<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurrekontuetako sarreren egoera-orrietako zenbatekoek izan dezaketen balio-mota; egoera-orrietan esanbidez behin betiko gisa sailkatuta egon behar dute balio horiek, edo legeak halakotzat jo behar ditu.</descrip>
    </descripGrp>
    <tig>
      <term>zenbatekoen behin betiko balio</term>
