  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zergapekoaren ondarearen balioan edozein aldaketa gertatzeagatik agerian jartzen den irabazia; zerga-arauek etekintzat jotzen dutena ez da ondare-irabazitzat hartzen.</descrip>
