<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Izaera publikoa duen erakunde instituzionala, herri-administrazioaren eskumenekoak diren jarduerak deszentralizazio-araubidean burutzeko helburua duena. Zuzenbide pribatuak arautzen du.</descrip>
