<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kobratu baino lehen kontabilizatzen den zenbatekoa, zergadunak ordain dezan hari jakinarazi zaion zor likidatu bati dagokiona.</descrip>
    </descripGrp>
    <tig>
      <term>aurretiazko zorpetu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
