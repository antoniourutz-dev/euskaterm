<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Helburu publiko bat lortzeko edo interes sozial edo erabilgarria den jarduera bat bultzatzeko pertsonei, erakunde publikoei edo erakunde pribatuei herri-administrazioaren kargura emandako edozein laguntza.</descrip>
    </descripGrp>
    <tig>
      <term>laguntza publiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>diru-laguntza publiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ayuda pública</term>
    </tig>
    <tig>
      <term>subvención pública</term>
    </tig>
