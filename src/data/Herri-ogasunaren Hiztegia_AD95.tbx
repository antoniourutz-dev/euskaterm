<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kapitalean sektore publiko foralaren % 50etik gorako partaidetza duen merkataritzako sozietatea. Partaidetza hori zehazteko, sektore publiko forala osatzen duten gainerako erakundeek sozietatearen kapitalean dauzkaten zuzeneko edo zeharkako partaidetzak hartzen dira kontuan.</descrip>
    </descripGrp>
    <tig>
      <term>merkataritzako foru-sozietate</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sociedad mercantil foral</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Ondarea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ondasun higiezinak besterendu ahal izateko beharrezkoa den deklarazioa; Euskadiko Ondareari buruzko Legeak arautzen du.</descrip>
    </descripGrp>
    <tig>
      <term>besterengarritasun-deklarazio</term>
