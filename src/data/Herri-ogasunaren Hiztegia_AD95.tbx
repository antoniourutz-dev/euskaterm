<termEntry id="-1">
  <descrip type='subjectField'>Aurrekontuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Finantzen aurretiazko egoera-orrietako taula, eskuratzea espero diren baliabideak, haien jatorria eta aktibo ibilgetuan edo zirkulatzailean izango duten erabilera zehazten dituena.</descrip>
    </descripGrp>
    <tig>
      <term>aurreikusitako finantzaketa-taula</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
