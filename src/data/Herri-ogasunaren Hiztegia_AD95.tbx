  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontrabando-delituagatik legeak ezartzen duen zigorra; ez da ezartzen salgaiak zilegi den merkataritzakoak badira eta hirugarren batek fede onez erosi baditu.</descrip>
