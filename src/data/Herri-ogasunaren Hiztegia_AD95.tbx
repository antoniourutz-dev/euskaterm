  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerga-sistema</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langileari diruzkoak ez diren ondasunak, eskubideak edo zerbitzuak emanez ordaintzen zaion lansaria.</descrip>
