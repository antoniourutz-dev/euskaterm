  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ekitaldi jakin bateko aurrekontuetako helburuak betetzeko beharko ez den dirua, herri-administrazioak beste eragiketa arruntetarako edo kapital-eragiketetarako erabil dezakeena.</descrip>
