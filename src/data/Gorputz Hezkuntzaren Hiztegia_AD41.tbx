<termEntry id="-1">
  <descrip type='subjectField'>Gimnastika</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gimnastika artistikoan, ariketak egiteko erabiltzen diren tresnetako bakoitza. Emakumeetan paralelo asimetrikoak, oreka-barra, jauzi-zaldia eta zorua bereizi ohi dira, eta gizonezkoetan, berriz, jauzi-zaldia, barra finkoa, zaldi arkuduna, zorua, eraztunak eta paraleloak.</descrip>
    </descripGrp>
    <tig>
      <term>gimnastikako aparatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
