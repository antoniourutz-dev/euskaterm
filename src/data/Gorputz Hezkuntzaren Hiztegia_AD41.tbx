  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizabanakoak, gainerako animalia-espezie gehienek bezala, mugimendu autogenoak sortzeko duen gaitasuna.</descrip>
    </descripGrp>
