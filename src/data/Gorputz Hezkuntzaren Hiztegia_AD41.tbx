<termEntry id="-1">
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hogei bat minutuz gutxienez, modu erritmiko, jarraitu eta atseginean egindako ariketa-konbinazioen seriea. Aerobic hitzak, berez, "oxigenoarekin" esan nahi du; edozein jarduera aerobikok gizabanakoari dakarkion ahaleginak oxigenoa erabiltzea eskatzen du energia lortzeko, eta horrek gorputzaren arnas eta bihotz-gaitasuna hobetzeko modua ematen du.</descrip>
    </descripGrp>
    <tig>
      <term>aerobic</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aerobic</term>
    </tig>
  </langSet>
</termEntry>
