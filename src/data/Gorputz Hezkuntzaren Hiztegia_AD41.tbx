  <descrip type='subjectField'>Gimnastika</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gimnastika erritmikoan, eskuz erabiltzeko aparatua, 80-90 cm-ko diametroa eta gutxienez 300 g-ko pisua duen egurrezko edo plastikozko eraztun batez osatua.</descrip>
