<termEntry id="-1">
  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputzak espazioan duen jarrera eta norabidea abiadura egokiarekin aldatzeko ahalmena. Horretarako, hainbat gaitasun (koordinazioa, abiadura, indarra eta malgutasuna) modu harmoniatsuan konbinatzen dira.</descrip>
    </descripGrp>
    <tig>
      <term>arintasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>agilidad</term>
    </tig>
  </langSet>
</termEntry>
