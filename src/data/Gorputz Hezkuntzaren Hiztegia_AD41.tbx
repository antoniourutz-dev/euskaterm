<termEntry id="-1">
  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hezur-giltzaduren eta bizkarrezurraren prestazio eta ezaugarrietan oinarrituz mugimenduak sortzeko gaitasuna. Giltzaduren forma eta egiturak eta muskulu, tendoi eta lokailuen luzera eta elastikotasunak osatzen dute mugikortasunaren oinarria.</descrip>
    </descripGrp>
