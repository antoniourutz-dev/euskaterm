<termEntry id="-1">
  <descrip type='subjectField'>Gimnastika</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gimnastikako, balleteko eta dantzako elementuak konbinatzen dituen gimnastikako diziplina; ariketak musikaz lagunduta egiten dira, bakarka nahiz taldeka, eta soka, uztaia, baloia, mazoak edo xingola erabiltzen dira. Jatorrian emakumeen diziplina izan den arren, azken urteotan gizonezkoak ere aritzen dira gimnastika erritmikoan.</descrip>
    </descripGrp>
    <tig>
      <term>gimnastika erritmiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>gimnasia rítmica</term>
    </tig>
  </langSet>
</termEntry>
