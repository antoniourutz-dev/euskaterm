  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizonezkoen gimnastika artistikoan erabiltzen den aparatua: portiko moduko bat da, bertatik bi kable daude esekita, eta haietako bakoitzak 18 cm-ko diametroa eta 28 mm-ko lodiera dituen uztai bati eusten dio.</descrip>
    </descripGrp>
    <tig>
      <term>eraztunak</term>
