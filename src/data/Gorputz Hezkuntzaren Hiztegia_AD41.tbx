  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputzaren zeharkako ardatza mugimendu-ardatz gisa hartuz, gerritik gorako zatia aurrerantz eramatean datzan mugimendua.</descrip>
    </descripGrp>
    <tig>
      <term>antebertsio</term>
