<termEntry id="-1">
  <descrip type='subjectField'>Gimnastika</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Larruzko, gomazko edo plastikozko objektu esferikoa, 1 kg-tik 5 kg-ra bitarteko pisua izan ohi duena. Indarra lantzeko erabiltzen da, ariketa globalen nahiz ariketa lokalizatuen bidez batez ere goiko gorputz-adarretako muskulu-taldeak, baina baita enborrekoak eta zangoetakoak ere, lantzeko.</descrip>
    </descripGrp>
    <tig>
      <term>baloi medizinal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>balón medicinal</term>
    </tig>
  </langSet>
</termEntry>
