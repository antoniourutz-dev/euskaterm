  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gimnastika erritmikoan, egurrez edo material sintetikoz egindako birla-itxurako eskuzko aparatua, luzeran 40-50 cm-koa eta pisuan gutxienez 150 g-koa.</descrip>
