      <term>Administrazio Orokorreko Azpieskala Laguntzailea</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntzarik ez duten toki-administrazioko funtzionarioen azpieskala</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Subescala Auxiliar de Administración General</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535379">
