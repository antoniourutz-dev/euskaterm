<termEntry id="535359">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herrigunetik bereizita egon arren toki-erakunde ez diren auzoetan edo zerbitzu-emateak hala eskatzen duen hirietan alkateak bertako auzotarren artean izendatzen duen ordezkaria. Agintari izaera du udal-eginkizunak betetzerakoan, alkatearen ordezkari den aldetik.</descrip>
    </descripGrp>
    <tig>
      <term>alkatearen ordezkari pertsonal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>representante personal del alcalde</term>
    </tig>
  </langSet>
</termEntry>
