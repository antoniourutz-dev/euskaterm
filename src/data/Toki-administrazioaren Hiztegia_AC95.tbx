  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Araban, kontzejuko edo udaleko erroldan inskribatuta ez badago ere, kontzejuko etxe batean bizi den pertsona.</descrip>
    </descripGrp>
