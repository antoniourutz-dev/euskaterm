<termEntry id="535095">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alkatearekin batera udalbatza osatzen duten pertsonetako bakoitza. Auzotarrek bozketa orokor, berdin, aske, zuzeneko eta isilpeko bidez hautatzen dituzte, eta zinegotzi horien artetik hautatzen da alkatea.</descrip>
    </descripGrp>
    <tig>
