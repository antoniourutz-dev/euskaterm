<termEntry id="535057">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Udalerria kudeatzen eta gobernatzen duen organo nagusia; udala osatzen duten nahitaezko organoak dira: alkatea, alkateordea, osoko bilkura eta, batzuetan, tokiko gobernu-batzarra. Udalari dagokio udalerria gobernatzea eta administratzea, legez kontzeju irekien araubidepean diharduten udalerrietan izan ezik.</descrip>
    </descripGrp>
    <tig>
      <term>udal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ayuntamiento</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535058">
  <descrip type='subjectField'>Biztanleria eta lurralde-mugaketa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>bandera</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bandera</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535059">
  <descrip type='subjectField'>Obrak eta zerbitzuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Agintariek leku publikoetan jartzen duten oharra, herritarrei erabakien edo abisuen berri emateko.</descrip>
    </descripGrp>
    <tig>
      <term>bando</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bando</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535060">
  <descrip type='subjectField'>Biztanleria eta lurralde-mugaketa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>auzo</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Udalerria baino lurralde-eremu txikiagoko erakundeek hartzen duten izenetako bat.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>barrio</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535061">
  <descrip type='subjectField'>Ondasunak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Toki-erakundeen jabetzako ondasun bereziak; haien aprobetxamendua auzotar guztien esku dago. Udalerriek eta udalerria baino lurralde-eremu txikiagoko erakundeek bakarrik izan ditzakete horrelako ondasunak.</descrip>
    </descripGrp>
    <tig>
      <term>herri-ondasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>auzo-ondasun</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bienes comunales</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535062">
  <descrip type='subjectField'>Ondasunak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>toki-erakundearen ondasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bienes de la entidad local</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535063">
  <descrip type='subjectField'>Ondasunak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zerbitzu publikoak eskaintzeko xedea duten ondasunak; adibidez, udaletxeak, ospitaleak, azokak, museoak, eskolak, hilerriak, kirol-instalazioak edo hiltegiak.</descrip>
    </descripGrp>
    <tig>
      <term>zerbitzu publikoko ondasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bienes de servicio público</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535064">
  <descrip type='subjectField'>Ondasunak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabilera publikorako diren ondasunak; adibidez, bideak, plazak, kaleak, parkeak, iturriak eta zubiak.</descrip>
    </descripGrp>
    <tig>
      <term>erabilera publikoko ondasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bienes de uso público</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535065">
  <descrip type='subjectField'>Ondasunak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabilera publikoko eta zerbitzu publikoko ondasunak.</descrip>
    </descripGrp>
    <tig>
      <term>jabari publikoko ondasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>herri-jabariko ondasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>bienes demaniales</term>
    </tig>
    <tig>
      <term>bienes de dominio público</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535066">
  <descrip type='subjectField'>Ondasunak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Toki-erakundeen jabetzakoak izanik, erabilera edo zerbitzu publikokoak ez diren ondasunak; diru-iturri izan daitezke erakundearentzat.</descrip>
    </descripGrp>
    <tig>
      <term>ondare-ondasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
