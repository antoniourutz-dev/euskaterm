<termEntry id="535175">
  <descrip type='subjectField'>Toki-erakundeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Interes erkideak dauzkaten hainbat udalerri elkartuz osatutako toki-erakundea. Interes horiek garatzeko beharrezkoak diren kudeaketa propioak bideratzea eta zerbitzu jakin batzuk eskaintzea dira erakunde horren xedeak.</descrip>
    </descripGrp>
    <tig>
      <term>hainbat udalerri elkartzen dituen erakunde</term>
