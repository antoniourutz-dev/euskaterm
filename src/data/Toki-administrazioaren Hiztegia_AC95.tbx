<termEntry id="535050">
  <descrip type='subjectField'>Toki-erakundeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiri-aglomerazio handiko udalerriek osatutako toki-erakundea; horietako herriguneen artean dauden ekonomia eta gizarteko loturek zenbait zerbitzu eta obren plangintza batera egitea eta koordinatzea eskatzen dutenean eratzen da.</descrip>
    </descripGrp>
    <tig>
      <term>metropolialde</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>área metropolitana</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535051">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontzeju irekiko araubidean, udalerriko edo udalerria baino lurralde-eremu txikiagoko erakundeko hautesle-errolda osatzen duten guztien bilkura.</descrip>
    </descripGrp>
    <tig>
      <term>auzo-batzar</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>asamblea vecinal</term>
    </tig>
  </langSet>
</termEntry>
