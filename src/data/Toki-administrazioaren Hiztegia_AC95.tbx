<termEntry id="535418">
  <descrip type='subjectField'>Jarduna eta araubide juridikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irizpen bat aldatzeko planteamendua, informazio-batzordeko kide batek egina. Irizpenarekin batera joan behar du informazio-batzordeak hura onartzen duen egunaren biharamunetik aurrera.</descrip>
    </descripGrp>
    <tig>
      <term>boto partikular</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
