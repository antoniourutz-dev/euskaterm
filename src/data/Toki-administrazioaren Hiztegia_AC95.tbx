  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Araban, tributuetatik eratorritako lurralde historikoaren finantza-baliabideak toki-erakundeen artean behar bezala banatzeko erabiltzen den funtsa.</descrip>
    </descripGrp>
    <tig>
      <term>Toki Erakundeak Finantzatzeko Foru Funts</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Fondo Foral de Financiación de las Entidades Locales</term>
    </tig>
    <tig>
      <term>FOFEL</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535187">
  <descrip type='subjectField'>Toki-ogasunak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gipuzkoan, tributuetatik eratorritako lurralde historikoaren finantza-baliabideak udalerrien artean behar bezala banatzeko erabiltzen den funtsa.</descrip>
    </descripGrp>
    <tig>
