<termEntry id="535161">
  <descrip type='subjectField'>Toki-erakundeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nafarroan, 5.000 biztanle baino gutxiagoko udalerriz osatutako toki-erakundea. Administrazio-barrutia eratzen duten udalerriek hainbat eskumen eskuordetzan ematen dizkiote hari, jarduera edo zerbitzu publiko jakin batzuk eskaintzeko.</descrip>
    </descripGrp>
    <tig>
      <term>administrazio-barruti</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
