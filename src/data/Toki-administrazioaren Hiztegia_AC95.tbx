  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontzeju gisa bereizitako herrigunerik ez duen udalerria.</descrip>
    </descripGrp>
    <tig>
      <term>udalerri bakun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>municipio simple</term>
    </tig>
  </langSet>
</termEntry>
