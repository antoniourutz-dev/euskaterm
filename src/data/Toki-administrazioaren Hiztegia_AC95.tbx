  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Goi-mailako eginkizunak betetzeko laguntza ematen duten funtzionarioen eskala.</descrip>
    </descripGrp>
    <tig>
      <term>Administrazio Orokorreko Kudeaketa Azpieskala</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntzarik ez duten toki-administrazioko funtzionarioen azpieskala</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Subescala de Gestión de Administración General</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535380">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Finantza- eta ekonomia-kudeaketa eta aurrekontuen kudeaketa kontrolatzeko eta barrutik ikuskatzeko lanaz, eta kontabilitateaz, diruzaintzaz eta diru-bilketaz arduratzen diren funtzionarioen azpieskala.</descrip>
    </descripGrp>
    <tig>
      <term>Kontu-hartzailetza Diruzaintza Azpieskala</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntza duten funtzionarioen eskalakoa.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Subescala de Intervención-Tesorería</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535381">
