  </langSet>
</termEntry>
<termEntry id="535177">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Administrazio-jardunari dagozkion eginkizunak betetzen dituzten funtzionarioen eskala.</descrip>
    </descripGrp>
    <tig>
      <term>Administrazio Orokorreko Eskala</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntzarik ez duten toki-administrazioko funtzionarioen eskala.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
