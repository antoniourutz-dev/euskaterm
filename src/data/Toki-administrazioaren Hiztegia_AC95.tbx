    </tig>
  </langSet>
</termEntry>
<termEntry id="535344">
  <descrip type='subjectField'>Biztanleria eta lurralde-mugaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Espainiako lurraldeko toki-erakunde guztiak inskribatzen diren erregistroa; izaera publikoa du eta Toki Administrazioaren Zuzendariordetza Nagusiaren mende dago, Toki Administrazioaren Zuzendaritza Nagusian.</descrip>
    </descripGrp>
