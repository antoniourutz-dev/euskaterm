    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>entidad que agrupa a varios municipios</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535176">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ikasketa batzuen nahiz lanbide edo ofizio baten berariazko xede diren eginkizunak betetzen dituzten funtzionarioen eskala.</descrip>
    </descripGrp>
    <tig>
      <term>Administrazio Bereziko Eskala</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntzarik ez duten toki-administrazioko funtzionarioen eskala.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Escala de Administración Especial</term>
