  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Udalerri bateko edo gehiagotako lurralde-zati bat bereiztea, beste udalerri bati gehitzeko edo udalerri berria sortzeko. Udal-mugartea aldatzeko moduetako bat da.</descrip>
