<termEntry id="535178">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Toki-korporazioetan funtzio publiko hauen administrazio-erantzukizuna erreserbatuta duten funtzionarioen eskala: a) idazkaritza-lana, fede publikoa eta aginduzko lege-aholkularitza ematea, b) finantza- eta ekonomia-kudeaketa eta aurrekontuen kudeaketa kontrolatzeko eta barrutik ikuskatzeko lana, eta kontabilitatea, diruzaintza eta diru-bilketa.</descrip>
    </descripGrp>
    <tig>
      <term>Estaturako Gaikuntza duen Eskala</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Escala de Habilitación de Carácter Nacional</term>
    </tig>
  </langSet>
</termEntry>
