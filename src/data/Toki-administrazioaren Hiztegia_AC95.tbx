  <descrip type='subjectField'>Biztanleria eta lurralde-mugaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Araban, kontzeju bateko auzotarrak biltzen dituen errolda.</descrip>
