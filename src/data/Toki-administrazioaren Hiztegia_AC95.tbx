<termEntry id="535079">
  <descrip type='subjectField'>Toki-erakundeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ezaugarri edo interes erkideak dituzten udalerriak elkartzeko, autonomia-erkidegoak sortutako toki-erakundea, errealitate fisiko, ekonomiko eta historiko bat partekatzen duena. Ezaugarri edo interes horien berariazko kudeaketa eta zerbitzu-ematea udalerriaz gaindiko mailan egin behar direnean eratzen da.</descrip>
    </descripGrp>
    <tig>
      <term>eskualde</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comarca</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535080">
  <descrip type='subjectField'>Herri-administrazioen arteko lankidetzarako antolakundeak (toki-administrazioko gaietan)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nafarroan, udalerri-mugarteak aldatzeari edo udalerrien elkartzeak sortzeari buruzko ikerketak, kontsultak, proposamenak eta txostenak egiteko ardura duen organoa.</descrip>
    </descripGrp>
    <tig>
      <term>Lurraldea Mugatzeko Batzorde</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Comisión de Delimitación Territorial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535081">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>osoko bilkurako batzorde</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Biztanle-kopuru handiko udalerrietan.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comisión del pleno</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535082">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Udaletan, kontuak aztertzeko ardura duen batzordea, kontu horiek osoko bilkurari onartzeko aurkeztu baino lehen.</descrip>
    </descripGrp>
    <tig>
      <term>kontuen batzorde berezi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comisión especial de cuentas</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535083">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Udal-administrazioaren aurrean auzotarren eskubideen alde egiten duen batzordea; zerbitzuen inguruko kexa eta iradokizunen berri ematen dio udalari. Biztanle-kopuru handiko udalerrietan izan ohi da.</descrip>
    </descripGrp>
    <tig>
      <term>iradokizunen eta erreklamazioen batzorde berezi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comisión especial de sugerencias y reclamaciones</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535084">
  <descrip type='subjectField'>Herri-administrazioen arteko lankidetzarako antolakundeak (toki-administrazioko gaietan)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nafarroan, Foru Erkidegoko administrazioaren eta toki-administrazioaren arteko lankidetza bideratzeko organo iraunkorra.</descrip>
    </descripGrp>
    <tig>
      <term>Toki Araubidearen Foru Batzorde</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Comisión Foral de Régimen Local</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535085">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabakitzeko eskumenik ez duen organoa, osoko bilkurak erabaki beharreko gaiak aztertu, horien gainean txostena egin zein horietaz aholkua emateko, eta alkatearen, tokiko gobernu-batzarraren eta zinegotzi eskuordedunen kudeaketaren jarraipena egiteko ardura duena.</descrip>
    </descripGrp>
    <tig>
      <term>informazio-batzorde</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comisión informativa</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535086">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gai jakin bat aztertzeko, gai horren ezaugarri bereziak direla-eta osoko bilkurak eratzen duen informazio-batzordea. Batzordea desegin egiten da irizpena emateaz bat edo txostena egiteaz bat, batzordea sortzeko osoko bilkuraren erabakian bestelakorik xedatu ezean.</descrip>
    </descripGrp>
    <tig>
      <term>informazio-batzorde berezi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comisión informativa especial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535087">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Izaera orokorreko informazio-batzordea, osoko bilkurak erabaki beharreko gaien banaketaren arabera eratutakoa. Osoko bilkurak erabaki behar ditu, alkateak edo lehendakariak proposatuta, informazio-batzorde iraunkorren hasierako kopurua eta izenak eta korporazioaren agintaldian izan ditzaketen aldaketak; informazio-batzorde hauen kopuruak eta izenek bat etorri behar dute, ahal dela, korporazioko zerbitzuek hartzen dituzten arlo nagusiekin.</descrip>
    </descripGrp>
    <tig>
      <term>informazio-batzorde iraunkor</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comisión informativa permanente</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535088">
  <descrip type='subjectField'>Herri-administrazioen arteko lankidetzarako antolakundeak (toki-administrazioko gaietan)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Estatuko Administrazio Orokorraren eta toki-administrazioaren arteko lankidetza bideratzeko organo iraunkorra.</descrip>
