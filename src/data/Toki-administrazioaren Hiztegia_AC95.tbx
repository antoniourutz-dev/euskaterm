<termEntry id="535163">
  <descrip type='subjectField'>Ondasunak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hondatuta, balioa galduta edo egoera txarrean daudelako udal-zerbitzuetarako edo, ondasunen izaera eta xedea kontuan izanik, ohikoa duten erabilerarako gauza ez diren ondasunak, inbentarioan sartuta jarraitzen duten arren.</descrip>
    </descripGrp>
    <tig>
      <term>erabili ezineko efektu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
