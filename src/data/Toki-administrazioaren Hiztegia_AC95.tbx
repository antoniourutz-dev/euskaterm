<termEntry id="535247">
  <descrip type='subjectField'>Jarduna eta araubide juridikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Osoko bilkurari zuzenean aurkezten zaion planteamendua; ahoz edo idatziz egiten da. Gaiaren presa dela-eta, informazio-batzordeak aztertu gabekoa eta gai-zerrendan sartu gabekoa da. Mozioa aurkezten duen taldeko bozeramaileari dagokio presakoa zergatik den arrazoitzea, eta osoko bilkurari, berriz, mozioa eztabaidatzea bidezkoa den erabakitzea.</descrip>
    </descripGrp>
    <tig>
      <term>mozio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>moción</term>
    </tig>
  </langSet>
</termEntry>
