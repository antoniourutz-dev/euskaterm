      <term>municipalización de servicios</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535253">
  <descrip type='subjectField'>Toki-erakundeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Estatuaren lurralde-antolaketaren lurralde mailako erakunde oinarrizkoa. Herritarrek herri-arazoetan esku hartzeko hurbilen duten bidea izanik, nortasun juridikoa du, eta bere helburuak betetzeko gaitasun osoa. Lurraldea, biztanleria eta antolaketa dira udalerriaren osagaiak, eta udala da haren gobernu-organo nagusia.</descrip>
    </descripGrp>
    <tig>
      <term>udalerri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>municipio</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535254">
  <descrip type='subjectField'>Toki-erakundeak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontzeju gisa bereizitako herrigune bat edo gehiago dituen udalerria.</descrip>
    </descripGrp>
    <tig>
      <term>udalerri konposatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>municipio compuesto</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535255">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Toki Araubidearen oinarriak arautzen dituen 7/1985 Legearen X. tituluan zehaztutako antolakuntza araubide berezia aplikatzen zaion udalerria. Sail honetan sartzen dira 250.000 biztanle baino gehiagoko udalerriak eta probintzia-hiriburu diren 175.000 biztanle baino gehiagokoak; baita ere, dagokion legebiltzarrak onartuz gero, probintzia- edo autonomia-hiriburu direnak, autonomia-erakundeen egoitza direnak, eta, 75.000 biztanle baino gehiago eduki eta izaera bereziren bat (ekonomikoa, historikoa, soziala edo kulturala) duten udalerriak.</descrip>
    </descripGrp>
    <tig>
      <term>biztanle-kopuru handiko udalerri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>municipio de gran población</term>
    </tig>
  </langSet>
</termEntry>
