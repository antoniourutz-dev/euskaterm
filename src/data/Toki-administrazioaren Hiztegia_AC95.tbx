  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Inbertsioen eta zerbitzuen arloan Estatuko Administrazio Orokorraren eta toki-administrazioaren arteko lankidetza bideratzeko organoa, estatuko gobernuak autonomia-erkidego bakoitzean sor dezakeena.</descrip>
