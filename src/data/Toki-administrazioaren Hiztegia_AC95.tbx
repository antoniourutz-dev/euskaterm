<termEntry id="535111">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Biztanle-kopuru handiko udalerrietan, ekonomia- eta gizarte-elkarteetako eta profesionalen eta auzotarren elkarteetako ordezkariez osatutako kontseilua. Hiriko ekonomia, estrategia-planak eta proiektu nagusiak garatzeko txostenak, azterlanak eta proposamenak egiteaz gain, osoko bilkurak arau organikoen bidez zehaztutako eginkizunak dira haren ardura.</descrip>
    </descripGrp>
