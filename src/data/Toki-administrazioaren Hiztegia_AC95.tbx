<termEntry id="535394">
  <descrip type='subjectField'>Antolaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alkate-kargua hutsik bada edo alkatea kanpoan, gaixorik edo ezinduta badago, izendapen-hurrenkeraren arabera haren eginkizunak betetzen dituen zinegotzia. Gainera, alkateari dagozkion eginkizunak har ditzake eskuordetzan hark berariaz emanda. Alkateak askatasunez izendatu eta kentzen ditu alkateordeak tokiko gobernu-batzarreko kideen artetik, eta batzar hori ez badago, zinegotzien artetik.</descrip>
    </descripGrp>
    <tig>
      <term>alkateorde</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>teniente de alcalde</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535395">
  <descrip type='subjectField'>Biztanleria eta lurralde-mugaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontzejuak bere eskumenak erabiltzeko duen lurraldea.</descrip>
    </descripGrp>
    <tig>
      <term>kontzeju-mugarte</term>
      <termNote type='normativeAuthorization'>4</termNote>
