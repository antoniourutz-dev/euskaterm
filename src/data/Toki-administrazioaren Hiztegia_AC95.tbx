  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gipuzkoako Lurralde Historikoko toki-erakunde guztiak inskribatzen diren foru-erregistroa; izaera publikoa du eta udal-barrutietan eskumena duen Foru Aldundiko organoak zuzentzen, kudeatzen eta gordetzen du.</descrip>
