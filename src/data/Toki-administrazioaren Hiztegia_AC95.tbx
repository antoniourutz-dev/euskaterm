<termEntry id="535188">
  <descrip type='subjectField'>Toki-ogasunak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bizkaian, tributuetatik eratorritako lurralde historikoaren finantza-baliabideak udalerrien artean behar bezala banatzeko erabiltzen den funtsa.</descrip>
    </descripGrp>
    <tig>
