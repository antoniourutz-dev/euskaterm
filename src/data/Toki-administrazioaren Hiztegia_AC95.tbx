</termEntry>
<termEntry id="535053">
  <descrip type='subjectField'>Herri-administrazioen arteko lankidetzarako antolakundeak (toki-administrazioko gaietan)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Estatu osoko edo autonomia-erkidego bateko toki-erakundeek beren interesen alde egiteko eratzen duten elkartea.</descrip>
    </descripGrp>
    <tig>
      <term>toki-erakundeen elkarte</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>asociación de entidades locales</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535054">
  <descrip type='subjectField'>Herri-administrazioen arteko lankidetzarako antolakundeak (toki-administrazioko gaietan)</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Euskal Autonomia Erkidegoko ia udalerri guztiak eta Nafarroako Foru Erkidegoko udal batzuk biltzen dituen elkartea. Udal-autonomiaren alde egitea eta tokiko interesak beste erakunde batzuen aurrean politikoki ordezkatzea da helburu nagusia.</descrip>
    </descripGrp>
    <tig>
      <term>Euskadiko Udalen Elkarte</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>EUDEL</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Asociación de Municipios Vascos</term>
    </tig>
    <tig>
      <term>EUDEL</term>
    </tig>
  </langSet>
</termEntry>
