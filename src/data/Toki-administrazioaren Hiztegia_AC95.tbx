  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Biztanle-kopuru handiko udalerrietako zinegotzitza edo udal-arlo nagusi batean, administrazio-antolakuntzaren ardura duen pertsona.</descrip>
    </descripGrp>
