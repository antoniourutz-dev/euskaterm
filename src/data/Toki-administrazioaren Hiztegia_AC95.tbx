  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Udalerri baten eskumenekoa izanik, beste udalerri batenak diren lurrez erabat inguratuta dagoen lur-eremua.</descrip>
    </descripGrp>
