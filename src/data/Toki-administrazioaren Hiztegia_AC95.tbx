  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arautegi orokorraren mende dagoen araubidea. Toki Araubidearen Oinarriak arautzen dituen Legeak osatzen du, funtsean, arautegi orokor hori.</descrip>
    </descripGrp>
    <tig>
