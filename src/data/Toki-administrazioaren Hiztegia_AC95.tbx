  <descrip type='subjectField'>Biztanleria eta lurralde-mugaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Euskadiko toki-erakunde guztiak inskribatzen diren erregistroa; izaera publikoa du eta Toki Administrazioko Sailburuordetzari atxikita dago.</descrip>
    </descripGrp>
