  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Idazkaritza-lana egiteaz eta fede publikoa eta aginduzko lege-aholkularitza emateaz arduratzen diren funtzionarioen azpieskala.</descrip>
    </descripGrp>
    <tig>
      <term>Idazkaritza Azpieskala</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntza duten funtzionarioen eskalakoa</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Subescala de Secretaría</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535382">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Idazkaritza-lanaz, fede publikoa eta aginduzko lege-aholkularitza emateaz, finantza- eta ekonomia-kudeaketa eta aurrekontuen kudeaketa kontrolatzeko eta barrutik ikuskatzeko lanaz, kontabilitateaz eta diru-bilketaz arduratzen diren funtzionarioen azpieskala.</descrip>
    </descripGrp>
    <tig>
      <term>Idazkaritza Kontu-hartzailetza Azpieskala</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntza duten funtzionarioen eskalakoa</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Subescala de Secretaría-Intervención</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535383">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gaitasun bereziren bat eskatzen duten eginkizunetan diharduten funtzionarioen azpieskala; eginkizun horietan jarduteko ez da eskatzen, oro har, titulu akademiko edo profesional berezirik. Azpieskala honetan sartzen dira: a) udaltzaingoa, b) suhiltzaileen zerbitzua, c) zeregin berezietako plazak, d) hainbat lanbidetako langileak.</descrip>
    </descripGrp>
    <tig>
      <term>Zerbitzu Berezien Azpieskala</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntzarik ez duten toki-administrazioko funtzionarioen azpieskala.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Subescala de Servicios Especiales</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535384">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bulego barruak zaintzen eta jagoten dituzten funtzionarioen eskala, baita korporazioaren eraikin eta zerbitzuetan etxezain, atezain, giltzazain edo antzeko lanetan diharduten funtzionarioena ere.</descrip>
    </descripGrp>
    <tig>
      <term>Administrazio Orokorreko Mendekoen Azpieskala</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntzarik ez duten toki-administrazioko funtzionarioen azpieskala.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Subescala de Subalternos de Administración General</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535385">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ikasketa batzuen xede diren eginkizunetan diharduten funtzionarioen eskala; eginkizun horietan jarduteko, titulu akademiko edo profesionalen bat eduki behar da legez. Tituluaren maila eta izaeraren arabera, funtzionarioak goi-mailako teknikariak, erdi-mailako teknikariak eta teknikari laguntzaileak dira, eta talde bakoitzak adar eta espezialitate desberdinak biltzen ditu.</descrip>
    </descripGrp>
    <tig>
      <term>Administrazio Bereziko Azpieskala Teknikoa</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntzarik ez duten toki-administrazioko funtzionarioen azpieskala.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Subescala Técnica de Administración Especial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535386">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Administrazio-izaerako goi-mailako kudeaketa, azterlanak eta proposamenak egiten dituzten funtzionarioen eskala.</descrip>
    </descripGrp>
    <tig>
      <term>Administrazio Orokorreko Azpieskala Teknikoa</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>Estaturako gaikuntzarik ez duten toki-administrazioko funtzionarioen azpieskala.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Subescala Técnica de Administración General</term>
    </tig>
  </langSet>
</termEntry>
