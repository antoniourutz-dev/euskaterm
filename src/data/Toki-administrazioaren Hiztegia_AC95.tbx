</termEntry>
<termEntry id="535189">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nafarroan, funtzio hauetako baten ardura duen toki-erakundeko funtzionarioa: fede publikoa eta aholkularitza legala; kudeaketa ekonomiko eta finantzarioaren barne-kontrola eta fiskalizazioa; eta kontabilitatea, diru-bilketa eta diruzaintza.</descrip>
    </descripGrp>
    <tig>
      <term>foru-administrazioak gaitutako funtzionario</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>funcionario con habilitación conferida por la administración foral</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535190">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Legezko izendapen baten ondorioz EAE edo Estatuko toki-erakunde batean zerbitzuak era iraunkorrean eskaintzen dituen pertsona; plantillan sarturik dago, eta soldata edo ordainsari finkoak jasotzen ditu toki-erakundearen aurrekontuetako pertsonal-atalaren eskutik. Lanbide-harreman hori Administrazio Zuzenbideak arautzen du.</descrip>
    </descripGrp>
    <tig>
      <term>karrerako funtzionario</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>funcionario de carrera</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535191">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lanbide-harreman ordainduaren bidez toki-administrazioari atxikita dagoen pertsona, zerbitzu jakin batzuk eskaintzeko; harreman hori Administrazio Zuzenbideak arautzen du.</descrip>
    </descripGrp>
    <tig>
      <term>toki-administrazioko funtzionario</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>funcionario de la administración local</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535192">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>EAE eta Estatuan, Estaturako Gaikuntza duen Eskalan sartuta dagoen toki-administrazioko funtzionarioa. Toki-erakundearen mende badago ere, Estatuko administrazioak du funtzionario hori lanpostutik kendu edo banatzeko eskumena. Toki-erakundeetan funtzio jakin batzuk dauzkate erreserbatuta: fede publikoa eta aholkularitza legala, kudeaketa ekonomiko eta finantzarioaren barne-kontrola eta fiskalizazioa, eta kontabilitatea, diru-bilketa eta diruzaintza.</descrip>
    </descripGrp>
    <tig>
      <term>Estaturako gaikuntza duen toki-administrazioko funtzionario</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>funcionario de la administración local con habilitación de carácter nacional</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535193">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>EAE eta Estatuan, Estaturako gaikuntza ez duen toki-administrazioko funtzionarioa. Nafarroan, foru-administrazioak gaitutakoa ez den toki-administrazioko funtzionarioa.</descrip>
    </descripGrp>
    <tig>
      <term>toki-erakundeko bertako funtzionario</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>funcionario propio de la entidad local</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535194">
  <descrip type='subjectField'>Toki-erakundeetako langileak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Legezko izendapen baten ondorioz Nafarroako administrazio publiko batean zerbitzuak era iraunkorrean eskaintzen dituen pertsona; plantillan sarturik dago, eta soldata edo ordainsari finkoak jasotzen ditu toki-erakundearen aurrekontuetako pertsonal-atalaren eskutik. Lanbide-harreman hori Administrazio Zuzenbideak arautzen du.</descrip>
    </descripGrp>
    <tig>
      <term>funtzionario publiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>funcionario público</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535195">
  <descrip type='subjectField'>Biztanleria eta lurralde-mugaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hainbat udalerriren mugarteak batzea, udalerri berria eratzeko. Udal-mugartea aldatzeko moduetako bat da.</descrip>
    </descripGrp>
    <tig>
      <term>udalerriak bat egite</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>fusión de municipios</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535196">
  <descrip type='subjectField'>Obrak eta zerbitzuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Toki-erakundearen eskumeneko zerbitzuak eskaintzeko, toki-erakundeak berak edo bere mendeko tokiko organismo autonomoek, enpresa-erakunde publikoek nahiz zerbitzu publikoek egindako kudeaketa.</descrip>
    </descripGrp>
    <tig>
      <term>zuzeneko kudeaketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>gestión directa</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535197">
  <descrip type='subjectField'>Obrak eta zerbitzuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Toki-erakundearen eskumeneko zerbitzuak eskaintzeko, beste erakunde batek emakida, errentamendu edo kontzertu bidez egindako kudeaketa.</descrip>
    </descripGrp>
    <tig>
      <term>zeharkako kudeaketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>gestión indirecta</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="535198">
  <descrip type='subjectField'>Obrak eta zerbitzuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Toki-erakundearen eskumeneko zerbitzuak zeharka eskaintzeko, toki-erakundeak eta enpresa batek egiten duten kudeaketa. Toki-erakundeak eta enpresak zerbitzu ustiapenaren mozkinak elkarrekin banatuko dituzte, kontratuz ezarritako proportzioan.</descrip>
    </descripGrp>
    <tig>
      <term>kudeaketa interesatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>gestión interesada</term>
    </tig>
  </langSet>
</termEntry>
