  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Osoko bilkurari aurkezten zaion planteamendua, informazio-batzordeak espedientea aztertu ondoren egina; azalpenari dagokion zatia eta hartu beharreko erabakiarena ditu.</descrip>
