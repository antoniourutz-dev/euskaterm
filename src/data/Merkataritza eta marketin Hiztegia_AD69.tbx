<termEntry id="-1">
  <descrip type='subjectField'>Merkatua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Denda edo saltoki batean erosteko ohitura duen bezeroa.</descrip>
