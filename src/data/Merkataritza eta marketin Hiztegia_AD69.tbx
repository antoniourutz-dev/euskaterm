    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>perishability</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zerbitzuen lau ezaugarrietako bat; ukiezintasuna, banaezintasuna eta galkortasuna dira beste hirurak. Aldakortasunak adierazten du zerbitzua ez dela bi aldiz berdin-berdina izango, aldatu egingo dela egunaren, orduaren, zerbitzariaren, bezeroaren edo lekuaren arabera.</descrip>
