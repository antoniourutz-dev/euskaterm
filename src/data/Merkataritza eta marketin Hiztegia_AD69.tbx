    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Deskontu erasokorra eta, ondorioz, oso prezio txikiak ezartzen dituen denda. Langile gutxi izaten ditu, aurkezpena oso soila, produktu-aukera oso murritza (oinarrizko produktuz osatua), eta markarik gabeko produktu edo banatzaile-produktu asko.</descrip>
    </descripGrp>
    <tig>
      <term>deskontu gogorreko denda</term>
