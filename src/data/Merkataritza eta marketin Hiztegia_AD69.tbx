    <tig>
      <term>JIT</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bitartekari gabeko banaketa-kanala: ekoizleak produktua zuzenean saltzen dio kontsumitzaileari, bestelako bitartekaririk gabe</descrip>
    </descripGrp>
