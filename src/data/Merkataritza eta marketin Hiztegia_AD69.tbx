  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktua kontsumitzaileari fisikoki helarazteko edo zerbitzua eskuragarri jartzeko egin beharreko eragiketen multzoa: kanalak aukeratzea, saltokiak zehaztea, logistika, saltokiko sustapen-ekintzak eta abar. Marketin-mixaren osagaietako bat da.</descrip>
