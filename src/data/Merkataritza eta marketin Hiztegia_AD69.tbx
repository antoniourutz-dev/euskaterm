    <tig>
      <term>marketing de données</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>database marketing</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Prezioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Denboraldi labur baterako ezartzen den prezio berezia, normala baino txikiagoa.</descrip>
