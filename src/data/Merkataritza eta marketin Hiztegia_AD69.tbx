  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktu bati buruzko interesa erakusten duen edo erakuts lezakeen bezeroa; enpresa saltzaileak helburutzat hartuko du, erosteko erabakia hartzera bultzatzeko.</descrip>
