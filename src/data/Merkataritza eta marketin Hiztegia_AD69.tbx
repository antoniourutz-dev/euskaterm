<termEntry id="-1">
  <descrip type='subjectField'>Komunikazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zuzenean kontsumitzaileari begira egindako komunikazio-ekintzen multzoa, kontsumitzailearen erantzuna edo harekiko harreman interaktiboa sustatu nahi duena. Datu-baseen kudeaketan oinarritzen da, eta hor sartzen dira zuzeneko posta, katalogo bidezko salmenta, telezerbitzuak, telemarketina eta abar. Komunikazio-mixaren osagaietako bat da.</descrip>
    </descripGrp>
    <tig>
      <term>zuzeneko marketin</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
