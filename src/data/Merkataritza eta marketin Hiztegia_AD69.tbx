  <langSet xml:lang='en'>
    <tig>
      <term>decline stage</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktuaren bizi-zikloaren bigarren etapa, merkaturatzearen ondorengoa: merkatuak produktua ezagutu eta onartu ahala, salmentak eta irabaziak haziz eta sendotuz joaten dira, lehia azkartuz joaten da, eta irabazi-marjinak maila gorenera iristen dira.</descrip>
