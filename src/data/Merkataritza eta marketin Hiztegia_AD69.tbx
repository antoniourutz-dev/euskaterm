  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Marketineko komunikazioaren osagai-multzoa: publizitatea, salmenta-sustapena, salmenta pertsonala, zuzeneko marketina eta harreman publikoak.</descrip>
