<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Maiz erosten den kontsumo-produktua. Prezio txikikoak eta oso eskuragarriak izaten dira, eta kontsumitzaileak denbora eta esfortzu gutxi gastatzen du erosteko prozesuan. Hiru sailetan banatzen dira: kontsumo arrunteko produktuak, bulkadazko produktuak eta larrialdietako produktuak.</descrip>
    </descripGrp>
