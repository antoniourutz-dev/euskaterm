<martif type="TBX" xml:lang="en">
  <martifHeader>
    <fileDesc>
      <titleStmt>
        <title>Merkataritza eta marketina Hiztegia</title>
      </titleStmt>
      <sourceDesc>
        <p>Merkataritza eta marketina Hiztegiaren TBX esportazioa</p>
      </sourceDesc>
    </fileDesc>
  </martifHeader>
<text>
<body>
<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>2.500 metro karratutik gorako salmenta-azalera duen saltegia. Elikagaiak eta bestelako produktuak saltzen ditu, aukera zabala eta prezio lehiakorrak eskainiz; herriaren kanpoaldean kokatuta egoten da, eta autoa uzteko aparkaleku handia izaten du.</descrip>
    </descripGrp>
    <tig>
      <term>hipermerkatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>hipermercado</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>hypermarché</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>hypermarket</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Komunikazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aire zabalean kokatutako euskarrietan egiten den publizitatea (errepide-bazterreko karteletan, hiri-altzarietan, hormetan, autobusetan eta abar).</descrip>
    </descripGrp>
    <tig>
      <term>kanpo-publizitate</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>publicidad exterior</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>publicité extérieure</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>outdoor advertising</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aldez aurretik pentsatu gabe erosten den komenentziako produktua; mementoan erabakita, saltokiko sustapen- edo komunikazio-ekintza batek eraginda erosten da askotan.</descrip>
    </descripGrp>
    <tig>
      <term>bulkadazko produktu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>producto de compra por impulso</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>produit de choc</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>impulse product</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Merkatua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aldez aurretik pentsatu gabeko erosketa. Dendan sartu aurretik erosteko asmorik ez izan arren, denda barruan ikusi delako edo eskaintza erakargarria delako egiten da erosketa.</descrip>
    </descripGrp>
    <tig>
      <term>bulkadazko erosketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>compra por impulso</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>achat spontané</term>
    </tig>
    <tig>
      <term>achat d'impulsion</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>impulse buying</term>
    </tig>
    <tig>
      <term>impulse purchase</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Komunikazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arreta, Interesa, Desira eta Akzioa oinarri dituen komunikazio-eredua. Marketineko komunikazioak kontsumitzailearen arreta lortu behar du lehenik, produktua badela jakin behar du kontsumitzaileak; gero, interesa piztu behar zaio produktua ezagutzeko; ezagutu ahala, erosteko desira sortu behar zaio; eta, azkenik, erosi egin behar du.</descrip>
    </descripGrp>
    <tig>
      <term>AIDA</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>AIDA</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>AIDA</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>AIDA</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Autozerbitzuetan, salgaiak aurkezteko erabiltzen den altzari luzea; behetik gora hiru edo lau apal izaten ditu inguru guztian.</descrip>
    </descripGrp>
    <tig>
      <term>gondola</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>góndola</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>gondola</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>shelves</term>
    </tig>
    <tig>
      <term>gondola</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Azken erabiltzaileen esparruko enpresek egindako marketina.</descrip>
    </descripGrp>
    <tig>
      <term>kontsumo-marketin</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>kontsumoko marketin</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>marketing de consumo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>marketing de consommation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>consumer marketing</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Azken kontsumitzaileari saltzen ez dion bitartekaria, beste ekoizle beti edo beste bitartekari bati (handizkari, txikizkari edo komisiodun bati) saltzen diona. Normalean, kantitate handiak erosten ditu, eta kantitate txikiagotan eta prezio handiagoan saltzen ditu.</descrip>
    </descripGrp>
    <tig>
      <term>handizkari</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>handizkako merkatari</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>mayorista</term>
    </tig>
    <tig>
      <term>comerciante al por mayor</term>
    </tig>
    <tig>
      <term>comerciante mayorista</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>grossiste</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>wholesaler</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Azken kontsumitzaileari zuzenean saltzen dion denda edo saltegia.</descrip>
    </descripGrp>
    <tig>
      <term>xehekako saltegi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>saltegi txikizkari</term>
