<termEntry id="-1">
  <descrip type='subjectField'>Prezioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktu berari erabiltzaile edo eroslearen araberako prezio desberdinak ezartzea. Erosle desberdin horien baldintzetara egokitzeko egiten da; esate baterako, museoko sarreraren prezioa ez da berdina jende guztiarentzat: ikasleek eta adinekoek beherapena izaten dute.</descrip>
    </descripGrp>
