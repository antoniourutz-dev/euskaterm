    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>differentiated product</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Merkatua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bezero potentzialak identifikatzea eta kalifikatzea. Saltzeko prozesuaren lehenengo fasea izan ohi da.</descrip>
    </descripGrp>
    <tig>
      <term>merkatu-prospekzio</term>
