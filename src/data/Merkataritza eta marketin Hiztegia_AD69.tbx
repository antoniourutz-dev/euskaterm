<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktuaren bizi-zikloaren azkeneko etapa, merkaturatzearen, hazkundearen eta heldutasunaren ondorengoa: salmentek behera egiten dute, hasierako beharra eta nahia aseta daudelako edo beste produktu berritzaile bat merkaturatu delako.</descrip>
