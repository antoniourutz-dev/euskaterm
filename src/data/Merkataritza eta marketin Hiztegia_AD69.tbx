  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bitartekarien bidezko banaketa-kanala: produktuak ez zaizkio zuzenean saltzen kontsumitzaileari, bitartekari baten edo gehiagoren eskuetatik pasatzen baitira lehenago.</descrip>
    </descripGrp>
    <tig>
      <term>zeharkako kanal</term>
