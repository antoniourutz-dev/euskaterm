  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktu berri bat merkatura ateratzen denean, produktua ezagutzera emateko eta kontsumitzaileak probatzera animatzeko egiten den eskaintza berezia.</descrip>
