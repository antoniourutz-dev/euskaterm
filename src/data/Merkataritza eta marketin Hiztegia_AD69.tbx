    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>franchise</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>franchise</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Merkatua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Merkatu bat ezagutzeko egiten den lana. Merkatuari buruzko informazioa bilatu, bildu eta aztertzen da, ezaugarri guztiak zehazteko: eskaria eta eskaintza, segmentuak, prezioak, banaketa-kanalak, lehiakideak, kontsumitzaileen premiak, erosteko portaerak eta abar.</descrip>
