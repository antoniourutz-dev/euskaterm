<termEntry id="-1">
  <descrip type='subjectField'>Merkatua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Denda edo saltoki batean noizbehinka zerbait erosten duen bezeroa, bertan erosteko ohiturarik ez duena.</descrip>
    </descripGrp>
    <tig>
      <term>noizbehinkako bezero</term>
