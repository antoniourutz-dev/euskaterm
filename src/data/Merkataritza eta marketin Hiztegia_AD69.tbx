<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Dendaren kanpoaldeko leiho antzeko eremua, beiraz itxia, kaletik ikusten dena. Dendan saltzen diren produktuen erakuskari bat jartzen da bertan, bezeroak dendara erakartzeko.</descrip>
    </descripGrp>
