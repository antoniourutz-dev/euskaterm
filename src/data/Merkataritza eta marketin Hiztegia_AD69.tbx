    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Komunikazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Marka bat ezagutzera emateko, haren irudia sortu, finkatu edo aldatzeko edo kontsumitzaileen markarekiko leialtasuna indartzeko egiten den publizitatea.</descrip>
