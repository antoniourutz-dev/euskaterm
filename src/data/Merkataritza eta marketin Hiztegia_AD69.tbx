<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktu berri bat merkaturatu aurretik kontsumitzaile batzuekin egiten den test edo proba. Esate baterako, kontsumitzaile batzuei produktua doan ematea, trukean haiek iritzia eman dezaten.</descrip>
