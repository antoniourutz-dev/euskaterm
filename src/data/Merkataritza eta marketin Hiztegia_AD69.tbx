  <langSet xml:lang='en'>
    <tig>
      <term>hard discount</term>
    </tig>
    <tig>
      <term>hard discount store</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Deskontu gogorreko denden eboluzioz sortutako denda-mota. Deskontu biguneko dendek deskontu gogorrekoek baino produktu-aukera sakonagoa izaten dute, eta aurkezpen zainduagoa (apaletan hobeto antolatua).</descrip>
    </descripGrp>
    <tig>
