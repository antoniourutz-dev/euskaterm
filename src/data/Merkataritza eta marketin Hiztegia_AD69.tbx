<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktu bat bere lehiakideetatik bereizteak, hau da, desberdin egiteak dakarren abantaila. Abantaila hori produktua nabarmenki hobea denean edota beste behar batzuei erantzuten dienean lortzen da.</descrip>
