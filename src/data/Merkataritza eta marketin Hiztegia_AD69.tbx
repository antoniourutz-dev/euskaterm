  <descrip type='subjectField'>Komunikazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lema edo esaldi esanguratsu, erakargarri eta oroiterraza, publizitate-mezu baten muina laburbiltzen duena.</descrip>
