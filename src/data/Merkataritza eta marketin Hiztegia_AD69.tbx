<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktu berri baten onarpen-kurban bereizten diren bost kontsumitzaile-motetatik azkena: produktua berritzaileen, lehen onartzaileen, lehen gehiengoaren eta azken gehiengoaren atzetik onartzen duen kontsumitzailea.</descrip>
