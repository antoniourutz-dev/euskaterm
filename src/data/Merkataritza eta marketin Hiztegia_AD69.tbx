    <tig>
      <term>seller</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bezeroak eskatutako produktua dendako saltzaileak zerbitzatzen duen saltegia. Normalean, produktu-klase bateko marka bat edo gehiago saltzen dituzte; batzuetan, produktu-aukera handiagoa izaten dute, baina lerro bakoitzean sakontasun handirik gabe.</descrip>
    </descripGrp>
    <tig>
      <term>denda tradizional</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>comercio tradicional</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>commerce traditionnel</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>traditional commerce</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Prezioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bezeroak produktu baten prezioa konparatzeko oinarri gisa erabiltzen duen prezioa. Izan daiteke lehendik gogoan duen prezioa, lehiakide baten produktuarena, antzeko beste produktu batena eta abar.</descrip>
    </descripGrp>
    <tig>
      <term>erreferentzia-prezio</term>
