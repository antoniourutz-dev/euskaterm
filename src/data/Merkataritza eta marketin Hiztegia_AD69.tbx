<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Marketineko aldagai nagusiak (produktua, prezioa, banaketa eta komunikazioa) konbinatzeko modua. Merkatuan lortu nahi diren helburuak lortzea izango da xedea.</descrip>
    </descripGrp>
