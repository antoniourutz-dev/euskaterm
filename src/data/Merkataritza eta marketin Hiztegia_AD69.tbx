  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prezioak eskualdearen arabera ezartzea. Garraio-kostuengatik egiten da normalean, baina egin daiteke lehia-arazoengatik ere.</descrip>
