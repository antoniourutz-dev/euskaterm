<termEntry id="-1">
  <descrip type='subjectField'>Merkatua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktu bat lehen aldiz merkaturatzea. Prozesu hori errazteko, merkatuan sartzeko estrategiak aplikatu ohi dira.</descrip>
