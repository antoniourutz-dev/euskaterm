  <descrip type='subjectField'>Merkatua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Merkatuak produktu bat gustuko ez duenean, erosteari uko egiten dionean eta, gainera, arloko produktu baten truke gehiago ordaintzeko prest dagoenean izaten den egoera. Eskari hutsala baino egoera okerragoa da.</descrip>
