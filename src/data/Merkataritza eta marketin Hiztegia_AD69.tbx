    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>prospecting</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bezero potentzialari produktu bati buruzko azalpenak ematen dizkion eta hura eros dezan konbentzitzen saiatzen den pertsona.</descrip>
    </descripGrp>
    <tig>
      <term>saltzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
