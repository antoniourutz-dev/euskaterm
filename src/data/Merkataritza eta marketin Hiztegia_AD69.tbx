    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>reference price</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Orokorra</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bezeroekin harreman sendo eta iraunkorrak ezartzera bideratutako marketina. Bezeroaren premiei erantzun globala ematen saiatzen da, haren leialtasuna lortzeko.</descrip>
    </descripGrp>
    <tig>
      <term>harreman-marketin</term>
      <termNote type='normativeAuthorization'>4</termNote>
