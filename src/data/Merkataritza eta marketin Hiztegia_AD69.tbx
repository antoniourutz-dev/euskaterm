  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontsumitzaileari produktuaren berri emateko eta erosteko gogoa pizteko egiten diren ekintzen-multzoa (publizitatea, salmenta-sustapena, harreman publikoak eta abar). Marketin-mixaren osagaietako bat da.</descrip>
