<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zerbitzuen lau ezaugarrietako bat; ukiezintasuna, banaezintasuna eta aldakortasuna dira beste hirurak. Galkortasunak adierazten du zerbitzua ezin dela biltegiratu; une jakin batean eskaintzen da, eta, une horretan kontsumitzen ez bada, galdu egiten da. Esate baterako, hotel bateko gela bat erreserbatzen ez bada, zerbitzu hori galdu egingo da, ezin da hurrengo egunerako metatu.</descrip>
    </descripGrp>
    <tig>
      <term>galkortasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
