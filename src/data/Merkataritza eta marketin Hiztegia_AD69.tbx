      <term>establecimiento de descuento blando</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>magasin soft-discount</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>soft discount</term>
    </tig>
    <tig>
      <term>soft discount store</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Banaketa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ekoizle edo handizkari batek produktuak beste ekoizle bati, beste handizkari bati edo txikizkari bati kantitate handitan saltzea.</descrip>
    </descripGrp>
    <tig>
      <term>handizkako salmenta</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
