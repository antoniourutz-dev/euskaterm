  <descrip type='subjectField'>Merkatua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Merkatuan antzeko beharrak dituzten bezeroak edo antzeko portaera dutenak identifikatzea eta, horren arabera, merkatua multzotan zatitzea. Multzo barruko bezeroak homogeneoak dira, eta multzo batetik besterakoak heterogeneoak.</descrip>
    </descripGrp>
    <tig>
      <term>merkatu-segmentazio</term>
