    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>brand advertising</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Produktua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Marka bat identifikatzen duen irudi, diseinu, marrazki, kolore-multzo eta letra-tipoen konbinazio grafikoa. Izena eta ikurra dira markaren elementu nagusiak; esate baterako, Apple marka-izena eta sagarraren ikurra.</descrip>
