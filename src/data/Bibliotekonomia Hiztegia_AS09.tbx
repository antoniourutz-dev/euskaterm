  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zenbaitetan, atariaren aurrean ezartzen den orria. Zuriz joan daitekeen arren, normalean liburuaren izenburua inprimatzen da bertan, laburtuta edo karaktere txikiagotan, atariarekin alderatuz gero.</descrip>
