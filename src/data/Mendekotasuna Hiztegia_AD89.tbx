<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gaixotasun neurologikoa, garuneko oinaldeko zelula espezializatu batzuen degenerazioak sortua. Normalean, 50 urtetik gorako pertsonengan agertzen da. Dardara, zurruntasuna eta mugimenduen baldartasun eta moteltasuna dira sintoma nagusiak.</descrip>
    </descripGrp>
    <tig>
      <term>Parkinson-en gaixotasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>parkinson</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>enfermedad de Parkinson</term>
    </tig>
    <tig>
      <term>párkinson</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>maladie de Parkinson</term>
    </tig>
    <tig>
      <term>Parkinson</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>Parkinson's disease</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ikusmen-eremuan ager daitekeen itsutasun partzialeko eremua, behin-behinekoa edo behin betikoa izan daitekeena. Erretinako edo ikusmen-nerbioko lesio batek sortua izan daiteke, baita odol-hodietako alterazio batek eragina ere.</descrip>
    </descripGrp>
    <tig>
      <term>eskotoma</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>escotoma</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
