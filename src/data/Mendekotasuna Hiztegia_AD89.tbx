    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>autonomie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>autonomy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendekotasunari buruzko gaietan Administrazioari egiten zaizkion eskaeretan eskatzailearen mendekotasun-maila zein den aztertzeko eta neurtzeko erabiltzen den eskala.</descrip>
    </descripGrp>
    <tig>
