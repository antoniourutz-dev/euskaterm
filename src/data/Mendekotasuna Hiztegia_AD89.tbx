<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Informazioa oroimenean aldi baterako soilik (30 bat segundo inguru) gordetzeko aukera ematen duten funtzio mentalen multzoa. Ondoren, informazio hori, iraupen luzeko oroimenean finkatzen ez bada, galdu egiten da.</descrip>
