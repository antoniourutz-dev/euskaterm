  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Batez bestekoa baino nabarmen apalagoa den gaitasun intelektuala, eguneroko bizitzako jarduerei aurre egiteko beharrezkoak diren egokitze-ahalmen mugatuak izatea eragiten duena. Jaiotzeko unean edo haurtzaroaren lehen faseetan hasten da, eta gizabanakoak behar bezala egokitzea eta ikastea eragozten du.</descrip>
    </descripGrp>
    <tig>
      <term>adimen-atzeratasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>retraso mental</term>
    </tig>
    <tig>
      <term>retraso intelectual</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>retard mental</term>
    </tig>
    <tig>
      <term>retard intellectuel</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>mental retardation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Batez bestekoa baino nabarmen apalagoa den garapen psikomotorra, eguneroko bizitzako jarduerei aurre egiteko beharrezkoak diren egokitze-ahalmen mugatuak edukitzea eragiten duena. Jaiotzeko unean edo haurtzaroaren lehen faseetan hasten da, eta gizabanakoak behar bezala egokitzea eta ikastea eragozten du.</descrip>
    </descripGrp>
    <tig>
      <term>atzeratasun psikomotor</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>retraso psicomotor</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>retard psychomoteur</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>psychomotor retardation</term>
    </tig>
  </langSet>
</termEntry>
