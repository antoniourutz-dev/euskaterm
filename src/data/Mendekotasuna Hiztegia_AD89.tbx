<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Usaimenaren galera edo gabezia nabarmena; behin-behinekoa edo behin betikoa izan daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>anosmia</term>
