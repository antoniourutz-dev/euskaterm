<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herriaren edo gizartearen ekimenezko erakunde pribatuek eratzen duten sektorea: hainbat eratakoak izan daitezke baina, betiere, elkartasunezko irizpideetan oinarritutakoak izaten dira. Gizartearen interesaren alde eta irabazi-asmorik gabe lan egiten dute, eta gizarte-eskubideak onartzea eta gauzatzea dute helburu.</descrip>
    </descripGrp>
    <tig>
      <term>hirugarren sektore sozial</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>hirugarren sektore solidario</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>tercer sector social</term>
    </tig>
    <tig>
      <term>tercer sector solidario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Jarduerak eta parte-hartzea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eguneroko bizitzan behar izaten diren ondasunak eta zerbitzuak aukeratu eta norbereganatu. Horien artean daude, esate baterako, hauek: janaria, edaria, arropa, garbiketako gauzak, erregaia, sukaldeko ontziak, etxeko aparatuak eta erremintak.</descrip>
    </descripGrp>
    <tig>
      <term>ondasunak eta zerbitzuak eskuratu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>adquisición de bienes y servicios</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acquérir des produits et des services</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>acquisition of goods and services</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Jarduerak eta parte-hartzea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eguneroko bizitzako oinarrizko mugikortasun-jarduera, urratsez urrats eta, gutxienez, oin bat beti lurrean edukiz, toki batetik bestera oinez higitzean datzana.</descrip>
    </descripGrp>
    <tig>
      <term>ibili</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>andar</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>marcher</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>walking</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Jarduerak eta parte-hartzea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nork bere burua zaintzeko egiten dituen eguneroko jarduerak: garbitu eta lehortzea, gorputza eta gorputzeko atalak zaintzea, iraizpeneko prozesuekin lotutako higiene-neurriak hartzea, janztea, jan eta edatea eta norberaren osasuna zaintzea.</descrip>
    </descripGrp>
    <tig>
      <term>norberaren zainketa</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cuidado personal</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>entretien personnel</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>self-care</term>
    </tig>
  </langSet>
</termEntry>
