  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Muskuluen etengabeko eta nahi gabeko mugimenduen ondoriozko ezohiko jarrera batek edo mugimenduek eragindako hipertonia.</descrip>
