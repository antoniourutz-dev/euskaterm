<termEntry id="-1">
  <descrip type='subjectField'>Jarduerak eta parte-hartzea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Etxean egiten diren ohiko zereginak egin. Horien artean sartzen dira, besteak beste, hauek: etxea garbitzea, arropa garbitzea eta konpontzea, eguneroko bizitzako oinarrizko produktuak erostea, ohea egitea eta otordua prestatzea.</descrip>
