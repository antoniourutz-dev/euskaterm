      <term>apraxia del habla</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>apraxie du langage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>speech apraxia</term>
    </tig>
  </langSet>
</termEntry>
