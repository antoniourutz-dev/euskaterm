<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputz-egitura baten edo funtzio fisiologiko nahiz mental baten galera; egitura edo funtzio horiek arau estatistiko batekiko duten desbiderapen esanguratsua.</descrip>
    </descripGrp>
    <tig>
      <term>urritasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
