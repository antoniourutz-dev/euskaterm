<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Epe mugatuan eta ahalik eta gaitasun funtzional handiena berreskuratzeko helburuarekin egiten diren esku-hartzeen multzoa. Urritasun bat duen pertsona bati bere maila fisiko, mental edo sozialik egokiena lortzen laguntzeko egin ohi da, pertsona horri bere bizitza aldatzeko baliabideak eskainiz.</descrip>
    </descripGrp>
    <tig>
      <term>errehabilitazio</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>rehabilitación</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>réhabilitation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>rehabilitation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>mendekotasuna duten adineko pertsonentzako egoitza</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>dependentzia duten adineko pertsonentzako egoitza</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>residencia de personas mayores en situación de dependencia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendekotasuna duen pertsona baten familiari mendekotasunera egokitzen laguntzeko eta, beharrezkoa balitz, mendekotasunari modu egokian aurre egiteko estrategiak eta baliabideak eskaintzen dizkion zerbitzua; taldeko edo familiako terapiak eta terapia indibidualak barne hartzen ditu.</descrip>
    </descripGrp>
    <tig>
      <term>zaintzaileei laguntza psikologikoa emateko zerbitzu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>servicio de apoyo psicológico para personas cuidadoras</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendekotasuna duen pertsona bati bere etxean ematen zaion zerbitzua, horretarako baimena duten enpresen edo erakundeen bitartez pertsona horren eguneroko premietan laguntzea helburu duena; barnean hartzen du etxeko lanak (garbiketa, otordu-prestaketa, etab.) egiteko, mendekotasuna duen pertsonak bere burua zaintzeko edota eguneroko bizitzako jarduerak egiteko laguntza.</descrip>
    </descripGrp>
    <tig>
      <term>etxeko laguntza-zerbitzu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>servicio de asistencia domiciliaria</term>
    </tig>
    <tig>
      <term>servicio de ayuda a domicilio</term>
    </tig>
    <tig>
      <term>servicio de atención doméstica</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendekotasun-motaren eta -mailaren arabera zer-nolako zaintza behar den kontuan hartuz, horretarako prestatuta dauden egoitza-zentroetan ematen den artapen pertsonal eta sanitario jarraitua. Zerbitzu hori iraunkorra izaten da egoitza-zentroa pertsonaren ohiko egoitza bihurtzen denean, edota aldi batekoa zentroa oporraldi nahiz asteburuetarako edo zaintzaile ez-profesionalen atsedenaldiengatiko egonaldiak egiteko bakarrik erabiltzen denean.</descrip>
    </descripGrp>
    <tig>
      <term>egoitza-zerbitzu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>servicio de atención residencial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendekotasuna duten pertsonei beren autonomia pertsonaleko maila hobetzen edo ahalik eta egokien mantentzen laguntzeko eta familiei edo zaintzaileei laguntzeko egunez edo gauez ematen den arreta integraleko zerbitzua.</descrip>
    </descripGrp>
    <tig>
      <term>eguneko eta gaueko zentroen zerbitzu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>servicio de centro de día y de noche</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gaixotasunari edo desgaitasunei eta horien ondorioei aurrea hartzeko egiten eta prestatzen diren programa eta laguntzen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>mendekotasun-egoerei aurrea hartzeko zerbitzu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>dependentzia-egoeren prebentzio-zerbitzu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>servicio de prevención de las situaciones de dependencia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bakarrik dagoen artean larrialdiren bat izan dezakeen gaixoari berehalako laguntza medikoa eskaintzeko erabiltzen den zerbitzua, informazioaren eta komunikazioaren teknologiak baliatzen dituena.</descrip>
    </descripGrp>
    <tig>
      <term>telelaguntza-zerbitzu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>servicio de teleasistencia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>prestazio tekniko</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>prestación técnica</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Eskubideen arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek, bere ezaugarri edo egoera konkretu batzuengatik, gizartean parte hartzeko aukera eta baliabideak eskuratzeko oztopoak izatea, eta, ondorioz, gizarte-ongizate eta bizi-kalitate eskasagoak lortzea. Ezaugarri edo egoera horiek izan daitezke desgaitasuna, pobrezia, gutxiengo bateko kide izatea eta abar.</descrip>
    </descripGrp>
    <tig>
      <term>gizarte-bazterketa</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>exclusión social</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>exclusion sociale</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>social exclusion</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Eskubideen arloa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona bat bere gizarte-ingurunean txertatzeko eta harekin interakzioan behar bezala aritzeko prozesua. Pertsona gizarteko kide oso bilakatzea da helburua; hau da, beste edozein kidek dituen eskubide eta betebehar berberak izatea.</descrip>
    </descripGrp>
    <tig>
      <term>gizarte-integrazio</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>gizarteratze</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>integración social</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>intégration sociale</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>social integration</term>
    </tig>
  </langSet>
</termEntry>
