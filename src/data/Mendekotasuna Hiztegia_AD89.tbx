  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eguneroko bizitzan ohikoa den hitzarmen ekonomikoa, konplexutasunik gabea; janariak erostean edo zerbitzuak trukatzean egiten dena, adibidez.</descrip>
