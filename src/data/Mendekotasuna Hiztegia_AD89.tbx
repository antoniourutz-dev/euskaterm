<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontzientziaren egoeretako bakoitza. Konbentzioz, funtzio mentalen asalduraren ondoriozko kontzientzia-maila hauek bereizten dira: obnubilazio mentala, estuporea eta koma.</descrip>
    </descripGrp>
    <tig>
      <term>kontzientzia-maila</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>nivel de conciencia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>niveau de conscience</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>state of consciousness</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontzientzia-mailaren beherakada arina, ernetasuna eta arreta gutxitzen dituena; baldartasun motorrarekin eta pentsamendu-prozesuak moteltzearekin batera agertzen da. Normalean, komaren aurretik gertatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>obnubilazio mental</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>adimen-lausotze</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>obnubilación mental</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>obscurcissement de la conscience</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>clouding of consciousness</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Muskulu-indarraren eta mugimenduaren erabateko galera, gorputz-atal bat edo gehiago ez mugitzea eragiten duena. Sistema muskuloeskeletikoaren hainbat zatitara irits daiteke, osorik edo neurri batean soilik.</descrip>
    </descripGrp>
    <tig>
      <term>paralisi</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>parálisis</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>paralysie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>paralysis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garuneko lesio batek eragindako paralisia. Garun-paralisia eragiten duten garuneko lesioak fetu-garaitik haurrak 3 urte dituen arte gertatzen dira; 3 urtetik aurrera garuneko lesioek eragin ditzaketen paralisiak ez dira garun-paralisitzat hartzen. Arazo psikomotorrekin batera, arazo sentsitiboak, kognitiboak, eta komunikazio eta pertzepziokoak eragiten ditu garun-paralisiak, eta, kasu batzuetan, baita portaerako arazoak ere. Garun-paralisia da umetan gertatzen den desgaitasunik usuena.</descrip>
    </descripGrp>
    <tig>
      <term>garun-paralisi</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>garuneko paralisi</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
