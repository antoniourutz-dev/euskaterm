<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Berez mugikorra den giltzadura bateko mugimenduak murriztea edo erabat ezabatzea. Normalean, ankilosiaren jatorria giltzaduran bertan egon ohi da.</descrip>
    </descripGrp>
    <tig>
      <term>ankilosi</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>anquilosis</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>ankylose</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ankylosis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Borondatezko ekintza bat (mintzatzea edo janztea, esaterako) egiteko zailtasuna edo ezintasuna, gaitasun fisikoa, ekintza egiteko nahia eta ulermena mantendu arren gertatzen dena; burmuineko lesioek eragiten dute.</descrip>
    </descripGrp>
    <tig>
      <term>apraxia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>apraxia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>apraxie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>apraxia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mintzairaren oinarrian dagoen programa motorraren kodifikazioak eta programazio fonologiko osoak huts egiten duenean sortzen den apraxia.</descrip>
    </descripGrp>
    <tig>
      <term>mintzatzeko apraxia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
