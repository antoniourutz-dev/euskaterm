<martif type="TBX" xml:lang="en">
  <martifHeader>
    <fileDesc>
      <titleStmt>
        <title>Mendekotasuna Hiztegia</title>
      </titleStmt>
      <sourceDesc>
        <p>Mendekotasuna Hiztegiaren TBX esportazioa</p>
      </sourceDesc>
    </fileDesc>
  </martifHeader>
<text>
<body>
<termEntry id="-1">
  <descrip type='subjectField'>Inguruneko faktoreak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lekuen eta zerbitzuen ezaugarria, erabiltzailearentzat (beraren egoera fisikoa edo sentsoriala gorabehera) iristeko eta erabiltzeko zailtasuna nolakoa den adierazten duena. Inguruko oztopoak edo barrerak gainditzen lagunduko duten faktore erraztaileak erabiltzen dira irisgarritasuna sustatzeko.</descrip>
    </descripGrp>
    <tig>
      <term>irisgarritasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>accesibilidad</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>accessibilité</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>accessibility</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Jarduerak eta parte-hartzea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Funtzionamenduari begira gizabanakoak duen ikuspegitik, ataza bat edo ekintza bat egitea.</descrip>
    </descripGrp>
    <tig>
      <term>jarduera</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>actividad</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>activité</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>activity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Jarduerak eta parte-hartzea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herritar guztientzat arrunta den edozein jarduera. Halakoak dira, besteak beste, hauek: norberaren zaintzako jarduerak, komunikaziokoak, sentimenen ingurukoak, eskulanekin lotuak, garraioari buruzkoak, loarekin lotuak, funtzio sexuala, jarduera fisikoak (intrintsekoak nahiz funtzionalak) eta jarduera sozialak nahiz aisiakoak.</descrip>
    </descripGrp>
    <tig>
      <term>eguneroko bizitzako jarduera</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>EBJ</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>actividad de la vida diaria</term>
    </tig>
    <tig>
      <term>AVD</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>activité de la vie quotidienne</term>
    </tig>
    <tig>
      <term>AVQ</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>activity of daily living</term>
    </tig>
    <tig>
      <term>ADL</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitz egiteko edo hizkuntza ulertzeko gaitasunaren nahasmendua edo galera, gaitasun hori normaltasunez eskuratu ondoren gertatzen dena; burmuin-hemisferioko lesioek eragiten dute.</descrip>
    </descripGrp>
    <tig>
      <term>afasia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>afasia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>aphasie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>aphasia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitz-jarioaren galera ezaugarri duen asaldua. Hizkera motela izaten da, pobrea, eta ahoskera eta intonazioak ez dira egokiak. Ulermena partzialki mantentzen da, eta errepikapena, izendapena, irakurmena eta idazmena kaltetuak egon daitezke.</descrip>
    </descripGrp>
    <tig>
      <term>Broca-ren afasia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>afasia de Broca</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>aphasie de Broca</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>Broca's aphasia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Entzumenezko ulermena normaltasunetik oso hurbil duen asaldua. Errepikapena, aldiz, oso kaltetua dago.</descrip>
    </descripGrp>
    <tig>
      <term>eroapeneko afasia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>kondukzio-afasia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>afasia de conducción</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>aphasie de conduction</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>conduction aphasia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Etenik gabe eta zentzurik gabe, akatsak zuzentzen saiatu barik, hitz egitea eragiten duen asaldua. Ulermena, errepikapena, izendapena, irakurmena eta idazmena kaltetuak daude.</descrip>
    </descripGrp>
    <tig>
      <term>Wernicke-ren afasia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>afasia de Wernicke</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>aphasie de type Wernicke</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>Wernicke's aphasia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Dastamena ez izatea edo galtzea, gaixotasun edo botika batek eraginda.</descrip>
    </descripGrp>
    <tig>
      <term>ageusia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ageusia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>agueusie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ageusia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Antsietate-egoera, mugimendu-hiperaktibitatearekin eta, maiz, oldarkortasunarekin batera azaltzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>agitazio psikomotor</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>asaldu psikomotor</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>agitación psicomotriz</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>agitation psychomotrice</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>psychomotor agitation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Objektuen forma nahiz ertzak distantzia laburrera eta luzera hautemateko modua ematen duten ikusmenaren funtzioen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>ikusmen-zolitasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>agudeza visual</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acuité visuelle</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>visual acuity</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Min neuropatikoa, zona anatomiko itxuraz osasuntsu batean kaltegabeko estimulu batek (ukimenekoa, termikoa edo mekanikoa) eragina edo sorrarazia.</descrip>
    </descripGrp>
    <tig>
      <term>alodinia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>alodinia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>allodynie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>allodynia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oroimena guztiz edo neurri batean galtzea.</descrip>
    </descripGrp>
    <tig>
      <term>amnesia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>amnesia</term>
    </tig>
