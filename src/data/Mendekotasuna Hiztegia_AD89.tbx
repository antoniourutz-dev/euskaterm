<termEntry id="-1">
  <descrip type='subjectField'>Jarduerak eta parte-hartzea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputza leku batetik beste batera eramatea, edozein gainazal edo espaziotan mugituz eta errazago edo beste modu batera mugitzeko diseinatutako tresna espezifikoak erabiliz. Tresna espezifiko horien artean daude, besteak beste, hauek: eskiak, ur azpian ibiltzeko ekipamendua, gurpil-aulkiak eta taka-takak.</descrip>
    </descripGrp>
    <tig>
      <term>ekipamendu bidez mugitze</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>ekipamendu bidez lekualdatze</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
