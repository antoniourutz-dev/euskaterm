<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zahartze normalaz gaindiko garuneko kalte edo lesioek sortutako nahasmendua, ezagutza-funtzioen galera progresiboa eragiten duena. Bereziki, oroimena, arreta eta problemen ebazpenaren arloak izan ohi dira gehien erasandako eremuak, baina sintoma nagusi horien aurretik denboran nahiz espazioan orientatzeko arazoak eta identitate-galerak azaltzen dira sarritan.</descrip>
    </descripGrp>
    <tig>
      <term>dementzia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>demencia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>démence</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>dementia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eguneroko bizitzako oinarrizko jarduerei aurre egiteko beste pertsona baten arreta edo laguntzaren premian aurkitzen den pertsonaren egoera: autonomia fisiko, mental, intelektual edota sentsorialaren gabezia edo galeraren ondorioz sortzen da, edo adinaren, gaixotasunaren edo desgaitasunaren ondorioz.</descrip>
    </descripGrp>
    <tig>
      <term>mendekotasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>dependentzia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>dependencia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>dépendance</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>dependence</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>narriadura kognitibo</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>deterioro cognitivo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>détérioration cognitive</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>cognitive impairment</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Jarduerak eta parte-hartzea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsonak, testuinguru eta ingurune sozialaren arabera egokia den jokaerari eutsiz, beste pertsona batzuekin duen oinarrizko elkarrekintza; adibidez, egoki denean estimua adieraztea edo besteen sentimenduei erantzun bat emateko gaitasuna erakustea.</descrip>
    </descripGrp>
    <tig>
      <term>pertsonen arteko oinarrizko interakzio</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>interacción interpersonal básica</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>interaction de base avec autrui</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>basic interpersonal interaction</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzak ahoskatzeko gaitasunaren galera edo asaldua, nerbio-sistema zentraleko edo periferikoko lesio batek eragindakoa. Pazienteak fonemen artikulazioarekin lotutako arazoak izan ohi ditu, ez mintzairaren arazoak.</descrip>
    </descripGrp>
    <tig>
      <term>disartria</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>disartria</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>dysarthrie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>dysarthria</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek duen urritasun fisiko, mental, sentimenezko edo intelektualaren eta inguruneko oztopoen arteko interakzioaren emaitza. Oinarrizko jarduerak betetzeko mugapenak ezartzen dizkio pertsona horri, eta eragotzi egiten dio gizartean osoki eta eraginkortasunez eta gainerakoekiko baldintza-berdintasunean parte hartzea.</descrip>
    </descripGrp>
    <tig>
      <term>desgaitasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>discapacidad</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>handicap</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>disability</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>desgaitasun intelektual</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>adimen-desgaitasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>discapacidad intelectual</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>déficience intellectuelle</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>intellectual disability</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mugimendu nahi gabekoa eta ezohikoa. Adibidez: korea, dardara, distonia, atetosia eta abar.</descrip>
    </descripGrp>
    <tig>
      <term>diszinesia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>discinesia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>dyskinésie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>dyskinesia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Txandakako mugimendu errepikatuak (esate baterako, esku-ahurrarekin edo eskugainarekin mahai gainean erritmikoki kolpeak ematea) modu bizkorrean egiteko ezintasuna. Batez ere, zerebeloko lesioen ondorioz gertatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>disdiadokozinesia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>adiadokozinesia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>disdiadococinesia</term>
    </tig>
    <tig>
      <term>adiadococinesia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>dysdiadococinésie</term>
    </tig>
    <tig>
      <term>adiadococinésie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>dysdiadochokinesia</term>
    </tig>
    <tig>
      <term>adiadochokinesia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nerbio-sistema zentraleko lesio batek eragindako hizkuntzaren nahasmendua, hitz egitea zailtzen duena: hartzeko eta adierazteko disfasia duen pertsonak zailtasunak izaten ditu bai hizketan ari denari entzundakoa osorik edo zati batean ulertzeko bai bere ideiak hitzen bidez adierazteko.</descrip>
    </descripGrp>
    <tig>
      <term>hartzeko eta adierazteko disfasia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>disfasia receptivo-expresiva</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>dysphasie de réception/expressive</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>receptive/expressive dysphasia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ahotsaren asaldua, ahotsaren ezaugarri akustikoei soilik (intentsitateari, tonuari edo tinbreari) eragiten diena.</descrip>
    </descripGrp>
    <tig>
      <term>disfonia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>disfonía</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>dysphonie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>dysphonia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zerbait hitzez adierazteko gaitasunaren nahasmendua, fonazioko organoen anomalia edo lesio batek eragindakoa. Hainbat lekutan egon daiteke lesioa: mihian, hortzetan, ezpainetan, ahosabaian edo faringean.</descrip>
    </descripGrp>
    <tig>
      <term>dislalia funtzional</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>dislalia funcional</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>dyslalie fonctionnelle</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>functional dyslalia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Inguruneko faktoreak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ekintza edo lan bat errazteko gailuen multzoa. Era askotakoak izan daitezke: protesiak, ortesiak, eta baita etxerako eta norberaren zainketarako tresna espezializatuak ere; norbera mugitzeko laguntzako gailuak (esate baterako, bastoiak, taka-takak, gurpil-aulkiak eta ziklomotorrak); komunikaziorako gailuak (esate baterako, betaurrekoak, ukipen-lenteak eta kokleako inplanteak) eta baita aisialdirako laguntzako gailuak ere.</descrip>
    </descripGrp>
    <tig>
      <term>laguntzako gailuak</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>dispositivos de ayuda</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>aides techniques</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>assistive devices</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
