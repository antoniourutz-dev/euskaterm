    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>qualifier</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>FNSren bi zati nagusietan bereizten diren bi azpizatietako bakoitza. Adibidez, bi osagai bereizten dira funtzionamenduari eta desgaitasunari buruzko zatian: gorputz-funtzioak eta gorputz-egiturak, alde batetik; eta jarduerak eta parte-hartzea, bestetik.</descrip>
    </descripGrp>
    <tig>
