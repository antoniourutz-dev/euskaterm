  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Trebetasun kontzeptualak (irakurtzea eta idaztea, dirua erabiltzea, etab.), abilezia praktikoak (jatea, garbitzea, botikak hartzea, etxeko lanak egitea, etab.) eta trebetasun sozialak (pertsonen arteko erantzukizuna, autoestimua, etab.) biltzen dituen portaera.</descrip>
    </descripGrp>
