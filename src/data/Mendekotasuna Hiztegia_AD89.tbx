<termEntry id="-1">
  <descrip type='subjectField'>Jarduerak eta parte-hartzea</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sortzen diren arazo eta egoeren aurrean konponbideak bilatu; era bateko edo besteko alderdiak identifikatu eta analizatuz, aukerak eta konponbideak zehaztuz, konponbideetatik sor daitezkeen ondorioak ebaluatuz eta aukeratutako konponbidea gauzatuz egiten da.</descrip>
