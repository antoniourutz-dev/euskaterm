<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Silabak edo hitzak errepikatzea eta hitz-jarioa espasmodikoki etetea eragiten dituen nahasmendua, psikoneurosi batek sortutakoa. Nahasmendu honetan, hiru alderdi nabarmentzen dira, hitz-jarioaren aldaketarekin batera: gehiegizko tentsio muskularra eta arnas erritmo desegokia mintzatzean, antsietatea edo herstura komunikazio sozialeko zenbait egoeratan, eta pertsona totelak bere buruarekiko duen igurikimen negatiboa.</descrip>
    </descripGrp>
    <tig>
      <term>hitz-moteltasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>toteltasun</term>
