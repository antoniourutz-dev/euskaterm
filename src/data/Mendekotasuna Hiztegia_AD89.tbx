<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>FNS osatzen duten eskaletako bakoitzean, sarrera edo epigrafe baten barnean bil daitezkeen elementuen multzoa. Elkarren artean erlazionaturiko ekintzek, funtzio fisiologikoek, egitura anatomikoek, zereginek eta bizitzako arloek osatzen dute.</descrip>
    </descripGrp>
    <tig>
      <term>domeinu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
