  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Leku batetik bestera gorputzaren posizioa aldatu gabe higitu; adibidez, ohean eserita egotetik aulki batean eserita egotera pasatu, edota, etzanda egonik, ohe batetik beste batera pasatu.</descrip>
