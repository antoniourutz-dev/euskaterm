<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona bat egoitza-zentro espezializatu batean barneratzea, denbora-epe luzerako edo betiko. Zentro hori izan daiteke geriatrikoa, osasun mentalekoa, adingabeentzakoa eta abar.</descrip>
