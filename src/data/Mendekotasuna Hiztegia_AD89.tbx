    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mugimendu borondatezkoak eta automatikoak hasteko edo egiteko zailtasuna edo ezintasuna, paralisirik egon ez arren gertatzen dena. Parkinson-en gaixotasunaren ezaugarria da, baina ez harena bakarrik.</descrip>
    </descripGrp>
    <tig>
      <term>azinesia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acinesis</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acinésie</term>
    </tig>
    <tig>
      <term>akinésie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>akinesia</term>
    </tig>
  </langSet>
</termEntry>
