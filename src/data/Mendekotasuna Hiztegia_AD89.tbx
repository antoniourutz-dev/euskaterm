  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giltzaduretako gaixotasun degeneratiboa, kartilagoari eragiten diona eta giltzaduraren mugimendua murrizten duena.</descrip>
    </descripGrp>
