    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Inguruneko faktoreak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Trakeotomia egin zaion pertsonaren lepoko azalaren gainean jartzen den aparatua, hotsak ahoskatzen saiatzen denean ahots mekaniko moduko bat sortzen duena.</descrip>
