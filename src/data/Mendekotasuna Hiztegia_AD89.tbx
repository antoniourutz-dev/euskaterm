  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zereginak ingurune erreal batean egitea edo betetzea. Jardueren eta parte-hartzearen osagaian bereizten diren bi konstruktuetako bat da.</descrip>
    </descripGrp>
