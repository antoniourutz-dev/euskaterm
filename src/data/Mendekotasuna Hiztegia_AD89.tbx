<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nork bere arau eta hobespenen arabera nola bizi behar duen kontrolatzeko eta erabaki pertsonalak bere kabuz hartzeko gaitasuna, eguneroko bizitzako oinarrizko jarduerak egiteko baliatzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>autonomia</term>
