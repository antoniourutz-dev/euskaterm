      <term>schéma</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>construct</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>FNSko osagaietako bakoitzaren kasuan, osagai horren eskalako item bat deskribatzen edo aldatzen duen elementua. Kalifikatzaileen multzoak osagai horren konstruktu jakin bat osatzen dute.</descrip>
    </descripGrp>
    <tig>
      <term>kalifikatzaile</term>
