  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mezuak igortzeko, keinuak, ikurrak, marrazkiak eta antzeko adierazpideak erabiltzea. Halakotzat hartzen dira, besteak beste, hauek: buruarekin ukatzea desadostasuna azaltzeko eta marrazki edo diagrama bat egitea ideia konplexu bat adierazteko.</descrip>
    </descripGrp>
    <tig>
      <term>hitzik gabeko mezuak ekoizte</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
