<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Borondatezkoa ez den mugimendu espasmodiko eta bat-batekoa, pertsonaren mugimendu normalak edo gorputzaren postura egokia zailtzen dituena.</descrip>
    </descripGrp>
