  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nahasmendu neuromuskularra, gorputz-adarren (batez ere, hatz eta eskuen) etengabeko eta nahi gabeko mugimendu motel eta bitxiekin agertzen dena.</descrip>
