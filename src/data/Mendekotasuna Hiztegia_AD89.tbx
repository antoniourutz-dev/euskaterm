  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizabanakoak bizimodu egokia izateko betebehar guztiak aseak dituen egoera, gizabanakoaren alderdi fisikoak, mentalak eta sozialak barnean hartzen dituena. Giza bizitza osatzen duten eremuen unibertso osoari dagokio, eta unibertso oso horretako eremuen azpiatal bat da osasuna.</descrip>
    </descripGrp>
