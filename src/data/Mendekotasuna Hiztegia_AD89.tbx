    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>impairment</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Maiztasun jakin bateko soinuak entzuteko gaitasunaren urritasuna. Dezibeletan adierazten da.</descrip>
    </descripGrp>
    <tig>
      <term>entzumen-urritasun</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
