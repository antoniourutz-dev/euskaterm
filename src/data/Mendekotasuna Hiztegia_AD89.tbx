<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendekotasunen bat duten pertsonen oinarrizko premia pertsonalak eta premia terapeutiko eta soziokulturalak egunez artatzeko zerbitzua eskaintzen duen instalazioa. Desgaitasuna duen pertsona bere ohiko ingurunean mantentzea izaten da helburu nagusia, eta, ahal dela, bere betiko bizimoduan mantentzen eta autonomia-maila handiagoa lortzen laguntzea.</descrip>
    </descripGrp>
    <tig>
      <term>eguneko zentro</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>centro de día</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>errehabilitazio-zentro</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>errehabilitazioko zentro</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>centro de rehabilitación</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Familia-unitate bateko kideei denbora baterako arreta-zerbitzu integrala eskaintzen dien laguntza-zentroa; familia horretako zaintzaileei aldi baterako atsedenaldia eta denbora librea eskaintzea izaten da helburua.</descrip>
    </descripGrp>
    <tig>
      <term>familien atsedenaldirako zerbitzu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>familiak atseden hartzeko zerbitzu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>servicio de respiro familiar</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>zentro okupazional</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
      <term>okupazio-zentro</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>centro ocupacional</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendekotasunen bat duten pertsonei ikuspegi biopsikosozial batetik zerbitzu pertsonal eta sanitario jarraituak eskaintzen dizkien zentroa. Egoitza-zentroetan egiten den egonaldia iraunkorra da zentroa pertsonaren ohiko egoitza bihurtzen denean; aldiz, egonaldia aldi batekoa da oporraldi nahiz asteburuetarako edo zaintzaile ez-profesionalen atsedenaldiengatiko egonaldiak egiteko bakarrik erabiltzen denean zentroa.</descrip>
    </descripGrp>
    <tig>
      <term>egoitza-zentro</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>centro residencial</term>
    </tig>
  </langSet>
</termEntry>
