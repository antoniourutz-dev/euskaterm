  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Inkontzientzia partzialeko egoera, obnubilazioaren eta komaren artekoa: egoera horretan dagoen pertsonak ez dio erantzuten hitzezko estimulazioari, eta gaizki eta motel erantzuten dio estimulazio mingarriari.</descrip>
    </descripGrp>
    <tig>
      <term>estupore</term>
