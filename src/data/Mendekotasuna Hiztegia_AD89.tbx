<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ikusmen-funtzioaren galera edo gabezia, erretina eta ikusmen-nerbioa osorik egon arren gertatzen dena; burmuineko lesioek eragiten dute.</descrip>
    </descripGrp>
    <tig>
      <term>anopsia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
