    <tig>
      <term>zaintzaile</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cuidador</term>
    </tig>
  </langSet>
</termEntry>
