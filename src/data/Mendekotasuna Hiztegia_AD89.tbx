  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Muskuluetako min zorrotza, zirkulazio arterialaren gutxiegitasunak eragiten duena; ariketa fisikoa egitean nabarmentzen da, eta atseden hartzean arintzen da.</descrip>
