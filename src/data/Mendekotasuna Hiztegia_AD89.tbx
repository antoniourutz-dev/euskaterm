  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lagunekin, lankideekin, ikaskideekin eta, oro har, beste pertsona batzuekin norbaitek izan ditzakeen noizbehinkako harreman arautu gabeak.</descrip>
