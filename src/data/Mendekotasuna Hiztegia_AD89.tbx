  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Desgaitasun intelektuala edota gaixotasun mentala duten pertsonek gizartean autonomia pertsonal egokia lortzeko behar duten laguntzen multzoa.</descrip>
