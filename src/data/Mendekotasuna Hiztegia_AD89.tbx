  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zentzumenen edo sentikortasun orokorraren sentsazio anormal eta desatsegina, ez-mingarria, inurridura- edo sorgortze-moduko sentsazio gisa nabarmentzen dena; nerbio-sistema zentraleko nahiz nerbio-sistema periferikoko egituren edozein ataletan gertatutako patologia batek sortu ohi du.</descrip>
    </descripGrp>
