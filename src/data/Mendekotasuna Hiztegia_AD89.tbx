    </tig>
    <tig>
      <term>OA</term>
    </tig>
    <tig>
      <term>arthrosis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Borondatezko mugimenduen koordinazio txarra eragiten duen nahasmendua, zerebeloko eta orno-muineko atzeko kordoietako edo adarretako lesioengatik gertatu ohi dena.</descrip>
    </descripGrp>
    <tig>
      <term>ataxia</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ataxia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>ataxie</term>
    </tig>
  </langSet>
