  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>stupor</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Inguruneko faktoreak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona baten ingurunean egoteagatik edo faltatzeagatik, funtzionamendua hobetu eta desgaitasuna murrizten duten faktoreetako bakoitza. Faktore horien artean, hauek sartzen dira: ingurune fisiko irisgarria izatea, eskura dagoen laguntzako teknologia egokia izatea, biztanleriak desgaitasunari buruz jarrera positiboak izatea eta bizitzaren eremu guztietan osasun-egoera jakin bat duten pertsonen parte-hartzea areagotzen saiatzen diren zerbitzu, sistema eta politikak izatea.</descrip>
    </descripGrp>
    <tig>
      <term>faktore erraztaile</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
    <tig>
