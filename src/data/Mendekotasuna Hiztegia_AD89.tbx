    </tig>
    <tig>
      <term>perte auditive</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>hearing loss</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
