</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Zerbitzuak eta prestazioak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mendekotasuna duten pertsonei beren familiako edo inguruko pertsonek, hau da, arreta pertsonalizatuko zerbitzu batekin lotuta ez dauden pertsonek, etxean emandako laguntza-zerbitzua.</descrip>
