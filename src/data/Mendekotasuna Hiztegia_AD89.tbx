      <term>domaine</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>domain</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>FNSko osagaietako bakoitza deskribatzeko edo aldatzeko erabiltzen diren kalifikatzaileen multzoa. Gaitasuna, performantzia eta funtzionamenduan edo gorputz-egituretan izandako aldaketak, esaterako, konstruktuak dira.</descrip>
    </descripGrp>
    <tig>
      <term>konstruktu</term>
      <termNote type='normativeAuthorization'>5</termNote>
    </tig>
  </langSet>
