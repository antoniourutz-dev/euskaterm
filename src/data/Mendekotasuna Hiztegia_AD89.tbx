<termEntry id="-1">
  <descrip type='subjectField'>Gorputz-funtzioak eta gorputz-egiturak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alfred Binetek eta Théodore Simonek haurren eta nerabeen adimena neurtzeko sortutako eskala, lehen aldiz 1914an erabili zena.</descrip>
    </descripGrp>
    <tig>
