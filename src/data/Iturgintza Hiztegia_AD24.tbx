<termEntry id="-1">
  <descrip type='subjectField'>Balbulak eta txorrota-motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hodi-sarean sortzen diren presio-kolpeak orekatzeko gailua; era askotakoak daude (aire-kuxinezkoak, malgukizkoak, mintzezkoak), eta gorako hodien punturik gorenetan jartzen dira, uraren abiada edo emaria handiak diren lekuan.</descrip>
    </descripGrp>
    <tig>
      <term>ahari-kolpearen kontrako balbula</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
