    <tig>
      <term>dispositif antibélier</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>non-concussive valve</term>
    </tig>
    <tig>
      <term>water-hammer arrester</term>
    </tig>
    <tig>
      <term>water hammer shock arrestor</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Balbulak eta txorrota-motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Flotagailu batek eraginda funtzionatzen duen balbula; flotagailua aurrez ezarritako maila batera iristen denean, itxi egiten da ur-iturria.</descrip>
