  <descrip type='subjectField'>Balbulak eta txorrota-motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irteerako hodiarekin angelu bat eratzen duela jartzen den balbula. Higiene-ontzietako ur-sarrerak ixteko jartzen da, adibidez (ur hotzarentzat bat, eta beroarentzat beste bat).</descrip>
