<termEntry id="-1">
  <descrip type='subjectField'>Balbulak eta txorrota-motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bloke berean bi aginte eta irteerako aho bat dituen txorrota; aginte batek ur beroa kontrolatzen du, besteak hotza, eta biak konbinatuz lortzen da ur-tenperatura epela.</descrip>
    </descripGrp>
    <tig>
      <term>monoblok txorrota</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>bi aginteko txorrota</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
