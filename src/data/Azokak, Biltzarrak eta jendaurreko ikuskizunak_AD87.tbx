  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aldez aurretik hitzartutako talde-otorduak prestatzen espezializatutako sukaldaritza zerbitzua; janariaz eta edariaz gain, normalean, barne hartzen ditu garraio-zerbitzua, janaria berotzeko azpiegitura eta mahai-tresneria ere.</descrip>
