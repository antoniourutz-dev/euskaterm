  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ehiztari-talde handi batek eremu handi batean ehiza larria guztiz nekatu arte jarraitzean datzan ehiza-metodoa. Oinez edo zaldi gainean eta arrasto-txakur askoz lagunduta ehizatzen da.</descrip>
