  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irabazi-asmorik gabe kudeatzen den ehiza-barrutia, ehizatzeko baldintzak bete arren, beste mota batzuetako ehiza-lurrak erabil ezin ditzaketen herritarrei ehizan aritzeko aukera erraztea helburu duena.</descrip>
