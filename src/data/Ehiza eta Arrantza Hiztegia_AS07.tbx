  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ehizarako debekatutako eremua, betiere ehiza-lur, araubide bereziko eremu edo fauna-babesleku gisa deklaratu ez bada, edo, legez, aurrez ikusitako beste zehaztapenen bidez ehizarako debekua ezarri bazaio.</descrip>
