<termEntry id="-1">
  <descrip type='subjectField'>Infekzioaren tratamendua</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gaixotasun bat organismo batean diagnostikatu ondoren erantzun immunitario jakin bat eragiteko erabil daitekeen txertoa.</descrip>
    </descripGrp>
    <tig>
      <term>txerto terapeutiko</term>
