  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>GIBak eragindako infekzioaren azken fasean agertu ohi den sindromea, infekzio oportunistak edo neoplasiak izatea ezaugarritzat duena.</descrip>
