  <descrip type='subjectField'>Epidemiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Azterketa epidemiologiko jakin batean, gaixotasun batek jotako pertsonen kopurua, azterketak kontuan hartzen duen populazio osoarekiko kalkulatua. Gaixotasun-kasu berriak nahiz zaharrak barne hartzen ditu prebalentziak.</descrip>
    </descripGrp>
