  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>DNA- edo RNA-sekuentzia baten kopia asko azkar lortzeko <i>in vitro</i> teknika, birus-karga neurtzeko edo infekzioaren diagnostikoa egiteko erabil daitekeena. DNA- edo RNA-sekuentzia kantitate txikitan dagoenean, erabilgarria da, detekziorako aukerak handitzen baititu.</descrip>
    </descripGrp>
    <tig>
      <term>polimerasaren kate-erreakzio</term>
