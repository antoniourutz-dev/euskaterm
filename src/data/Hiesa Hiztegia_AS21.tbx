    <tig>
      <term>transfert de Western</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>Western blot</term>
    </tig>
    <tig>
      <term>Western transfer</term>
    </tig>
  </langSet>
</termEntry>
