</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Infekzioaren prebentzioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gaixotasun infekzioso batek organismo bati kalte egin aurretik erantzun immunitario jakin bat eragiteko erabil daitekeen txertoa. Gaur egun, ez dago GIBaren aurkako txerto profilaktikorik, baina, GIBagatiko infekzioetan, infekzio oportunista jakin batzuei aurrea hartzeko erabil daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>txerto profilaktiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>vacuna profiláctica</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>vaccin prophylactique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>prophylactic vaccine</term>
    </tig>
  </langSet>
</termEntry>
