<termEntry id="-1">
  <descrip type='subjectField'>Infekzioaren diagnostikoa eta lotutako patologiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Proteina espezifikoak detektatzen dituen teknika, transferentzia elektrikoaren bidez egiten dena. GIBaren infekzioaren proba diagnostiko gisa erabiltzen da.</descrip>
    </descripGrp>
    <tig>
      <term>Western blot</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>Western transferentzia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Western blot</term>
    </tig>
    <tig>
      <term>transferencia Western</term>
    </tig>
  </langSet>
