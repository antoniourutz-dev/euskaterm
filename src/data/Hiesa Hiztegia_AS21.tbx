  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>B linfozitoetan antigorputz-kopuru normala izateko eta immunitate zelular normala lortzeko beharrezkoa den T linfozitoa. Immunitate zelularraren eragile nagusia da. T linfozito laguntzailea da GIBak infektatzen duen linfozito-mota.</descrip>
