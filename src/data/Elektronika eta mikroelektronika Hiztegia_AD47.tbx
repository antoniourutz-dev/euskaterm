<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Elektroien fluxuan gertatzen diren fenomenoak aztertzen eta erabiltzen dituen jakintzagaia; jakintzagai horretan oinarritutako teknologia.</descrip>
