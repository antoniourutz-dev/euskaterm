  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>EDO atearen kontrako emaitza ematen duen ate logikoa. Aldagai guztiek 0 izan beharko dute, irteera 1 izateko; aldagaietako bat 1 bada, irteera 0 izango da.</descrip>
