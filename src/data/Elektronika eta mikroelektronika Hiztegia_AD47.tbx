      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>transistor bidireccional</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
