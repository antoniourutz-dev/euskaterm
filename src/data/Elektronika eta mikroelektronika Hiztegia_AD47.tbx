<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irteerako tarte dinamikoa sarrerakoa baino murritzagoa egiten duen gailua.</descrip>
    </descripGrp>
