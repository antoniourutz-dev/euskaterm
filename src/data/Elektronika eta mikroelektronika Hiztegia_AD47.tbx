<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hainbat materialen ezaugarri piezoelektrikoa erabiltzen duen transduktorea. Material horien gainazalak elektrizitatez kargatzen dira eragin mekanikoaren ondorioz.</descrip>
