  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi eroale zentrokidez osatutako kablea. Bi eroaleak dielektriko bitartez isolatuta eta kanpo-geruza batez inguratuta daude.</descrip>
