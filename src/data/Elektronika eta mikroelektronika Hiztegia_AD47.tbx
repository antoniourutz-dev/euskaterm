  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Funtzioak berariazko aplikazio baten bidez programatuak izaten dituen zirkuitu logikoa; hau da, zirkuitua fabrikatu eta gero programatzen dira funtzioak.</descrip>
