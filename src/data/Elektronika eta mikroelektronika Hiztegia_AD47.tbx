  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irteeran tentsio konstantea eskaintzeko funtzioa duen gailua. Korronte zuzeneko elikatze-iturri erregulatuetan ezarri ohi da.</descrip>
