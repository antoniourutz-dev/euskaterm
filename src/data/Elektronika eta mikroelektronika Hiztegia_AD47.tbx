<termEntry id="-1">
  <descrip type='subjectField'>Elektronika digitala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Seinale analogiko jarraituak bit-korronte digital bihurtu eta sarrerako seinale digitalak deskodetzen eta modu analogikoan itzultzen dituen gailua.</descrip>
    </descripGrp>
