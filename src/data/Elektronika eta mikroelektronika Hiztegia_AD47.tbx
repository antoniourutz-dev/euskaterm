<termEntry id="-1">
  <descrip type='subjectField'>Elektronika digitala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eragiketa logikoak egiten dituen zirkuitu elektronikoa, hainbat ate eta funtzio logikoz osatua.</descrip>
    </descripGrp>
    <tig>
      <term>zirkuitu logiko</term>
