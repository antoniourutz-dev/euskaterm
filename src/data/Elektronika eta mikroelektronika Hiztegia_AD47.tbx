</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zirkuitu edo multzo batean, banaka eta bereiz ezartzen den elementua. Osagai integratuak ez bezala, elementu hori multzotik askatzeko aukera dago.</descrip>
    </descripGrp>
