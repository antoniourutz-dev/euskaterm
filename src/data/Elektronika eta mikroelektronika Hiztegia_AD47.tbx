<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Potentzia elektrikoa kontrolatzeko eta transformatzeko aplikazio teknikoez arduratzen den elektronikaren atala.</descrip>
