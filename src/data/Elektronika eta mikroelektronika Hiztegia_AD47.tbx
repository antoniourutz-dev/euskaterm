    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>intrinsic semiconductor</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eramaile positibo (hutsune) baino eramaile negatibo (elektroi aske) gehiago dituen erdieroale estrintsekoa. Eramaile ugarienak (eramaile maioritarioak) elektroiak dira.</descrip>
