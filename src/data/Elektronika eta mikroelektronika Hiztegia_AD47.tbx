  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irteera egiazkoa izateko aldagaiak desberdin izatea eskatzen duen eragiketa boolearrari dagokion ate logikoa. Aldagaiek desberdinak izan behar dute irteera 1 izateko; aldagaiak berdinak badira, irteera 0 izango da.</descrip>
