      <term>registre à décalage</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>shift register</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika digitala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Desplazamendu-erregistro mota bat: idaztean sartu den lehen bita izango da irakurtzean lehen irtengo dena.</descrip>
