      <term>rectificador controlado de silicio</term>
    </tig>
    <tig>
      <term>SCR</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>redresseur commandé au silicium</term>
    </tig>
    <tig>
      <term>RCS</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>silicon controlled rectifier</term>
    </tig>
    <tig>
      <term>SCR</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sarrerako tentsio alterno baten ziklo-erdi positiboa bakarrik pasatzen uzten duen zirkuitua.</descrip>
