    <tig>
      <term>transistor bipolar de unión</term>
    </tig>
    <tig>
      <term>transistor bipolar</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>transistor bipolaire à jonctions</term>
    </tig>
    <tig>
      <term>transistor bipolaire</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
