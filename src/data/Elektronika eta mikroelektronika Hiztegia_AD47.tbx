    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>bus</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika digitala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sistema logiko baten osagai guztiak koordinatzeko behar diren kontrol-seinaleak garraiatzen dituen busa.</descrip>
