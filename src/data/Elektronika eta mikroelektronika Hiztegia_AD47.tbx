  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Serie/paralelo eta paralelo/serie bihurketak egiten dituen zirkuitu integratua; bit bakar bateko linea batetik seriean transmititzeko egiten du bihurketa, igorpenean transmisio asinkronoari dagozkion hasierako eta bukaerako bitak erantsiz.</descrip>
