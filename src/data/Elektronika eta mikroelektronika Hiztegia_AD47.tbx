<termEntry id="-1">
  <descrip type='subjectField'>Elektronika digitala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zirkuitu baten plakan edo multzo konplexuago baten egituran txertatuta dagoen elementua. Osagai diskretuak ez bezala, ezin da elementu hori banaka ezarri edo askatu.</descrip>
    </descripGrp>
