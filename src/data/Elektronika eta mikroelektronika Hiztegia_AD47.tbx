    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>électronique numérique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>digital electronics</term>
    </tig>
  </langSet>
</termEntry>
