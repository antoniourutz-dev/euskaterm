    <tig>
      <term>circuito secuencial</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>circuit séquentiel</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>sequential circuit</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sarrerako seinaleen baturarekiko proportzionala den irteera-tentsioa ematen duen zirkuitua. Sarrera-kopurua eta batu nahi den tentsio-kopurua berdinak dira.</descrip>
    </descripGrp>
    <tig>
      <term>zirkuitu batutzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>batugailu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>circuito sumador</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>circuit additionneur</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>adding circuit</term>
    </tig>
  </langSet>
</termEntry>
