  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Integrazio-eragiketa egiteko gai den zirkuitua.</descrip>
    </descripGrp>
    <tig>
      <term>zirkuitu integratzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
