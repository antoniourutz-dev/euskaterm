    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>printed circuit</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika digitala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Material erdieroalezko txip bakarrean egindako zirkuitu elektronikoa, tamaina txikikoa, osagai aktibo eta pasibo ugariz eratua. Funtzio logiko edo lineal espezifikoa betetzen du; funtzioa oso konplexua izan daiteke (mikroprozesadorea, adibidez) edo kuantitatiboki handia (memoria, adibidez).</descrip>
    </descripGrp>
    <tig>
      <term>zirkuitu integratu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
