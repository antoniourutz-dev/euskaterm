    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>half-wave rectifier</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sarrerako tentsio alterno garbi batetik abiatuz irteeran seinale positibo hutsa lortzen duen zirkuitua; ziklo-erdi positiboa pasatzen uzten du, eta negatiboa alderantzikatu egiten du.</descrip>
