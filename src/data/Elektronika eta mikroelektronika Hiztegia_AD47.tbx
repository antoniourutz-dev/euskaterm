  <descrip type='subjectField'>Elektronika digitala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Une jakin bateko irteera-egoera une horretako sarrera-egoeraren mende bakarrik dagoen zirkuitu logikoa; hau da, sarreren aurretiko egoerak ez du inolako eraginik.</descrip>
