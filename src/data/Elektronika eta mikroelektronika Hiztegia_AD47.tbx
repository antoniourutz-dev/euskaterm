      <term>rectifier</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Diodo artezle kontrolatu gisa funtzionatzen duen artezgailua, korrontea noranzko bakarrean pasatzen uzten duena. Hiru terminal dauzka: anodoa, katodoa eta atea. Atean tentsioa aplikatzen ez den bitartean ez du korrontea pasatzen uzten.</descrip>
    </descripGrp>
    <tig>
