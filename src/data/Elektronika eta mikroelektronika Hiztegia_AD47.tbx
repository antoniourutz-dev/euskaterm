<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Elektrikoki edo elektromagnetikoki eragindako kommutadorea, kontrol-zirkuitu batek beste bat eten eta/edo ixteko erabiltzen dena.</descrip>
