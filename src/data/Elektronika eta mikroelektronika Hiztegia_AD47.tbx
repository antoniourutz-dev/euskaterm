  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kanpoko interferentzia elektrikoez babesteko kanpo-elementu bat duen kablea. Oro har, kablearen kanpoaldean ezartzen den eroale elektriko bat izan ohi da babes-elementu hori; adibidez, metalezko sare bat.</descrip>
