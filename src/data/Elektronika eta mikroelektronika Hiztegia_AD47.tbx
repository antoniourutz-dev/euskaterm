  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gai isolatzaileen eta gai eroaleen arteko ezaugarri elektrikoak dituen materiala. Erdieroaleak isolatzaileak dira eroankortasuna kontuan hartuz gero, baina ezaugarriak alda ditzakete ezartzen zaizkien hainbat baldintzaren arabera. Ezagunenak silizioa eta germanioa dira.</descrip>
    </descripGrp>
    <tig>
      <term>erdieroale</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>semiconductor</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>semi-conducteur</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>semiconductor</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Taula periodikoko talde desberdinetako bi elementuz edo gehiagoz osaturiko konposatu erdieroalea. Garrantzitsuenak, egun, AsGa (bi elementuz osatua), InGaAs (hiru) eta AlInGaP (lau) dira; banda-zuzenekoak direnez, argia silizioak baino efizientzia askoz handiagoz igortzen dute, eta optoelektronikan eta LED eta laser diodoetan ezinbestekoak dira.</descrip>
    </descripGrp>
    <tig>
      <term>erdieroale konposatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>semiconductor compuesto</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>semi-conducteur composé</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>compound semiconductor</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Metalezko, oxidozko eta erdieroalezko geruza bana bata bestearen gainean ezarriz zirkuitu integratuak fabrikatzeko erabiltzen den egitura. Hiru geruza horiek aluminiozkoa, silizezkoa eta siliziozkoa izan daitezke, hurrenez hurren.</descrip>
    </descripGrp>
    <tig>
      <term>metal oxidozko erdieroale</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>MOS</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>metal óxido semiconductor</term>
    </tig>
    <tig>
      <term>MOS</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>semi-conducteur d'oxyde de métal</term>
    </tig>
    <tig>
      <term>MOS</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>metal oxide semiconductor</term>
    </tig>
    <tig>
      <term>MOS</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eroankortasun elektrikoa handitzeko ezpurutasunen bat gehituta duen erdieroalea. Ezpurutasun hori izan daiteke fosforoa, antimonioa, artsenikoa, boroa, galioa edo indioa, besteak beste.</descrip>
    </descripGrp>
    <tig>
      <term>erdieroale estrintseko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>semiconductor extrínseco</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>semi-conducteur extrinsèque</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>extrinsic semiconductor</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Elementu bakar eta hutsez eratutako erdieroalea; adibidez, germanio edo silizio hutsez osatutakoa.</descrip>
    </descripGrp>
    <tig>
      <term>erdieroale intrintseko</term>
