    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>circuit intégré</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>integrated circuit</term>
    </tig>
  </langSet>
</termEntry>
