<termEntry id="-1">
  <descrip type='subjectField'>Elektronika digitala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Biegonkor-kate batek osatutako erregistroa; informazioak osoki dekalatzen dira biegonkor batetik bestera, noranzko batean edo bestean, erloju-seinale baten erritmoan.</descrip>
