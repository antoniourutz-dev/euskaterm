</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tentsioa edo korronte-irabazia emateko gai den osagaia; seinaleak sortzeko, anplifikatzeko edo eraldatzeko gaitasuna du. Adibidez, transistorea edo tiristorea.</descrip>
    </descripGrp>
