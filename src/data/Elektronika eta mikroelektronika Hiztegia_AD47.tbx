  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ardatz baten inguruan hari eroalezko hainbat kiribil ezarriz egiten den induktantzia. Kiribilak zeharkatzen dituen korronte elektrikoak eremu magnetiko bat eratzen du.</descrip>
