      <term>integrate component</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Seinale optikoen eta elektrikoen arteko transduktore gisa funtzionatzen duen osagaia.</descrip>
