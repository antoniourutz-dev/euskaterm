  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ezeztapenaren funtzio boolearrari dagokion ate logikoa. Aldagaia ukatu egiten du, aldagaia ez den beste irteera bat sortuko du.</descrip>
