      <term>thermoelectric transducer</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Elektronika analogikoa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Indukzio elektromagnetikoa erabiliz eta potentzia eta maiztasuna mantenduz tentsioa igotzeko edo jaisteko erabiltzen den osagaia.</descrip>
