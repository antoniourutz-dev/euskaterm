<termEntry id="-1">
  <descrip type='subjectField'>Elektronika digitala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sistema logiko baten osagaien artean datuak transmititzen dituen busa. Zenbat bit dituen sistemak darabilen hitz edo datuak, hainbat eroale izango ditu busak; gehien erabiltzen diren formatuak 4, 8, 16, 32 edo 64 bitekoak dira.</descrip>
    </descripGrp>
