  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>50 langile baino gutxiago dituzten enpresetan, langile guztien ordezkaritza bateratua gauzatzeko, langile guztiek hautatzen duten ordezkaria. Langileen ordezkari bat edo hiru izan ditzakete 50 langile baino gutxiagoko enpresek.</descrip>
