<termEntry id="102">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmen kolektibo berri bat adosten denean, hitzarmen berriak zaharra ordeztu behar duela ezartzen duen printzipioa.</descrip>
    </descripGrp>
    <tig>
      <term>modernitate-printzipio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
