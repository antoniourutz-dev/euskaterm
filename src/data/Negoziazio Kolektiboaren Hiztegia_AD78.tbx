<termEntry id="36">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Indarrean dauden bi hitzarmenek aplikazio-eremu bera arautzen dutenean, zein aplikatuko den ebazteko arauak.</descrip>
    </descripGrp>
    <tig>
      <term>hitzarmenen konkurrentzia-arauak</term>
