  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmen kolektiboa negoziatzeko eta adosteko, gizarte-jarlekuak eta jarleku ekonomikoak osatutako batzordea.</descrip>
