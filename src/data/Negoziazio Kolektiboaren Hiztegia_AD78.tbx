      <term>reglas de concurrencia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="37">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmen kolektiboa negoziatzen duen alderdi bakoitzeko ordezkaritza. Enpresa bakar bateko hitzarmena negoziatzean, langileen ordezkariak (adibidez, enpresa-batzordeko kideak edo delegatu sindikalak) eta enpresaren ordezkariak izango dira subjektu negoziatzaileak; sektore bateko hainbat enpresetako hitzarmena negoziatzean, berriz, sektoreko sindikatuek hautatutako ordezkariez eta sektoreko enpresa-elkarteak baimendutako ordezkariez gainera, ordezkari horien aholkulariek eta Lan Ministerioko bitartekariak ere parte har dezakete.</descrip>
    </descripGrp>
    <tig>
      <term>subjektu negoziatzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
