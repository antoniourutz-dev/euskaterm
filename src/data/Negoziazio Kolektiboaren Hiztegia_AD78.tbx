    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ultraactividad del convenio</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="107">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmena negoziatzen duten alderdiek adostutako epea, haren indarraldi juridikoa zehazten duena.</descrip>
    </descripGrp>
    <tig>
      <term>hitzarmenaren indarraldi</term>
