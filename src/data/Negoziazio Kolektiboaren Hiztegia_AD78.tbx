    </tig>
  </langSet>
</termEntry>
<termEntry id="103">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Indarrean dagoen hitzarmen kolektiboa automatikoki luzatzeari uko egiten diola adieraziz, alderdietako batek besteari egiten dion legezko jakinarazpena.</descrip>
    </descripGrp>
    <tig>
      <term>hitzarmena salatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>denuncia del convenio</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="104">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alderdi negoziatzaileek adosten duten hitzarmenaren iraupen-denbora. Bestelakorik zehazten ez bada, eta alderdietako batek salatzen ez badu, hitzarmena urtetik urtera luzatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>hitzarmen kolektiboaren iraupen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>duración del convenio colectivo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="105">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>hitzarmenaren luzapen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
