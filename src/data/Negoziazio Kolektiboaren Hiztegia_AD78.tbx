<termEntry id="35">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lanbide arteko esparru-akordioen bidez, negoziazio-unitate desberdineko hitzarmen kolektiboak era egituratuan eta osagarrian antolatzen dituen negoziazio kolektiboa.</descrip>
    </descripGrp>
