      <term>prórroga del convenio</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="106">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmen kolektiboek 2012ko lan-erreforma arte zuten ezaugarria, hitzarmen berri bat adostu arte, salatutako hitzarmenaren eduki arauemailea bere hartan iraunarazten zuena, eta berebeharren edukia indargabetzen zuena.</descrip>
    </descripGrp>
    <tig>
      <term>hitzarmenaren aurreraeragin</term>
