<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE martif PUBLIC "ISO 12200:1999A//DTD MARTIF core (DXFcdV04)//EN" "TBXcdv04.dtd">
<martif type="TBX" xml:lang="en">
  <martifHeader>
    <fileDesc>
      <titleStmt>
        <title>Negoziazio Kolektiboaren Hiztegia</title>
      </titleStmt>
      <sourceDesc>
        <p>Negoziazio Kolektiboaren Hiztegiaren TBX esportazioa</p>
      </sourceDesc>
    </fileDesc>
  </martifHeader>
<text>
<body>
<termEntry id="1">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmen kolektibo aplikagarririk ez dagoenean, enpresa jakin bateko enpresaburuaren eta langileen ordezkarien artean, langileen estatutuak aurrez ikusitako arazo zehatzei buruz lortutako akordioa.</descrip>
    </descripGrp>
    <tig>
      <term>enpresa-akordio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acuerdo entre la empresa y los representantes de los trabajadores</term>
    </tig>
    <tig>
      <term>acuerdo de empresa</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="2">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Negoziazio kolektiboari buruzko klausulak ezartzen dituen lanbide arteko hitzarmena. Hala dagokionean, hitzarmenen konkurrentzia konpontzeko erregelak ere jasotzen ditu. Estatu osorako edo autonomia-erkidego baterako hitzarmena izan daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>lanbide arteko esparru-akordio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acuerdo marco interprofesional</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="3">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lan-harremanetako gai jakin bat edo gehiago arautzen dituen lanbide arteko hitzarmena, enpresaburuen eta sindikatu nagusien artean sinatzen dena. Estatu osorako edo autonomia-erkidego baterako hitzarmena izan daiteke, eta zuzenean aplikatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>gai zehatzen gaineko akordio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acuerdo sobre materia concreta</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="4">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Batetik, ekonomia-mendekotasuneko langile autonomoak ordezkatzen dituzten elkarteen edo sindikatuen, eta, bestetik, langile horien lanbide-jarduera kontratatzen duten enpresen arteko hitzarmena; lanbide-jardueraren modu-, denbora- eta leku-baldintzak, edota kontratazioaren beste baldintza orokor batzuk arautzen ditu. Lanbide-intereseko akordioen eraginkortasun pertsonala alderdi sinatzaileetara mugatzen da, eta, hala dagokionean, autonomoen elkarte edo sindikatu sinatzaileetan afiliatutako pertsonetara, betiere, afiliatu horiek horretarako esanbidezko adostasuna eman badute.</descrip>
    </descripGrp>
    <tig>
      <term>lanbide-intereseko akordio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acuerdo de interés profesional</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="5">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beren esparruko lan-harreman indibidualen eta kolektiboen baldintzak hitzarmen edo itun bidez arautzeko, langileek eta enpresaburuek duten autonomia.</descrip>
    </descripGrp>
    <tig>
      <term>autonomia kolektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>autonomía colectiva</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="6">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>autorregulazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>autorregulación</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="7">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>negoziazio kolektiborako eskubide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>derecho a la negociación colectiva</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="8">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Enplegatu publikoen oinarrizko estatus juridikoa ezartzen duen legea.</descrip>
    </descripGrp>
    <tig>
      <term>Enplegatu Publikoaren Oinarrizko Estatutua</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Estatuto Básico del Empleado Público</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="9">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>Langileen Estatutua</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Estatuto de los Trabajadores</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="10">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <tig>
      <term>zuzenbidearen iturri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>fuente de derecho</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="11">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langileen eta enpresaburuen autonomia kolektibotik kanpo, lan-arloko botere publikoek ezartzen duten araua. Aginduzko zuzenbidearen agerpena da, lan-kontratuko nahiz hitzarmen kolektiboko alderdien borondatez aldarazi ezin diren zenbait betebehar, debeku, betekizun eta eskaerari erreferentzia egiten diena.</descrip>
    </descripGrp>
    <tig>
      <term>heteronomia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>arau heteronomo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>heteronomía</term>
    </tig>
    <tig>
      <term>norma heterónoma</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="12">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>1. Sindikatuak sortzeko, sindikatuetara afiliatzeko eta jarduera sindikala gauzatzeko langileek duten askatasuna; 2. Sindikatuek jarduera sindikala autonomiaz garatzeko duten askatasuna.</descrip>
    </descripGrp>
    <tig>
      <term>sindikatu-askatasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>askatasun sindikal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>libertad sindical</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="13">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Funtzionario publikoen negoziazioaren esparruan sinatzen den hitzarmena; hura sinatzen duen administrazio publikoko organoaren eskumenaren barruan dauden gaiei buruzkoa da.</descrip>
    </descripGrp>
    <tig>
      <term>itun kolektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>pacto colectivo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="14">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Negoziazioan enpresaburuen interesen defentsa egiten duen alderdia, alegia, enpresaburua (enpresako esparruan) edo enpresaburu-elkartea (sektoreko esparruan).</descrip>
    </descripGrp>
    <tig>
      <term>enpresaburuen ordezkariak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>enpresako ordezkariak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>representantes de la empresa</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="15">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Negoziazioan langileen interesen defentsa egiten duen alderdia, alegia, enpresa-batzordea, langileen delegatua edo delegatuak (enpresako esparruan) edo sindikatu-ordezkaritza (enpresako esparruan nahiz sektorean).</descrip>
    </descripGrp>
    <tig>
      <term>langileen ordezkariak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>representantes de los trabajadores</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="16">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Negoziazio kolektiboaren emaitza den kontratu arauemailea.</descrip>
    </descripGrp>
    <tig>
      <term>hitzarmen kolektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>convenio colectivo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="17">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langileen estatutuko III. tituluak ezarritakoaren arabera negoziatu den hitzarmen kolektiboa. Eraginkortasun pertsonal orokorra du, eta bere eremuko langile eta enpresa guztiei aplikatzen zaie, beren afiliazioa edozein dela ere.</descrip>
    </descripGrp>
    <tig>
      <term>estatutuaren araberako hitzarmen kolektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>convenio colectivo estatutario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="18">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langileen estatutuko III. tituluak ezarritakoari jarraitu gabe negoziatu den hitzarmen kolektiboa. Eraginkortasun pertsonal mugatua du, eta hitzarmena adostu duten enpresaburuen elkarte eta sindikatuetara afiliatutakoei soilik aplikatzen zaie.</descrip>
    </descripGrp>
    <tig>
      <term>estatutuz kanpoko hitzarmen kolektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>convenio colectivo extraestatutario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="19">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Enpresa baino aplikazio-eremu zabalagoa duen hitzarmen kolektiboa, jarduera ekonomiko bereko enpresei aplikatzen zaiena.</descrip>
    </descripGrp>
    <tig>
      <term>enpresaz gaindiko hitzarmen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>sektoreko hitzarmen kolektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>convenio de ámbito superior a la empresa</term>
    </tig>
    <tig>
      <term>convenio supraempresarial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="20">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Enpresa bakarrera mugatutako aplikazio-eremua duen hitzarmen kolektiboa.</descrip>
    </descripGrp>
    <tig>
      <term>enpresa-hitzarmen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>enpresako hitzarmen kolektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>convenio de empresa</term>
    </tig>
    <tig>
      <term>convenio colectivo de empresa</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="21">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aplikazio-eremu pertsonal murriztua duen hitzarmena, multzo bereko, kategoria bereko, lantoki bereko, titulazio bereko edo sail bereko langileei aplikatzen zaiena.</descrip>
    </descripGrp>
    <tig>
      <term>enpresa azpiko banda-hitzarmen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>bandako hitzarmen kolektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>convenio colectivo de franja</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="22">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lan-zuzenbideko iturri batek gutxieneko lan-baldintzak bermatzen dituenean, baldintza horiek okerragotzeko ezintasuna.</descrip>
    </descripGrp>
    <tig>
      <term>in peius indargabetze-ezintasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>inderogabilidad in peius</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="23">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lan-zuzenbideko arauen arteko harreman-mota, arau batek beste bat osatzen duenean ezartzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>osagarritasun-harreman</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>osatze-harreman</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>relación de complementariedad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="24">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lan-zuzenbideko arauen arteko harreman-mota, aplikatu beharreko arau batek beste araurik aplikatu ezina dakarrenean ezartzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>baztertze-harreman</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>relación de exclusión</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="25">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lan-zuzenbidean, gai beraren inguruan bi arauren artean ezar daitekeen harreman-mota, betiere arau horietako baten xedapen-hutsunearen ordez beste arauak ezarritakoa aplikatzen denean gertatzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>ordezko harreman</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>relación de supletoriedad</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="26">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Legez arautua egon den gai bat alderdi kolektiboen esku uztea.</descrip>
    </descripGrp>
    <tig>
      <term>hitzarmenaren aldeko deslegeztatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>hitzarmenaren aldeko deslegalizazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>repliegue legal a favor del convenio</term>
    </tig>
    <tig>
      <term>deslegalización</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="27">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Indarrean dagoen hitzarmen bati atxikitzeko, alderdi negoziatzaileek lortzen duten adostasuna.</descrip>
    </descripGrp>
    <tig>
      <term>hitzarmen kolektiboari atxikitze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>hitzarmenari atxikitze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>adhesión a un convenio</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="28">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmen kolektiboak lotzen dituen enpresen eta langileen multzoa. Erabiltzen diren sailkapen-irizpideen arabera, aplikazio-eremua funtzionala, lurraldekoa edo pertsonala izan daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>hitzarmenaren aplikazio-eremu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>hitzarmenaren negoziazio-unitate</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ámbito de aplicación</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="29">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmenaren hedadura zehazten duen irizpidea: enpresakoa, enpresa azpikoa edo enpresaz gaindikoa izan daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>eremu funtzional</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ámbito funcional</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="30">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmen kolektiboa aplikatzen zaien langileen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>pertsona-eremu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>eremu pertsonal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ámbito personal</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="31">
  <descrip type='subjectField'>Negoziazio kolektiboa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hitzarmenaren indarraldia, noiz hasten den eta zenbat iraungo duen zehazten duena.</descrip>
