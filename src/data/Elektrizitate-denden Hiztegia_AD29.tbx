<termEntry id="1">
  <descrip type='subjectField'>Kableak eta instalazio-elementuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Argindarra hornitzen duen enpresak etxebizitza bakoitzeko instalazio elektrikoaren hasieran jartzen duen etengailu automatikoa, bezeroak kontratatutako potentziaren arabera.</descrip>
    </descripGrp>
    <tig>
      <term>potentzia-kontrolatzeko etengailu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>interruptor de control de potencia</term>
    </tig>
    <tig>
      <term>ICP</term>
    </tig>
  </langSet>
</termEntry>
