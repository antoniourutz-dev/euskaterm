    </tig>
    <tig>
      <term>collaborative blog</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Blogek, blogariek eta haien arteko konexio eta interakzioek osatutako komunitate edo sistema.</descrip>
