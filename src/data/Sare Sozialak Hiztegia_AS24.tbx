<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Facebooken moduko sare sozialetan, erabiltzaile baten profilean dagoen atal nagusia. Argitaratzen dituen sarrera edo eguneratzeak biltzen ditu, eta lagunek iruzkinak edo estekak parteka ditzakete bertan.</descrip>
