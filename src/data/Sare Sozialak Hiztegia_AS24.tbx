<martif type="TBX" xml:lang="en">
  <martifHeader>
    <fileDesc>
      <titleStmt>
        <title>Sare Sozialak Hiztegia</title>
      </titleStmt>
      <sourceDesc>
        <p>Sare Sozialak Hiztegiaren TBX esportazioa</p>
      </sourceDesc>
    </fileDesc>
  </martifHeader>
<text>
<body>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Web 2.0-ren eta sare sozialen erabiltzailea, aldi berean produktore eta kontsumitzaile dena. Web 2.0 zerbitzuetan eta sare sozialetan bi alderdiak batu ohi dituzte erabiltzaileek.</descrip>
    </descripGrp>
    <tig>
      <term>prosumitzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
      <termNote type='usageNote'>"Produktore" eta "kontsumitzaile" hitzen uztarketaz osatutako terminoa da.</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>prosumidor</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>prosommateur</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>prosumer</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialen motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Argazkiak argitaratzeko eta partekatzeko helburu nagusia duen bloga. Sarrera bakoitzean argazki bat gehitu ohi da; gehienetan, etiketatua.</descrip>
    </descripGrp>
    <tig>
      <term>fotoblog</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>fotoblog</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>blogue photo</term>
    </tig>
    <tig>
      <term>photoblogue</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>photoblog</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Argitaratzeko sisteman sartu den baina oraindik argitaratu ez den sarrera, artikulu edo mezua. Geroago zuzendu edo hobetzeko asmoa dagoenean gorde ohi da sistema horretan.</descrip>
    </descripGrp>
    <tig>
      <term>zirriborro</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>borrador</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>brouillon</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>draft</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>ASCII karaktereekin egindako irudia, albo batetik begiratuta giza aurpegiaren itxura duena. Aurpegiaren espresioarekin bidaltzaileak bere gogo-aldartea adierazten du: adibidez, :) alaitasuna adierazteko, edo :( tristura adierazteko.</descrip>
    </descripGrp>
    <tig>
      <term>emotikono</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>emoticono</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>frimousse</term>
    </tig>
    <tig>
      <term>émoticône</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>emoticon</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialen motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Audio-fitxategiak argitaratzeko eta partekatzeko helburu nagusia duen bloga. Sarrera bakoitzean audio-fitxategi bat gehitu ohi da; gehienetan, etiketatua.</descrip>
    </descripGrp>
    <tig>
      <term>audioblog</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>audioblog</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>blogue audio</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>audioblog</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Berrerabiltzeko, berriro banatzeko edo bertsioak egiteko eskubideei buruz lege-murrizketarik ez duen edozein eduki: testua, irudia, argazkia edo bestelakoa.</descrip>
    </descripGrp>
    <tig>
      <term>eduki ireki</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>eduki libre</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>contenido abierto</term>
    </tig>
    <tig>
      <term>contenido libre</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>contenu libre</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>open content</term>
    </tig>
    <tig>
      <term>free content</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beste erabiltzaile batek lehenago bidalitako txio bat errepikatuz bidaltzen den txioa.</descrip>
