  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Emotikono-mota berezia, jatorriz Japoniakoa, aurpegiaren irudia bertikalean irudikatzen duena; hau da, ez da burua albo batera okertu behar aurpegia ikusteko: adibidez, O_o harridura adierazteko edo >_< mina adierazteko.</descrip>
