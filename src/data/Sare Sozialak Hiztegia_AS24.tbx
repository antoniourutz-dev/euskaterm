  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Facebooken moduko sare sozialetan, enpresa, erakunde edo pertsona publiko batek sor dezakeen espazio berezia. Helburu espezifikoak izateaz gainera, taldeek edo profilek ez bezalako aukerak eskaintzen ditu.</descrip>
