  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sare sozialetan erabiltzaile-izen bat gehitua duen mezu edo argitalpena. Erabiltzaile jakin bati zuzentzeko edo erreferentzia egiteko erabiltzen da.</descrip>
