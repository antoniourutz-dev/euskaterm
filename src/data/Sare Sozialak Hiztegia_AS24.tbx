    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sare sozial batzuetan haur eta nerabeak babesteko ezarri den sistema. Haur edo nerabeenganako abusuren bat detektatzen bada sarean, baliabide hori erabil daiteke agintariei lehenbailehen horren berri emateko.</descrip>
    </descripGrp>
