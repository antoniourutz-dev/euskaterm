<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialen motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabiltzaileak eduki-mota edo gai jakin batekin harremanetan jartzen dituen sarea. Eduki horiek izan daitezke, adibidez: argazkiak (Flickr, Instagram), bideoak (YouTube, Vimeo), musika (Spotify) eta aurkezpenak (Scribd, Slideshare).</descrip>
    </descripGrp>
