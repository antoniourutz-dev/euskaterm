  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Blog-sarrera batera bideratzen duen URL esteka iraunkorra. Sarrera blogeko orrialde nagusitik desagertu eta artxiboetara pasatu eta gero ere esteka ez da aldatzen, eta, horregatik, erraztu egiten du sarrera hori beste blog eta webguneetan modu egonkorrean estekatzea edota geroago berreskuratzeko gordetzea.</descrip>
    </descripGrp>
    <tig>
      <term>permalink</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>permalink</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>permalien</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>permalink</term>
    </tig>
  </langSet>
</termEntry>
