  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Web-sarea datu-base handitzat hartuta, informazio semantikoa eta adimen artifizialaren teknologiak aplikatzeko asmoa luketen web-zerbitzuen multzoa. Nolabait, Interneteko hirugarren belaunaldia eratzen du.</descrip>
