      <term>sidebar</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sare sozialek eskaintzen dituzten ezaugarriez baliatzen den marketineko teknika edo prozedura berezia. Publizitatu nahi den produktu, zerbitzu, ideia edo mezu bati sare sozialen bidez hedapen zabal eta lasterra ematean datza.</descrip>
    </descripGrp>
    <tig>
      <term>marketin biral</term>
      <termNote type='normativeAuthorization'>4</termNote>
