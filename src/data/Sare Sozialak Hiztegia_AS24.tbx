<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Web-jario edo sindikazio-sistema baten bidez multimedia-fitxategiak (audioak, bideoak) banatzeko sistema. Erabiltzaileak fitxategi horiek jasoko ditu, eta nahi duenean erreproduzitzeko aukera izango du.</descrip>
    </descripGrp>
    <tig>
      <term>podcast</term>
      <termNote type='normativeAuthorization'>4</termNote>
