<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialen motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bideoak argitaratzeko eta partekatzeko helburu nagusia duen bloga. Sarrera bakoitzean bideo bat gehitu ohi da; gehienetan, etiketatua.</descrip>
