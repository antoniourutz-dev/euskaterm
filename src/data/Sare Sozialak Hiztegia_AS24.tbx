  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Era guztietako edukia partekatuz harreman horizontala edo parekoa bideratzen duen sarea, adibidez: Facebook, Google plus, Tuenti eta Twitter.</descrip>
