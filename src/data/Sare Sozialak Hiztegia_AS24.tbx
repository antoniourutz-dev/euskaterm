  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Edukien autoreen aitortza egitearekin bat eduki horiek kopiatzeko, aldatzeko edo berriro banatzeko baimena ematen duen lizentzia. Mota honetako lizentziak zehaztea izan da Creative Commons erakundearen helburua.</descrip>
