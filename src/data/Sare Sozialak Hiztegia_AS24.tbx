<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek Interneten bidez proiektatzen duen identitate birtuala. Interneten duen jardueraren bitartez eta gainerako erabiltzaileek pertsona horrekin duten interakzioen bidez osatzen eta formatzen da haren identitate digitala.</descrip>
    </descripGrp>
