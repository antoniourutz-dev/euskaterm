    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabiltzaileei eduki estatikoak pasiboki kontsumitzeko aukera besterik ematen ez dien web-zerbitzuen multzoa. Nolabait, Interneteko lehen belaunaldia eratzen du. Web 2.0 erako zerbitzuen aurrekoa da, hau da, interakzioa eta parte-hartzea ezartzen dituen zerbitzuen aurrekoa.</descrip>
    </descripGrp>
    <tig>
      <term>Web 1.0</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Web 1.0</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
