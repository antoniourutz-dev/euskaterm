    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>retweet</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beste erabiltzaile batek lehenago bidalitako txio bat errepikatzen duen txioa bidali.</descrip>
