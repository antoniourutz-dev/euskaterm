  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sistema informatiko batean sartu, bere burua bikoiztu eta konektatuta dauden sistema eta ordenagailuetara barreiatzen den softwarea.</descrip>
