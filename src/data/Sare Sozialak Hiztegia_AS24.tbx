<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sare sozial bateko erabiltzaile baten profilaren adierazpen grafikoa. Edozein irudi erabil badaiteke ere, profila pertsona bati badagokio, ohikoa izaten da pertsonaren argazkiren bat erabiltzea, eta, marka edo zerbitzu bati badagokio, logotipoa.</descrip>
    </descripGrp>
    <tig>
      <term>avatar</term>
      <termNote type='normativeAuthorization'>4</termNote>
