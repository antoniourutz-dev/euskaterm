    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>Web 1.0</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabiltzaileen artean lankidetza, interakzioa eta informazio-trukea bideratzen dituzten web-zerbitzuen multzoa. Haientzat sortu diren eduki estatikoak pasiboki kontsumitzeaz gainera, erabiltzaileak berak ere eduki-sortzaile dira eredu honetan. Mota honetakoak dira, besteak beste, sare sozialeko zerbitzuak, wikiak, blogak edo folksonomiak. Nolabait, Interneteko bigarren belaunaldia eratzen du.</descrip>
    </descripGrp>
    <tig>
      <term>Web 2.0</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>Web 2.0</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>Web 2.0</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>Web 2.0</term>
    </tig>
  </langSet>
</termEntry>
