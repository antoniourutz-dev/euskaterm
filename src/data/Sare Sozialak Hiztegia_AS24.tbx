<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialen motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabiltzaile guztiek eduki guztietan etiketak gehitzeko aukera eskaintzen duen folksonomia. Ondorioz, erabiltzaile askok elementu berbera etiketa dezakete, eta elementu horren informazioa osatuz joango da. Folksonomia zabalaren adibide ezaguna Delicious da.</descrip>
    </descripGrp>
