  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erabiltzaileak sare sozial baten bidez komunikatzen eta interakzioan ibiltzen diren ingurune edo espazio birtuala.</descrip>
    </descripGrp>
