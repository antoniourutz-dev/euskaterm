    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>panic button</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sare sozial, foro edo Interneteko bestelako komunitate batean, gainerako erabiltzaileak probokatzeko eta gogaitzeko asmoz edo besterik gabe ondo pasatzeko asmoz mezu probokatzaileak edo interesik gabekoak plazaratzen aritzen den pertsona.</descrip>
    </descripGrp>
