<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Facebooken, beste erabiltzaile baten kontaktu-zerrendan dagoen erabiltzailea. Lagun izateko, eskaera bidaltzen da, eta beste profilak onartu egin behar du eskaera hori; horrela, bien artean harremana eratu eta edukiak partekatu ahal izango dituzte.</descrip>
