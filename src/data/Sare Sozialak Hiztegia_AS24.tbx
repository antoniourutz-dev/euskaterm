  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Telefono adimendunen bidezko mezularitzan edo web bidezko komunikazioetan erabiltzen den ideograma edo irudi estandarizatua, jatorriz Japoniakoa eta emotikonoen antzeko funtzioa betetzen duena.</descrip>
