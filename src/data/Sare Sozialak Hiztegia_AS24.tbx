  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sare sozialaren orri edo horma nagusiaren alboan dagoen barra, hainbat funtzio eta aukera eskaintzen dituena.</descrip>
    </descripGrp>
