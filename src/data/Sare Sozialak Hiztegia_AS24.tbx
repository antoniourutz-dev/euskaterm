  <descrip type='subjectField'>Sare sozialen motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Blogari bakarra izan ordez hainbat blogarik idatziz osatzen duten bloga.</descrip>
    </descripGrp>
