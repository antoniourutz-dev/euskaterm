  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Webgune batean egindako eguneratzeen informazio laburtua jasotzen duen fitxategia. Erabiltzaileak bere agregatzailean jaso dezake, baldin eta jario horretara harpidetuta badago.</descrip>
    </descripGrp>
    <tig>
      <term>web-jario</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>fuente web</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>fil d'actualité</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>feed</term>
    </tig>
    <tig>
      <term>web feed</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Termino orokorrak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Webgune batek jasotako bisiten datuak bildu eta analizatzeko tekniken multzoa. Erabiltzaileen ezaugarriak eta portaera aztertzea izan ohi da helburua.</descrip>
    </descripGrp>
    <tig>
      <term>web-analitika</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>analítica web</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>analyse Web</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>Web analytics</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Webgune bateko artikulu edo dokumentu baterako esteka bat jartzen denean webgune horren egileek jakinarazpen bat jasotzeko balio duen sistema. Horri esker, egileak erraz jakingo du bere edukia nor eta non estekatzen ari den.</descrip>
    </descripGrp>
    <tig>
      <term>pingback</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>pingback</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>pingback</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>pingback</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialen motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Webgune jakin batzuk sustatzeko helburu hutsa duen bloga. Webgune horiek bilatzaileetan duten posizioa hobetu nahi izaten dute, gero bertan bisitarien arabera ordaintzen duten publizitate-iragarkiak argitaratzeko asmoz.</descrip>
    </descripGrp>
    <tig>
      <term>splog</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>spam blog</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>splog</term>
    </tig>
    <tig>
      <term>spam blog</term>
    </tig>
  </langSet>
