<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Facebookeko orri batek duen jarraitzailea. Orri hori atsegin izateko botoiari emanez bihurtzen da erabiltzaile bat zale.</descrip>
    </descripGrp>
