    <tig>
      <term>splog</term>
    </tig>
    <tig>
      <term>spam blog</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialen motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Webgune pertsonal edo kolektiboa, aldizka-aldizka eguneratzen dena erabiltzaileak idatzitako sarrera edo artikuluen bitartez. Sarrera edo artikulu horiek kronologikoki ordenatuta eskaintzen dira, berrienetik zaharrenera, eta bisitariek iruzkinak egin ditzakete.</descrip>
    </descripGrp>
    <tig>
      <term>blog</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>weblog</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
