    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Blog batean beste blog bateko edukia gehitzen denean ezar daitekeen esteka berezia. Blogean esteka hori ezarriz, bere testu bat aipatu dela adierazten duen abisua jasoko du jatorrizko blogak. Normalean, jatorrizko testua duen blog-sarreraren iruzkinetan gehitzen da automatikoki abisu hori.</descrip>
    </descripGrp>
    <tig>
      <term>trackback</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>atzeraesteka</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>trackback</term>
    </tig>
    <tig>
      <term>retroenlace</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>rétrolien</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>trackback</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Blog batean idazten den testu sinatua, normalean argitalpen-data zehaztua duena. Bloga sarrera edo artikuluak idatzi ahala eguneratzen da, eta sarrera bakoitzak iruzkinak jaso ditzake.</descrip>
    </descripGrp>
    <tig>
      <term>sarrera</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>artikulu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>entrada</term>
    </tig>
    <tig>
      <term>artículo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>billet</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>post</term>
    </tig>
    <tig>
      <term>entry</term>
    </tig>
  </langSet>
</termEntry>
