  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>mention</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialen motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Estekak partekatzeko helburu nagusia duen bloga. Sarrera bakoitzean esteka bat gehitu ohi da.</descrip>
    </descripGrp>
