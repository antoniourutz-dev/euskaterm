<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Facebook edo LinkedInen moduko sare sozialetan, administratzaile batek gai bati buruzko interakzioa pizteko sortzen duen orria. Erabiltzaileak orri horretara batu daitezke, talde horretako kide egiteko.</descrip>
