<termEntry id="-1">
  <descrip type='subjectField'>Sare sozialetako funtzioak eta osagaiak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Facebooken moduko sare sozialetan, erabiltzaile batek sortzen duen orri berezia; lagunei ekitaldi edo gertaera jakin baten berri emateko eta bertarako gonbita zabaltzeko erabiltzen da.</descrip>
    </descripGrp>
