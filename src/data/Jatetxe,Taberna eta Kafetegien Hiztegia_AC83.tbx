  <descrip type='subjectField'>Okindegikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Okindegian lehenengo errealdia eman ondoren, izoztu eta erabat egin gabe saltzen den ogia. Jan behar den unean erre eta egiten bukatzen da.</descrip>
