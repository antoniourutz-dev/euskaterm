  <descrip type='subjectField'>Pintxoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Txerri-haragi zatiak piperrauts, baratxuri, oregano eta abarrekin maneatuz eta ziri batean sartuz egiten den pintxoa.</descrip>
