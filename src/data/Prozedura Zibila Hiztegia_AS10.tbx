    </tig>
  </langSet>
</termEntry>
<termEntry id="674167">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Legean zehaztutako denboran alderdiek jarduerarik egin ez dutelako prozesua bukatzeko egintza prozesala. Arrazoi prozesaletan oinarrituta, prozesua modu ezohikoan bukatzeko moduetako bat da. Auto bidez adierazten da.</descrip>
    </descripGrp>
    <tig>
      <term>prozesua iraungitze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>iraungitze prozesal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>caducidad procesal</term>
    </tig>
    <tig>
      <term>caducidad del proceso</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674131">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alderdi bakoitzak auzitegiari eska diezaiokeen itaun-multzoa, gainerako alderdiei egitekoa judizioaren objektuarekin lotura duten eta ezagutzen dituzten egitate eta inguruabarrei buruz. Alderdiek prozesuan eska ditzaketen frogabideetako bat da, Prozedura Zibilaren Legearen 301. artikulutik 316. artikulura arautua.</descrip>
    </descripGrp>
    <tig>
      <term>alderdien galdeketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>alderdiei galdeketa egite</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>interrogatorio de las partes</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674132">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alderdiek auzitegiari eska diezaioketen galdeketa, lekukoei egitekoa judizioaren objektuarekin lotura duten eta ezagutzen dituzten egitate eztabaidagarriei buruz. Alderdiek prozesuan eska ditzaketen frogabideetako bat da, Prozedura Zibilaren Legearen 360. artikulutik 381. artikulura arautua.</descrip>
    </descripGrp>
    <tig>
      <term>lekukoen galdeketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>interrogatorio de los testigos</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674133">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arrazoi fisiko, psikiko edo zentzumenezkoak oinarri hartuta hasten den deklarazio-prozesu berezia. Prozesu hori hasten da pertsona batek jarduteko gaitasuna mugatuta duenean edo bere ondasunak administratzeko gai ez denean.</descrip>
    </descripGrp>
    <tig>
      <term>pertsonen gaitasunari buruzko prozesu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>proceso sobre la capacidad de las personas</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674134">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzi-jartzaileak edo demandatzaileak jurisdikzio-organoen aurrean babes judiziala idazki bidez eskatzeko egintza prozesala.</descrip>
    </descripGrp>
    <tig>
      <term>demanda</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>demanda</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674135">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auziko alderdiek eta Fiskaltzak duten baliabidea, epaileak auziaz arduratzeari utz diezaion haren inpartzialtasuna zalantzan jartzeko arrazoiak daudenean.</descrip>
    </descripGrp>
    <tig>
      <term>epaileen errekusazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>epaileak errekusatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>recusación de jueces</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674136">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzitegi Goreneko lehendabiziko sala, Botere Judizialaren Lege Organikoaren 56. artikuluan zehaztutako gaiez arduratzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>Auzitegi Goreneko arlo zibileko sala</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sala de lo civil del Tribunal Supremo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674137">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzitegi nagusiko justizia-saletako bat; arlo zibilean, Botere Judizialaren Lege Organikoaren 73. artikuluaren 1. eta 2. paragrafoetan zehaztutako gaiez arduratzen da.</descrip>
    </descripGrp>
    <tig>
      <term>auzitegi nagusiko arlo zibileko eta zigor-arloko sala</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sala de lo civil y penal del tribunal superior de justicia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674138">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzitegi zibilek auziak alderdiek ekarritako uzi, egitate eta frogen arabera ebatziko dituztela ezartzen duen printzipioa.</descrip>
    </descripGrp>
    <tig>
      <term>erregututako justiziaren printzipio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>erregu-printzipio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>principio de justicia rogada</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674139">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Betearazpen-izaerako erakunde prozesala, irmo ez diren ebazpen judizialen betearazpena baimentzen duena.</descrip>
    </descripGrp>
    <tig>
      <term>behin-behineko betearazpen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>behin-behineko exekuzio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ejecución provisional</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674140">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Betearazpen-neurri zehatza, alderdi betearazleari betearazpeneko zenbatekoa eskuratzeko aukera ematen diona.</descrip>
    </descripGrp>
    <tig>
      <term>ordaintzeko administrazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>administración para pago</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674141">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Betearazpen-prozesuari hasiera ematen dion dokumentua.</descrip>
    </descripGrp>
    <tig>
      <term>exekuzio-demanda</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>demanda betearazle</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>betearazpen-demanda</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>demanda ejecutiva</term>
    </tig>
    <tig>
      <term>demanda de ejecución</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674142">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Demanda jarri aurretik zegoen egoeraren eta demanda jarri ondoren sortzen den egoeraren arteko haustura; demanda onartzeak sortzen duen ondore prozesal multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>auzibitarte</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>litispendencia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674143">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Demandatua demandatzailearen eskaerarekin bat datorrela adierazten duen egintza prozesala. Arrazoi materialetan oinarrituta, prozesua modu ezohikoan bukatzeko moduetako bat da. Kondena-epai bidez adierazten da, eta gauza epaituaren efektua du.</descrip>
    </descripGrp>
    <tig>
      <term>amore-emate prozesal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>prozesuari amore emate</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>allanamiento procesal</term>
    </tig>
    <tig>
      <term>allanamiento del proceso</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674144">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Demandatuak demandatzailearen aurka jartzen duen demanda (kontrademanda), demanda nagusia ebazten duen prozeduraren bidez erabakitzen dena. Ezinbestekoa da bi auzien arteko lotura.</descrip>
    </descripGrp>
    <tig>
      <term>errekonbentzio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>reconvención</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674145">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Demandatuaren prozesuko egintza, alderdi auzi-jartzaileak formulatutako demandari erantzuna ematekoa.</descrip>
    </descripGrp>
    <tig>
      <term>demanda-erantzun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>demandari erantzute</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>contestación a la demanda</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674146">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Demandatzailearen egintza prozesala, demandatzaileak berak egikaritutako akzioa edo bere uziaren oinarri den eskubidea alde batera uzten duela adieraztekoa. Arrazoi materialetan oinarrituta, prozesua modu ezohikoan bukatzeko moduetako bat da. Gauza epaituaren efektua sortzen du.</descrip>
    </descripGrp>
    <tig>
      <term>prozesuari uko egite</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>uko-egite prozesal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>renuncia procesal</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674147">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Demandatzailearen egintza prozesala, demandatzaileak berak hasitako prozesua uzteko borondatea adieraztekoa. Arrazoi prozesaletan oinarrituta, prozesua modu ezohikoan bukatzeko moduetako bat da. Uzia epaitu gabe geratzen da.</descrip>
    </descripGrp>
    <tig>
      <term>atzera-egite prozesal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>prozesuan atzera egite</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>desistimiento procesal</term>
    </tig>
    <tig>
      <term>desistimiento del proceso</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674148">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Edozein jaraunskidek edo zati alikuotaren legatu-hartzailek judizio bidez jarauntsiaren zatiketa erreklamatzeko deklarazio-prozesu berezia. Prozesu hori hasten da baldin eta zatiketa hori gauzatu behar ez badu testamentugileak izendatutako komisario edo kontulari-banatzaileak edo zatiketa jaraunskideen arteko hitzarmenaren nahiz ebazpen judizialaren bidez egin behar ez bada.</descrip>
    </descripGrp>
    <tig>
      <term>jarauntsia zatitzeko prozesu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>jaraunspena zatitzeko prozesu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>herentzia zatitzeko prozesu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>proceso para la división de la herencia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674149">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egintza prozesalak, eragina izan dezaten, prozesuko une egokian eta bakarrik orduan gauzatu behar direla ezartzen duen printzipioa.</descrip>
    </descripGrp>
    <tig>
      <term>preklusio-printzipio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>preklusio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>principio de preclusión</term>
    </tig>
    <tig>
      <term>preclusión</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674150">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egitateak argitzeko edo aintzat hartzeko, epaileak berak toki, objektu edo pertsonaren bat aztertzea. Alderdiek prozesuan eska ditzaketen frogabideetako bat da, Prozedura Zibilaren Legearen 353. artikulutik 359. artikulura arautua.</descrip>
    </descripGrp>
    <tig>
      <term>azterketa judizial</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>reconocimiento judicial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674151">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Epaile edo auzitegi batek kategoria bereko beste bati bidaltzen dion komunikazioa; eginbide judizialen bat egin dezan adierazten dio komunikazio horretan.</descrip>
    </descripGrp>
    <tig>
      <term>exhorto</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>exhorto</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674152">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Epaileak edo agintari eskudunak aginduta, ondasunak atxikitzea, eta prozeduran zein judizioan gertatzen denaren zain uztea.</descrip>
    </descripGrp>
    <tig>
      <term>enbargo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>embargo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674153">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ezkontzaren edozein ondasun-eraentza likidatzeko deklarazio-prozesu berezia. Prozesu hori hasten da ezkontideen arteko hitzarmenik ez badago eta ondasun-eraentza horrek zehazten badu, ezkontza-itunen edo lege-xedapenen bidez, zama eta betebehar batzuei lotutako ondasun eta eskubideen masa erkidea dagoela.</descrip>
    </descripGrp>
    <tig>
      <term>ezkontzaren ondasun-eraentza likidatzeko prozesu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>ezkontzaren araubide ekonomikoa likidatzeko prozesu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>proceso para la liquidación del régimen económico matrimonial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674154">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontu pribatuez gain, gainerako jurisdikzio-ordenei berariaz esleitu ez zaizkien auziez arduratzen den ordena jurisdikzionala.</descrip>
    </descripGrp>
    <tig>
      <term>jurisdikzio zibil</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>jurisdikzio-ordena zibil</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>jurisdicción civil</term>
    </tig>
    <tig>
      <term>orden jurisdiccional civil</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674155">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hasitako prozesu bateko alderdi bakoitzak zerbait emanez, hitzemanez edo atxikiz prozesua amaitzeko kontratua. Arrazoi materialetan oinarrituta, prozesua modu ezohikoan bukatzeko moduetako bat da. Auto bidez adierazten da, titulu betearazlea da autoa, eta gauza epaitu formalaren efektua du.</descrip>
    </descripGrp>
    <tig>
      <term>transakzio prozesal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>transacción procesal</term>
    </tig>
    <tig>
      <term>transacción del proceso</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674156">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hirugarren batek sustatutako akzioa, bere jabetzako ondasun baten gainean enbargoa trabatu delako baliatzen duena.</descrip>
    </descripGrp>
    <tig>
      <term>jabari-hirugarrengotza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>tercería de dominio</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674157">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hirugarren batek sustatutako akzioa, bere kreditua, alderdi betearazlearenarekin alderatuta, lehentasunezkoa delako baliatzen duena.</descrip>
    </descripGrp>
    <tig>
      <term>eskubide hobeko hirugarrengotza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>tercería de mejor derecho</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674158">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Idazkari judizialaren ebazpen arrazoitua, kasu hauetan ematen duena: demanda izapidetzea onartzen denean, idazkari judizialaren eskumen esklusiboko prozedura amaitzen denean, eta edozein motatako prozeduratan beharrezkoa denean edo ebatzitakoa arrazoitzea komenigarria denean.</descrip>
    </descripGrp>
    <tig>
      <term>dekretu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>decreto</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674159">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Idazkari judizialaren ebazpena, autoei legeak ezarritako bidea ematea helburu duena.</descrip>
    </descripGrp>
    <tig>
      <term>antolaketa-eginbide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>antolaketarako eginbide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>diligencia de ordenación</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674160">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
