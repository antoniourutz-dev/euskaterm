<martif type="TBX" xml:lang="en">
  <martifHeader>
    <fileDesc>
      <titleStmt>
        <title>Prozedura Zibila Hiztegia</title>
      </titleStmt>
      <sourceDesc>
        <p>Prozedura Zibila Hiztegiaren TBX esportazioa</p>
      </sourceDesc>
    </fileDesc>
  </martifHeader>
<text>
<body>
<termEntry id="674168">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kide bakarreko organo judiziala, lehen auzialdiko edo instrukzioko epaitegirik ez dagoen udalerrietan jurisdikzioa duena. Arlo zibilean, 90 eurotik gorako muntakoak ez diren hitzezko judizioez arduratzen da, betiere Prozedura Zibilaren Legearen 250. artikuluaren lehenengo paragrafoan zehaztutako kasuetako bat ez bada.</descrip>
    </descripGrp>
    <tig>
      <term>bake-epaitegi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>juzgado de paz</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674169">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Maila eta mota bereko organo judizialen artean, jarduteko ahala zein lurralde judiziali dagokion zehazten duen irizpidea.</descrip>
    </descripGrp>
    <tig>
      <term>lurralde-eskumen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>competencia territorial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674170">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Modu orokorrean, prozesu zibilean ebazten diren interes pribatuek eraginda, alderdiek prozesuan jarrera aktiboa izan dezaketela ezartzen duen printzipioa. Printzipioak bi eduki ditu: batetik, judizio zibila hasteko nahitaezkoa da alderdien ekimena, eta, bestetik, alderdiek aurkeztutako egitate-materialak soilik ezagutzen ditu epaileak.</descrip>
    </descripGrp>
    <tig>
      <term>xedapen-printzipio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>principio dispositivo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674171">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nahitaezko betearazpenaren jarduera jurisdikzionala, titulu betearazleak zerbait egiteko, ez egiteko edo diru-kopurua ez den gauza bat emateko kondena nahiz betebeharra jasotzen duenean gauzatzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>ez-diruzko betearazpen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>diruzkoa ez den exekuzio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ejecución no dineraria</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674172">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nahitaezko betearazpenaren jarduera jurisdikzionala, titulu betearazleak, zuzenean edo zeharka, diru-kopuru likidoa emateko eginbeharra jasotzen duenean gauzatzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>diruzko betearazpen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>diruzko exekuzio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ejecución dineraria</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674173">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Notarioak, funtzionario publiko eskudunak edo fede-emaile publikoak eskuetsitako dokumentua, alegatutako egitate baten egiatasuna frogatzeko erabil daitekeena. Prozedura Zibilaren Legearen 317. artikuluan zehazten dira dokumentu publikoak. Alderdiek prozesuan aurkez ditzaketen frogabideetako bat da, Prozedura Zibilaren Legearen 317. artikulutik 323. artikulura arautua.</descrip>
    </descripGrp>
    <tig>
      <term>dokumentu publiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>agiri publiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>documento público</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674174">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eskubideak, interesak edo egoera juridikoak prozesu judizial batean galdatzeko pertsona batek erabil dezakeen baliabidea.</descrip>
    </descripGrp>
    <tig>
      <term>akzio zibil</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acción civil</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674175">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozedura batean, alderdien ondare-eskubideak bermatzeko, kontrolatzeko eta babesteko ordenamendu juridikoak aurreikusten duen baliabidea. Prozedura Zibilaren Legearen 630. artikuluan zehaztutako kasuetan era daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>administrazio judizial</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>administración judicial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674176">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozedura Zibilaren Legearen 317. artikuluan zerrendatuta ez dagoen edozein dokumentu, alegatutako egitate baten egiatasuna frogatzeko erabil daitekeena. Alderdiek prozesuan aurkez ditzaketen frogabideetako bat da, Prozedura Zibilaren Legearen 324. artikulutik 327. artikulura arautua.</descrip>
    </descripGrp>
    <tig>
      <term>dokumentu pribatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>agiri pribatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>documento privado</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674177">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozedura Zibilaren Legearen 399. artikuluan eta hurrengoetan aurreikusitako izapideak jarraitzen dituen deklarazio-prozesua. Judizio arruntaren bidez izapidetzen dira: Prozedura Zibilaren Legearen 249.1 artikuluan jasotako gaiei buruzko demandak, legeak berariaz judizio-mota horren bidez bideratu behar direla zehazten dituen demandak, horien munta edozein izanda, eta, azkenik, 6.000 eurotik gorako muntako demandak eta interes ekonomiko kalkulaezina dutenak.</descrip>
    </descripGrp>
    <tig>
      <term>judizio arrunt</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>epaiketa arrunt</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>juicio ordinario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674178">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozedura Zibilaren Legearen 437. artikuluan eta hurrengoetan aurreikusitako izapideak jarraitzen dituen deklarazio-prozesua. Hitzezko judizioaren bidez izapidetzen dira Prozedura Zibilaren Legearen 250.1 artikuluan aurreikusitako gaiei buruzko demandak eta 6.000 eurotik gorako munta ez duten demandak, betiere Prozedura Zibilaren Legearen 249.1 artikuluan jasotako gaiei buruzkoak ez badira.</descrip>
    </descripGrp>
    <tig>
      <term>hitzezko judizio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>hitzezko epaiketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>juicio verbal</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674179">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesu arruntik egin gabe, betearazpen-titulu bat sortzeko deklarazio-prozesu berezia. Prozesu monitorioa egokia da diru-zorra, edozein kopurutakoa izanik, likidoa, mugaeguneratua, galdagarria eta zenbateko zehatzekoa bada eta Prozedura Zibilaren Legearen 812. artikuluan ezarritako dokumentuen bidez egiaztatzen bada.</descrip>
    </descripGrp>
    <tig>
      <term>prozesu monitorio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>proceso monitorio</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674180">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesu zibiletan, auzitegiek eta auzitegietara bertaraturik bertan parte hartzen dutenek Prozedura Zibilaren Legean xedatutakoarekin bat jardun behar dutela ezartzen duen printzipioa.</descrip>
    </descripGrp>
    <tig>
      <term>prozesuaren legezkotasun-printzipio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>principio de legalidad procesal</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674181">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesuan baliozko egintzak gauzatzeko gaitasuna.</descrip>
    </descripGrp>
    <tig>
      <term>gaitasun prozesal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>auzitarako gaitasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>capacidad procesal</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674182">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzilariak lekuko baten deklarazioaren froga-indarra ahultzeko egiten duen alegazioa. Lekukoaren deklarazioa partziala izan daitekeela uste duelako egiten du auzilariak alegazio hori.</descrip>
    </descripGrp>
    <tig>
      <term>lekukoak arbuiatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>lekukoak narriopean jartze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>lekukoen narrio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>tacha de testigos</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674183">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesuan sortzen diren eta prozesuak aurrera jarraitzea eragozten duten arazoak daudelako prozesua bukatzeko ondore edo efektua. Arrazoi prozesaletan oinarrituta, prozesua modu ezohikoan bukatzeko moduetako bat da. Auto bidez adierazten da.</descrip>
    </descripGrp>
    <tig>
      <term>prozesua largeste</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>largespen prozesal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sobreseimiento procesal</term>
    </tig>
    <tig>
      <term>sobreseimiento del proceso</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674184">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesuaz arduratzen ari den epaileak edo auzitegiak eskumenik ez duela deklaratzeko planteatzen den eskumen-arazoa.</descrip>
    </descripGrp>
    <tig>
      <term>deklinatoria</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>declinatoria</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674185">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesu bateko eskubideen, betebeharren, kargen eta espektatiben titular izateko gaitasuna.</descrip>
    </descripGrp>
    <tig>
      <term>alderdi izateko gaitasun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>capacidad para ser parte</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674186">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Epaileak ez dituen ezagutzak (zientifikoak, artistikoak, teknikoak zein praktikoak) dituen pertsona batek prozesuko egitate edo inguruabar garrantzitsuak baloratzeko edo horiek egiaztatzeko ematen duen irizpena. Alderdiek prozesuan aurkez ditzaketen frogabideetako bat da, Prozedura Zibilaren Legearen 335. artikulutik 352. artikulura arautua.</descrip>
    </descripGrp>
    <tig>
      <term>peritu-irizpen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>adituaren irizpen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>dictamen pericial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674187">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesuko lehen auzialdiaren, intzidenteen, errekurtsoen, kautela-neurrien eta epai-betearazpenen ezagutza eta ardura zein jurisdikzio-organori dagokion zehazten duen irizpidea.</descrip>
    </descripGrp>
    <tig>
      <term>eskumen funtzional</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>competencia funcional</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="674188">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesuko materia eta munta oinarri hartuta, jarduteko ahala zein jurisdikzio-organori dagokion zehazten duen irizpidea.</descrip>
    </descripGrp>
    <tig>
      <term>eskumen objektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>competencia objetiva</term>
    </tig>
  </langSet>
</termEntry>
