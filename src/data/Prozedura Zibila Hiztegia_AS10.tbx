<termEntry id="674237">
  <descrip type='subjectField'>Zuzenbide prozesal zibila</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzilariak aditu baten irizpenaren froga-indarra ahultzeko egiten duen alegazioa. Adituaren irizpena partziala izan daitekeela uste duelako egiten du auzilariak alegazio hori.</descrip>
    </descripGrp>
