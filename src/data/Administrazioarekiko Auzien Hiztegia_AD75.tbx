  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auziaren egoera, demanda jarri eta onartutakoan hasi eta behin betiko epaia eman arte irauten duena. Gatazka bat prozesu baten mende dagoela adierazten du.</descrip>
