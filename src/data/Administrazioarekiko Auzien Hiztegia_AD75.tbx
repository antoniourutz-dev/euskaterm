  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Epaia betearazteko abian jartzen den prozesu-aldia, epaia epe barruan bete ez denean edo epaia jakinarazi denetik legean ezarritako denbora igaro denean hasten dena.</descrip>
