  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Administrazioak betearazpen-egintza borondatez betetzen ez duenean, organo judizialak erantzule den agintari edo enplegatuari ezartzen dion diru-zehapena.</descrip>
