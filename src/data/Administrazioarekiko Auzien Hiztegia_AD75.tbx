<body>
<termEntry id="1">
  <descrip type='subjectField'>Administrazioarekiko auzien jurisdikzioa: eremua, eskumenak eta organoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auziaren gaiaren arabera, auziaz ardura dadin edo auzia ebatz dezan organo judizialari ematen zaion eskumena.</descrip>
    </descripGrp>
    <tig>
      <term>eskumen objektibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>gaiaren araberako eskumen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>competencia objetiva</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="2">
  <descrip type='subjectField'>Administrazioarekiko auzien jurisdikzioa: eremua, eskumenak eta organoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lurraldearen arabera, auziaz ardura dadin edo auzia ebatz dezan organo judizialari ematen zaion eskumena.</descrip>
    </descripGrp>
    <tig>
      <term>lurralde-eskumen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>lurraldearen araberako eskumen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>competencia territorial</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="3">
  <descrip type='subjectField'>Administrazioarekiko auzien jurisdikzioa: eremua, eskumenak eta organoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Administrazio bereko organoen artean sortzen den gatazka; eskumena nork duen erabakitzeko orduan gertatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>eskudantzia-gatazka</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>conflicto de atribuciones</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="4">
  <descrip type='subjectField'>Administrazioarekiko auzien jurisdikzioa: eremua, eskumenak eta organoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Organo judizialen artean edo organo judizialen eta administrazio-organoen artean sortzen den gatazka; auzi batez arduratzeko eskumena nork duen erabakitzeko orduan gertatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>jurisdikzio-gatazka</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>conflicto de jurisdicción</term>
    </tig>
    <tig>
      <term>conflicto jurisdiccional</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="5">
  <descrip type='subjectField'>Administrazioarekiko auzien jurisdikzioa: eremua, eskumenak eta organoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi jurisdikzio-ordenatako organo judizialen artean sortzen den arazoa; auzi batez arduratzeko eskumena nork duen erabakitzeko orduan gertatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>eskumen-arazo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cuestión de competencia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="6">
  <descrip type='subjectField'>Administrazioarekiko auzien jurisdikzioa: eremua, eskumenak eta organoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzi nagusiari erantsita eta hertsiki lotuta planteatzen den administrazioarekiko arazoa. Auzi nagusiarekin batera ebazten da, hartarako beste prozedurarik hasteko beharrik gabe.</descrip>
    </descripGrp>
    <tig>
      <term>arazo intzidental</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cuestión incidental</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="7">
  <descrip type='subjectField'>Administrazioarekiko auzien jurisdikzioa: eremua, eskumenak eta organoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Administrazio-auzi bat epaitzen denean sortzen den zibileko edo lan-arloko arazoa, baina administrazioarekiko auzi-errekurtso batekin zuzeneko erlazioa duena. Administrazioarekiko auzien jurisdikzioak berak ebazten du, eta hartutako erabakiak ez du efekturik izaten prozesu horretatik kanpo eta ez du lotzen zibileko edo lan-arloko jurisdikzio-ordena.</descrip>
    </descripGrp>
    <tig>
      <term>epaitu aurreko arazo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>judizio aurreko arazo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cuestión prejudicial</term>
    </tig>
  </langSet>
</termEntry>
