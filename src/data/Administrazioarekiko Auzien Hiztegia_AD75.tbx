  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Epaileak adituak izendatzeko erabiltzen duen bidea: ontzi batean zenbakia duten edo adituen izena duten txartelak sartuta, bat edo gehiago ateratzea, zoriaren arabera.</descrip>
