    </tig>
  </langSet>
</termEntry>
<termEntry id="183">
  <descrip type='subjectField'>Probidentzien, autoen eta epaien aurkako errekurtsoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Apelaziorik edo kasaziorik jar ez dakiekeen probidentzia edo autoen aurka jartzen den errekurtsoa. Ez du eragozten aurkaraturiko ebazpena gauzatzea, non eta jurisdikzio-organoak ez duen kontrakoa erabakitzen, ofizioz edo alderdi-eskariz.</descrip>
    </descripGrp>
    <tig>
      <term>erregu-errekurtso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>recurso de súplica</term>
    </tig>
  </langSet>
