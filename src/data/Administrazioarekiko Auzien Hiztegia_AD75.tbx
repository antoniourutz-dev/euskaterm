  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prozesuan agertzea, prozesu horretan alderdi gisa formalki aurkezteko asmoz. Legez gaitutako prokuradore bidez edo alderdi izateko borondatea adierazten duen idatzizko deklarazio baten bidez egin daiteke.</descrip>
