  <descrip type='subjectField'>Administrazioarekiko auzien jurisdikzioa: eremua, eskumenak eta organoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzitegi nagusietan, administrazioarekiko auzien gaineko ardura duen kide anitzeko organo judiziala. Auzialdi bakarrean edo bigarrenean arduratzen da auzi horietaz.</descrip>
