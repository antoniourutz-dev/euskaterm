  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Administrazioarekiko auzien epaileek auzialdi bakarrean emandako epaiak eta auzitegi nagusietako eta Auzitegi Nazionaleko administrazioarekiko auzien salek emandako epaiak legearen interesean aurkaratzeko errekurtsoa, epai horiek interes orokorrari kalte larria egiten diotela eta okerrak direla iritziz gero aurkezten dena. Errekurtsoaren bidez, errekurrituriko epaitzarako erabakigarri izan diren arauak zuzen interpretatu eta aplikatu diren epaitzen da, ez besterik.</descrip>
    </descripGrp>
    <tig>
      <term>legearen intereseko kasazio-errekurtso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>recurso de casación en interés de la ley</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="180">
  <descrip type='subjectField'>Probidentzien, autoen eta epaien aurkako errekurtsoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzitegi Goreneko, Auzitegi Nazionaleko eta auzitegi nagusietako administrazioarekiko auzien salek auzialdi bakarrean emandako epaien kontra jartzen den errekurtsoa; auzilari berei buruz edo egoera berean ziren auzilari batzuei buruz epaitza desberdinak eman direnean jartzen da, funtsean berdinak izanik egitateak, oinarriak eta uziak. Orobat jar dakieke errekurtso hau Auzitegi Nazionalak eta auzitegi nagusiek auzialdi bakarrean emandako epaiei, Auzitegi Gorenak emandako epaiekin kontraesanean gertatzen badira.</descrip>
    </descripGrp>
    <tig>
      <term>doktrina bateratzeko kasazio-errekurtso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>recurso de casación para la unificación de doctrina</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="181">
  <descrip type='subjectField'>Probidentzien, autoen eta epaien aurkako errekurtsoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alderdiak zuzenean goragoko auzitegian jartzen duen errekurtsoa; beheko auzitegiak apelazioa edo bestelako errekurtso arrunten bat onartzen ez duenean jartzen da.</descrip>
    </descripGrp>
    <tig>
      <term>kexa-errekurtso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>kexako errekurtso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>recurso de queja</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="182">
  <descrip type='subjectField'>Probidentzien, autoen eta epaien aurkako errekurtsoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzitegi Gorenean, Auzitegi Nazionalean eta auzitegi nagusietan epai irmoen kontra jartzen den errekurtso berezia; Administrazioarekiko Auzien Jurisdikzioaren Legeko 102. artikuluan ezarritako kasuetan jartzen da.</descrip>
    </descripGrp>
    <tig>
      <term>berrikuspen-errekurtso</term>
