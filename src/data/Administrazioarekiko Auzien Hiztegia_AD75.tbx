<termEntry id="112">
  <descrip type='subjectField'>Administrazioarekiko auzien prozedura</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurretiaz tasatutako kostuak ordaintzera behartzeko hartzekodun den administrazioak erabilitako premiamendu bidea; ordaintzera kondenatutakoak kostuak ordaindu ez dituenean erabiltzen da.</descrip>
