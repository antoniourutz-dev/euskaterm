<termEntry id="-1">
  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hezur-ehuna sortzeko prozesu histologikoa. Ehun konektibotik abiatzen da beti, zuzenean hasikin fibroso batetik (mintzezko osifikazioa, osifikazio periostikoa), edota kartilagozko molde baten gainean eratzen da hezurra (osifikazio endokondrala).</descrip>
    </descripGrp>
