  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Besoaren aurreko eta azaleko konpartimentuan, sorbalda-hezurretik erradioaren tuberositate bizipitalera doan muskulua, bi buru edo iturburu dituena, luzea bata eta laburra bestea.</descrip>
