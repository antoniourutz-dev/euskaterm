    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>malleolus</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hezur bakoitia, zentrala eta simetrikoa; beheko masailezurraren eskeletoa berak bakarrik osatzen du. Gorputz kurbatu batez (zeinetan ahokatzen baitira beheko hortz-haginak) eta loki-hezurrekin artikulatzen diren goranzko bi adarrez osatua dago. Baraila da garezurreko hezur mugikor bakarra, eta hari esker dira posible murtxikatzeko mugimenduak.</descrip>
    </descripGrp>
    <tig>
      <term>baraila</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>beheko masailezur</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>mandíbula</term>
    </tig>
    <tig>
      <term>maxilar inferior</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>mandibule</term>
    </tig>
    <tig>
      <term>maxillaire inférieur</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>mandible</term>
    </tig>
    <tig>
      <term>lower jaw</term>
    </tig>
  </langSet>
