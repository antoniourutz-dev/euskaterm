<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hezur luzea, izterraren eskeletoa osatzen duena. Goiko aldean, edo alde proximalean, hezur iliakoarekin artikulatzen da, izterrezur-buruaren eta kotiloaren arteko giltzaduraren bitartez, eta beheko aldean, edo alde distalean, tibiarekin eta errotularekin. Gorputz osoko hezurrik luzeena da.</descrip>
    </descripGrp>
    <tig>
      <term>izterrezur</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>femur</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
