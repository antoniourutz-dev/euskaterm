    <tig>
      <term>tinción de Gram</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>coloration de Gram</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
