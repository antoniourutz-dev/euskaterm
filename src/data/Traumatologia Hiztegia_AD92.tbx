    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Iskionarekin eta pubisarekin batera hezur iliakoa osatzen duten hiru hezurretako bat. Iliona beste biak baino gorago kokatua dago, eta pala iliakoa eratzen du.</descrip>
    </descripGrp>
