<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giltzadura bat inguratzen duen mintz sinobialez tapizatutako zuntzezko zakua, artikulazioa osatzen duten hezurren giltzadura-kartilagoaren ertzetan lotzen dena. Ehun konektibo trinkoz dago eratua, kolagenozko zuntz eta zuntz elastiko ugarirekin.</descrip>
    </descripGrp>
    <tig>
      <term>giltzadura-kapsula</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
