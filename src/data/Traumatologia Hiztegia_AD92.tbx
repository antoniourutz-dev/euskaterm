    <tig>
      <term>C-reactive protein</term>
    </tig>
    <tig>
      <term>CRP</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Diagnostikoa. Laborategia. Proba eta prozedura diagnostikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>X izpiek gorputz bat zeharkatu ondoren inpresionaturiko filma. Zilar bromurozko pikorrek ematen diote sentikortasuna filmari, erradiazio ionizatzaileen eraginez erreduzitzen direnez.</descrip>
    </descripGrp>
    <tig>
      <term>erradiografia</term>
      <termNote type='normativeAuthorization'>4</termNote>
