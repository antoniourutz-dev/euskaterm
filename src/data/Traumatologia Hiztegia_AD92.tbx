    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nerbio-sistema zentralean hartzaile opioideei eragiten dien analgesikoa. Morfina da talde zabal hori osatzen duten konposatu kimikoen artean ezagunena. Analgesiko opioide edo narkotiko sintetiko guztiek dituzte, mina kentzeko eraginaz gain, ezaugarri baretzaile, euforizante eta antsiolitikoak, eta, albo-ondorio moduan, tolerantzia, mendekotasuna eta are toxikomania ere ekar ditzakete.</descrip>
    </descripGrp>
    <tig>
      <term>analgesiko opioide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>analgesiko narkotiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>analgésico opioide</term>
    </tig>
    <tig>
      <term>analgésico narcótico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>analgésique narcotique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>narcotic analgesic</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputzeko zona jakin eta mugatu batean, berehalako eta erabateko sorgortasun edo sentikortasunik eza eragiten duen substantzia.</descrip>
    </descripGrp>
    <tig>
      <term>anestesiko lokal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>anestésico local</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>anesthésique local</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>local anesthetic</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hainbat egoeratan agertzen diren hantura, mina eta zurruntasuna prostaglandinen sintesia inhibituz arintzen dituen medikamentua. Nerbio-sistema zentralean ez, baizik eta maila periferikoan jarduten du botika-talde zabal honek; aspirina edo azido azetil salizilikoa da adibiderik ezagunena.</descrip>
    </descripGrp>
    <tig>
      <term>antiinflamatorio ez-esteroide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>AIEE</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>hantura-kontrako ez-esteroide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>HKEE</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>antiinflamatorio no esteroide</term>
    </tig>
    <tig>
      <term>AINE</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>anti-inflammatoire non stéroïdien</term>
    </tig>
    <tig>
      <term>AINS</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>non-steroidal anti-inflammatory drug</term>
    </tig>
    <tig>
      <term>NSAID</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Irudiaren bidezko diagnostikoan erabiltzen den aparatua, X izpien bidez gorputzaren barne-egitura ikusteko aukera eskaintzen duena.</descrip>
    </descripGrp>
    <tig>
      <term>X izpien aparatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
