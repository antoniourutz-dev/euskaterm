    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hezur eta muskuluen deformazio eta desbideratzeak zuzentzeaz arduratzen den medikuntzaren atala.</descrip>
