  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erradioaren burua kubituaren barrunbe sigmoideo txikiaren barruan mantentzen duen zuntzezko banda.</descrip>
