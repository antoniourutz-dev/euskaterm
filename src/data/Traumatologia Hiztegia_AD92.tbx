  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Edozein etiologiatako mina arintzen edo ezabatzen duen farmakoa, bestelako sentsazioak aldarazten ez dituena.</descrip>
    </descripGrp>
