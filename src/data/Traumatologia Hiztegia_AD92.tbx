    <tig>
      <term>aparato de rayos X</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>appareil de radiographie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>radiographic system</term>
    </tig>
    <tig>
      <term>X-ray system</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giltzadura baten ankilosia lortzeko (bestela esanda, artikulazio horren mugikortasuna kentzeko) egiten den ebakuntza kirurgikoa.</descrip>
    </descripGrp>
    <tig>
      <term>artrodesi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>artrodesis</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>arthrodèse</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>arthrodesis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Terapeutika medikoaren atala, eskuz eta tresneriaren laguntzaz ebakuntzak egiteaz arduratzen dena. Deformitateak zuzentzea, zauriak sendatzea edo gaixotasun jakin batzuk diagnostikatu nahiz tratatzea du helburu.</descrip>
    </descripGrp>
    <tig>
      <term>kirurgia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cirugía</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>chirurgie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>surgery</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Saihets baten gainean (eskuineko nahiz ezkerreko alboaren gainean) etzanda eratzen den jarrera.</descrip>
    </descripGrp>
