<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Humeroaren atzealdean kokatua dagoen muskulua, hiru buru dituena. Besaurrearen hedapena edo estentsioa da haren eginkizuna.</descrip>
