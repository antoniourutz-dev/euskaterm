<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Izterrezurra errain-hezurrarekin lotzen duen hezur laua. Pelbiseko gerrikoa izenez ezagutzen den enborraren eta beheko gorputz-adarraren loturaren aurreko eta alboko zatiak eratzen ditu. Jatorrian ilion, iskion eta pubis izeneko hiru hezur independentez osatua badago ere, pertsona helduan kartilago trirradiatuak pieza bakarra osatuz elkartzen ditu hiru pieza horiek azetabulu-barrunbean.</descrip>
    </descripGrp>
    <tig>
      <term>hezur iliako</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>hezur koxal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
