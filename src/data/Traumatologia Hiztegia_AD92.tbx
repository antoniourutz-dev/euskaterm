<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kubituaren goiko muturreko apofisi bertikala, besahezurraren olekranon-barrunbean ahokatzen dena. Epikondiloarekin eta epitroklearekin batera, ukondoko hiru koskorrak osatzen dituzte.</descrip>
