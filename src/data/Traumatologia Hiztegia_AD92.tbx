<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zuntzezko banda zuria, luzexka eta erresistentea, muskulu bat eta egitura mugikor bat (adibidez, hezur bat) elkarrekin lotzen dituena. Tendoi batzuk mintz sinobialean bilduta daude -eskuko muskulu tolestaileak, esaterako- beren ibilbidearen zati bat zorro baten barruan egiten baitute, edo ehun konektibo laxozko paratendoi batez inguratuta bestela -eskuko muskulu hedatzaileen kasuan, adibidez- azalaren azpian lerratu ahal izateko. Tendoiak gogorrak eta malguak izan ohi dira.</descrip>
    </descripGrp>
    <tig>
      <term>tendoi</term>
      <termNote type='normativeAuthorization'>4</termNote>
