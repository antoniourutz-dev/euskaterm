  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Karpoko bigarren ilarako hezurra, lau hezurrekin artikulatzen dena: eskafoidearekin, trapezoidearekin eta lehen nahiz bigarren metakarpo-hezurrekin, hain zuzen ere.</descrip>
