  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Azkeneko lau nerbio zerbikalen eta lehenengo nerbio torazikoaren aurreko adarren artean sortzen diren anastomosi edo loturek osatutako sarea. Goiko gorputz-adarraren inerbazio osoaz arduratzen da.</descrip>
