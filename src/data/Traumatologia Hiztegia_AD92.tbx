  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Goiko gorputz-adarretako bakoitza. Goitik behera, humeroak edo besahezurrak, kubituak eta erradioak, eta karpoko eta hatzetako hezurrek osatzen dute besoaren eskeletoa.</descrip>
