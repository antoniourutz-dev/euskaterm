  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Izterrezur-lepoaren distrofia: izterrezurraren lepo eta gorputzaren ardatzen arteko angelua 135º baino handiagoa da.</descrip>
    </descripGrp>
    <tig>
      <term>coxa valga</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
