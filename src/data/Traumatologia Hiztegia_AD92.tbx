<termEntry id="-1">
  <descrip type='subjectField'>Patologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kanpoko indar batek eragindako barruko nahiz kanpoko lesioa, eragile edo agente mekaniko, fisiko nahiz kimikoek sortua. Traumatismo mekaniko nagusiak hezur, muskulu eta tendoietako lesioak dira; traumatismo fisikoen artean, berriz, beroak eragindako erredurak, hotzak eragindako izozketak, eztanden ondoriozko lesioak, elektrokuzioak, etab. daude; traumatismo kimikoak, azkenik, substantzia erregarriek sortutako erredurak dira.</descrip>
    </descripGrp>
    <tig>
      <term>traumatismo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
