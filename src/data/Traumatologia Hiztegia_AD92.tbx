<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bular-ornoez, saihets-hezurrez eta bularrezurraz eratuta dagoen hezurrezko egitura. Muskuluek hezurren arteko guneak betetzen dituzte. Organo torazikoak torazikoei (bihotza, birikak eta odol-hodi nagusiak) eusten eta babesa ematen die, eta arnasketarako biziki garrantzizkoa da.</descrip>
    </descripGrp>
