<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eskuaren eskeleto proximala, besaurreko hezurren eta metakarpoaren artean kokatua. Bi ilaratan antolatutako zortzi hezur laburrez osatua dago: aurreneko ilaran eskafoidea, semilunarra, piramidala eta pisiformea daude, eskumuturreko artikulazioa, zentzu hertsian, eratuz; bigarren ilaran, berriz, artikulazio karpometakarpianoa eratzen duten trapezioa, trapezoidea, hezur handia eta kako-hezurra bereizten dira.</descrip>
    </descripGrp>
    <tig>
      <term>karpo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>carpo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>carpe</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>carpus</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Enborraren eta goiko gorputz-adarraren arteko lotura eratzen duen zona anatomikoa, bularrezurrak, klabikulak eta eskapulak osatua. Lepoaren oinaldetik bularreko muskulu handiaren azpiko ertzeraino hedatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>eskapula-gerriko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
