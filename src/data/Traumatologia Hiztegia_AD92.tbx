    <tig>
      <term>spinal canal</term>
    </tig>
    <tig>
      <term>vertebral duct</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizakiaren gorputz-alboetako paretak zurruntzen dituzten hogeita lau hezur luze, zapal eta kurbatuetako bakoitza. Saihets-hezurrek osatzen dute kutxa torazikoa, bizkarrezurrarekin eta bularrezurrarekin batera birikak eta bihotza babestu, eta arnasketaren mekanismoan tresna pasibo gisa jokatzen duena. Aurreko aldean, bularrezurrean lotzen dira, eta, atzeko aldean, bizkarrezurrean.</descrip>
    </descripGrp>
    <tig>
      <term>saihets-hezur</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>costilla</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>côte</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>rib</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bularrezurrera iristeko beste saihets batzuekin elkartzen den saihets-hezurra. Hiru pare dira.</descrip>
    </descripGrp>
    <tig>
      <term>saihets-hezur aizun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>saihets-hezur faltsu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>costilla falsa</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>fausse côte</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>false rib</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sabelaldeko muturra askea duten saihets-hezurretako bakoitza. Ez dira bularrezurrean lotzen, ezta gainean duten saihets-hezurrean ere. Gizakiaren kasuan, azken biak dira, goitik hasita.</descrip>
    </descripGrp>
    <tig>
      <term>saihets-hezur loka</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
