  <langSet xml:lang='es'>
    <tig>
      <term>costalgia</term>
    </tig>
    <tig>
      <term>dolor costal</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>costalgie</term>
    </tig>
    <tig>
      <term>douleur costale</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>costalgia</term>
    </tig>
    <tig>
      <term>rib pain</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
