      <term>hand</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurpegiko eskeletoa osatzen duen hezurra, beste aldeko bere kidekoarekin artikulatuz goiko masailaren hezurrezko zatia eratzen duena. Ahoaren gainean, betzuloaren azpian eta sudur-barrunbeen kanpoko aldean kokatuta dago.</descrip>
    </descripGrp>
    <tig>
      <term>goiko masailezur</term>
      <termNote type='normativeAuthorization'>4</termNote>
