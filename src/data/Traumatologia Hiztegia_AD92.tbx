<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tartsoko hezurra, goian astragaloarekin eta aurrean kuboide hezurrarekin artikulatzen dena. Haren beheko aldeko tuberositatea zoruaren gainean jartzen da. Orpoa izeneko oin-zatiari dagokio.</descrip>
    </descripGrp>
