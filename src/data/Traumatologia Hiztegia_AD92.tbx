  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sorbaldako muskulu triangeluar handia, sorbaldaren goiko aldetik humeroaren diafisira doana eta besoa alboetarantz jasotzen duena.</descrip>
