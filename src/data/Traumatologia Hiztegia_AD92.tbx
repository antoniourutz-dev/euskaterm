  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aurretik atzerako ardatzak eta zeharkako ardatzak zehazten duten planoa. Gorputz-adarren ardatzarekiko perpendikularra izaten da.</descrip>
