<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giza eskuaren zati konkabo samarra, hatz-oinaldeen eta eskumuturraren artean dagoena. Ukabila ixten denean, hatzak haren gainean tolesten dira.</descrip>
