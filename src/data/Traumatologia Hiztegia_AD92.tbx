<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Supinazio-mugimendua egiten duen muskulua, besahezurraren alboko epikondiloan sortu eta erradioaren alboko aurpegian txertatzen dena.</descrip>
