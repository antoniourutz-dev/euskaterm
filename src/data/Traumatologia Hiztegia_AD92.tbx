  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Karpoko hezurretan handiena, ilara distalean kokatua. Kanpoan, eskafoide eta trapezoidearekin artikulatzen da; barruan, kako-hezurrarekin; goian, hezur semilunarrarekin, eta, behean, bigarren, hirugarren eta laugarren metakarpianoekin.</descrip>
