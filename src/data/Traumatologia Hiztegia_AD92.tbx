<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sesamo-ale baten itxura duen hezur txikia (hortik izena), tendoi batean (flexorean) txertatuta dagoena. Lehenengo hatz eta behatzaren artikulazio metakarpo eta metatartsofalangikoetan binaka kokatzen dira, giltzaduraren oinaldearen albo banatan. Tendoiak giltzadura-gainazalean edukiko lukeen marruskadura arintzen edo saihesten du.</descrip>
    </descripGrp>
    <tig>
      <term>hezur sesamoideo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
