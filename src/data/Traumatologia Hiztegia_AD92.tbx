</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizakiaren eskeletoa osatzen duten 206 zati gogorretako bakoitza. Hezurra eratzen duen ehuna batez ere kaltzio fosfatoz zurrundutako eta gogortutako ehun konektiboz dago osatua. Morfologiaren arabera, hezur luzeak, laburrak eta lauak bereizten dira. Hezurraren kanpoko kortikala trinkoa da, barruan ehun arolez osatutako sare bat hartzen du, eta han kokatzen da hezur-muina.</descrip>
    </descripGrp>
    <tig>
      <term>hezur</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
