  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputz-atal bati baino gehiagori (buruari, bularraldeari, sabelaldeari eta gorputz-adarrei) erasaten dien traumatismoa, askotan pazientearen bizia arriskuan jar dezakeena.</descrip>
    </descripGrp>
    <tig>
      <term>politraumatismo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
