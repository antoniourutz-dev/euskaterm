<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zangoaren erdialdean dagoen giltzadura, femur, tibia eta belaunezurraren artekoa. Zentzu zabalean, giltzadura hori bere barnean hartzen duen zango-zatia, eta bereziki eremu horren aurreko aldea. Atzeko aldeari popliteo deritzo.</descrip>
    </descripGrp>
