    <tig>
      <term>upper jaw</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Fibrokartilagozko diskoa, ilargi-formakoa, giltzadura-gainazalen artean kokatuta egonik haien bat-etortze edo kongruentzia areagotzen duena. Belaunekoak dira ezagunenak (mediala eta laterala), eta nahiko sarritan urratu eta hausten dira, barrukoa bereziki.</descrip>
    </descripGrp>
