    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erpuruaren muskulu aduktorea, hatz lodia esku-ahurrera hurbiltzen duena.</descrip>
