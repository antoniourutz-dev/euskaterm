  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oin-zolaren ohiko kurbadura desagertzen denean azaltzen den oinaren deformitatea. Horrela, oin-zola ia bere luze-zabal osoan bermatzen da zoruan. Sortzetikoa izan daiteke, edo hartua, eta beste deformazio batzuekin batera ager daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>oin zapal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
