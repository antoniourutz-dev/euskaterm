<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Agente fisikoak, naturalak zein artifizialak (ura, airea, elektrizitatea, argi-erradiazioak, X izpiak, gorputz erradiaktiboak, hotza, beroa, etab.) helburu terapeutikoekin erabiltzea. Fisioterapiaren barruan sartzen dira, era berean, klima, altitude, atseden eta mugimenduaren erabilera eta ibilera- eta gimnastika-ariketak.</descrip>
    </descripGrp>
    <tig>
      <term>fisioterapia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
