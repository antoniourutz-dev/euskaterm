<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Uzkurdura bidez gorputz-adar edo zati bat tolesten duen muskulua. Bestela esanda, hezurren arteko angelua txikitzen duen muskulua; adibidez, besoa ukondoaren mailan tolesten duena edo erpurua esku-ahurrerantz eramaten duena.</descrip>
    </descripGrp>
    <tig>
      <term>muskulu tolestaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
