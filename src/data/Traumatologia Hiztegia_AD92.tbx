<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tartsoa osatzen duten piramide-formako hezurretako bakoitza. Hiru hezur labur dira (barrutik kanporantz zenbatzen dira), eta eskafoidearen aurrean kokatuta daude, tartsoaren bigarren hezur-ilaran.</descrip>
