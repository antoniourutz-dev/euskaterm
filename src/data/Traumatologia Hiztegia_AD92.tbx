<termEntry id="-1">
  <descrip type='subjectField'>Diagnostikoa. Laborategia. Proba eta prozedura diagnostikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giltzadura baten barrualdea ikusi eta aztertzeko modua ematen duen teknika endoskopikoa, aztertu nahi den giltzadura disoluzio fisiologiko batekin zabalduz egiten dena. Zauri txiki batzuen bidez, artikulazioaren egoera ikusteaz gain, maniobra terapeutikoak egitea ere ahalbidetzen du.</descrip>
    </descripGrp>
    <tig>
      <term>artroskopia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>artroscopia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>arthroscopie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>arthroscopy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Diagnostikoa. Laborategia. Proba eta prozedura diagnostikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giltzadura baten barrunbea begiz ikusteko baliatzen den endoskopioa. Trokar batek, haren kanulak eta sistema optiko batek osatzen dute tresna.</descrip>
    </descripGrp>
    <tig>
      <term>artroskopio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
