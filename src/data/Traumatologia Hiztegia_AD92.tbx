  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputzaren erdiko ardatzean kokatutako hezurrak (garezurra, bizkarrezurra, saihets-hezurrak eta bularrezurra), 80 hezur guztira.</descrip>
    </descripGrp>
