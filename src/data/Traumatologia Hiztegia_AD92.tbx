  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputzeko ehun konektiboaren, bereziki artikulazioen eta haiekin lotutako egituren (muskulu, giltzadura-poltsa, tendoi eta zuntz-ehunaren) inflamazioarekin eta degenerazio edo alterazio metabolikoarekin agertzen den gaixotasuna. Mina eta zurruntasuna dira sintoma kliniko nagusiak.</descrip>
    </descripGrp>
    <tig>
      <term>gaixotasun erreumatiko</term>
