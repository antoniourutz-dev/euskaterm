<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Uzkurtzeko gaitasuna duten zuntzez osatutako ehuna. Bi eratako muskuluak daude: batetik, eskeletikoak edo ildaskatuak, borondatearen arabera uzkurtzen direnak, eta, bestetik, lisoak, erraien paretak eta odol-hodiak estali eta nahi gabe uzkurtzen direnak.</descrip>
