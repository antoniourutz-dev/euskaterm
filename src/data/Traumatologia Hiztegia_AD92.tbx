<termEntry id="-1">
  <descrip type='subjectField'>Administrazio Sanitarioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Medikuntzaren adarra, lokomozio-aparatuaren eta hari lotutako egituren traumatismoen prebentzio, azterketa kliniko, diagnostiko, tratamendu eta ikerkuntzaz arduratzen den diziplina zientifikoa.</descrip>
