<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zangoko hezurrak (tibia eta peronea) oineko hezurrekin (tartsoarekin) lotzen dituen artikulazioa. Troklea motako giltzadura da, 70º inguruko flexio-estentsioko mugimenduak besterik ahalbidetzen ez duena.</descrip>
    </descripGrp>
