<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Jatorri konplexua eta zerra-forma duten gorputz-enborreko muskuluetako bakoitza. Gehienetan, ornoetatik edo saihets-hezurretatik sortzen dira.</descrip>
