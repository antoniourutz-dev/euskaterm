<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tartsoko hezurra, tibiarekin eta peronearekin artikulatuta orkatilako giltzadura osatzen duena. Zangoko hezurrekin lotura duen tartsoko hezur bakarra da, eta ez dauka muskulu-lotunerik. Kalkaneoarekin eta eskafoide hezurrarekin ere artikulatzen da.</descrip>
    </descripGrp>
