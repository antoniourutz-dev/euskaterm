</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hezur laua, bularraldearen aurreko paretan kokatua, alde bakoitzean saihets-hezurrekin eta klabikularekin artikulatzen dena. Bertan kirtena (edo manubrioa), gorputza eta xifoide apofisia edo apendizea bereizten dira, goitik behera.</descrip>
    </descripGrp>
