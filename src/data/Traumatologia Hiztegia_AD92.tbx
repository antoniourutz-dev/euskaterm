<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zenbait ornoren apofisi zorrotzak sorbalda-hezurraren erdiko ertzarekin lotzen dituzten trapezioaren azpiko bi muskuluetatik bakoitza.</descrip>
