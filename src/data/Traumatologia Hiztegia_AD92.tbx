<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Besaburuaren eta ukondoaren arteko hezurra. Goiko muturrak forma biribildua dauka (besahezurraren burua esaten zaio) eta eskapulako barrunbe glenoideoarekin artikulatzen da. Beheko muturra, aldiz, besaurreko bi hezurrekin artikulatzen da: kubituarekin eta erradioarekin.</descrip>
    </descripGrp>
