    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>serratus muscle</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eskapularen saihets-aldean sortu eta humeroaren tuberkulu txikian (trokinean) txertatzen den muskulua. Haren eginkizuna besoa hurbildu eta barrurantz biraraztea da.</descrip>
    </descripGrp>
