  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Karpoko aurreneko ilarako bigarren hezurra, behera begirako konkabitatea duen ilargi-erdi baten forma duena. Bost hezurrekin artikulatzen da: erradioarekin, eskafoidearekin, karpoko hezur handiarekin, piramidalarekin eta kako-hezurrarekin.</descrip>
