<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zangoaren atzeko konpartimentuko muskulua, hango muskuluetatik sakonena, tibiaren eta peronearen atzealdetik eta hezur arteko mintzetik abiatuz oineraino iristen dena. Jatorrian muskulua bada ere, orkatilan lotailu bilakatzen da, eta, barneko maleoloaren atzetik pasa ondoren, oineko hezur nabikularrean eta lehen hezur kuneiformean txertatzen da. Oinaren flexio plantarra eta adukzioa ditu funtziorik garrantzitsuenak.</descrip>
    </descripGrp>
    <tig>
      <term>atzeko tibia-muskulu</term>
