<termEntry id="-1">
  <descrip type='subjectField'>Patologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hiperaktibitate sinpatikoarekin erlazionaturiko sindrome mingarria, goiko gorputz-adarretan behekoetan baino maiztasun handiagoz gertatzen dena. Bi mota bereizten dira: I. mota, traumatismoen ondorioz sortua (distrofia erreflexu sinpatikoa), eta II. mota, nerbio-lesio zentral edo periferiko baten ondorioz sortua (kausalgia).</descrip>
    </descripGrp>
    <tig>
      <term>min erregional konplexuaren sindrome</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
