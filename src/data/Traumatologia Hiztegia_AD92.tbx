    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>complex regional pain syndrome</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Patologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Asaldu neurologiko kronikoa, gehienetan traumatismo txiki batek sortua. Sindrome honen ezaugarri nagusiak mina, hantura eta azaleko alterazio basomotorrak izaten dira; halakoek ez dute dermatoma zehatz baten eremua errespetatzen. Askoz ohikoagoa da goiko gorputz-adarretan.</descrip>
    </descripGrp>
    <tig>
      <term>distrofia erreflexu sinpatiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>I. motako min erregional konplexuaren sindrome</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>Sudeck-en sindrome</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
