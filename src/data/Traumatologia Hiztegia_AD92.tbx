<termEntry id="-1">
  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Muskulu ildaskatuaren unitate anatomiko eta funtzionala, aktinaz eta miosinaz osatua. Muskuluaren uzkurdura miosinazko zuntzexkak aktinazko zuntzexka finen gainean lerratzean datza, nerbioen erregulaziopean eta kaltzio ioien partaidetzarekin.</descrip>
    </descripGrp>
