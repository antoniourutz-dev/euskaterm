<termEntry id="-1">
  <descrip type='subjectField'>Diagnostikoa. Laborategia. Proba eta prozedura diagnostikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Odol-serumean inflamazio, infekzio, nekrosi edo tumore-kasuetan maila altuagoan agertu ohi den proteina. Analisi batean proteina honen maila altu egoteak diagnostikoa egiten lagun dezake.</descrip>
    </descripGrp>
    <tig>
      <term>proteina C-erreaktibo</term>
      <termNote type='normativeAuthorization'>4</termNote>
