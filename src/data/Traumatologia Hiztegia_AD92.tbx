<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>L1 ornotik L4 ornora bitarteko nerbio errakideoen aurreko adarren artean sortzen diren anastomosi edo loturek osatutako sarea. T12 ornoko nerbioak ere hartzen du parte plexuaren sorreran.</descrip>
