<termEntry id="-1">
  <descrip type='subjectField'>Tresnak eta aparatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>0,75 eta 1.000 µm bitarteko uhin-luzera duten erradiazio elektromagnetikoak, giza begiak ikusten ez dituenak. Argiaren espektroan, argi gorriaren eta mikrouhinen artekoak dira.</descrip>
    </descripGrp>
    <tig>
