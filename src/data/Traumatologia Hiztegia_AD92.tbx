      <term>infiltración</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>infiltration</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>infiltration</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputz-adarren edo beste edozein gorputz-atal mugikorren mugimendua eragoztea, bereziki hezur hautsiena edo giltzadurena. Ferula edo igeltsu baten bidez egin daiteke, adibidez.</descrip>
    </descripGrp>
