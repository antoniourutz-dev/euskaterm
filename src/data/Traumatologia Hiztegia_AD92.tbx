<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Goiko gorputz-adarraren zati distalean, besaurrearen muturrean, dagoen gorputz-atala. Hiru zati ditu: karpoa, metakarpoa eta hatzak. Gizakietan, atzitze-funtzioetarako espezializatuta dago.</descrip>
    </descripGrp>
    <tig>
      <term>esku</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
