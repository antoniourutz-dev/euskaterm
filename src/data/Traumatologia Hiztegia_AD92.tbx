</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Tresnak eta aparatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputz-atal mugikor edo desplazatuak (bereziki, hautsitako edo lokatutako hezurrak) immobilizatzeko eta beren posizio naturalean eusteko erabiltzen den aparatua, zurruna edo malgua. Igeltsuz, zurez, metalez, kartoiz, plastikoz edo bestelako materialen batez egina izan ohi da.</descrip>
    </descripGrp>
    <tig>
      <term>ferula</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>férula</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
