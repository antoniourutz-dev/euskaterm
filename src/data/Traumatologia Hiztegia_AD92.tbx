    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>synarthrosis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi kartilagoren artean, esaterako okzipitalaren apofisi basilarraren eta esfenoidearen gorputzaren artean, biak oraindik kartilaginosoak direnean eratzen den mugimendurik gabeko artikulazioa. Osifikazioa gertatzen denean, bi giltzadura-gainazalak fusionatu egiten dira normalean, aipatu giltzaduran gertatzen den bezala.</descrip>
    </descripGrp>
    <tig>
      <term>sinkondrosi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
