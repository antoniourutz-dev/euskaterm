    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zelulen ugalketa eta hazkundea estimulatzen dituen substantzia. Hainbat fenomeno biologikotan eragiten du, mekanismo endokrino edo parakrinoen bitartez jokatuz.</descrip>
    </descripGrp>
    <tig>
      <term>hazkunde-faktore</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>factor de crecimiento</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
