      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cintura escapular</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>ceinture scapulaire</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>scapular waist</term>
    </tig>
    <tig>
      <term>shoulder girdle</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sorbalda-gerrikoa osatzen duen hezurretako bat, kurbadura handirik gabeko S etzan baten forma duena. Mutur proximalean bularrezurrarekin artikulatzen da, eta mutur distalean eskapula edo sorbalda-hezurrarekin.</descrip>
    </descripGrp>
    <tig>
      <term>lepauztai</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>klabikula</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>clavícula</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>clavicule</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>clavicle</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bizkarrezurraren beheko muturra osatzen duen hezurrezko pieza, bolumenean aurrenekotik azkenekora murriztuz doazen eta elkar soldatuak dauden lau-sei orno-hasikinez osatua. Aurreneko orno kokzigeoa errain-hezurraren erpinarekin artikulatzen da. Uzkornoa errudimentarioa da gizakietan, eta beste animalia-espezie batzuen isatsaren aztarnatzat hartzen da.</descrip>
    </descripGrp>
    <tig>
      <term>kokzix</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>uzkorno</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cóccix</term>
    </tig>
    <tig>
      <term>hueso coccígeo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>coccyx</term>
    </tig>
    <tig>
      <term>os coccyx</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>coccyx</term>
    </tig>
    <tig>
      <term>tailbone</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giza besoaren eta besaurrearen arteko giltzadura; baita giltzadura horri dagokion eremu anatomikoa ere, atzealdekoa batik bat.</descrip>
    </descripGrp>
    <tig>
      <term>ukondo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>codo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>coude</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>elbow</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Orno-muinaren bukaerako zatian sortzen diren eta lehenengo orno lunbarraren (L1 ornoaren) azpian kokatuta dauden nerbio-sustraien multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>zaldi-buztan</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cola de caballo</term>
    </tig>
    <tig>
      <term>cauda equina</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>queue de cheval</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>cauda equina</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizakien bizkarrezur-muina babesten duen goitik beherako ornoen segida, enborraren hezurrezko ardatza eratzen duena. Bizkarrezurra bost orno-multzotan banatzen da: lepaornoak (7), bizkar-ornoak (12), gerri-ornoak (5), errain-hezurra eta uzkornoa, eta ornoarteko diskoei esker mugikortasun handia dauka. Bizkarrezurra ez da erabat zuzena, zenbait kurbadura ditu (lordosi zerbikal nahiz lunbarra eta zifosi torazikoa).</descrip>
    </descripGrp>
    <tig>
      <term>bizkarrezur</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>erraki</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>columna vertebral</term>
    </tig>
    <tig>
      <term>raquis</term>
    </tig>
