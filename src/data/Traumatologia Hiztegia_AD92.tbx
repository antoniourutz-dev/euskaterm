  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>iliac fossa</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garezurraren goialdean eta aurrealdean, hezur parietalaren hurrenean, dagoen mintz-hezur bikoitia; gizakiaren kasuan, bi hezurrok elkartu egiten dira, kopeta eta betzuloen gainaldea eratzen duen hezur bakarra eratuz.</descrip>
    </descripGrp>
