<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputz-atal bat immobilizatzeko, igeltsua ezarri. Uretan busti ondoren, igeltsua erabat gogortzen da, gorputz-adarra edo gorputz-enborra behar bezala lerrokatua edukitzeko.</descrip>
    </descripGrp>
    <tig>
      <term>igeltsua jarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>igeltsuztatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>enyesar</term>
    </tig>
    <tig>
      <term>escayolar</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>plâtre</term>
