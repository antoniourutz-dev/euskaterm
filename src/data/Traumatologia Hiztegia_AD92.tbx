      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>egiazko saihets-hezur</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>costilla verdadera</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>côte vraie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>true rib</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizakiaren buru-eskeletoa edo buruko hezurren multzoa, adiera zabalean; adiera hertsian, aldiz, entzefaloa barruan hartzen duen hezurrezko kaxa.</descrip>
    </descripGrp>
    <tig>
      <term>garezur</term>
