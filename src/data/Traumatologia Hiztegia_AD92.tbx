<termEntry id="-1">
  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hezurren eratze-prozesua, osteoblastoen eta osteoklastoen funtzioa aktibatzearen ondorioz gertatzen dena. Aurreneko osifikazio-guneak sei bat asteko fetuan agertzen dira. Osifikazioaren abiapuntua bi eratakoa izan daiteke: zuntzezko matrize batetik abiatzen bada, osteogenesi desmala esaten zaio (garezur-gangako hezurrak sortzen dira horrela); kartilagozko matrize batetik abiatzen bada, berriz, osteogenesi endokondrala izaten da (izterrezurraren moduko hezur luzeak eratzen dira horrela).</descrip>
    </descripGrp>
    <tig>
      <term>osteogenesi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
