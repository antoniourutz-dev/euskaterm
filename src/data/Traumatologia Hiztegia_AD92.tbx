  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oinaren azpialdea, ganga konkabo moduan orpotik behatzetaraino hedatua, zutikako egoeran zein ibiltzean zorua ukitzen duena.</descrip>
