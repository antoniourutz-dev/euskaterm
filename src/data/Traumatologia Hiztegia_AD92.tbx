    <descripGrp>
      <descrip type='definition'>Hezurretako edo hezur-ehunetako gaitza.</descrip>
    </descripGrp>
    <tig>
      <term>osteopatia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
