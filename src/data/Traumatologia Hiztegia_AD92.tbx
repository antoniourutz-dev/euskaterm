    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>physiotherapy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Larruazalaren eta/edo mukosen eta azalpeko ehunen etena, kirurgialariak gorputzeko edozein eremutara iristeko asmoz asepsia-baldintza egokietan egina.</descrip>
    </descripGrp>
    <tig>
      <term>zauri kirurgiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>herida quirúrgica</term>
    </tig>
  </langSet>
