<termEntry id="-1">
  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zenbait muskuluk egoera normalean duten uzkurdura partzial eta iraunkorra, gorputzaren zenbait jarrera hartzeko modua eman eta ariketa batzuetarako prest egotea ahalbidetzen duena.</descrip>
    </descripGrp>
