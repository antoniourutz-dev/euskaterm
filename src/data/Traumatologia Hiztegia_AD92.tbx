<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zangoaren atzeko konpartimentuko muskulua, Akiles-en tendoiaren bidez elkartuta kalkaneoan txertatzen diren hiru buruk (muskulu soleoak, eta barruko nahiz kanpoko muskulu bikiek) osatzen dutena. Oinaren flexio plantarra egiteaz gain, berak ematen du ibilera edo jauzirako lehen bultzada ere.</descrip>
