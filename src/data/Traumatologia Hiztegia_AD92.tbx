  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bularraldea eta sabela horizontalki pausatuta ahuspez etzanda eratzen den jarrera.</descrip>
