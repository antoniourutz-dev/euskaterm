    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>radiografía</term>
    </tig>
    <tig>
      <term>placa</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>radiographie</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>radiograph</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Diagnostikoa. Laborategia. Proba eta prozedura diagnostikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>10 eta 0,01 nanometro bitarteko uhin-luzera duten erradiazio elektromagnetikoak, atomoak energia handiko partikulekin (elektroiekin, eskuarki) bonbardatzean igortzen direnak. Espektro elektromagnetikoan, izpi ultramoreen eta gamma izpien artekoak dira. Materia zeharkatzeko, ionizatzeko eta substantzia jakin batzuekiko interakzioan argia sortzeko gaitasunagatik, medikuntzan oso erabiliak dira gorputzaren barruko egituren azterketan.</descrip>
    </descripGrp>
    <tig>
      <term>X izpiak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>Roentgen izpiak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>rayos X</term>
    </tig>
    <tig>
      <term>rayos Roentgen</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>rayons X</term>
    </tig>
    <tig>
      <term>rayons Roentgen</term>
    </tig>
  </langSet>
