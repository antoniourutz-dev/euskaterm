      <term>palsy</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Patologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oin-zolaren kurbadura gehiegizkoa denean azaltzen den oinaren deformitatea. Deformazio hau desoreka muskular bati lotua dago, normalean. Behatzek makurtu eta uzkurtzeko joera dute, eta metatartsianoen buruen gainean egindako presioak kailuak eta mina dakartza.</descrip>
    </descripGrp>
    <tig>
      <term>oin sakon</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>oin kabo</term>
