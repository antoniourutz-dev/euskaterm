    <tig>
      <term>immobilisation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>immobilization</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mugimendua eragotzi, ferula baten edo igeltsu baten bidez, esaterako.</descrip>
    </descripGrp>
    <tig>
      <term>immobilizatu</term>
      <termNote type='normativeAuthorization'>4</termNote>
