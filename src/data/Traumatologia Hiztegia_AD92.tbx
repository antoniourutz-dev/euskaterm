<termEntry id="-1">
  <descrip type='subjectField'>Tresnak eta aparatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gailu ortopedikoa, aldi baterakoa nahiz iraunkorra, gorputz-atal jakin baten funtzionaltasuna handituz erabiltzaileei independentzia handiagoa eta bizi-kalitate hobea eskaintzen diena. Deformazioak zuzendu edo lerrokatzeko ere erabiltzen da. Ortesiak dinamikoak nahiz estatikoak izan daitezke, besteak beste: ferula zurrunak, gerrialdeko paxak, giltzadura-babesle elastikoak, eta abar.</descrip>
    </descripGrp>
    <tig>
      <term>ortesi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ortesis</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>orthèse</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>orthosis</term>
    </tig>
    <tig>
      <term>orthesis</term>
    </tig>
  </langSet>
</termEntry>
