  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zangoaren atzealdean kokatutako bi muskulu txikiek osatzen duten muskulua, soleoarekin batera zangoko trizepsa osatzen duena.</descrip>
