<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Izterrezurraren nahiz besahezurraren buruari jarraitzen dion zona estuagoa, diafisiarekin lotzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>lepo anatomiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
