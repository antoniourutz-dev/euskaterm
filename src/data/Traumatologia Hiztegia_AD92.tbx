<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giltzadura bati (bereziki belaunaz eta ukondoaz ari garenean, baina baita beste giltzadura askori ere) albo banatatik egonkortasuna ematen dioten lotailuetako bakoitza. Bi lotailu izaten dira: lotailu albokide laterala (kanpoaldetik) eta lotailu albokide mediala (barnealdetik).</descrip>
    </descripGrp>
    <tig>
      <term>lotailu albokide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>ligamento colateral</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
