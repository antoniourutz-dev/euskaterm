<termEntry id="-1">
  <descrip type='subjectField'>Administrazio Sanitarioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ospitalean izaten diren egonaldien batez besteko egun-kopurua. Kalkulu hori egiteko, ospitaleratuta egindako egun-kopurua epealdi batean izandako ospitaleratze-kopuruarekin zatitzen da.</descrip>
