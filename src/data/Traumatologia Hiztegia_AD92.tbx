    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>floating rib</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kasu bakoitzean dagokion saihets-kartilagoaren bidez bularrezurreraino iristen den saihets-hezurra. Zazpi pare dira gizakiaren kasuan.</descrip>
    </descripGrp>
