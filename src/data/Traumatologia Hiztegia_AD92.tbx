    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>collateral ligament</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zangoaren beheko muturrean dauden hezurrezko irtenguneetako bakoitza, kanpokoa eta barnekoa. Lehena, kanpoko maleoloa, peronearen beheko muturrak osatzen du; bigarrena, barneko maleoloa, tibiaren irtengunea da.</descrip>
    </descripGrp>
    <tig>
      <term>maleolo</term>
