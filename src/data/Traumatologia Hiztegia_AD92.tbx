    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>pectoralis minor muscle</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Toraxaren aurrealdean kokatzen den muskulua, klabikula, bularrezur eta lehen sei saihets-hezurretatik sorbaldaraino hedatzen dena. Besoaren hurbilketa eta barne-errotazioa eragiten ditu.</descrip>
