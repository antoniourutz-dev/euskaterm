    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>triceps surae muscle</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Izterreko koadrizepsaren osagai diren hiru muskuluetako bakoitza: albokoa edo laterala, erdialdekoa edo mediala eta tartekoa edo krurala.</descrip>
