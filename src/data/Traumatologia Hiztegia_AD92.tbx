  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oinaren atzealdeko hezurren multzoa, zangoko hezurren eta metatartso-hezurren artean dagoena. Bi ilaratan antolatutako zazpi hezurrek osatzen dute: astragaloak eta kalkaneoak atzeko ilaran, eta eskafoideak, kuboideak eta hiru hezur kuneiformeek aurreko ilaran.</descrip>
    </descripGrp>
    <tig>
      <term>tartso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
