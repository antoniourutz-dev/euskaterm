    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>knee joint</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Enartrosien motako giltzadura, besahezurraren burua sorbalda-hezurreko barrunbe glenoideoarekin lotzen duena.</descrip>
