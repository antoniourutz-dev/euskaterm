  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lepoko muskulu zeiharra, klabikulatik eta bularrezur-kirtenetik mastoide apofisira eta goiko lerro okzipitalera hedatzen dena. Lau buruk (esternookzipitalak, esternomastoideoak, kleidookzipitalak eta kleidomastoideoak) osatzen dute.</descrip>
    </descripGrp>
