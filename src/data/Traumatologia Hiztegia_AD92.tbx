  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ilion eta iskion hezurrekin batera hezur iliakoa osatzen duen hezurra. Jaio ondoren fetuan independenteak diren bi pubis hezurrek bat egiten dute, pubisaren aurreko alde osoa betetzen duen sinfisia eratuz.</descrip>
    </descripGrp>
