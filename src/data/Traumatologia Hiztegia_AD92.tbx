<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputz-atalen bat (gehienetan gorputz-adar bat izan ohi da) erdiko ardatzetik urrun zabaldu edo hedatzen duen muskulua. Bestela esanda: hezurren arteko angelua handitzen duen muskulua, besaurrea besoarekin lerrokatzen duena, esaterako.</descrip>
    </descripGrp>
    <tig>
      <term>muskulu hedatzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>muskulu estentsore</term>
      <termNote type='normativeAuthorization'>3</termNote>
