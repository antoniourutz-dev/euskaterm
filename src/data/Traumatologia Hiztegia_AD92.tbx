    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Toraxaren aurrealdean kokatzen den muskulua, 3. eta 5. saihets-hezurren erdialdetik eskapularen korakoide apofisiraino hedatzen dena. Sorbalda jaistea da haren funtzio nagusia.</descrip>
    </descripGrp>
