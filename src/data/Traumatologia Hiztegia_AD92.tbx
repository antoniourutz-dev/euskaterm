<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erradio hezurrarekin medialki kokatuta dagoen hezur luzea. Bien artean besaurreko eskeletoa osatzen dute. Goiko aldean, humeroarekin eta erradioaren buruarekin artikulatzen da, ukondoko giltzadura osatuz; beheko aldean, erradio hezurraren barrunbe sigmoideoarekin artikulatzen da, urruneko giltzadura erradiokubitala osatuz.</descrip>
    </descripGrp>
    <tig>
      <term>kubitu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>ulna</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cúbito</term>
    </tig>
    <tig>
      <term>ulna</term>
    </tig>
  </langSet>
