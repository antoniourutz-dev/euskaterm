  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>tarsus</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garezurraren albo bietako hezur konposatua. Zati petrosoa garezur-oinaldearen osaeraren parte da, eta bertan daude kokatuak tinpano-kaxa eta barne-belarria; zati ezkatatsua, aldiz, garezur-gangaren osaeraren parte da. Loki-hezurra bost hezurrekin artikulatzen da: parietalarekin goian, okzipitalarekin atzean, esfenoidearekin aurre eta barrualdean, malarrarekin aurre eta kanpoaldean, eta barailarekin behean, non artikulazio tenporomandibularra eratzen duten.</descrip>
    </descripGrp>
    <tig>
      <term>loki-hezur</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>hezur tenporal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
