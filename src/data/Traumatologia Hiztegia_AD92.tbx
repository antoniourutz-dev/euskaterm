<termEntry id="-1">
  <descrip type='subjectField'>Tresnak eta aparatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oihalezko pieza, goiko gorputz-adarrean lesionatuta dagoen atal bati eusteko eta hura immobilizatuta mantentzeko erabiltzen dena.</descrip>
