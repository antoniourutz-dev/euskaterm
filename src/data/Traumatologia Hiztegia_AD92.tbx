<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bigarren lepaornoa, goian atlasarekin eta behean hirugarren lepaornoarekin artikulatzen dena. Axisaren alderdirik bereizgarriena odontoide apofisia da, enbriologikoki atlasaren gorputza besterik ez dena eta atlas ornoaren aurreko arkuko giltzadura-aurpegiarekin artikulatzen dena. Buruko errotazio-mugimenduetarako ardatz gisa jokatzen du, eta hortik datorkio izena, grezieraz axis hitzak ardatza esan nahi baitu.</descrip>
    </descripGrp>
    <tig>
      <term>axis</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
