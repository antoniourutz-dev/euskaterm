    <tig>
      <term>Roentgen rays</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Diagnostikoa. Laborategia. Proba eta prozedura diagnostikoak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Germenak bereizteko erabiltzen den tindaketa bakteriologikoa. Koloragarria hartzen duten mikrobioak gram-positiboak dira, eta hartzen ez dutenak, berriz, gram-negatiboak.</descrip>
    </descripGrp>
    <tig>
      <term>Gram tindaketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
