  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Besaurrearen eta eskuaren artean kokatua dagoen gorputz-atala. Bertan artikulatzen dira kubitua eta erradioa karpo-hezurrekin.</descrip>
