    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>splint</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Tresnak eta aparatuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batean gorputz-atal bat, organo bat edo organo-zati bat ordezteko ezartzen den pieza edo tresna artifiziala.</descrip>
