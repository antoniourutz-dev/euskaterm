<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Karpoko bigarren ilarako hezurrak metakarpianoen oinaldearekin lotzen dituzten artikulazioetako bakoitza. Lehenengoa (trapezio hezurraren eta lehenengo metakarpianoaren arteko giltzadura, alegia) elkarrekiko ahokapen bat da; gainerakoak, berriz, artrodiak.</descrip>
    </descripGrp>
