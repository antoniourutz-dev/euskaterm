<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Besaurrearen kanpoko aldean, humeroaren eta karpoko hezurren artean kokatua dagoen hezurra, hezur arteko mintzaren bitartez barrutik kubituarekin artikulatzen dena. Goiko aldetik humeroarekin artikulatzen da, eta, beheko aldetik, berriz, karpoko hezurrekin.</descrip>
    </descripGrp>
