<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kartilago hialinoz estalitako gainazala, beste hezur bateko gainazal baliokidearekin batera giltzadura bat osatzen duena.</descrip>
    </descripGrp>
    <tig>
      <term>giltzadura-gainazal</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
