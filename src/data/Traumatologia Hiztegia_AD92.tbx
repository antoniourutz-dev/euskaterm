<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Anatomia ikasteko, konbentzioz onartutako postura edo jarrera erreferentziakoa: gorputza, tente (zutik); burua, aurrerantz begira; besoak, beherantz luzatuak, gorputzaren albo banatan; esku-ahurrak, aurrerantz; hatz-puntak, aurrerantz begira; zangoak, luzatuta eta zertxobait bananduta; eta behatz-puntak, aurrerantz jarrita.</descrip>
