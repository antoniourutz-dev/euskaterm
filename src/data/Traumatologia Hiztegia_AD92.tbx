  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gorputzaren erdiko planoan bi pubis hezurren baturak aurrealdean sortzen duen artikulazio kartilaginosoa, ez oso mugikorra.</descrip>
