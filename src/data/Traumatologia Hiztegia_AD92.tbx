<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mobilizatu beharreko hezurraren gainean tendoia lotu edo finkatzen den gunea.</descrip>
