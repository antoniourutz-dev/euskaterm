  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giza anatomian, sorbaldak, besondoak, besaurreak, eskumuturrak eta eskuak eratzen duten gorputz-adarra.</descrip>
