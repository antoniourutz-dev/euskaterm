    </tig>
    <tig>
      <term>rachis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hezur-irtengune biribildua, ardatz bat bestea baino luzeagoa duena (adibidez, izterrezurrekoa edo besahezurrekoa) eta beste hezur batekin artikulatzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>kondilo</term>
      <termNote type='normativeAuthorization'>4</termNote>
