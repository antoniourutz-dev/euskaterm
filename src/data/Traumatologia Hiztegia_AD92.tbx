    <tig>
      <term>plaie opératoire</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>surgical wound</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Handitua dagoen artikulazio batean edo zona mingarri batean substantzia bat injektatzea. Normalean, likido anestesiko edo hantura-kontrakoren bat izaten da.</descrip>
    </descripGrp>
    <tig>
      <term>infiltrazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
