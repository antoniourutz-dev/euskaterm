  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Atze-oina tarteko oinarekin lotzen duen giltzadura. Bertan bi artikulazio bereizten dira, bata bestearen segidan kokatuak: astragaloeskafoideoa eta kalkaneokuboideoa.</descrip>
    </descripGrp>
