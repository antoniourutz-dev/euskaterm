<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Muskulu bat hezurrean lotu edo finkatzen den gunea. Zuzeneko lotunea izan daiteke, zuntz muskularrek berek egina, baita tendoi edo aponeurosi bat baliatuz gertatutakoa ere.</descrip>
