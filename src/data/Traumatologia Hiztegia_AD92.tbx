    <tig>
      <term>femur</term>
    </tig>
    <tig>
      <term>thigh bone</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ilion hezurreko hegalaren erraien aldeko kurbaren sakonunea. Hedaduraz, maila horretan dagoen zona osoa eta bertan aurkitzen diren pelbiseko erraiak.</descrip>
    </descripGrp>
