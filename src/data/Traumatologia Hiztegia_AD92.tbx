<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ilion eta pubis hezurrekin batera hezur illiakoa osatzen duten hiru hezur fetaletako bat. Koxalaren atzeko eta beheko zatian dago kokatua. Tuberositate iskiatikoa esertzerakoan oinarri gisa erabiltzen den irtenguneetako bat iskion hezurraren zatia da.</descrip>
    </descripGrp>
