  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>condyle</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hezurrez eta aponeurosiz osatutako kanala, ornoen arkuen aurrean eta orno-gorputzen atzean kokatua. Orno-muina, meningeak eta ornoen sustraiak hartzen ditu bere barruan, eta zulo okzipitalarekin jarraitzen du goiko aldean.</descrip>
    </descripGrp>
    <tig>
      <term>orno-hodi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>bizkarrezur-hodi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
