<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Karpoko aurreneko ilarako hirugarren hezurra, alderantzikatutako piramide baten forma duena. Lau hezurrekin artikulatzen da: kubituarekin, hezur pisiformearekin, semilunarrarekin eta kako-hezurrarekin.</descrip>
