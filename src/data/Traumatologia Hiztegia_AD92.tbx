    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kirurgia bidezko ekintza, tresnak erabiliz eta teknika edo metodo definituei jarraituz egiten dena. Hondatutako zati, atal edo organo bat erauzteko edo osatzeko baliatzen da.</descrip>
