    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Patologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bizkarrezurreko orno bat azpikoaren gainetik aurrerantz mugitzea, bizkarrezur-arkuko akats batengatik edo artikulazioaren endekapenezko gaitz batek artikulazio-gainazala higatzen duelako. Gehienetan, azken bi orno lunbarretan gertatu ohi da.</descrip>
    </descripGrp>
