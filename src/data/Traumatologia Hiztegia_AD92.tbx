  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ardatz bertikalak eta aurretik atzerako ardatzak zehazten duten planoa, gorputza bi zati simetrikotan (ezkerrekoa eta eskuinekoa) banatzen duena.</descrip>
