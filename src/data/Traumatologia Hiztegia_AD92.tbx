  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>bone</term>
    </tig>
    <tig>
      <term>os</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oineko hezurra, laburra, tartsoaren kanpoaldean kokatua. Kalkaneoarekin, nabikularrarekin eta azken bi metatartsianoekin giltzatzen da.</descrip>
