<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zangoaren aurreko konpartimentuko muskulua, tibiaren kanpoaldeko tuberositatetik eta hezur arteko mintzetik abiatuz oineraino iristen dena. Jatorrian muskulua bada ere, orkatilan lotailu bilakatzen da, eta haren bidez txertatzen da oineko lehen hezur kuneiformean eta lehen metatartsianoan. Oinaren flexio dortsala eta inbertsioa ahalbidetzen ditu.</descrip>
    </descripGrp>
    <tig>
      <term>aurreko tibia-muskulu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>aurreko muskulu tibial</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
