    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>osteogenesis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Besaurrearen eta eskuaren mugimendua, supinazioaren kontrakoa. Oinarrizko posizio anatomikotik abiatuz, eskuak barrurantz bira egiten du, eta esku-ahurra atzera eta barrura begira geratzen da.</descrip>
    </descripGrp>
    <tig>
      <term>pronazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
