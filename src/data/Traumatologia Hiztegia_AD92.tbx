<body>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pelbiseko hezur koxalean –iskion, ilion eta pubis hezurren arteko loturan– dagoen kopa-formako giltzadura-barrunbea, izterrezurraren burua bere barnean jasotzen duena.</descrip>
    </descripGrp>
    <tig>
      <term>azetabulu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>barrunbe kotiloideo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>kotilo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acetábulo</term>
    </tig>
    <tig>
      <term>cavidad cotiloidea</term>
    </tig>
    <tig>
      <term>cótilo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acétabulum</term>
    </tig>
    <tig>
      <term>cavité cotyloïde</term>
    </tig>
    <tig>
      <term>cotyle</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>acetabulum</term>
    </tig>
    <tig>
      <term>cotyloid cavity</term>
    </tig>
    <tig>
      <term>cotyle</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sorbalda-hezurreko arantzaren muturreko apofisia, giltzadura akromioklabikularra osatzeko klabikularen kanpoko muturrarekin artikulatzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>akromion</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acromion</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>acromion</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>acromion</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Errain-hezurraren aurreko aldean dauden zortzi zuloetako bakoitza. Nerbio sakroen adar bentralak igarotzen dira bertatik.</descrip>
    </descripGrp>
    <tig>
      <term>errain-hezurreko zulo</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>agujero sacro</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>trou sacré</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>sacral foramina</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Mugimendu txikiko giltzadura, fibrokartilago batek elkarturiko bi giltzadura-gainazal lauk osatua. Ornoen gorputzen arteko giltzadurak, adibidez, anfiartrosiak dira.</descrip>
    </descripGrp>
    <tig>
      <term>anfiartrosi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>giltzadura erdimugikor</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
    <tig>
      <term>sinfisi</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>anfiartrosis</term>
    </tig>
    <tig>
      <term>articulación semimóvil</term>
    </tig>
    <tig>
      <term>sínfisis</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>amphiarthrose</term>
    </tig>
    <tig>
      <term>articulation semi-mobile</term>
    </tig>
    <tig>
      <term>symphyse</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>amphiarthrosis</term>
    </tig>
    <tig>
      <term>cartilaginous joint</term>
    </tig>
    <tig>
      <term>symphysis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ukondoko giltzaduraren eta eskumuturraren artean kokatua dagoen goiko gorputz-adarraren zatia.</descrip>
    </descripGrp>
    <tig>
      <term>besaurre</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>antebrazo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>avant-bras</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>forearm</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Orno bakoitzean dauden apofisietako bakoitza; bi apofisi-pare dira: goikoak eta behekoak. Beheko ornoaren goiko giltzadura-apofisiak goiko ornoaren beheko giltzadura-apofisiekin artikulatzen dira. Giltzadura-apofisien egitura diferentea da, bizkarrezur-eremuaren arabera.</descrip>
    </descripGrp>
    <tig>
      <term>giltzadura-apofisi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>apófisis articular</term>
    </tig>
    <tig>
      <term>proceso articular</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>processus articulaire</term>
    </tig>
    <tig>
      <term>apophyse articulaire</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>articular process</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sorbalda-hezurraren goiko ertzean kokatua dagoen tamaina handi samarreko apofisia, erdi-flexionatutako hatz baten forma duena (bele-mokoaren antza duelako hartzen du izen hori grezieraz). Bertan lotzen da bularreko muskulu txikia.</descrip>
    </descripGrp>
    <tig>
      <term>korakoide apofisi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>apófisis coracoides</term>
    </tig>
    <tig>
      <term>proceso coracoideo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>processus coracoïde</term>
    </tig>
    <tig>
      <term>apophyse coracoïde</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>coracoid process</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Orno-gorputzaren atzealdera proiektatzen den hezurrezko xafla bakoitia, arku neuralean sagitalki kokatua. Bertan lotzen dira arantza-muskuluak.</descrip>
    </descripGrp>
    <tig>
      <term>apofisi zorrotz</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>arantza-apofisi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>apófisis espinosa</term>
    </tig>
    <tig>
      <term>proceso espinoso</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>processus épineux</term>
    </tig>
    <tig>
      <term>apophyse épineuse</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>spinous process</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Axisaren orno-gorputzaren goiko aldean kokatua dagoen irtengune zilindrokonikoa, hortz baten antza duena. Han artikulatzen da atlas ornoa, eta pibote gisa funtzionatzen du harentzat.</descrip>
    </descripGrp>
    <tig>
      <term>odontoide apofisi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>axisaren hortz</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>apófisis odontoides</term>
    </tig>
    <tig>
      <term>diente del axis</term>
    </tig>
    <tig>
      <term>proceso odontoideo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>dent de l'axis</term>
    </tig>
    <tig>
      <term>apophyse odontoïde</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>dens axis</term>
    </tig>
    <tig>
      <term>odontoid process</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ornoen arku neuraletik zeharkako noranzkoan albo banatara irteten den tamaina handi samarreko apofisia. Bizkarrezur torazikoan artikulazio kostotransbertsoak osatzen dituzte orno bakoitzean, dagokien saihets-hezurrarekin.</descrip>
    </descripGrp>
    <tig>
      <term>zeharkako apofisi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>apófisis transversa</term>
    </tig>
    <tig>
      <term>proceso transverso</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>processus transverse</term>
    </tig>
    <tig>
      <term>apophyse transverse</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>transverse process</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bularrezurraren behealdeko muturra, pertsona gazteetan oraindik kartilaginosoa eta zaharretan erabat hezurtua egon ohi dena. Bularrezurraren eta xifoide apendizearen arteko loturaren parean artikulatzen dira zazpigarren saihets-kartilagoak.</descrip>
    </descripGrp>
    <tig>
      <term>xifoide apofisi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>xifoide apendize</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>xifoide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>apófisis xifoides</term>
    </tig>
    <tig>
      <term>apéndice xifoides</term>
    </tig>
    <tig>
      <term>proceso xifoideo</term>
    </tig>
    <tig>
      <term>xifoides</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>processus xiphoïde</term>
    </tig>
    <tig>
      <term>appendice xiphoïde</term>
    </tig>
    <tig>
      <term>apophyse xiphoïde</term>
    </tig>
    <tig>
      <term>xiphoïde</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>xiphoid process</term>
    </tig>
    <tig>
      <term>xiphoid appendix</term>
    </tig>
    <tig>
      <term>xiphoid</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tendoien luzapena, zuntzezko mintz zuri, gogor eta distiratsu batez osatua, muskuluen estalki gisa (bilkin-aponeurosia) edota muskuluak mugitzen dituzten zatiekin lotzeko (lotune-aponeurosia) balio duena.</descrip>
    </descripGrp>
    <tig>
      <term>aponeurosi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>faszia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>aponeurosis</term>
    </tig>
    <tig>
      <term>fascia</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>aponévrose</term>
    </tig>
    <tig>
      <term>fascia</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>aponeurosis</term>
    </tig>
    <tig>
      <term>fascia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kopeta-hezurraren begi gaineko prominentzia, bekainaren azpi-azpian kokatua.</descrip>
    </descripGrp>
    <tig>
      <term>bekain-arku</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>arku superziliar</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>arco superciliar</term>
    </tig>
    <tig>
      <term>arcada superciliar</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>arcade sourcilière</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>superciliary arch</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi hezur edo gehiagoren lotunea. Mugimenduari begira, giltzadurak honela banatzen dira: diartrosiak edo giltzadura mugikorrak (mugimendu-ardatz bakarra dutenak, troklea edo trokoideak; bi mugimendu-ardatz dituztenak, kondileoak eta zela modukoak; nahiz hiru ardatz eduki ditzaketenak, enartrosiak), anfiartrosiak (erdimugikorrak) eta sinartrosiak (edo giltzadura mugiezinak).</descrip>
    </descripGrp>
    <tig>
      <term>giltzadura</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>artikulazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>articulación</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>articulation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>joint</term>
    </tig>
    <tig>
      <term>articulation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Elkarrengandik urrun dauden bi hezur zuntzezko ehun baten bidez (lotailuz edo zuntzezko mintz bidez) lotzen dituen giltzadura-mota.</descrip>
    </descripGrp>
    <tig>
      <term>sindesmosi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>sindesmosis</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>syndesmose</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>syndesmosis</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giltzadura sinobiala, bi giltzadura-gainazalak pibote bat balira bezala kokatuak dituena. Hori dela eta, soilik luzeranzko ardatzean egin daitezke mugimenduak, hau da, errotazio medial eta laterala baino ez ditu onartzen.</descrip>
    </descripGrp>
    <tig>
      <term>trokoide</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>pibote-itxurako giltzadura</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>articulación trocoide</term>
    </tig>
    <tig>
      <term>articulación en pivote</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>articulation trochoïde</term>
    </tig>
    <tig>
      <term>articulation à pivot</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>pivot joint</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Klabikula eta akromiona (sorbalda-hezurreko irtengunea) lotzen dituen giltzadura.</descrip>
    </descripGrp>
    <tig>
      <term>giltzadura akromioklabikular</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>akromion-lepauztai giltzadura</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>articulación acromioclavicular</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>articulation acromio-claviculaire</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>acromioclavicular joint</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kondilo-itxurako giltzadura: erradio hezurraren beheko muturrak eta karpoko lehenengo lerroko hiru hezurrek (eskafoide, semilunar eta piramidalak) eratutako kondiloak osatzen dute. Mugimendu ugari ahalbidetzen ditu: flexioa, estentsioa eta desbideraketa erradial eta kubitala.</descrip>
    </descripGrp>
    <tig>
      <term>eskumuturreko giltzadura</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>giltzadura erradiokarpiano</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>erradio-karpo giltzadura</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>articulación de la muñeca</term>
    </tig>
    <tig>
      <term>articulación radiocarpiana</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>articulation du poignet</term>
    </tig>
    <tig>
      <term>articulation radio-carpienne</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>wrist joint</term>
    </tig>
    <tig>
      <term>radiocarpal joint</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Izterrezurraren beheko muturra errotularekin eta tibiarekin lotzen duen giltzadura. Bi artikulaziok osatzen dute: batetik, izterrezurraren troklearen eta errotularen atzeko aldearen artean ezartzen den troklea-motakoak, eta, bestetik, izterrezur-kondiloen eta tibiaren meseten artean ezartzen den kondilo-itxurakoak. Azken giltzadura horrek bi menisko artikular dauzka.</descrip>
    </descripGrp>
    <tig>
      <term>belauneko giltzadura</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
