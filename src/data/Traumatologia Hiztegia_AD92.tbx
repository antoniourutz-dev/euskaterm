    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>flexor muscle</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bizkarreko muskulua, eskapulako hobi infraespinosotik trokiterrera zabaltzen dena.</descrip>
