<termEntry id="-1">
  <descrip type='subjectField'>Patologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lepoaren tortsio mingarria, muskulu esternokleidomastoideoetako baten uzkurdurak eragina (trapezioaren eta esplenioaren uzkurdurari lotua nahiz ez). Horrek buruaren albo-makurdura sortzen du. Era askotakoa izan daiteke: sortzetikoa, sekundarioa, neurogenoa, mentala, etab.</descrip>
    </descripGrp>
