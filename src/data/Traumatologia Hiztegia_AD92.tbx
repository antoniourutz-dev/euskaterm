      <term>traction trans-osseuse</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>skeletal traction</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Terapeutika. Botikak. Tratamendurako teknikak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hautsi edo lokatutako hezurra bere posizio egokian geldirik edukitzeko igeltsuz eta bendaz eginiko geruza babesle eta euskarria.</descrip>
