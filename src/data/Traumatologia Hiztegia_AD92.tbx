<termEntry id="-1">
  <descrip type='subjectField'>Anatomia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Belaunaren erdialdeko euskarrietako bat, tibiaren aurre eta erdialdetik femurraren kanpoko kondiloaren barne eta atzealderantz hedatzen den zuntz lodi eta sendo batez osatua. Haren funtziorik garrantzitsuena belaunari egonkortasuna ematea da, batik bat aurreranzko gehiegizko mugimenduak ekidinez.</descrip>
