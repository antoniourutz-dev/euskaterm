  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>sarcomère</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>sarcomere</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="-1">
  <descrip type='subjectField'>Fisiologia</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Besaurrearen mugimendua, pronazioaren kontrakoa. Oinarrizko posizio anatomikotik abiatuz, esku-ahurra aurrerantz edo gorantz zuzentzen da.</descrip>
    </descripGrp>
