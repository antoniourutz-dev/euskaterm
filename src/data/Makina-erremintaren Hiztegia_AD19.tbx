<termEntry id="346824">
  <descrip type='subjectField'>Makina-motak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aldi berean funtzionatzen duten zenbait ardatzen bidez, mekanizazio-prozesu bi (torneaketa eta fresaketa, normalean) edo gehiago konbinatzen dituen makina. Piezak oratze bakarrean mekanizatzeko erabiltzen da; bestela, makina batean baina gehiagotan egin beharko litzateke mekanizazioa.</descrip>
    </descripGrp>
    <tig>
      <term>ataza anitzeko makina</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
