</termEntry>
<termEntry id="666327">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giza bizitzaren aurkako delitua: beste pertsona bati bizia kentzea.</descrip>
    </descripGrp>
    <tig>
