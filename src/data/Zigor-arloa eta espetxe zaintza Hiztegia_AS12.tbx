<termEntry id="666337">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Errudunak berriro delitu egitean datzan inguruabar astungarria. Berrerortzea egongo da, errudunak, delitu egiten duenerako, betearazi beharreko kondena jaso badu Zigor Kodearen titulu berean bildutako delitu baten ondorioz, betiere delitu hori izaera berekoa bada.</descrip>
    </descripGrp>
    <tig>
      <term>berrerortze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>reincidencia</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666338">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tratamendu-batzarrak egiten duen proposamena, zigor askatasun-gabetzaileetan inguruabar zehatzak biltzen dituzten epaituentzat ezartzen den baldintzapeko askatasunaren ingurukoa.</descrip>
    </descripGrp>
    <tig>
      <term>baldintzapeko askatasunaren proposamen</term>
