  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Barneratu bakoitzari ezarritako tratamendu-programak edo espetxe-eredu indibidualak betearazteaz arduratzen den lantaldearen nahitaezko txostena.</descrip>
