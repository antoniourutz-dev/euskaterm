    <tig>
      <term>responsabilidad penal</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666300">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delitu egitera bultzatzea, pertsona-multzo baten aurrean edo inprimaketa, irrati-difusioa edo antzeko eraginkortasuna duen eta publizitatea errazten duen beste edozein bide erabilita zuzenean.</descrip>
    </descripGrp>
    <tig>
      <term>delitu egiteko probokazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>provocación para delinquir</term>
    </tig>
    <tig>
      <term>provocación delictiva</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666301">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delitu egitea erabaki duenak beste pertsona bat edo batzuk delitu egitera gonbidatzea.</descrip>
    </descripGrp>
    <tig>
      <term>delitu egiteko proposamen</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
