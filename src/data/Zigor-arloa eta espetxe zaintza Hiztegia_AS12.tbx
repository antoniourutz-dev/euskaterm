    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>establecimiento de régimen ordinario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666299">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delituaren egile, egilekide, ezinbesteko laguntzaile, induzitzaile, sopikun edo estaltzaile izateak dakarren ondorioa.</descrip>
    </descripGrp>
    <tig>
