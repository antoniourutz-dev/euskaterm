  </langSet>
</termEntry>
<termEntry id="666295">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beste eginkizun batzuen artean, barneratu bakoitzarentzako tratamendu-programak edo betearazpeneko espetxe-eredu indibidualak ezartzeaz arduratzen den batzarra. Barneratuaren pertsonalitatearen berezitasunak eta kondenaren gutxi gorabeherako iraupena hartzen dira kontuan barneratuak egin beharreko jarduera definitzerakoan.</descrip>
    </descripGrp>
    <tig>
      <term>tratamendu-batzar</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>junta de tratamiento</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666296">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beste eginkizun batzuen artean, barneratu bakoitzarentzako tratamendu-programak edo betearazpeneko espetxe-eredu indibidualak ezartzeaz arduratzen den batzarraren txostena.</descrip>
    </descripGrp>
    <tig>
      <term>tratamendu-batzarraren txosten</term>
