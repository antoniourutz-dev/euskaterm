    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>establecimiento psiquiátrico penitenciario</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666286">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Auzitegiek, besteak beste epaiaren emaitza bermatzeko edo jokoan egon daitezkeen hainbat ondasun babesteko, behin-behinean hartzen duten neurria.</descrip>
    </descripGrp>
    <tig>
      <term>kautela-neurri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
