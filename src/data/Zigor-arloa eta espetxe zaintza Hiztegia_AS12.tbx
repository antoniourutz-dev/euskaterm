  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>equipo multidisciplinar</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666292">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beste batekin edo batzuekin batera delitu egin duen pertsona.</descrip>
