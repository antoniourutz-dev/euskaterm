  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hartzekodunei ondasunak ezkutatzea, zor zaiena kobra ezin izan dezaten.</descrip>
    </descripGrp>
    <tig>
      <term>ondasunak ostentzearen delitu</term>
