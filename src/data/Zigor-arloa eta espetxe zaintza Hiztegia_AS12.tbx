<termEntry id="666334">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egitatea era maltzurrean gauzatzean datzan inguruabar astungarria. Maltzurkeria dago errudunak pertsonen aurkako edozein delitu zuzenean edo bereziki segurtatzeko bideak, moduak edo erak erabiltzen baditu, ofendituaren defentsatik arriskurik ez hartzeko.</descrip>
    </descripGrp>
    <tig>
      <term>maltzurkeria</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>alevosía</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666335">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egitatea donari baten truke gauzatzean datzan inguruabar astungarria.</descrip>
    </descripGrp>
