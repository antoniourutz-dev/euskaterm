<termEntry id="666302">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delitu egin dela jakinda eta bertan egile edo sopikun gisa parte hartu gabe, delitu hori gauzatu eta gero modu hauetakoren batean esku hartzen duen pertsona: 1) irabazirik lortzeko asmorik gabe, egileei edo sopikunei laguntza emanez, haiek delituaren probetxu, produktu edo preziotik onura atera dezaten; 2) delitua ezagutu dadin eragozteko, delitu horren gorputza, efektuak edo tresnak ezkutatuz, aldatuz edo deuseztatuz;  3) inguruabar jakin batzuetan, agintaritzaren zein haren agenteen ikerketa saihesteko edo haien bilaketatik edo harrapaketatik ihes egiteko, delitu baten ustezko erantzuleei laguntza emanez.</descrip>
    </descripGrp>
    <tig>
      <term>estaltzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>encubridor</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666303">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delituaren egile, ezinbesteko laguntzaile edo induzitzaile izan gabe, aurretiazko edo une bereko egintzen bidez delitugintzan parte hartzen duen pertsona.</descrip>
    </descripGrp>
    <tig>
      <term>sopikun</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>cómplice</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666304">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delitugile batek hainbat delitu egin dituenean eta, ondorioz, hainbat arau penal aplikatu behar zaizkionean sortzen den egoera. Delitu-pilaketa erreala, ideala edo mediala izan daiteke.</descrip>
    </descripGrp>
    <tig>
      <term>delitu-pilaketa</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>concurso de delitos</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666305">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delitugilearen, egilekidearen, ezinbesteko laguntzailearen, induzitzailearen, sopikunaren edo estaltzailearen zigor-erantzukizuna amaitzea.</descrip>
    </descripGrp>
    <tig>
      <term>erantzukizun kriminala azkentze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>erantzukizun penala azkentze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>extinción de la responsabilidad criminal</term>
    </tig>
    <tig>
      <term>extinción de la responsabilidad penal</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666306">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delitugilea erantzukizun kriminaletik salbuesten duen inguruabarra.</descrip>
    </descripGrp>
    <tig>
      <term>inguruabar salbuesle oso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>circunstancia eximente completa</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666307">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erantzukizun kriminaletik salbuesteko baldintza guztiak betetzen ez direnean gertatzen den inguruabar aringarria.</descrip>
    </descripGrp>
    <tig>
      <term>inguruabar salbuesle ez-oso</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>inguruabar salbuesle osatugabe</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>circunstancia eximente incompleta</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666308">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delitugilearen erantzukizun penala arintzen duen inguruabarra. Adibidez, errudunak, haren aurkako prozedura judiziala abian dela jakin aurretik, egindako arau-haustea agintaritzari aitortzea.</descrip>
    </descripGrp>
    <tig>
      <term>inguruabar aringarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>aringarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>circunstancia atenuante</term>
    </tig>
    <tig>
      <term>atenuante</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="666309">
  <descrip type='subjectField'>Zuzenbide penala</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Delitugilearen erantzukizun penala astuntzen duen inguruabarra. Adibidez, berrerorlea izatea.</descrip>
    </descripGrp>
    <tig>
      <term>inguruabar astungarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>astungarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
