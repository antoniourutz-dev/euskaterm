<termEntry id="412064">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zenbaki atomikoa 4 duen elementu kimikoa (Be). Naturan konbinaturik soilik aurki daiteke (berilo mineralean, bereziki). Erreaktore nuklearretan, aleazioetan eta espaziontzien materialetan erabiltzen da, eta erregai fosilen errekuntzaren ondorioz aireratzen da batik bat. Arnasten denean, biriketan metatzen da ,eta beriliosia eragiten du. Hezurrei ere erasaten die.</descrip>
    </descripGrp>
    <tig>
      <term>berilio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
