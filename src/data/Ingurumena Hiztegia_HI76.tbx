  </langSet>
</termEntry>
<termEntry id="417728">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Estatu edo ingurumen-politikan esku duen herrialde batean sortzen den eta beste estatu edo herrialde bati nahiz inorena ez den inguru bati (nazioarteko urak, estratosfera) erasaten dion poluzioa, halako moldez non kutsatzaile-iturburu bakoitzaren ekarpena eta beraz horrek dakarren erantzukizuna zehaztea zaila edo ezinezkoa baita.</descrip>
    </descripGrp>
    <tig>
      <term>mugaz haraindiko kutsadura</term>
