<termEntry id="413885">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eransten den substantzia baten eraginez likido bateko partikula esekiak elkarri atxikiz malutak osatzea. Malutak, gero, jalkiz edo iragaziz bereiz daitezke likidotik. Hondakin-uren arazketan erabiltzen da.</descrip>
    </descripGrp>
    <tig>
      <term>malutapen</term>
