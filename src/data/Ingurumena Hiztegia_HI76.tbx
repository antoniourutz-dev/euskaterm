    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>tourbière</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>bog</term>
    </tig>
    <tig>
