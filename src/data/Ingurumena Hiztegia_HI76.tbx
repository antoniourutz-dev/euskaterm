  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erregai fosilek (gasolinak, gasolioak, gas naturalak, harrikatzak et abarrek) sulfuro gisa duten sufre-edukia txikiagotzeko prozesua. Eragiketa garrantzitsua da, erregaiek sufre dioxido gutxiago airera dezaten erretzen direnean.</descrip>
    </descripGrp>
