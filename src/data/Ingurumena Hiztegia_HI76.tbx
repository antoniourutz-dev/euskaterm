<termEntry id="417690">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Naturan, ingurune batean edo gai batean oso kantitate txikian dagoen elementu kimikoa, halako moldez non kontzentrazioa zehaztea ezinezkoa izan baitaiteke. Lurrazalari buruz, aztarna-elementutzat 1.000 ppm baino kontzentrazio txikiagoan daudenak hartu ohi dira (eskuarki, honako multzo honetakoak ez diren elementu guztiak: oxigenoa, silizioa, aluminioa, karbonoa, burdina, kaltzioa, magnesioa, sodioa, potasioa, titanioa, hidrogenoa, manganesoa eta fosforoa)</descrip>
    </descripGrp>
