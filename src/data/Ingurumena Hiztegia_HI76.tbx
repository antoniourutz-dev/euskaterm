<termEntry id="415653">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Elikagaietan dauden eta bizidunen metabolismoan parte hartzen duten konposatu organiko eta ez-organikoetako bakoitza, janariaren bidez edo modu ez-organikoan eskuratua. Honela sailkatu ohi dira: gluzidoak, lipidoak, proteinak, bitaminak, gatz mineralak eta metabolizatzen diren bestelako konposatu organikoak.</descrip>
