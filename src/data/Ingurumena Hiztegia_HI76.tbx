<termEntry id="413568">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ordenamendu juridikoaren alorra, ingurumena babestera bideratua eta gorputz sistematikoa osatzen duten arauak, printzipioak eta neurri juridikoak hartzen dituena.</descrip>
