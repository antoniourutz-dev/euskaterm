<termEntry id="415497">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ekosistema, komunitate edo osagai biologiko bitxi, ahul, garrantzitsu edo bakanak izateagatik bereziki babestu beharra aitortzen zaion natur gunea. Zenbait lege edo arautan -adibidez, Espainiako 4/89 legearen 14. artikuluan- ezartzen den natur gune babestu motetako bat da. </descrip>
    </descripGrp>
    <tig>
      <term>natura-erreserba</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
