  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ingurumenaren kudeaketaren ikuspegitik, produktua egiteko behar diren lehengaien ustiapenetik hasi eta produktua bera deuseztatu, ezabatu edo birziklatu arteko urratsen segida edo katea.</descrip>
    </descripGrp>
