    <tig>
      <term>biological indicator</term>
    </tig>
    <tig>
      <term>ecological indicator</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="413285">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Organismo batek ekosistema batean betetzen duen funtzioa. Ez dagokio organismoak betetzen duen espazio fisikoari, baizik eta betetzen duen eginkizunari. Funtzio hori organismoak bizi, hazi eta ugaltzeko behar dituen baldintzen (tenperatura, hezetasuna, gazitasuna...) eta baliabideen (ura, elikagaiak, babeslekua...) arabera eta bazka-sarean duen posizioaren arabera zehazten da. Lehia bidezko esklusioaren printzipioa dela eta, ezinezkoa da bi espezie txoko berean orekan irautea denbora luzean.</descrip>
    </descripGrp>
    <tig>
      <term>txoko ekologiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>nicho ecológico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>niche écologique</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>ecological niche</term>
    </tig>
  </langSet>
</termEntry>
