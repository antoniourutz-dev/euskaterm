  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Atomo-nukleoa partikula (adibidez, neutroi) batekiko talkaren eraginez tamaina txikiagoko bi nukleo edo gehiagotan zatitzea. Jatorrizko nukleoaren masa erreakzioaren emaitza diren nukleoen masen batura baino handiagoa da, eta kendura energia bihurtzen da. Energia hori erabiltzen da erreaktore eta lehergailu nuklearretan.</descrip>
    </descripGrp>
    <tig>
      <term>fisio</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
    <tig>
      <term>fisio nuklear</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
