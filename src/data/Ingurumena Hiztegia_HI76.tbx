    <tig>
      <term>biomonitoring</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="412140">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Uretako edo lurzoruetako kutsatzaileak deuseztatzeko edo degradatzeko bizidunak (bakterioak, onddoak...) erabiltzen dituzten tekniken multzoa. Esaterako, petrolioa itsasora isurtzeak eragiten duen marea beltzaren kontra hidrokarburoak degradatzeko gai diren bakterioak erabiltzea.</descrip>
    </descripGrp>
    <tig>
      <term>biorremediatze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
