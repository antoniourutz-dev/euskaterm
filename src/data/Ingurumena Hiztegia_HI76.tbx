    </tig>
  </langSet>
</termEntry>
<termEntry id="415893">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tamaina txikiko materia-zati solido edo likidoa, gas edo likido batean (eskuarki, airean edo uretan) esekia dena. Aireko zatiki-iturri garrantzitsuenak ibilgailuen motorrak, harrikatza darabilten zentral termikoak, egurra darabilten berogailuak eta industriak dira. </descrip>
    </descripGrp>
