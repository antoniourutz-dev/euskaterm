<termEntry id="525401">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Europako Ingurumen Agentziak eta Agentziaren kide diren estatuek ingurumena babesteko beharrezkoak diren neurriak hartzeko behar duten informazioa ematen laguntzen duten erakundeen sarea, honako hauez osatua: Europako Gaikako Zentroak, Puntu Fokal Nazionalak eta informazio-sare nazionalen Elementu Osagai Nagusiak (Erreferentziako Zentro Nazionalak, Batasunaren Puntu Fokalak eta beste hainbat erakunde, hala nola unibertsitateak, ikerketa-zentroak, laborategiak, enpresak, etab.). EIONET, aldi berean, Interneteko lotura publikoak erabiltzen dituen sare telematikoa (e-EIONET) da. </descrip>
    </descripGrp>
    <tig>
      <term>EIONET</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>Ingurumen Informazio eta Behaketako Europako Sarea</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>EIONET</term>
    </tig>
    <tig>
      <term>Red Europea de Información y Observación del Medio Ambiente</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>EIONET</term>
    </tig>
    <tig>
      <term>Réseau Européen d'Information et d'Observation pour l'Environnement</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>EIONET</term>
    </tig>
    <tig>
      <term>European Environment Information and Observation Network</term>
    </tig>
  </langSet>
</termEntry>
