  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsonetan edo gainerako bizidunetan gaixotasuna eragin dezaketen mikroorganismoak edo haien toxinak dituen substantzia. Europako Batasuneko 91/689 Zuzentarauaren arabera, substantziak eta hondakinak legez arriskutsutzat jotzeko ezaugarrietako bat da.</descrip>
