  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Landareek fotosintesi-prozesuan karbono dioxidoa eta eguzki-energia erabiliz sintetizatzen duten materia organikoan metaturiko energia. Energia berriztagarria da, beraz.</descrip>
    </descripGrp>
