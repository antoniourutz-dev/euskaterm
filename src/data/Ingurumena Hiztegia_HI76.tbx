<termEntry id="413884">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Likido batean esekiak dauden partikulak, eskuarki likidoari gehitzen zaion substantzia baten eraginez, elkarri atxikitzean eratzen duten tamaina handiagoko multzoa, errazago jalkitzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>maluta</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
