<termEntry id="413421">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Emisio-iturri batek aireratutako edo isuritako polutzaile-kopuruaren eta kontsumitutako energiaren edo lehengaien arteko erlazioa. Esaterako,  t CO<SUB>2</SUB>/TJ eran adieraz daiteke emisio-faktorea (terajouleko hainbeste tona karbono dioxido)</descrip>
    </descripGrp>
