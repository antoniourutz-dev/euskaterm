<termEntry id="418157">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>1946an sortutako nazioarteko erakundea; 1948az geroztik Nazio Batuen Erakundearen menpeko erakunde espezializatua da. Munduko herrialde guztietan osasun-maila hobetzea du helburu. Ingurumenaren arazoak osasunarekin zuzeneko lotura dutenez, MOEk poluzioari loturiko osasun-arazoak aztertzen ditu eta ingurumenaz arduratzen diren gainerako erakundeekin, nazioartekoekin zein estatu-mailakoekin, lan egiten du. Aholku-emaile funtzioa du, ez besterik. Genevan du egoitza nagusia.</descrip>
    </descripGrp>
    <tig>
      <term>OME</term>
      <termNote type='normativeAuthorization'>4</termNote>
