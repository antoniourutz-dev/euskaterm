    <tig>
      <term>United Nations Environment Program</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="417828">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nazio Batuen Erakundearen menpeko erakunde espezializatua, 1946an sortua. Parisen du egoitza nagusia. Erakundearen helburua da mundu osoan bakea eta ongizatea zabaltzea eta hezkuntza, zientzia eta kultura bultzatuz herrien arteko harremanak sendotzea. UNESCOren MAB programak biosfera-erreserbak izendatzen ditu mundu osoan.</descrip>
    </descripGrp>
    <tig>
      <term>Hezkuntza, Zientzia eta Kulturarako Nazio Batuen Erakundea</term>
