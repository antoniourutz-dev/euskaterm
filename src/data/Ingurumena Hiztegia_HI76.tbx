  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Poluzio lausoaren eragile den poluzio-iturria, kokapen jakin eta bakarra ez duena, barreiatua baizik. Isurtzen diren euri-urek, lixibiazioak eta abarrek bideratzen dituzte kutsatzaileak ingurunera.</descrip>
