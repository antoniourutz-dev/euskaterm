  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bernan 1979ko  irailaren 19an sinatutako nazioarteko hitzarmena. Haren helburua da Europako basabiziaren, flora nahiz faunaren, kontserbazioa ziurtatzea, ingurune naturala -habitat naturalak- kontserbatzea eta arlo horretan estatuen arteko lankidetza sustatzea.</descrip>
    </descripGrp>
    <tig>
      <term>Bernako Hitzarmena</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
