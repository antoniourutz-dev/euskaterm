  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nukleo atomikoaren fusio edo fisiotik askatzen den energia erabiltzen duten arma guztiz suntsitzailea.</descrip>
