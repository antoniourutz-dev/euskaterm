<termEntry id="418617">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Herrialde, eskualde edo lurralde jakin batean bakarrik bizi den landare- edo animalia-espeziea. Adibidez, <i>Armeria euskadiensis</i> landarea Euskal Herriko kostaldeko espezie endemikoa da.</descrip>
    </descripGrp>
    <tig>
      <term>endemiko</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
