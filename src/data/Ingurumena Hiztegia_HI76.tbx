<termEntry id="412063">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Berilioak eragindako intoxikazioa, pneumonia akutua edo nagusiki birikei erasaten dien granulomatosia dakarrena. Berilio-konposatu edo -aleazioen hautsak arnasteagatik gertatzen da, batez ere.</descrip>
