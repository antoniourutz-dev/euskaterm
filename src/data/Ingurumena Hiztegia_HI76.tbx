<termEntry id="530677">
  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nazioarteko hitzarmena, 1998ko ekainaren 25ean Aarhusen (Danimarka) sinatua. Hitzarmenaren bidez bermatu nahi dira ingurumenari buruzko informazioa eskuratzeko eskubidea, herritarrek ingurumenari dagozkion erabakietan parte hartzeko duten eskubidea eta ingurumenari dagozkion auzietan justiziara jotzeko eskubidea.</descrip>
