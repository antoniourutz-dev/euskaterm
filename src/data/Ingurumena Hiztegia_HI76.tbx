  </langSet>
</termEntry>
<termEntry id="413795">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lorerik eta hazirik gabeko landare baskularren izen arrunta. Sustraiak, zurtoinak eta  frondeak dituzte, eta esporen bidez ugaltzen dira.</descrip>
