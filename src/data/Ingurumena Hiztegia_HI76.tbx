  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lohiak flotazioz edo grabitatez loditzeko erabiltzen den tanga.</descrip>
