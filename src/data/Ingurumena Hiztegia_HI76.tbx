  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eskualde edo habitat txiki bateko klima, inguruko eskualdeetako klimatik bereizten duten zenbait parametro ezaugarri dituena, dela natura-faktoreen eraginez dela horien eta gizakiaren esku-hartzearen konbinazioaren ondorioz sortuak.</descrip>
