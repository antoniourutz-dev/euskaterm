    </tig>
  </langSet>
</termEntry>
<termEntry id="534501">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Urarekin zerikusia duten zerbitzuak, eta, horrez gain, uraren egoeran ondorio garrantzitsuak izan ditzakeen beste edozein jarduera.</descrip>
    </descripGrp>
    <tig>
      <term>uraren erabilerak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
