    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>internal combustion engine</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="414733">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Itsasgora eta itsasbehera bizien artean dagoen itsasbazterreko zerrenda. Ekosistema berezia izaten dute, kondizio fisikoak oso aldakorrak direlako. </descrip>
    </descripGrp>
