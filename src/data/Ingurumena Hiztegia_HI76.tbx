<termEntry id="530008">
  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Udal-agintariek sustatutako eta garatutako ekintza-plana, ingurumen, gizarte eta ekonomiari dagozkien alorretan garapen jasangarria lortzeko eta, horrekin batera, udalerriko biztanleen bizi-kalitatea hobetzeko. Tokiko Agenda 21en kontzeptua Rio de Janeiron sortu zen, 1992an, Ingurumenari eta Garapenari buruzko Nazio Batuen Konferentzian. Orduko hartan, Agenda 21 dokumentua onartu zen, garapen jasangarria lortzeko jarraitu beharreko bidea azaldu eta lehentasuna duten ekintzen programa biltzen duena; 28. atalean esaten denaren arabera, herri-agintarien parte-hartzea ezinbestekoa da dokumentuan jasotako helburuak lortzeko</descrip>
    </descripGrp>
    <tig>
      <term>Tokiko Agenda 21</term>
