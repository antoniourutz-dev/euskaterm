  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oinezkoak soilik ibil daitezkeen hiri- edo herri-alderdi mugatua, ibilgailuak ibiltzea debekatuta edo zerbitzu-mota batzuetarako (garraio publikoa, larrialdiak, zamalanak, etab.) soilik baimenduta dagoena. </descrip>
    </descripGrp>
    <tig>
