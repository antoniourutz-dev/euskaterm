<termEntry id="413813">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Likido edo gas batean esekita dauden zatiki solidoak bereizteko tresna, zatikiei iragaten uzten ez dien eta bere barnean atxikitzen dituen gai porodun bat duena. Zatiki solidoak bereizteko bestelako prozedurak erabiltzen dituzten zenbait tresnari ere, batzuetan, iragazki deritze (adibidez, iragazki elektrostatikoa)</descrip>
    </descripGrp>
    <tig>
      <term>iragazki</term>
      <termNote type='normativeAuthorization'>4</termNote>
