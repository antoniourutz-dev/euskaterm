    <tig>
      <term>continental waters</term>
    </tig>
    <tig>
      <term>inland waters</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="414661">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona edo abereentzat edo labore edo elikagaietarako kaltegarri diren intsektuak hiltzeko produktua.</descrip>
