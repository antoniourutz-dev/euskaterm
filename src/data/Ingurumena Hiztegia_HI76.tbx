<termEntry id="416608">
  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Andeatutako ekosistema bat narriadurarik ez duen egoerara ekartzeko ekintzen multzoa. Birgaitu ondoren, ekosistemak andeatu aurretik zituen ezaugarriak (<i>leheneratze</i>) edo beste ezaugarri batzuk izango ditu. </descrip>
    </descripGrp>
