<termEntry id="414776">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Larruazala edo muki-mintza ukitzean hantura eragiten duen substantzia edo prestakin ez-korrosiboa. Europako Batasunaren 92/32 Zuzentarauaren arabera, substantziak eta hondakinak legez arriskutsutzat jotzeko ezaugarrietako bat da. Gai narritagarrien etiketetan <i>Xi</i> ikurra erabiltzen da. Besteak beste, lixiba, amoniakoa, trementina-esentzia (edo agoarras) eta abar narritagarriak dira.</descrip>
    </descripGrp>
    <tig>
      <term>narritagarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>irritante</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
