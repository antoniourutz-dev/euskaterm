    <tig>
      <term>visual impact</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="418518">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ingurumen-inpaktu mota bat. Ingurumen-inpaktua larria denean, ezinbestekoa da jatorrizko ingurumen-egoerara itzultzeko babes- eta zuzentze-neurriak hartzea, eta, hartuta ere, denbora luzea behar izaten daleheneratzeko. Ingurumen-inpaktuari buruzko 1131/1988 Errege Dekretuak zehazten dituen inpaktuetariko bat da, eta ingurumen-inpaktuaren azterlanean proiektuek edo jarduerek ingurumenean duten inpaktu orokorra baloratzeko, besteak beste, erabiltzen da.</descrip>
    </descripGrp>
    <tig>
      <term>ingurumen-eragin larri</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
    <tig>
