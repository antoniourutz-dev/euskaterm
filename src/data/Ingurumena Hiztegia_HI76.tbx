  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Esperimentu batean aztertutako substantzia bati dagokionez, saiakuntzan antzematen den eragin kaltegarririk ez duen gehienezko kontzentrazioa. Maila horretan, litekeena da bestelako efektuak antzematea, baina kaltegarritzat jotzen den efekturik ez.</descrip>
    </descripGrp>
