    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>ecoefficacité</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>eco-efficiency</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="530020">
  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produkzio-prozesu baten abiapuntua den gai birziklatua.</descrip>
    </descripGrp>
    <tig>
      <term>bigarren mailako lehengai</term>
