<termEntry id="411575">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hondakin-uren tratamendu biologikoan, hondakin-uren eta lohi aktibatuen nahastea irabiatzeko eta aireztatzeko prozesua. Ondoren, lohi aktibatua jalki eta bereizi egiten da hondakin-ur araztuetatik, behar izanez gero prozesuan berriz ere erabili ahal izateko. </descrip>
    </descripGrp>
