<termEntry id="415885">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gizakiak gutxi ustiatu edota eraldatu duen natur gunea, paisaiaren ederragatik, ekosistemak oso adierazgarriak izateagatik edo flora, fauna edo formazio geologiko berezi-bereziak izateagatik, lehentasunezko kontserbazioa merezi duten balio ekonomikoak, estetikoak, hezkuntzazkoak eta zientziazkoak dituena (Espainiako martxoaren 27ko 4/1989 Legean agertzen den lege-izendapena da, eta EAEko Natura Babesteko 16/1994 Legean eta Nafarroako Lurraldea Erabili eta Babesteko 6/1987 Legean ezartzen den <i>natur parke</i> izendapenaren baliokidea da). </descrip>
    </descripGrp>
    <tig>
      <term>parke</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>parque</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
