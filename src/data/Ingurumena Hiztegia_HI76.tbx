<termEntry id="413378">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tentsio elektriko bat aplikatuz eragindako dialisia, likido batetik ioiak kentzeko erabilia. Bi mintz gutxienez (bata ioi negatiboekiko iragaztezina, eta bestea positiboekiko) dituen upela batean egiten da, eta bereziki itsas ura gatzgabetzeko erabiltzen da.</descrip>
    </descripGrp>
