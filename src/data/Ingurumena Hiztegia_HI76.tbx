    </tig>
    <tig>
      <term>fuente no renovable de energía</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>source d'énergie non renouvelable</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>non-renewable energy source</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="475748">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Naturan etengabe berritzen ez den eta ahi daitekeen iturri batetik lortzen den energia, edo ustiatu baino askoz ere abiadura motelagoan berritzen den eta, beraz, ahitzeko arriskuan dagoen iturri batetik lortzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>energia berriztaezin</term>
      <termNote type='normativeAuthorization'>4</termNote>
