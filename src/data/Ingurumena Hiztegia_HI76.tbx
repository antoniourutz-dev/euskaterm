  </langSet>
</termEntry>
<termEntry id="413141">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Likido bat berotu eta osagaiak lurrunketaz bereizteko prozedura. Likidoak arazteko eta nahasteetako osagaiak bereizteko erabiltzen da; adibidez, purutasun handiko ura (ur destilatua) lortzeko. Bestalde, petrolioa fintzeko prozedura nagusietako bat da. Nahastea ontzi berezi batean berotzen da; lehenengo, osagairik lurrunkorrena lurruntzen da, eta lortutako lurruna hoztu eta berriz likidotzen da. Horrela lortzen da delako osagai hori besteetatik bereiztea.</descrip>
    </descripGrp>
    <tig>
      <term>destilazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
