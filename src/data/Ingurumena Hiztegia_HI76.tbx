<termEntry id="415638">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Atomoaren nukleoa transformatzen duen erreakzioa. Emaitza beste nukleo batzuk, neutroiak eta erradiazioa dira, eta energia handia askatzen da. Erreakzio nuklear nagusiak fisioa, fusioa eta desintegrazio erradioaktiboa dira. </descrip>
    </descripGrp>
