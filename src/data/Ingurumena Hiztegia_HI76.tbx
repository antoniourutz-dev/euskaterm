<termEntry id="413292">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Naturaren defentsa eta, horren barnean, giza espeziearena, aldezten duen mugimendu soziopolitikoa, gizartearen eta naturaren arteko harremanen aldaketa eskatzen duena. Definizio zabal horren barnean azpijoera eta ideologia asko daude, 1970eko hamarkadan agertu ziren gizarte-mugimendu berri gehienak barne.</descrip>
    </descripGrp>
