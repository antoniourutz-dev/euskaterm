<termEntry id="415968">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hidrokarburo-nahaste likatsu eta sukoia, kolore ilun eta usain bortitzekoa, lurpean metatutako organismoen transformazio geldoaren emaitza dena. Hidrokarburo asez edo parafinikoz, hidrokarburo ziklikoz edo naftenikoz eta, batzuetan, hidrokarburo aromatikoz osatua dago. 48 MJ/kg inguruko berotze-ahalmena du.</descrip>
    </descripGrp>
    <tig>
      <term>petrolio</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>petróleo</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
