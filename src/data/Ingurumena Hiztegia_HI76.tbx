  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zentral termikoetan-eta, errekuntza-ganberatik irteten diren hondar-gasen bero-energia galdara berotzen duen urari transferitzeko erabiltzen den bero-trukagailua. Horren bidez, bero-energia gutxiago xahutzen da errekuntzan, hondar-beroaren parte bat berriz erabiltzen baita, eta ingurunera bero gutxiago egozten da.</descrip>
