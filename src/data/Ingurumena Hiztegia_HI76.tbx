  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Dituen balio estetiko edo kulturalengatik babes berezia merezi duela aitortzen zaion natur gunea. </descrip>
    </descripGrp>
    <tig>
      <term>paisaia babestu</term>
