<termEntry id="418934">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Itsasertzetik gertu ez dagoen eta itsaertzaren eragina nabari ez den itsas hedadura. Ekosistema gisa, itsasertzeko ekosistemetatik (estuarioa, itsas padura, arrezifea) bereizia da.</descrip>
    </descripGrp>
    <tig>
      <term>itsas zabal</term>
