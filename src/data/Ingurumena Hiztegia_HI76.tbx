<termEntry id="418533">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi bentzeno-eraztun edo gehiago dituen konposatu organikoa (izendapen hau bi karbono-atomo komun dituzten zikloez osatutako konposatu organikoak adierazteko erabiltzen da eskuarki: naftalenoa, antrazenoa, fenantrenoa...). Harrikatz-mundrunetik lortzen dira gehienbat. Emisio-iturri nagusia erregai fosilen errekuntza burutugabea da. Batzuk kartzinogeno bortitzak dira (bentzopirenoa eta dibentzoantrazenoa)</descrip>
