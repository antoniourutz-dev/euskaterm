  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hondakin-urak bakterio aerobio ugari dituen lohiarekin nahasi eta irabiatuz aireztatzean sortzen den lohi-antzeko gai malutatu eta biologikoki aktiboa. Uretako materia organikoaren degradazioa azkartzen du.</descrip>
