<termEntry id="414750">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Uretatik anioi eta katioi jakin batzuk kentzeko prozedura, direlako ioien truke beste batzuk askatzen dituen material batetik igaroaraziz egiten dena.</descrip>
