<termEntry id="413563">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ur, aire, lurzoru, lurralde eta naturaren egoerari buruzko informazio oro, bai eta elementu horiek babesteko hartutako neurriei edo gauzatzen ari diren ekintzei buruzkoa ere, Administrazioaren jarduerei eta ingurumena kudeatzeko plan edo programei buruzkoak barne.</descrip>
