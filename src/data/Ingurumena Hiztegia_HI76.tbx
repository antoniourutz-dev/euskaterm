    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>distillation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="413165">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Etxeko kontsumoaren ondorio diren hondakin solidoen multzoa. Askotariko hondakinak izaten dira nahasian, eta horrek arazoak sortzen ditu hondakin-mota bakoitzari behar duen tratamendu egokia emateko. Gaikako zabor-bilketa bultzatzea da arazo hori konpontzeko bide bat. </descrip>
    </descripGrp>
    <tig>
