<termEntry id="418929">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tamaina, adina, historia edo bestelako ezaugarri nabarmenengatik babes berezia merezi duela aitortzen zaion zuhaitza. </descrip>
