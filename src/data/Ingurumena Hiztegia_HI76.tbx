<termEntry id="418950">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Balio zientifiko, ekologiko edo kulturala duelako edo oso ezaugarri bereziak dituelako, babesa eta arreta berezia merezi duen landare- edo animalia-espeziea<br/>Espainiako natura babesteko 4/1989 Legeak finkatutako fauna eta flora babesteko kategoria da. Kategoria horretan sartzen dira balio zientifiko, ekologiko edo kulturala edo oso ezaugarri bereziak izateagatik babesa eta arreta berezia merezi duen landare- edo animalia-espezieak, beti ere <i>espezie sentibera</i>, <i>habitataren eraldaketaren mendeko espezie</i> edo <i>galzoriko espezie</i> bezala sailkatu ez baldin badira.</descrip>
    </descripGrp>
    <tig>
