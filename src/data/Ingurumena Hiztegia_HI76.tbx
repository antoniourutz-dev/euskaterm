<termEntry id="413403">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zatiki solidoak tamainaren arabera bereizteko metodoa, fluido baten korronte bat erabiliz gauzatzen dena. Fluido batean ur- edo aire-korronte batean, adibidez esekita dauden zatikiek, grabitate-indarraren eraginez, hondoratu edo jalkitzeko joera dute. Baina, bestalde, fluidoak eragindako arraste-indarra ere jasaten dute. Fluidoaren abiadura aldaraziz, arraste-indarra handiagotu edo txikiagotu egin daiteke eta jalkitze-abiaduran eragin. Horrela lortzen da zatiki solidoak tamainaren arabera bereiztea.</descrip>
    </descripGrp>
    <tig>
      <term>elutriazio</term>
      <termNote type='normativeAuthorization'>4</termNote>
