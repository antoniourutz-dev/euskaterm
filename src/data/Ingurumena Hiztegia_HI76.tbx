<termEntry id="414752">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hondakin-uretatik zenbait ioi kentzeko erabiltzen den gailua, ioi-trukea egiten duen materiala duena.</descrip>
