<termEntry id="414753">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egitura-aldaketa garrantzitsurik gertatu gabe likido bateko ioiak hartu eta haien ordez bere barnean finkaturik dituen beste batzuk aska ditzakeen materiala, modu itzulgarrian lan egin dezakeena.</descrip>
    </descripGrp>
