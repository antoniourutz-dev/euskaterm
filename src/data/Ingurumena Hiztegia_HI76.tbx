      <term>couche d'inversion</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>inversion layer</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="414748">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Elektroi bat edo batzuk hartu edo galdu dituen atomoa edo molekula. Elektroiak irabaziz gero, ioiak karga negatiboa du (<i>anioi</i> deritzo orduan); galdu baditu, berriz, karga positiboa (<i>katioi</i> deritzo orduan)</descrip>
    </descripGrp>
    <tig>
      <term>ioi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
