<termEntry id="413136">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Neurri jakineko poroak (eskuarki, 0,1 eta 1 mikrometro bitarteko poroak) dituen iragazki batetik igaroarazi ondoren bereizi barik geratu diren uretako gai organikoen karbono-edukia. Uraren kalitatea aztertu eta kontrolatzeko erabiltzen diren parametroetako bat da.</descrip>
    </descripGrp>
