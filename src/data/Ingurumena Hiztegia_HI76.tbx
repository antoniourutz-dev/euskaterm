<termEntry id="415816">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arrain-populazio bat gehiegi ustiatzearen ondorioz, populazioaren emankortasuna murriztea eta, arrantzaren bideragarritasunari dagokionez, definitu den maila onargarriaren azpitik gelditzea arrain-stocka. Arrantzaren kostua kontuan hartzen duen alderdi ekonomikotik begiratuta, esaten da gehiegizko arrantza gertatzen dela arrainen heriotza-tasaren igoerak arrainen biomasa-stockaren hazkunde negatiboa eragiten duenean; ondorioz, gehiegizko arrantzak baliabidearen errentaren hazkunde marjinal negatiboa eragiten du. </descrip>
    </descripGrp>
    <tig>
      <term>gainarrantza</term>
