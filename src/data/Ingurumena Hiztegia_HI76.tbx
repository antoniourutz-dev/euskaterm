<termEntry id="418940">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Itsasoko urak barneratzen diren kostaldeko haran estua. Glaziazioen ondoren itsas maila igotzearen ondorioz eratuak dira eta lehorrerantz barneratu ahala sakonera txikiagoa da, fiordetan ez bezala. </descrip>
