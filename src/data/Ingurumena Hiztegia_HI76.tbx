<termEntry id="412144">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bizidunak bizi diren Lur planetaren geruza, atmosferaren behealdea, litosferaren goialdea eta hidrosfera bere barnean hartzen dituena. Bizidunen iraganeko eta gaur eguneko jarduerek baldintzatutako konposizioa, egitura eta energia-sistema dituen Lurraren geruza da; biziaren sistema osoa da, Lurraren zati bizigabea -geosfera- euskarri duena.</descrip>
    </descripGrp>
    <tig>
      <term>biosfera</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>biosfera</term>
    </tig>
    <tig>
      <term>ecosfera</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
