<termEntry id="415983">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Solido kristalino zuria (C<SUB>6</SUB>H<SUB>5</SUB>OH), bentzenoaren deribatua. Uretan disolbatzen da, eta usain berezia du, korrosiboa da eta oso toxikoa. Harrikatzaren mundruna destilatuz edo bentzenotik sintetizatuz lortzen da. Produktu askoren sintesi-abiapuntua da industria kimikoan.</descrip>
    </descripGrp>
    <tig>
      <term>fenol</term>
      <termNote type='normativeAuthorization'>4</termNote>
