<termEntry id="418924">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aldaketa irregular edo aldizkakoen gisa nabari den ingurumen-efektua. Ingurumen-inpaktuari buruzko 1131/1988 Errege Dekretuak zehazten dituen efektuetariko bat da, eta ingurumen-inpaktuaren azterlanean proiektuek edo jarduerek ingurumenean eragiten dituzten inpaktuak identifikatzeko eta baloratzeko, besteak beste, erabiltzen da.</descrip>
    </descripGrp>
