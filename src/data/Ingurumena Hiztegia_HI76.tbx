  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Gaixotasuna sortzen duena edo sor dezakeena. Normalean, organismoak izendatzeko erabiltzen da, hala nola gaixotasunak sor ditzaketen birusak, bakterioak, protozooak, etab.</descrip>
    </descripGrp>
    <tig>
      <term>patogeno</term>
