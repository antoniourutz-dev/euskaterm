<termEntry id="413312">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ingurune fisikoak eta bizidunen komunitateak elkarrekintzan dauden biosferaren zatia. Bizitza mantentzeko beharrezkoak diren ezaugarriak dituen zatirik txikiena da, hau da, biotopo bateko organismoek, horien inguruneak eta bien arteko materia- eta energia-truke guztiek eratutako unitate funtzionala.</descrip>
    </descripGrp>
    <tig>
      <term>ekosistema</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
