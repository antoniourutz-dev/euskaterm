    </tig>
  </langSet>
</termEntry>
<termEntry id="418619">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Giza jarduerak nagusiki eraldatu ez dituen ekosistemak dauden lurraldea, landare- edo animalia-espezie interesgarriak edota balio estetikoa duten paisaiak dituena.</descrip>
