</termEntry>
<termEntry id="414770">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eragiten duen aldaketaren aurreko egoerara iltzultzea ezinezkoa edo biziki zaila den ingurumen-efektua. Ingurumen-inpaktuari buruzko 1131/1988 Errege Dekretuak zehazten dituen efektuetariko bat da, eta ingurumen-inpaktuaren azterlanean proiektuek edo jarduerek ingurumenean eragiten dituzten inpaktuak identifikatzeko eta baloratzeko, besteak beste, erabiltzen da.</descrip>
    </descripGrp>
    <tig>
      <term>efektu itzulezin</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>efecto irreversible</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>effet irreversible</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>irreversible effect</term>
    </tig>
  </langSet>
</termEntry>
