      <term>integral reserve</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="418960">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nolabaiteko ekologia- edo paisaia-balioa izaki, kontserbatzeko edo egoera hobetzeko babesa ematen zaion natur gunea. Giza jarduerak onartuta daude bertan, baina egoki antolatu behar dira gunearen balioak ez andeatzeko. Nafarroako Foru Erkidegoan, natur gune babestuen motetako bat da.</descrip>
    </descripGrp>
    <tig>
      <term>lekune natural</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
