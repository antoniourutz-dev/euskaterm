    </tig>
  </langSet>
</termEntry>
<termEntry id="415910">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Landareen deskonposizio partzialaren emaitza den gai ilun eta harroa, ur ugaria eta oxigenazio urria duten belardi, zingira eta antzekoetan sortzen dena. Harrikatzetan berriena da (zenbaitzuek ez dute harrikatzen artean sailkatzen), eta, beraz, karbono-edukirik txikienekoa. Bero-ahalmen txikiko erregaia da (lehortuta, 17 MJ/kg-ko berotze-ahalmena izan dezake, gehienaz ere). Zohikatzaren diagenesiaz, lignitoa eratzen da.</descrip>
    </descripGrp>
    <tig>
      <term>zohikatz</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
