    </tig>
    <tig>
      <term>biotechnologie environnementale</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>environmental biotechnology</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="530675">
  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ikastetxeko eta haren inguruko ingurumenaren kalitatearen eta jasangarritasunaren alde lan egiteko, hezkuntza-komunitateak hartutako konpromisoa. Eskolako Agenda 21ek ikasleei beren ingurumen hurbilaren arazoa aztertu eta ulertzea ahalbidetzen die, eta herritar gisa gizarte bidezkoago eta ekologikoki jasangarriago baten alde aritzeko prestatzen ditu.</descrip>
    </descripGrp>
    <tig>
      <term>Eskolako Agenda 21</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
