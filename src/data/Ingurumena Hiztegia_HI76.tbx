<termEntry id="530032">
  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ingurumenaren kalitatea babestera eta leheneratzera bideratutako teknika biologiko modernoen multzoa. Adibidez, mikroorganismo bidezko degradazioa, biorremediatze-teknikak eta kontrol biologikoa ingurumen-bioteknologiaren parte dira.</descrip>
    </descripGrp>
    <tig>
      <term>ingurumen-bioteknologia</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
