  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Jatorriz eskualde batekoa izanik, beste eskualde batean zabaltzen den espeziea, eskualde horretako ekosistema, habitat eta espezieei kalte egin diezaiekeena. Azken urteotan, espezie inbaditzaileak asko zabaldu dira munduan, bai jendearen mugikortasunaren ondorioz bai espezie arrotzen eskuragarritasunagatik ere.</descrip>
