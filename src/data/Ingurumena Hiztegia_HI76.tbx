<termEntry id="414644">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kontinenteetako azaleko ur geldiak, ur-lasterrak eta lurpeko urak. Lurrean dagoen ur guztiaren % 0,6421 dira, eta honela daude banatuta: % 0,62 lurpeko ura da, % 0,009 ur gezako aintziretan dago, % 0,008 ur gaziko aintziretan eta barne-itsasoetan, % 0,0001 ibaietan eta % 0,005 lurzoruan.</descrip>
    </descripGrp>
    <tig>
      <term>ur kontinentalak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
