<termEntry id="413799">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Landareen mantenugai diren substantziak modu ez-organiko edo organikoan dituen produktua, lurzoruari emankortasuna handitzeko gehitzen zaiona. Dena den, ongarriek alde txarra ere badute. Izan ere, gehiegizko mantenugai-kontzentrazioak eutrofizazioa eragiten du, eta horrek lurzoruaren eta uraren poluzioa dakar berekin.</descrip>
    </descripGrp>
    <tig>
      <term>ongailu</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
