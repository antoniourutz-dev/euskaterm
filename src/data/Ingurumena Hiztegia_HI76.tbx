<termEntry id="414742">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Tenperatura garaierarekin batera handitzen den atmosferako geruza horizontal edo ia horizontala. Tenperatura-gradientea dela eta, kutsatzaileak ez dira gorantz barreiatzen eta geruzan metatu egiten dira.</descrip>
    </descripGrp>
    <tig>
      <term>inbertsio-geruza</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>capa de inversión</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
