<termEntry id="413273">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Produktu baten bizi-zikloaren azterketa osoa, diseinatzen denetik ezabatzen den arte. Produktu batek ingurumenean duen benetako inpaktua neurtzeko balio du, alderdi guztiak hartzen baititu, hala nola energia-kontsumoa, lehengaien erabilera eta sortutako kutsadura. Enpresan erabakiak hartzeko tresna lagungarria da.</descrip>
    </descripGrp>
