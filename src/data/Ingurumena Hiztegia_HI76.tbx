    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>irritant</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="414781">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zatiki esekiak aireratzen dituzten kutsadura-iturriak kontrolatzeko laginketa-mota; haren bereizgarria da lagin-hartzearen abiadura eta norabidea isurtzen ari den gasaren abiaduraren eta norabidearen berdinak izatea.</descrip>
    </descripGrp>
    <tig>
      <term>laginketa isozinetiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
