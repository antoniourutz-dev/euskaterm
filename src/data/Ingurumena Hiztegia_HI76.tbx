<termEntry id="415875">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nagusiki zuretik lortzen den landare-zuntzezko orea hedatuz eta lehortuz lortzen den gaia, gehienbat elkarri atxikitako zelulosa-zuntzez osatua. </descrip>
