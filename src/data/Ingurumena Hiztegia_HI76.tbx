<termEntry id="411899">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Konposatu organikoa, bentzenoarena bezalako karbono-eraztun bat edo batzuk dituen hidrokarburo baten deribatua. Esate baterako, dioxinak.</descrip>
