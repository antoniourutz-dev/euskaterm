<termEntry id="417079">
  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Uraren tratamenduan, ale-tamaina jakineko hondarrezko iragazki batean zehar ura goitik behera eta emari jakin batez iragaztea, bidean gertatzen diren prozesu fisiko, kimiko eta biologikoen bidez ur garbia emateko</descrip>
