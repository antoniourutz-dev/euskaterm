  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ur-eremu mugatua, non arrantzaleek, baimena izanez gero, arrantza egin dezaketen urte-sasoi jakinetan (arrantza egiteko aldia mugatuta egoten da, arrainen ugalketa eta kontserbazioa ziurtatzearren)</descrip>
