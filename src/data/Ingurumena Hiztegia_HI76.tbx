<termEntry id="412074">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bi gurpilez osatutako ibilgailua, haren gainean eserita doanak pedal-sistema bati eraginez higiarazten duena. Gurpilak plano berean daude, bata bestearen atzetik, metalezko hodiz osatutako egitura bati ardatzetatik atxikiak, eta kate baten bidez transmititzen da pedalen higidura atzeko gurpilera.</descrip>
    </descripGrp>
