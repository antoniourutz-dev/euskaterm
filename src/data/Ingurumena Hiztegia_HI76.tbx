  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lagina hartzen eta analizatzen den arteko denboran, lagin horretan aldaketarik izan ez dadin egiten den prozesua; prozedura fisiko edota kimikoz baliatzen da.</descrip>
    </descripGrp>
    <tig>
      <term>laginaren egonkortze</term>
