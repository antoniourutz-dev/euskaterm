    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>School Agenda 21</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="530676">
  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Harrapatu ondoren itsasora botatzen diren arrainak. Besteak beste, txikiegiak direlako edo helburu-espeziekoak ez direlako botatzen dira.</descrip>
    </descripGrp>
