<termEntry id="530031">
  <descrip type='subjectField'>Ingurumena.</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Substantzia kimiko toxikoak bizidunetan gero eta kontzentrazio handiagoan metatzea bazka-sarean gora egin ahala. Organismoen gorputzak ez dira gai hainbat substantzia toxiko kanporatzeko, eta, horregatik, substantzia horiek metatu egiten dira. Adibidez, arrainek bizitza osoan jandako bazkan dagoen DDTa metatu egiten dute. Arrain handiek bizitza osoan jandako arrain txikiek metatutako DDTa metatu egiten dute. Guk jaten ditugun arrain handiek metatutako DDTa metatu egiten dugu. Hala, maila bakoitzean gero eta handiagoa da DDTaren kontzentrazioa.</descrip>
    </descripGrp>
    <tig>
      <term>biohanditze</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>biomagnifikazio</term>
      <termNote type='normativeAuthorization'>3</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>biomagnificación</term>
    </tig>
    <tig>
      <term>magnificación biológica</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>amplification biologique</term>
    </tig>
    <tig>
      <term>bioamplification</term>
    </tig>
