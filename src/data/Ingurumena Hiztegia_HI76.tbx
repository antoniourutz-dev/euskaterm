</termEntry>
<termEntry id="418951">
  <descrip type='subjectField'>Ingurumena</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Bilgarri eta ontzien hondakinak gaika bildu eta birziklatzeko sistemaren adierazgarria. Puntu berde bat inprimatuta duen bilgarriak adierazten du birziklatze-sistema integratu batean sartzekoa dela eta bilgarri hori duen produktuaren fabrikatzaileak gaikako bilketa eta birziklatzearen sistema finantzatzeko diru-kopuru bat aurreratu duela. Sistema hau Alemanian ezarri zen 1980ko hamarkadaren amaieran, eta Europako beste herrialde batzuetara hedatu da. Hego Euskal Herrian, Ecoembalajes erakundea arduratzen da bilgarriak jasotzeaz; beirazko ontziez, berriz, Ecovidrio erakundea arduratzen da. Ipar Euskal Herrian, ostera, material-mota guztiak Eco-Emballages erakundeak kudeatzen ditu. </descrip>
    </descripGrp>
    <tig>
      <term>puntu berde</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
