    <tig>
      <term>Programa de Naciones Unidas para el Medio Ambiente</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>PNUE</term>
    </tig>
    <tig>
      <term>Programme des Nations Unies pour l'Environnement</term>
