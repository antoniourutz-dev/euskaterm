  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kearen opakotasuna mailakatzeko erabiltzen den 0tik 5era bitarteko eskala. 0 balioa ke zuriari dagokio eta 5a ke beltzari.</descrip>
