    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>brazier</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680803">
  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oin eta lepo estuko 6 litro inguruko ontzia, ardoa edo olioa gordetzeko erabiltzen zena.</descrip>
    </descripGrp>
    <tig>
      <term>gurbil txiki</term>
