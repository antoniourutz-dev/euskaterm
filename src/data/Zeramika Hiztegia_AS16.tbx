    <tig>
      <term>flux</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680691">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Berun sulfuroa (PbS). Berun-mea da, eta berun-beiradura egiteko erabiltzen da zeramikan.</descrip>
    </descripGrp>
