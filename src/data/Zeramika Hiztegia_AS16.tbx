  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zeramika zuri eta zeharrargia, funtsean kaolinak, silizeak eta urgarri pixka batek osatutako pasta tenperatura altuan erreta lortzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>portzelana</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
