    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>frit</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680690">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Buztin-masaren edo beiraduraren fusio-tenperatura murrizten duen substantzia. Urgarriak funtsezkoak dira beiraztatze-prozesuan.</descrip>
    </descripGrp>
    <tig>
      <term>urgarri</term>
      <termNote type='normativeAuthorization'>4</termNote>
