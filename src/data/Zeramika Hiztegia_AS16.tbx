    </tig>
  </langSet>
</termEntry>
<termEntry id="680675">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Montmorillonitaren taldeko buztin bolkanikoa. Egokia da zenbait oretan erabiltzeko. Beiraduren ezaugarriak hobetzeko eta beiradura esekitzeko ere erabiltzen da bentonita.</descrip>
    </descripGrp>
    <tig>
      <term>bentonita</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
