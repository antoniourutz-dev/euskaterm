  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Akazia-espezie batzuek adarretan eta enborrean jariatzen duten goma antzeko substantzia. Zeramikan, engobeetan eta beiraduretan erabiltzen da.</descrip>
