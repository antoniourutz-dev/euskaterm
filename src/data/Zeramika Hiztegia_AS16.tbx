<termEntry id="680808">
  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Diametro handiko eta sakonera txikiko zeramikazko ontzia, garai batean -pitxerrarekin batera- eskuak eta aurpegia gelan bertan garbitzeko erabiltzen zena.</descrip>
