      <term>bain</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>pouring</term>
      <termNote type='usageNote'>isuriz egiten dena</termNote>
    </tig>
    <tig>
      <term>dipping</term>
      <termNote type='usageNote'>murgilduz egiten dena</termNote>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680973">
  <descrip type='subjectField'>Dekorazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Apaintze-teknika: kolore desberdineko bi pasta edo gehiago nahasten dira, baina kolore bakarreko pasta lortzeraino nahasi gabe. Kolore-konbinazio horren emaitza izan daiteke marmolaren antzeko efektua edo, pasta ebakita, motibo apaingarri jakin bat.</descrip>
    </descripGrp>
    <tig>
      <term>neriage</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
