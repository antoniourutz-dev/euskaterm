    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>carbonation</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680972">
  <descrip type='subjectField'>Dekorazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pieza beiraduraz edo engobez estaltzeko teknika. Pieza kasuan kasuko substantziaz betetako ontzian murgilduz egiten da, edo substantzia hori pieza gainera isuriz.</descrip>
    </descripGrp>
    <tig>
      <term>bainu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
