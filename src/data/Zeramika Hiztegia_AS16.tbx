  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Sistema baten osaera kuantitatiboki adierazteko ezinbestekoak diren banakako aldagai independenteetako bakoitza (lurrun, likido zein solidoa).</descrip>
