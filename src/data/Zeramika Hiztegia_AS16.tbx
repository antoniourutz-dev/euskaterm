<termEntry id="680677">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Buztin zuri naturala, hein handi batean kaolinitak osatua. Tenperatura altuak jasaten ditu, eta portzelanaren osagai garrantzitsua da. Engobeak, beiradurak eta bestelako buztinak egiteko erabili ohi da.</descrip>
    </descripGrp>
    <tig>
      <term>kaolin</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
