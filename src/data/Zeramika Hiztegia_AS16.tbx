<termEntry id="680708">
  <descrip type='subjectField'>Prozesuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erregaiak eskatzen duenarekin alderatuta ez oxigeno gehiegi ez gutxiegi duen atmosfera edo labearen barne-ingurunea. Erreketa atmosfera neutroan gertatzen denean, oxigeno erabilgarri guztia karbono monoxidorik sortu gabe erretzen da.</descrip>
