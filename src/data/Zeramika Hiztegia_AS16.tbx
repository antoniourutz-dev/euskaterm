<termEntry id="680671">
  <descrip type='subjectField'>Zeramika</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Buztina nahiz bestelako lehengai inorganikoak beroaren bidez eraldatuz egindako objektuen multzoa.</descrip>
    </descripGrp>
    <tig>
      <term>zeramika</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
