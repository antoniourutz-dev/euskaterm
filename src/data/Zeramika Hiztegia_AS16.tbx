<termEntry id="680694">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Nesosilikatoen klaseko minerala, 1.000 eta 1.200 ºC arteko tenperatura altuko pastetan aluminosilikatozko orratz-formako kristalak sortzen dituena. Zeramika eta portzelana egiteko erabiltzen da, kristalek horien propietateak hobetzen baitituzte: trinkotasun eta gogortasun handiagoa ematen dizkiete, eta lotura sendoagoa sortzen dute beiraduraren eta pastaren artean. Egonkorra da oso tenperatura altuetan.</descrip>
    </descripGrp>
    <tig>
      <term>mullita</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>mullita</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>mullite</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>mullite</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680695">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
