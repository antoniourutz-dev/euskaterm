<termEntry id="680812">
  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erlijio-erritualetarako erabili izan den zeramika-pieza, edo erlijiosoek erabili izan dutena. Erabilera erlijiosoko ontziak dira, adibidez, argiontzia, kofradiako pitxerra, aguamanila, koilara-ontzia eta moja-platera.</descrip>
    </descripGrp>
    <tig>
      <term>erabilera erlijiosoko ontzi</term>
