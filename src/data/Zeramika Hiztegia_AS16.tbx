  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pieza zeramikoei labean beroa aplikatzeko prozesua. Piezek hezetasuna galtzen dute, gogortu egiten dira, eta bestelako ezaugarri batzuk hartzen dituzte.</descrip>
