    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>terra cotta</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680798">
  <descrip type='subjectField'>Zeramika-objektuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pieza baten azala ikustean (ikusmenezko testura) edo ukitzean (ukimenezko testura) hautematen den egitura.</descrip>
    </descripGrp>
    <tig>
      <term>testura</term>
