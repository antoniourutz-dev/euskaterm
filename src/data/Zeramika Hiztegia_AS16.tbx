  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>carbonate</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680679">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beiraduren edo engobeen osagai den hautsa, landareak edo animalien hezur edo maskorrak erreaz lortu ohi dena. Urgarri gisa jokatzen du, erreketa-tenperatura jaitsarazten baitu.</descrip>
    </descripGrp>
    <tig>
      <term>errauts</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
