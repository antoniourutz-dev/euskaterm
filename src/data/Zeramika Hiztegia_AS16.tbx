  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aluminio oxidoa (Al2O3). Bai buztinaren, bai beiraduraren osagai garrantzitsua da.</descrip>
    </descripGrp>
