<termEntry id="680680">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erre eta eho den buztin erregogorra, hainbat tamainatako pikorrek osatua. Buztinari gehitzen zaio.</descrip>
    </descripGrp>
    <tig>
      <term>txamota</term>
