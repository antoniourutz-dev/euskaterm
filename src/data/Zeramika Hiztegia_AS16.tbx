<termEntry id="680811">
  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ontzi handia, sabel zabala, aho bat eta, erabat aurrez aurre, helduleku goratu bat eta hodi bat dituena. Euskal Herriko zeramika-pieza bereizgarrienetako bat da.</descrip>
