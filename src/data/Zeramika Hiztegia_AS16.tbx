<termEntry id="680799">
  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Txerri-hiltzeetarako ontzia, pareta lodikoa eta kono-enbor formakoa, aho oso zabala eta azpialde laua duena. Ontzi horiek bi, hiru edo lau helduleku izan ditzakete, tamainaren arabera, eta barneko aldea esmaltatua izaten dute. Hankak, arropa edo baxera garbitzeko ere erabiltzen ziren garai batean.</descrip>
    </descripGrp>
    <tig>
      <term>barrinoi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>terreina</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>barreñón</term>
    </tig>
    <tig>
      <term>terrizo</term>
    </tig>
    <tig>
      <term>mondonguera</term>
    </tig>
    <tig>
      <term>lebrillo</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680800">
  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Oiloei, usoei eta abarri ura jartzeko ontzia.</descrip>
    </descripGrp>
