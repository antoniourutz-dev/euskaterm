  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Buztin likidoa, piezak bata bestearekin itsasteko, tornuarekin lan egiteko (lubrifikatzaile gisa) eta isurketarako moldeetan erabili ohi dena.</descrip>
