  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ontzi biribil sakon samarra, globo-itxurako gorputzekoa, erabat aurrez aurre jarrita bi helduleku dituena.</descrip>
    </descripGrp>
