  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Plastikotasun txikiko materiala, buztinei edo buztin-nahasteei gehitzen zaiena plastikotasuna eta koipe-edukia murrizteko.</descrip>
