<termEntry id="680686">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Buztinak izan ditzakeen egoera fisikoetako bakoitza: gordina (erre gabea), errea, buztin-lohia, likidoa, lehorra, larru-trinkotasuna eta hautsa.</descrip>
