  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Garai batean janaria kontserbatzeko erabiltzen zen buztin errezko ontzia.</descrip>
    </descripGrp>
    <tig>
      <term>kontserbatarako ontzi</term>
