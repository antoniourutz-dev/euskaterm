<termEntry id="680688">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Partikula txikiak elkartzen dituen gehigarria. Esekiduran dauden partikulak eta hauts-nahasteei gehitzen zaizkien substantziak aglomeratzeko eta jalkiarazteko erabiltzen da, produktuaren aleak ondo batuta gera daitezen.</descrip>
    </descripGrp>
    <tig>
      <term>malutatzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
