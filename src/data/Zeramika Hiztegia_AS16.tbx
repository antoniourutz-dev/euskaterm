<termEntry id="680685">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Egoera likidoan dagoen buztina. Normalean, buztinezko gainazal bati aplikatzen zaio -oro har, larruaren trinkotasuna duenean- kolorea eta testura emateko.</descrip>
    </descripGrp>
    <tig>
      <term>engobe</term>
