      <term>bentonite</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680676">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Behe-tenperaturako beiraduretan erabiltzen den urgarrietako bat.</descrip>
    </descripGrp>
    <tig>
      <term>borax</term>
