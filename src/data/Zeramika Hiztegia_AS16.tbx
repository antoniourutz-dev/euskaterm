<termEntry id="680682">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Dagoeneko beiratuta dagoen pieza bati hirugarren errealdian aplikatzen zaion beiradura koloreduna.</descrip>
