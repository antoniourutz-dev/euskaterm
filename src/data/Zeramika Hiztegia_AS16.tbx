      <term>calorífero</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680802">
  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Barnean jarritako txingarren beroa irteten uzteko azal guztian zuloak dituen ontzia. Garai batean hankak berotzeko erabiltzen zen.</descrip>
    </descripGrp>
    <tig>
      <term>eltze-motako suontzi</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>lapiko-motako suontzi</term>
      <termNote type='normativeAuthorization'>4</termNote>
