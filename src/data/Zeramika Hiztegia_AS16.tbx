      <term>china clay</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>kaolin</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>china clay</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680678">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Azido karbonikoaren gatz edo esterra, CO32- anioia duena. Karbonatoak zeramika-beiraduren osagai gisa eta karea ekoizteko erabiltzen dira, besteak beste.</descrip>
    </descripGrp>
    <tig>
      <term>karbonato</term>
