<termEntry id="680673">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arroka igneoek -hala nola granitoak- duten feldespatoa deskonposatzearen ondorioz sortzen den material naturala, mineral-pikor txikiek osatua. Urarekin nahasita, zeramikan eta buztingintzan lehengai nagusi gisa erabiltzen den pasta plastikoa osatzen du.</descrip>
    </descripGrp>
    <tig>
      <term>buztin</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>arcilla</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>argile</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>clay</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680674">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zeramika-objektuen azala estaltzen duen beirazko geruza.</descrip>
    </descripGrp>
