  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>porcelain</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="680795">
  <descrip type='subjectField'>Zeramika-objektuak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zeramika-objektu baten ertzetan edo azalean nabarmentzen den soberako materia.</descrip>
    </descripGrp>
