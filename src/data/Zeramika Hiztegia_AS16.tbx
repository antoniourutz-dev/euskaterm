  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Material baten tenperatura 1 ºC igotzen denean materiala zenbat luzatzen den adierazten duen parametroa.</descrip>
    </descripGrp>
