<termEntry id="680807">
  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Likidoak edukitzeko erabiltzen den zeramika-pieza esmaltatua. Pitxerrek helduleku bakarra izan ohi dute.</descrip>
    </descripGrp>
