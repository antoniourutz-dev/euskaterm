<termEntry id="680971">
  <descrip type='subjectField'>Dekorazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erredukzio-prozesua, erreketan labearen barne-inguruneko oxigenoa agortzen denean (atmosfera karbonatzaile bilakatzen denean) gertatzen dena. Zeramika belzteko egiten da.</descrip>
    </descripGrp>
    <tig>
      <term>karbonazio</term>
