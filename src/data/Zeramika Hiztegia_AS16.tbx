<termEntry id="680974">
  <descrip type='subjectField'>Dekorazioa</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Apaintze-teknika, erreketa-prozesuan kea sorrarazi eta, hala, zeramikaren azalean orban ilunak sortzean datzana.</descrip>
    </descripGrp>
