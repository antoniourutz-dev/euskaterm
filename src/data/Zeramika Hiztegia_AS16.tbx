  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ura, ardoa, olioa eta antzeko likidoak kontserbatzeko ontzi handia, azal leunekoa eta beiradurarik gabea. Ildaska, kordoi edo hatz-marka bidezko dekorazioa izan ohi du.</descrip>
