<termEntry id="680805">
  <descrip type='subjectField'>Euskal zeramikagintzako ontziak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Katilua baino ontzi zapal eta txikiagoa, kirtenik gabekoa eta zopak hartzeko erabiltzen dena.</descrip>
