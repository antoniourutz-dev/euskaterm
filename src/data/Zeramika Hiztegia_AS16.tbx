</termEntry>
<termEntry id="680689">
  <descrip type='subjectField'>Materialak</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Beiradura edo berniz ehoa, beiradura gordina ez bezala labean errea izan dena. Bere horretan erabil daiteke, beiradura gisa. Beste beiradura baten osagai gisa ere erabil daiteke, fusioa kontrolatzeko eta koloreen uniformetasuna eta beiraduraren banaketa erregularra bermatzeko.</descrip>
    </descripGrp>
    <tig>
      <term>fritakin</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
