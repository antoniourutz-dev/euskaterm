  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kaltearen aldetik ondoriorik ez edo ondorio hutsala izan duen gertakaria, baina, arrisku baten materializazioa denez, istripu-iturri izan zitekeena.</descrip>
