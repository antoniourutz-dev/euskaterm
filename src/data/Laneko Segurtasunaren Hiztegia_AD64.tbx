  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Makinetan pertsonak babesteko jartzen den gailua, babes-estalkiaz bestelakoa; arriskua ezabatzen du, arriskua bera gauzatzera iritsi aurretik.</descrip>
