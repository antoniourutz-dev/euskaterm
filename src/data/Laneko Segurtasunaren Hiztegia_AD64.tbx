<termEntry id="137">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Laneko istripu edo gaixotasun batek eragindako behin betiko lesio, mutilazio edo deformazioa, langilearen lanerako gaitasunaren gain ezintasun iraunkorrik utzi gabe, haren osotasun fisikoan murrizketa edo alterazioren bat sortzen duena.</descrip>
    </descripGrp>
    <tig>
      <term>baliaezintasunik gabeko lesio iraunkor</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>lesión permanente no invalidante</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="138">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langile baten edo gehiagoren osotasun psikologikoaren aurkako portaera umiliagarria etengabe errepikatuz egiten den erasoa; langile horientzat, gehienetan, ondorio kaltegarriak eragiten ditu bai maila pertsonalean bai profesionalean.</descrip>
    </descripGrp>
    <tig>
      <term>laneko jazarpen psikologiko</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>laneko jazarpen</term>
      <termNote type='normativeAuthorization'>4</termNote>
