<termEntry id="129">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langileari bere ohiko lanbidearen funtsezko eginkizun batzuetan edo guztietan aritzeko gaitasuna kentzen dion ezintasun iraunkorra, baina beste lan batean aritzeko gaitasuna uzten diona.</descrip>
