  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Diziplina anitzeko zientzia-eremua, laneko baliabideak eta baldintzak langilearen premietara eta ezaugarri fisiologiko eta psikologikoetara egokitzeko helburua duena.</descrip>
