    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>class C fire</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="35">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Metal jakin batzuekin sortzen den sua: magnesio, potasio, aluminio-hauts, zink, sodio, titanio, zirkonio eta abarrekin.</descrip>
    </descripGrp>
    <tig>
