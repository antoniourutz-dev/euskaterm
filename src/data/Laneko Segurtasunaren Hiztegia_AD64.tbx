<termEntry id="355">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsonentzat, ingurumenarentzat eta ondasunentzat arrisku-egoera larria sortzen duen ezusteko eta bat-bateko gertakaria; adibidez, isuri, ihes, sute edo leherketa bat.</descrip>
    </descripGrp>
