  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek makina baten segurtasun-eremuko muga pasatzen duenean aktibatzen den gailua, makina gerarazten edo makinaren mugimendua alderantzikatzen duena eta, hala, istripu-arriskuak ezabatzen edo murrizten dituena.</descrip>
