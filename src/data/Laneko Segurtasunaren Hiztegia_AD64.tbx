      <term>síndrome de desgaste profesional</term>
    </tig>
    <tig>
      <term>agotamiento psíquico</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>syndrome d'épuisement professionnel</term>
    </tig>
    <tig>
      <term>épuisement professionnel</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>burnout</term>
    </tig>
  </langSet>
</termEntry>
