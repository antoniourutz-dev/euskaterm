  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prebentzioko neurriak nahitaez hobetzea eskatzen ez duen arrisku-maila. Hala ere, komeni da neurri horien aldizkako kontrolak eta egiaztapenak egitea, eta, ahal bada, karga ekonomiko ez oso handiko hobekuntzak edo konponbideak kontuan hartzea.</descrip>
