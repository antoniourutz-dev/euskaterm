  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prebentzioko prozedura ororen hasierako etapa, hau da, enpresan aurki daitezkeen arriskuak identifikatzea eta sailkatzea, prebentzioko neurriak hartzeko asmoz.</descrip>
