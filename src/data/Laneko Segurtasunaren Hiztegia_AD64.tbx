    </tig>
  </langSet>
</termEntry>
<termEntry id="37">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Hidrokarburo arinen nahasketa, oso baldintza jakinetan egoera likidora eramanda dagoena. Adibidez: propanoa, propilenoa, butanoa, butilenoa edo butadienoa. Erregai gisa erabiltzen da, eta petrolioaren finketaz edo gas naturalaren tratamenduz ateratzen da.</descrip>
