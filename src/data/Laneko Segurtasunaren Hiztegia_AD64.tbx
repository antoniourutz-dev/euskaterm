  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Babeseko elementua, pertsonari berari edo haren gorputz-atalei makina baten arrisku-eremura iristen ez uzteko edo iristeko bidea oztopatzeko jartzen dena.</descrip>
