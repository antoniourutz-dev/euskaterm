  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Lan-eremu batean, arriskuko edo kontrolez kanpoko egoera bat sortzen denean jendea ohartarazteko gailuak martxan jartzen dituen sistema.</descrip>
