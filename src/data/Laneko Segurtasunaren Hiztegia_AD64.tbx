  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langile bakoitzak bere laneko segurtasunaren edo osasunaren kontrako arrisku batetik edo batetik baino gehiagotatik babesteko eraman edo eduki behar duen ekipamendua; baita helburu hori bera izan dezakeen beste edozein osagarri edo lagungarri ere.</descrip>
