<termEntry id="314">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ustezko larrialdi-egoera bat nahita sortuz egiten den proba. Larrialdietako planean aurrez ikusita dauden ekintza eta neurri guztiak praktikan jartzea da helburua.</descrip>
