<termEntry id="199">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Alarma-egoerak kudeatzeko giza taldea. Haren egitekoak dira alarma ematea, bere sektorean ebakuazio erabatekoa eta ordenatua egiten laguntzea eta ebakuazioa egin dela egiaztatzea.</descrip>
