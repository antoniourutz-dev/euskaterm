      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>acoso discriminatorio</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
