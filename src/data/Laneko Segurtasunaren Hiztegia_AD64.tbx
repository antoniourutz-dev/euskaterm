<termEntry id="128">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langilearen laneko errendimendua, ohiko lanbidearen funtsezko eginkizunetan aritzeko gaitasunik erabat kendu gabe, % 33, gutxienez, jaisten duen ezintasun iraunkorra.</descrip>
