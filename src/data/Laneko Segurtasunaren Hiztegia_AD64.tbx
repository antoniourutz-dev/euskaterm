  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langilea edozein lanbide edo ofizio egiteko ezgaitzeaz gainera, bizitzako gauzarik funtsezkoenak egiteko ere beste pertsona baten laguntza-beharrean uzten duen ezintasun-maila.</descrip>
