<termEntry id="222">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Solairu bat baino gehiagoko etxe-blokeetan jartzen den suteen kontrako hodi bertikala, ur-sarera konektatua. Presio handiko ura izaten du, eta beti egoten da urez elikatua; sua sortuz gero, solairuetan ura hartzeko erabiltzen dute suhiltzaileek.</descrip>
    </descripGrp>
    <tig>
