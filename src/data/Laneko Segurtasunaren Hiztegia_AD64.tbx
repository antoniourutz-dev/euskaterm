<termEntry id="330">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Suak piztu ahal izateko behar dituen hiru elementuek -erregaiak, oxigenoak (erregarriak) eta beroak edo aktibatzeko energiak- osatzen duten multzoa. Horietako elementuren bat falta bada, ezin da surik piztu.</descrip>
    </descripGrp>
