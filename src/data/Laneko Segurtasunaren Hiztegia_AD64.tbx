      <term>surveillance de la santé</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>health surveillance</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="322">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erradiazio ionizatzaileen iturri bat egoteagatik mugatuta dagoen eremua; han lan egin behar dutenek erradiazio-dosiak hartuko dituztenez, erradiazioen kontrako babesari buruzko teknika eta erregelamenduetan aditua den eta gai horiei buruzko neurriak aplikatzeko ardura duen teknikari batek kontrolaturik eta gainbegiraturik dago.</descrip>
    </descripGrp>
    <tig>
      <term>kontrolpeko eremu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>zona controlada</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
