  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Kargatuta, guztira, 20 kg-tik gorako pisua duen itzalgailua, leku batetik bestera eramateko gurpil batzuk izaten dituena.</descrip>
