<termEntry id="345">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Larrialdietako argiak, zona bat ebakuatu behar duten edo, zona hustu aurretik, arriskutsua izan daitekeen lanen bat bukatu behar duten pertsonen segurtasuna bermatzeko jartzen direnak.</descrip>
    </descripGrp>
    <tig>
      <term>segurtasun-argiak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>alumbrado de seguridad</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>éclairage de sécurité</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>safety lighting</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="346">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Segurtasuneko argien barruan, ebakuazio-bideak eta -baliabideak non dauden ikusteko eta erabili ahal izateko jartzen diren argiak.</descrip>
    </descripGrp>
    <tig>
      <term>ebakuazio-argiak</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
