    <tig>
      <term>alumbrado de evacuación</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>éclairage d'évacuation</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>evacuation lighting</term>
    </tig>
  </langSet>
</termEntry>
