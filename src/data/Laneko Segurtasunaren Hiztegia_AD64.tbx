<termEntry id="209">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Jendeak erabili behar dituen substantzia arriskutsuei arauak agintzen duen etiketa jartzea. Substantzia arriskutsuen ontziak garbi eta erraz irakurtzeko eta nekez ezabatzeko moduan etiketatu behar dira, Estatuko hizkuntza ofizialean.</descrip>
    </descripGrp>
