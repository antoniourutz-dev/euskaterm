<termEntry id="224">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zuzenean laneko giroaren azterketa higienikoa egiteaz arduratzen den higiene industrialaren adarra: lanpostuen analisia, kutsatzaileen detekzioa eta esposizio-denbora, zuzeneko neurketak eta lagin-hartzea, balio estandarrekiko konparazioa eta higiene-teknika orokorrak.</descrip>
    </descripGrp>
    <tig>
