<termEntry id="255">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Istripu larriei aurrea hartzeko edo, halakorik gertatuz gero, haien ondorioak arintzeko sortzen den marko organiko eta funtzionala; babes-neurri egokienak, behar diren giza baliabide eta baliabide materialak eta esku hartu behar duten erakundeen koordinazio-eskema ezartzen ditu.</descrip>
