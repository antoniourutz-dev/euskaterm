<termEntry id="319">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eraikin bateko edo eraikin horren zona bateko jende guztiak kanpoko irteera batera iristeko behar duen denbora, ebakuazio-seinalea ematen denetik kontatzen hasita neurtzen dena.</descrip>
