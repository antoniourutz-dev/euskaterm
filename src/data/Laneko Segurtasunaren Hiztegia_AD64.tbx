  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ardura hau duen diziplina: langileen osasunean eragina izan dezaketen faktoreei eta haien konfort-maila jaitsarazi edo lan-eraginkortasuna gutxitu dezaketenei aurrea hartzea, antzematea, haiek ebaluatzea eta kontrolatzea.</descrip>
