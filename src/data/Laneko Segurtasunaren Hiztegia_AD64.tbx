<termEntry id="331">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Baldintza anormaletan -hala nola korrontearen intentsitateak balio jakin bat gainditzen duenean- zirkuitu elektriko bat automatikoki eteten duen gailua.</descrip>
    </descripGrp>
