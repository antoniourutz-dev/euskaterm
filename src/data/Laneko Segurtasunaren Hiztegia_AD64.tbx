      <term>controlled area</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="323">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Esposizio bakar batean urte guztiko dosi-mugaren gainetik dagoen kutsadura- edo irradiazio-maila hartzeko arriskua duen eremua, jendearentzat ez sartzeko markatuta dagoena.</descrip>
    </descripGrp>
