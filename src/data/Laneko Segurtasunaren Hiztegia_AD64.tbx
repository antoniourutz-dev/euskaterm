<termEntry id="348">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Eraikin barruko atea, ezbehar bat gertatzen denean suari, une batez behintzat, zabaltzen ez uzteko eta eraikin bateko lokalak isolatzeko bereziki diseinatua. Horretarako, noski, su-gerarazleen hiru baldintzak bete behar ditu: egonkortasuna, estankotasuna, eta surik ez dagoen aurpegiaren aldetik gas sukoirik ateratzen ez uztea.</descrip>
    </descripGrp>
    <tig>
      <term>ate su-gerarazle</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>puerta parallamas</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>porte pare-flammes</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>firestop door</term>
    </tig>
    <tig>
      <term>fire-arresting door</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="349">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Suarekiko portaerari dagokionez lau ezaugarri hauek dituen eraikuntzako elementua: erresistentzia mekanikoa, hau da, egonkortasuna edo sostengu-ahalmena izatea; estankotasuna, hots, sugarra eta gas beroak pasatzen ez uzteko gaitasuna; surik ez dagoen aurpegiaren aldetik gas sukoirik ateratzen ez uztea; eta erresistentzia termikoa edo beroa transmititzen ez uzteko gaitasuna.</descrip>
    </descripGrp>
    <tig>
      <term>suaren kontrako elementu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
    <tig>
      <term>su-ebakitzaile</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>elemento resistente al fuego</term>
    </tig>
    <tig>
      <term>elemento cortafuegos</term>
    </tig>
    <tig>
      <term>cortafuegos</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>résistant au feu</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>fire resistant</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="350">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Aire eta gasezko nahasketak piztu ondoren erretzen jarraitzeko behar duen tenperaturarik txikiena. Sugar-puntuarena baino gradu batzuk handixeagoa izaten da.</descrip>
    </descripGrp>
    <tig>
      <term>errekuntza-puntu</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>punto de combustión</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>point de combustion</term>
    </tig>
    <tig>
      <term>température de combustion</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>fire point</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="351">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Laneko giroak gizabanakoaren gain eragiten duen presio-maila. Osasun-arazoak, pertsonen arteko harremanen hondamena, absentismoa eta produktibitate-galera eragin ditzake.</descrip>
    </descripGrp>
    <tig>
      <term>laneko estres</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
  <langSet xml:lang='es'>
    <tig>
      <term>estrés laboral</term>
    </tig>
  </langSet>
  <langSet xml:lang='fr'>
    <tig>
      <term>stress du travail</term>
    </tig>
  </langSet>
  <langSet xml:lang='en'>
    <tig>
      <term>occupational stress</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="352">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Neke fisiko, emozional eta intelektualeko egoera, lanbidearen eskakizunei erantzuteko gai ez izatera iritsi den langileak nabari duen estresaren ondorioz sortzen dena.</descrip>
    </descripGrp>
    <tig>
      <term>neke profesionalaren sindrome</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
  </langSet>
