<termEntry id="202">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Autobabeseko taldea, egiteko hauek dituena: larrialdi batean lesionatutakoei lehen sorospena eman eta, behar izanez gero, ondoren eman beharko zaien tratamendu medikoa kontrolatu eta bideratu.</descrip>
