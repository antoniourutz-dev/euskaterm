<termEntry id="286">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Ura suteen kontrako babes-sistemaren konexio-puntuetaraino eramateko hodi, balbula eta gehigarrien multzoa. Kasu eta instalazio jakin batzuetan beharrezkoa izaten da suaren kontrako ur-instalazio espezifikoa izatea.</descrip>
