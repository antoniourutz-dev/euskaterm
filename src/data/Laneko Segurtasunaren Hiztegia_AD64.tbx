    <tig>
      <term>class D fire</term>
    </tig>
  </langSet>
</termEntry>
<termEntry id="36">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Argindarra duten aparatu elektrikoetan sortzen den sua. Tentsio elektrikoa neutralizatzeko ahalmen dielektrikoa izan behar dute era horretako sua itzaltzeko erabiltzen diren agente itzaltzaileek.</descrip>
    </descripGrp>
