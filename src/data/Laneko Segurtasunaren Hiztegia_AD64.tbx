  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Zati mugikor batzuk makinaren aginteko mekanismoekin konektatzen dituen babesgarria, arrisku-eremuetara iristeko bidea itxita egon arte makinari martxan jartzen uzten ez diona.</descrip>
