<termEntry id="212">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Pertsona batek, baldintza fisiko normaletan, jasan dezakeen esposizio profesionalik handiena, pertsonaren bizitza guztirako eragin kaltegarri nabarmenak izatera iristen ez dena.</descrip>
