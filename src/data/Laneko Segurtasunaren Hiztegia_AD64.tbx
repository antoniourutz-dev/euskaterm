<termEntry id="337">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Prebentzio-ekintza edo kontroleko txostenik eskatzen ez duen arrisku-maila; aski da ebaluazioa egitea.</descrip>
    </descripGrp>
    <tig>
      <term>arrisku arin</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
