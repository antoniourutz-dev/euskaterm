  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langile batek egunean zehar jasaten duen agente batekiko esposizioa (zarata-maila, bibrazioak, erradiazioa, kutsadura kimikoa...) neurtzeko erabiltzen den gailua.</descrip>
