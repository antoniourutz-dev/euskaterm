<termEntry id="63">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Arriskua gutxitu arte lanik ez hastea eta ez jarraitzea eskatzen duen arrisku-maila. Arriskua ezin bada gutxitu -ezta beharrezkoak diren baliabide guztiak erabilita ere-, lan hori debekatu beharko da.</descrip>
