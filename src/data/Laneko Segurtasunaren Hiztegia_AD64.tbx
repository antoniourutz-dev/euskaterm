<termEntry id="246">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Erretzen ez den horma eta, ezbehar bat gertatzen denean, suari une batez behintzat zabaltzen ez uzteko eta eraikin bateko lokalak isolatzeko bereziki diseinatua dagoena. Horretarako, noski, su-ebakitzaileen lau baldintzak bete behar ditu: erresistentzia mekanikoa, estankotasuna, erresistentzia termikoa eta surik ez dagoen aldetik gas sukoirik ez ateratzen uztea.</descrip>
