<termEntry id="15">
  <descrip type='subjectField'>Segurtasuna eta osasuna</descrip>
  <langSet xml:lang='eu'>
    <descripGrp>
      <descrip type='definition'>Langilearen erosotasun-mailarik egokiena lortzeko egiten den ahaleginaren emaitza. Lanpostuaren eta giza gorputzaren arteko interakzio-maila egokia bilatzea da helburu nagusia; horretarako, gizakiaren datu antropometrikorik garrantzitsuenak kontuan hartu eta lanpostua osatzen duten elementuak (eserlekuak, erremintak, distantziak...) horren arabera diseinatzen dira.</descrip>
    </descripGrp>
    <tig>
      <term>postura-konfort</term>
      <termNote type='normativeAuthorization'>4</termNote>
    </tig>
